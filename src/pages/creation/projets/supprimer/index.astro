---
import Layout from "../../../../layouts/Layout-back-office.astro";
import ItemCard from "../../../../components/ItemCard.astro";
import ActionsSearch from "../../../../components/ActionsSearch.astro";
import slugify from "slugify";
import { getCreationViewUrl } from "../../../../utils/creationRoutes";

let error = "";
let success = "";

// Récupérer la liste des projets
let projetsRaw;
try {
  projetsRaw = await (Astro.locals as any).pb
    .collection("projets")
    .getFullList(500, { sort: "-updated" });
} catch (e) {
  console.error("Impossible de récupérer les projets:", e);
  error = "Impossible de charger la liste des projets.";
}

projetsRaw = projetsRaw || [];

// Mapper les données essentielles
const projets = projetsRaw.map((p: any) => ({
  id: p.id,
  title: p.titre,
  slug: slugify(p.titre || "", { lower: true, strict: true }),
  subtitle: p.nom_adresse,
  updated: p.updated,
  source: "projet" as const,
}));

function formatDate(dateStr?: string): string {
  if (!dateStr) return "";
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  } catch {
    return dateStr;
  }
}

// Gestion POST pour suppression multiple
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    // Récupérer toutes les valeurs des cases à cocher nommées "ids"
    const ids = formData
      .getAll("ids")
      .map((v) => v.toString())
      .filter(Boolean);
    if (!ids || ids.length === 0) {
      error = "Aucun projet sélectionné.";
    } else {
      const failed: string[] = [];
      for (const id of ids) {
        try {
          await (Astro.locals as any).pb.collection("projets").delete(id);
        } catch (e) {
          console.error("Erreur suppression id:", id, e);
          failed.push(id);
        }
      }
      if (failed.length === 0) {
        return Astro.redirect(
          `/creation/projets/supprimer?success=${encodeURIComponent(`${ids.length} projet(s) supprimé(s) avec succès.`)}`,
        );
      } else {
        error = `Échec de la suppression pour ${failed.length} projet(s).`;
      }
    }
  } catch (e) {
    console.error("Erreur lors du POST suppression:", e);
    error = "La suppression des projets a échoué.";
  }
}

// Afficher le message de succès s'il est présent dans les paramètres de requête.
try {
  const s = Astro.url.searchParams.get("success");
  if (s) success = s;
} catch (e) {
  console.debug(e);
}
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="mb-0">
        <h1 class="mb-3 text-3xl font-bold text-accent font-poppins md:text-4xl">Supprimer des projets</h1>
        <p class="text-base text-base-content md:text-lg">
          Sélectionnez plusieurs projets puis cliquez sur "Supprimer sélection".
        </p>
      </div>
      <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
        <a href="/creation/projets" class="btn btn-border btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md">Retour aux projets</a>
      </div>
    </div>

    <div
      id="delete-flash-flags"
      data-success={success}
      data-error={error}
      class="hidden"
    ></div>

    <form method="POST" id="deleteForm">
      <div class="mb-4 space-y-4">
        <div class="card rounded-2xl border border-base-300 bg-base-100 shadow-sm">
          <div class="card-body p-4 md:p-6">
            <div class="mb-4">
              <h2 class="card-title text-2xl">Filtrer</h2>
              <p class="mt-1 text-sm text-base-content">
                Filtrez rapidement vos projets.
              </p>
            </div>
            <ActionsSearch embedded={true} showBeneficiary={false} />
          </div>
        </div>
        <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
          <label class="flex items-center gap-2">
            <input type="checkbox" id="selectAll" />
            <span class="text-sm">Tout sélectionner</span>
          </label>
          <button
            type="submit"
            id="bulkDelete"
            class="btn btn-error btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md"
            >Supprimer sélection</button
          >
        </div>
      </div>

      <div
        id="cards-grid"
        class="grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-5 lg:grid-cols-3 lg:gap-6"
      >
        {
          projets.map((projet: any) => (
            <ItemCard
              id={projet.id}
              title={projet.title}
              slug={projet.slug}
              source={projet.source}
              subtitle={projet.subtitle}
              formattedDate={formatDate(projet.updated)}
              viewUrl={getCreationViewUrl("projet", projet.id, projet.slug)}
              editUrl={getCreationViewUrl("projet", projet.id, projet.slug)}
              showCheckbox={true}
              checkboxSlot={`<input class="checkbox checkbox-primary shrink-0" type="checkbox" name="ids" id="id_${projet.id}" value="${projet.id}" data-item-id="${projet.id}" data-title="${projet.title}" data-updated="${projet.updated}" />`}
              maxHeightContent={true}
              deleteMode={true}
            />
          ))
        }
      </div>
      <div id="cards-pagination" class="mt-6 flex justify-center"></div>
    </form>
  </div>

  <script>
    import { initDeletePageHandler } from "../../../../utils/deletePageHandler";

    initDeletePageHandler({
      cardSelector: "div[data-item-id]",
      itemSingular: "projet",
      itemPlural: "projets",
      emptyStateMessage: "Aucun projet disponible pour le moment.",
    });
  </script>
</Layout>
