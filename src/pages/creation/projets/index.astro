---
import Layout from "../../../layouts/Layout-back-office.astro";
import ActionsSearch from "../../../components/ActionsSearch.astro";
import ItemCard from "../../../components/ItemCard.astro";
import SectionPaginator from "../../../components/SectionPaginator.astro";
import slugify from "slugify";
import { getCreationEditUrl } from "../../../utils/creationRoutes";
import { resolveCreatorName } from "../../../utils/utilitaires.js";

interface ProjectItem {
  id: string;
  title: string;
  slug: string;
  source: "projet";
  updated?: string;
  date?: string;
  beneficiary?: string;
  authorName?: string;
}

const projetsRaw: any[] = await Astro.locals.pb
  .collection("projets")
  .getFullList(200, { sort: "-updated", expand: "cree_par" });

const projets: ProjectItem[] = projetsRaw
  .map((p) => ({
    id: p.id,
    title: p.titre,
    slug: slugify(p.titre || "", { lower: true, strict: true }),
    source: "projet" as const,
    updated: p.updated,
    date: p.date,
    beneficiary: p.nom_adresse,
    authorName: resolveCreatorName(p) || "Auteur inconnu",
  }))
  .sort((a, b) => new Date(b.updated || 0).getTime() - new Date(a.updated || 0).getTime());

function formatDate(dateStr?: string): string {
  if (!dateStr) return "";
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  } catch {
    return dateStr;
  }
}
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="mb-0">
        <h1 class="mb-3 text-3xl font-bold text-accent font-poppins md:text-4xl">
          Projets
        </h1>
        <p class="text-base text-base-content/70 md:text-lg">
          Gérez vos projets, recherchez, filtrez et modifiez rapidement.
        </p>
      </div>
      <div class="w-full grid grid-cols-1 gap-3 [@media(min-width:420px)]:grid-cols-2 md:flex md:flex-wrap md:items-center md:justify-end">
        <a
          href="/projets"
          class="btn btn-border btn-sm rounded-full w-full [@media(min-width:420px)]:col-span-2 md:flex-initial md:w-fit md:col-auto md:btn-md"
        >
          Voir sur le site
        </a>
        <a
          href="/creation/projets/supprimer"
          class="btn btn-border btn-sm rounded-full w-full md:flex-initial md:w-fit md:btn-md"
        >
          Supprimer des projets
        </a>
        <a
          href="/creation/projets/nouveau"
          class="btn btn-accent btn-sm rounded-full w-full md:flex-initial md:w-fit md:btn-md"
        >
          Créer un projet
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-4 mb-12">
      <div class="card bg-base-100 shadow-md">
        <div class="card-body text-center p-4">
          <div class="text-4xl! font-bold text-base-content">{projets.length}</div>
          <div class="text-base-content">Projets</div>
        </div>
      </div>
    </div>

    <div class="card mb-8 rounded-2xl border border-base-300 bg-base-100 shadow-sm">
      <div class="card-body p-4 md:p-6">
        <div class="mb-4">
          <h2 class="card-title text-2xl">Rechercher</h2>
          <p class="mt-1 text-sm text-base-content/60">
            Filtrez rapidement vos projets puis triez l'affichage.
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <div class="w-full">
            <p class="mb-2 font-medium text-base-content/70">Filtres</p>
            <ActionsSearch showBeneficiary={false} embedded={true}>
              <label slot="secondary-extra" class="form-control w-full gap-1" for="sort-select">
                <span class="text-sm! font-medium tracking-wide text-base-content">
                  Trier par date
                </span>
                <select id="sort-select" class="select select-bordered w-full">
                  <option value="updated_desc">Récent → Ancien</option>
                  <option value="updated_asc">Ancien → Récent</option>
                </select>
              </label>
            </ActionsSearch>
          </div>
        </div>
      </div>
    </div>

    <div
      id="projects-grid"
      class="grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-5 lg:grid-cols-3 lg:gap-6"
    >
      {projets.map((projet) => (
        <div
          data-project-item
          data-search={`${projet.title} ${projet.beneficiary || ""} ${projet.authorName || ""} ${formatDate(projet.date)}`}
          data-updated={projet.updated}
          class="h-full"
        >
          <ItemCard
            class="h-full"
            id={projet.id}
            title={projet.title}
            slug={projet.slug}
            source={projet.source}
            beneficiary={projet.beneficiary}
            authorName={projet.authorName}
            formattedDate={formatDate(projet.date)}
            editUrl={getCreationEditUrl("projet", projet.id, projet.slug)}
            showViewButton={false}
            showDeleteButton={false}
          />
        </div>
      ))}
    </div>

    <SectionPaginator
      itemAttr="data-project-item"
      pageSize={9}
      sortSelectId="sort-select"
      filterEventName="actions-filter-change"
      emptyMessage="Aucun projet disponible pour le moment."
    />
  </div>
</Layout>
