---
import Layout from "../../../layouts/Layout-back-office.astro";
import ItemCard from "../../../components/ItemCard.astro";
import slugify from "slugify";
import { getCreationEditUrl, getCreationViewUrl } from "../../../utils/creationRoutes";

interface ProjectItem {
  id: string;
  title: string;
  slug: string;
  source: "projet";
  updated?: string;
  date?: string;
  beneficiary?: string;
}

const projetsRaw: any[] = await Astro.locals.pb
  .collection("projets")
  .getFullList(200, { sort: "-updated" });
const projets: ProjectItem[] = [
  ...projetsRaw.map((p) => ({
    id: p.id,
    title: p.titre,
    slug: slugify(p.titre || "", { lower: true, strict: true }),
    source: "projet" as const,
    updated: p.updated,
    date: p.date,
    beneficiary: p.nom_adresse,
  })),
].sort(
  (a, b) =>
    new Date(b.updated || 0).getTime() - new Date(a.updated || 0).getTime(),
);

function formatDate(dateStr?: string): string {
  if (!dateStr) return "";
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  } catch {
    return dateStr;
  }
}
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    {/* Titre et boutons d'action */}
    <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="mb-0">
        <h1 class="mb-3 text-3xl font-bold text-accent font-poppins md:text-4xl">
          Projets
        </h1>
        <p class="text-base text-base-content/70 md:text-lg">
          Gérez vos projets, recherchez, filtrez et modifiez rapidement.
        </p>
      </div>
      <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
        <a
          href="/projets"
          class="btn btn-border btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md"
        >
          Voir le site
        </a>
        <a
          href="/creation/projets/nouveau"
          class="btn btn-accent btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md"
        >
          Créer un projet
        </a>
      </div>
    </div>

    {/* Statistique */}
    <div class="grid grid-cols-1 gap-4 mb-12">
      <div class="card bg-base-100 shadow-md">
        <div class="card-body text-center p-4">
          <div class="text-4xl! font-bold text-base-content">
            {projets.length}
          </div>
          <div class="text-base-content">Projets</div>
        </div>
      </div>
    </div>

    {/* Grille de projets */}
    <div class="grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-5 lg:grid-cols-3 lg:gap-6">
      {projets.map((projet) => (
        <ItemCard
          id={projet.id}
          title={projet.title}
          slug={projet.slug}
          source={projet.source}
          beneficiary={projet.beneficiary}
          formattedDate={formatDate(projet.date)}
          viewUrl={getCreationViewUrl("projet", projet.id, projet.slug)}
          editUrl={getCreationEditUrl("projet", projet.id, projet.slug)}
          showDeleteButton={true}
        />
      ))}
    </div>

    {projets.length === 0 && (
      <div class="text-center py-12">
        <p class="text-base-content/60">Aucun projet trouvé</p>
      </div>
    )}
  </div>
</Layout>
