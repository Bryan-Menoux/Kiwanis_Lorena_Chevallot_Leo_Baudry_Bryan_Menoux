---
import Layout from "../../../layouts/Layout-back-office.astro";
import ItemCard from "../../../components/ItemCard.astro";
import SectionPaginator from "../../../components/SectionPaginator.astro";
import { formatDateShort } from "../../../utils/utilitaires.js";

interface PartenaireItem {
  id: string;
  nom: string;
  logo?: string;
  logoUrl?: string;
  updated?: string;
}

interface ContributeurItem {
  id: string;
  nom: string;
  metier?: string;
  description?: string;
  updated?: string;
}

const asText = (value: FormDataEntryValue | null): string =>
  typeof value === "string" ? value.trim() : "";

const redirectWith = (type: "success" | "error", message: string) =>
  Astro.redirect(
    `/creation/remerciements?${type}=${encodeURIComponent(message)}`,
  );

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const entity = asText(formData.get("entity"));
    const intent = asText(formData.get("intent"));
    const id = asText(formData.get("id"));

    if (entity === "partenaire") {
      const nom = asText(formData.get("nom"));

      if (intent === "update") {
        if (!id) {
          throw new Error("Partenaire introuvable.");
        }

        const logo = formData.get("logo");

        if (!nom) {
          throw new Error("Le nom du partenaire est obligatoire.");
        }
        const updateData: Record<string, string | File> = { nom };
        if (logo instanceof File && logo.size > 0) {
          updateData.logo = logo;
        }

        await Astro.locals.pb.collection("partenaires").update(id, updateData);
        return redirectWith("success", "Partenaire modifié avec succès.");
      }

      if (intent === "delete") {
        if (!id) {
          throw new Error("Partenaire introuvable.");
        }

        await Astro.locals.pb.collection("partenaires").delete(id);
        return redirectWith("success", "Partenaire supprimé avec succès.");
      }

      throw new Error("Action partenaire inconnue.");
    }

    if (entity === "contributeur") {
      const nom = asText(formData.get("nom"));
      const metier = asText(formData.get("metier"));
      const description = asText(formData.get("description"));

      if (intent === "update") {
        if (!id) {
          throw new Error("Contributeur introuvable.");
        }
        if (!nom) {
          throw new Error("Le nom du contributeur est obligatoire.");
        }

        await Astro.locals.pb.collection("contributeurs").update(id, {
          nom,
          metier,
          description,
        });
        return redirectWith("success", "Contributeur modifié avec succès.");
      }

      if (intent === "delete") {
        if (!id) {
          throw new Error("Contributeur introuvable.");
        }

        await Astro.locals.pb.collection("contributeurs").delete(id);
        return redirectWith("success", "Contributeur supprimé avec succès.");
      }

      throw new Error("Action contributeur inconnue.");
    }

    throw new Error("Type d'élément inconnu.");
  } catch (error) {
    const message =
      error instanceof Error ? error.message : "Une erreur est survenue.";
    return redirectWith("error", message);
  }
}

const partenairesRaw: any[] = await Astro.locals.pb
  .collection("partenaires")
  .getFullList(200, { sort: "-updated" });
const contributeursRaw: any[] = await Astro.locals.pb
  .collection("contributeurs")
  .getFullList(200, { sort: "-updated" });

const partenaires: PartenaireItem[] = partenairesRaw.map((partenaire) => ({
  id: partenaire.id,
  nom: partenaire.nom || "Sans nom",
  logo: partenaire.logo,
  logoUrl: partenaire.logo
    ? Astro.locals.pb.files.getURL(partenaire, partenaire.logo)
    : "",
  updated: partenaire.updated,
}));

const contributeurs: ContributeurItem[] = contributeursRaw.map(
  (contributeur) => ({
    id: contributeur.id,
    nom: contributeur.nom || "Sans nom",
    metier: contributeur.metier || "",
    description: contributeur.description || "",
    updated: contributeur.updated,
  }),
);

const stats = {
  total: partenaires.length + contributeurs.length,
  partenaires: partenaires.length,
  contributeurs: contributeurs.length,
};

const success = (Astro.url.searchParams.get("success") || "").trim();
const error = (Astro.url.searchParams.get("error") || "").trim();
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    <div
      class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between"
    >
      <div class="mb-0">
        <h1
          class="mb-3 text-3xl font-bold text-accent font-poppins md:text-4xl"
        >
          Remerciements
        </h1>
        <p class="text-base text-base-content/70 md:text-lg">
          Gérez les partenaires et les contributeurs depuis une seule page.
        </p>
      </div>
      <div class="flex flex-col gap-3">
        <label class="text-sm font-medium text-base-content">Ce que vous voulez ajouter</label>
        <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
          <a
            href="/creation/remerciements/nouveau?tab=partenaire"
            class="btn btn-accent btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md"
          >
            Ajouter un partenaire
          </a>
          <a
            href="/creation/remerciements/nouveau?tab=contributeur"
            class="btn btn-accent btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md"
          >
            Ajouter un contributeur
          </a>
        </div>
      </div>
    </div>

    {
      success && (
        <div
          id="remerciements-success-flag"
          data-message={success}
          class="hidden"
        />
      )
    }
    {
      error && (
        <div
          id="remerciements-error-flag"
          data-message={error}
          class="hidden"
        />
      )
    }

    <div class="mb-12 grid grid-cols-1 gap-4 md:grid-cols-3 lg:grid-cols-3">
      <div class="card bg-base-100 shadow-md">
        <div class="card-body p-4 text-center">
          <div class="text-4xl! font-bold text-base-content">{stats.total}</div>
          <div class="text-base-content">Éléments</div>
        </div>
      </div>
      <div class="card bg-base-100 shadow-md">
        <div class="card-body p-4 text-center">
          <div class="text-4xl! font-bold text-base-content">
            {stats.partenaires}
          </div>
          <div class="text-base-content">Partenaires</div>
        </div>
      </div>
      <div class="card bg-base-100 shadow-md">
        <div class="card-body p-4 text-center">
          <div class="text-4xl! font-bold text-base-content">
            {stats.contributeurs}
          </div>
          <div class="text-base-content">Contributeurs</div>
        </div>
      </div>
    </div>

    <section class="mb-12">
      <div class="mb-6 flex items-center justify-between gap-4">
        <h2 class="text-2xl font-bold">Partenaires</h2>
      </div>

      {
        partenaires.length === 0 ? (
          <div class="rounded-xl border border-base-300 bg-base-100 p-6 text-base-content/60">
            Aucun partenaire pour le moment.
          </div>
        ) : (
          <>
            <div class="mb-6">
              <label class="form-control w-full gap-2 md:max-w-md">
                <span class="label-text font-medium">
                  Rechercher un partenaire
                </span>
                <input
                  id="partenaires-search-input"
                  type="text"
                  class="input input-bordered w-full"
                  placeholder="Filtrer par nom du partenaire"
                />
              </label>
            </div>

            <div
              class="grid grid-cols-1 gap-4 md:grid-cols-3 lg:grid-cols-3"
              id="partenaires-grid"
            >
              {partenaires.map((partenaire, partenaireIndex) => (
                <div
                  data-partenaire-item={partenaireIndex}
                  data-search={`${partenaire.nom} ${formatDateShort(partenaire.updated)} ${partenaire.updated || ""}`}
                  class="space-y-3"
                >
                  <ItemCard
                    id={partenaire.id}
                    title={partenaire.nom}
                    photoUrl={partenaire.logoUrl}
                    source="partenaire"
                    formattedDate={formatDateShort(partenaire.updated)}
                    viewUrl={`/creation/remerciements/edit/${partenaire.id}`}
                    editUrl={`/creation/remerciements/edit/${partenaire.id}`}
                  />
                  
                </div>
              ))}
            </div>

            <SectionPaginator
              itemAttr="data-partenaire-item"
              pageSize={6}
              searchInputId="partenaires-search-input"
              emptyMessage="Aucun partenaire ne correspond à la recherche."
            />
          </>
        )
      }
    </section>

    <section>
      <div class="mb-6 flex items-center justify-between gap-4">
        <h2 class="text-2xl font-bold">Contributeurs</h2>
      </div>

      {
        contributeurs.length === 0 ? (
          <div class="rounded-xl border border-base-300 bg-base-100 p-6 text-base-content/60">
            Aucun contributeur pour le moment.
          </div>
        ) : (
          <>
            <div class="mb-6">
              <label class="form-control w-full gap-2 md:max-w-md">
                <span class="label-text font-medium">
                  Rechercher un contributeur
                </span>
                <input
                  id="contributeurs-search-input"
                  type="text"
                  class="input input-bordered w-full"
                  placeholder="Filtrer par nom, métier ou description"
                />
              </label>
            </div>

            <div
              class="grid grid-cols-1 gap-4 md:grid-cols-3 lg:grid-cols-3"
              id="contributeurs-grid"
            >
              {contributeurs.map((contributeur, contributeurIndex) => (
                <div
                  data-contributeur-item={contributeurIndex}
                  data-search={`${contributeur.nom} ${contributeur.metier} ${contributeur.description}`}
                  class="space-y-3"
                >
                  <ItemCard
                    id={contributeur.id}
                    title={contributeur.nom}
                    subtitle={contributeur.metier || contributeur.description}
                    source="contributeur"
                    formattedDate={formatDateShort(contributeur.updated)}
                    viewUrl={`/creation/remerciements/edit/${contributeur.id}`}
                    editUrl={`/creation/remerciements/edit/${contributeur.id}`}
                  />
                </div>
              ))}
            </div>

            <SectionPaginator
              itemAttr="data-contributeur-item"
              pageSize={6}
              searchInputId="contributeurs-search-input"
              emptyMessage="Aucun contributeur ne correspond à la recherche."
            />
          </>
        )
      }
    </section>
  </div>
</Layout>

<script>
  import { showAlert, showConfirm } from "../../../utils/alerts";

  document.addEventListener("submit", (event) => {
    const form = event.target;
    if (!(form instanceof HTMLFormElement)) return;
    if (!form.hasAttribute("data-delete-form")) return;

    event.preventDefault();
    const message = form.dataset.confirmMessage || "Confirmer la suppression ?";

    void showConfirm({
      title: "Supprimer",
      message,
      confirmLabel: "Supprimer",
      cancelLabel: "Annuler",
      type: "warning",
    }).then((confirmed) => {
      if (!confirmed) return;
      HTMLFormElement.prototype.submit.call(form);
    });
  });

  const successFlag = document.getElementById("remerciements-success-flag");
  const errorFlag = document.getElementById("remerciements-error-flag");

  if (successFlag instanceof HTMLElement) {
    const message = (successFlag.dataset.message || "").trim();
    if (message) {
      showAlert({ type: "success", message });
      const url = new URL(window.location.href);
      url.searchParams.delete("success");
      window.history.replaceState({}, "", url.toString());
    }
  }

  if (errorFlag instanceof HTMLElement) {
    const message = (errorFlag.dataset.message || "").trim();
    if (message) {
      showAlert({ type: "error", message });
      const url = new URL(window.location.href);
      url.searchParams.delete("error");
      window.history.replaceState({}, "", url.toString());
    }
  }
</script>
