---
import Layout from "../../../../layouts/Layout-back-office.astro";

const asText = (value: FormDataEntryValue | null): string =>
  typeof value === "string" ? value.trim() : "";

const redirectWith = (type: "success" | "error", message: string) =>
  Astro.redirect(`/creation/remerciements?${type}=${encodeURIComponent(message)}`);

const id = Astro.params.id;

let error = "";
let itemRecord: any = null;
let itemType: "partenaire" | "contributeur" = "partenaire";
let title = "";

if (id) {
  try {
    // Try partenaire first
    itemRecord = await Astro.locals.pb.collection("partenaires").getOne(id);
    itemType = "partenaire";
    title = "Modifier le partenaire";
  } catch {
    try {
      // Try contributeur
      itemRecord = await Astro.locals.pb.collection("contributeurs").getOne(id);
      itemType = "contributeur";
      title = "Modifier le contributeur";
    } catch (err) {
      console.error("Erreur lors du chargement :", err);
      error = "Impossible de charger l'élément.";
    }
  }
}

const partenaireState = {
  nom: itemRecord?.nom || "",
};

const contributeurState = {
  nom: itemRecord?.nom || "",
  metier: itemRecord?.metier || "",
  description: itemRecord?.description || "",
};

const logoUrl =
  itemType === "partenaire" && itemRecord?.logo
    ? Astro.locals.pb.files.getURL(itemRecord, itemRecord.logo)
    : "";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const entity = asText(formData.get("entity"));

    if (!id || !itemRecord) {
      throw new Error("Élément introuvable.");
    }

    if (entity === "partenaire") {
      const nom = asText(formData.get("nom"));
      const logo = formData.get("logo");

      if (!nom) {
        throw new Error("Le nom du partenaire est obligatoire.");
      }

      const updateData: Record<string, string | File> = { nom };
      if (logo instanceof File && logo.size > 0) {
        updateData.logo = logo;
      }

      await Astro.locals.pb.collection("partenaires").update(id, updateData);
      return redirectWith("success", "Partenaire modifié avec succès.");
    }

    if (entity === "contributeur") {
      const nom = asText(formData.get("nom"));
      const metier = asText(formData.get("metier"));
      const description = asText(formData.get("description"));

      if (!nom) {
        throw new Error("Le nom du contributeur est obligatoire.");
      }

      await Astro.locals.pb.collection("contributeurs").update(id, {
        nom,
        metier,
        description,
      });
      return redirectWith("success", "Contributeur modifié avec succès.");
    }

    throw new Error("Type d'élément inconnu.");
  } catch (caughtError) {
    error =
      caughtError instanceof Error
        ? caughtError.message
        : "Une erreur inconnue est survenue.";
  }
}
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    <div class="mb-8 flex flex-col gap-3">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold text-accent font-poppins">
          {title}
        </h1>
        <p class="text-base-content mt-2">
          {itemType === "partenaire"
            ? "Mettez à jour les informations du partenaire."
            : "Mettez à jour les informations du contributeur."}
        </p>
      </div>
    </div>

    {
      error && (
        <div class="alert alert-error mb-6 rounded-lg">
          <span>{error}</span>
        </div>
      )
    }

    <div class="w-full">
      <div class="card rounded-2xl border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body p-6 md:p-8">
          {itemType === "partenaire" ? (
            <form method="POST" enctype="multipart/form-data" class="space-y-6">
              <input type="hidden" name="entity" value="partenaire" />

              <div class="space-y-2">
                <label
                  for="edit-partenaire-nom"
                  class="block text-sm font-semibold text-base-content"
                >
                  Nom du partenaire <span class="text-error">*</span>
                </label>
                <input
                  id="edit-partenaire-nom"
                  type="text"
                  name="nom"
                  class="input input-bordered w-full text-base"
                  placeholder="Exemple : Partenaire local"
                  value={partenaireState.nom}
                  required
                />
              </div>

              <div class="space-y-2">
                <label
                  for="edit-partenaire-logo"
                  class="block text-sm font-semibold text-base-content"
                >
                  Logo
                </label>
                <div
                  id="logo-preview-container"
                  class="h-24 overflow-hidden rounded-xl border border-base-300/60 bg-base-200/60 md:h-48"
                >
                  {logoUrl ? (
                    <img
                      id="logo-preview-img"
                      src={logoUrl}
                      alt={`Logo ${partenaireState.nom}`}
                      class="h-full w-full object-contain object-center px-4 py-2"
                    />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center text-sm text-base-content/60">
                      Aucun logo
                    </div>
                  )}
                </div>
              </div>

              <div class="space-y-2">
                <label
                  for="edit-partenaire-logo-new"
                  class="block text-sm font-semibold text-base-content"
                >
                  Remplacer le logo
                </label>
                <input
                  id="edit-partenaire-logo-new"
                  type="file"
                  name="logo"
                  accept="image/*"
                  class="file-input file-input-bordered w-full"
                />
                <span class="label-text-alt text-base-content/60">
                  Laissez vide pour conserver l'image actuelle.
                </span>
              </div>

              <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
                <a
                  href="/creation/remerciements"
                  class="btn btn-ghost btn-sm rounded-lg flex-1 w-full md:flex-initial md:w-fit md:btn-md"
                >
                  Retour
                </a>
                <button type="submit" class="btn btn-accent btn-sm rounded-lg flex-1 w-full md:flex-initial md:w-fit md:btn-md md:px-8">
                  Enregistrer
                </button>
              </div>
            </form>
          ) : (
            <form method="POST" class="space-y-6">
              <input type="hidden" name="entity" value="contributeur" />

              <div class="grid grid-cols-1 gap-6 md:grid-cols-2 items-end">
                <div class="space-y-2">
                  <label
                    for="edit-contributeur-nom"
                    class="block text-sm font-semibold text-base-content"
                  >
                    Nom du contributeur <span class="text-error">*</span>
                  </label>
                  <input
                    id="edit-contributeur-nom"
                    type="text"
                    name="nom"
                    class="input input-bordered w-full text-base"
                    placeholder="Exemple : Jean Dupont"
                    value={contributeurState.nom}
                    required
                  />
                </div>

                <div class="space-y-2">
                  <label
                    for="edit-contributeur-metier"
                    class="block text-sm font-semibold text-base-content"
                  >
                    Métier
                  </label>
                  <input
                    id="edit-contributeur-metier"
                    type="text"
                    name="metier"
                    class="input input-bordered w-full text-base"
                    placeholder="Exemple : Photographe"
                    value={contributeurState.metier}
                  />
                </div>
              </div>

              <div class="space-y-2">
                <label
                  for="edit-contributeur-description"
                  class="block text-sm font-semibold text-base-content"
                >
                  Description
                </label>
                <textarea
                  id="edit-contributeur-description"
                  name="description"
                  class="textarea textarea-bordered min-h-32 w-full text-base"
                  placeholder="Quelques mots sur la contribution..."
                >
                  {contributeurState.description}
                </textarea>
              </div>

              <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
                <a
                  href="/creation/remerciements"
                  class="btn btn-ghost btn-sm rounded-lg flex-1 w-full md:flex-initial md:w-fit md:btn-md"
                >
                  Retour
                </a>
                <button type="submit" class="btn btn-accent btn-sm rounded-lg flex-1 w-full md:flex-initial md:w-fit md:btn-md md:px-8">
                  Enregistrer
                </button>
              </div>
            </form>
          )}
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const logoInput = document.getElementById("edit-partenaire-logo-new");
  const previewImg = document.getElementById("logo-preview-img");
  const previewContainer = document.getElementById("logo-preview-container");

  if (logoInput && previewContainer) {
    logoInput.addEventListener("change", (event) => {
      const file = (event.target as HTMLInputElement).files?.[0];

      if (file) {
        const reader = new FileReader();

        reader.onload = (e) => {
          const imageUrl = e.target?.result as string;

          // Si une image existe, on la remplace
          if (previewImg instanceof HTMLImageElement) {
            previewImg.src = imageUrl;
          } else {
            // Sinon, on crée une nouvelle image
            const newImg = document.createElement("img");
            newImg.id = "logo-preview-img";
            newImg.src = imageUrl;
            newImg.alt = "Aperçu du nouveau logo";
            newImg.className =
              "h-full w-full object-contain object-center px-4 py-2";
            previewContainer.innerHTML = "";
            previewContainer.appendChild(newImg);
          }
        };

        reader.readAsDataURL(file);
      }
    });
  }
</script>
