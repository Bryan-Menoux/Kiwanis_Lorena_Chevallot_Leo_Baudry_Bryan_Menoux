---
import Layout from "../../../../layouts/Layout-back-office.astro";
import ItemCard from "../../../../components/ItemCard.astro";
import SectionPaginator from "../../../../components/SectionPaginator.astro";
import { normalizeImageUrl, resolveCreatorName } from "../../../../utils/utilitaires.js";

let error = "";
let success = "";

type DeletePartenaire = {
  id: string;
  title: string;
  nom: string;
  photoUrl: string;
  updated: string;
  authorName: string;
  type: "partenaire";
  source: "partenaire";
  search: string;
};

type DeleteContributeur = {
  id: string;
  title: string;
  nom: string;
  subtitle: string;
  updated: string;
  authorName: string;
  type: "contributeur";
  source: "contributeur";
  search: string;
};

// Récupérer la liste des partenaires et contributeurs
let partenairesRaw = [];
let contributeursRaw = [];
try {
  partenairesRaw = await (Astro.locals as any).pb
    .collection("partenaires")
    .getFullList(500, { sort: "-updated", expand: "cree_par" });
} catch (e) {
  console.error("Impossible de récupérer les partenaires:", e);
  error = "Impossible de charger la liste des partenaires.";
}

try {
  contributeursRaw = await (Astro.locals as any).pb
    .collection("contributeurs")
    .getFullList(500, { sort: "-updated", expand: "cree_par" });
} catch (e) {
  console.error("Impossible de récupérer les contributeurs:", e);
  error = "Impossible de charger la liste des contributeurs.";
}

// Mapper les partenaires
const partenaires: DeletePartenaire[] = partenairesRaw.map((p: any) => {
  const photoUrl = normalizeImageUrl(p.logo, p, (Astro.locals as any).pb) || "";

  return {
    id: p.id,
    title: p.nom || "Partenaire sans nom",
    nom: p.nom || "Partenaire sans nom",
    photoUrl,
    updated: p.updated,
    authorName: resolveCreatorName(p) || "Auteur inconnu",
    type: "partenaire",
    source: "partenaire" as const,
    search: `${p.nom || ""} ${resolveCreatorName(p) || ""} ${p.updated || ""}`.trim(),
  };
});

// Mapper les contributeurs
const contributeurs: DeleteContributeur[] = contributeursRaw.map((c: any) => ({
  id: c.id,
  title: c.nom || "Contributeur sans nom",
  nom: c.nom || "Contributeur sans nom",
  subtitle: c.metier || "",
  updated: c.updated,
  authorName: resolveCreatorName(c) || "Auteur inconnu",
  type: "contributeur",
  source: "contributeur" as const,
  search: `${c.nom || ""} ${c.metier || ""} ${c.description || ""} ${resolveCreatorName(c) || ""} ${c.updated || ""}`.trim(),
}));

// Gestion POST pour suppression multiple
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const ids = formData
      .getAll("ids")
      .map((v) => v.toString())
      .filter(Boolean);

    if (!ids || ids.length === 0) {
      error = "Aucun élément sélectionné.";
    } else {
      const failed: string[] = [];
      for (const id of ids) {
        try {
          // Essayer d'abord partenaires, puis contributeurs
          try {
            await (Astro.locals as any).pb.collection("partenaires").delete(id);
          } catch {
            await (Astro.locals as any).pb.collection("contributeurs").delete(id);
          }
        } catch (e) {
          console.error("Erreur suppression id:", id, e);
          failed.push(id);
        }
      }
      if (failed.length === 0) {
        return Astro.redirect(
          `/creation/remerciements/supprimer?success=${encodeURIComponent(`${ids.length} élément(s) supprimé(s) avec succès.`)}`,
        );
      } else {
        error = `Échec de la suppression pour ${failed.length} élément(s).`;
      }
    }
  } catch (e) {
    console.error("Erreur lors du POST suppression:", e);
    error = "La suppression a échoué.";
  }
}

// Afficher le message de succès s'il est présent dans les paramètres de requête.
try {
  const s = Astro.url.searchParams.get("success");
  if (s) success = s;
} catch (e) {}
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="mb-0">
        <h1 class="mb-3 text-3xl font-bold text-accent font-poppins md:text-4xl">Supprimer des remerciements</h1>
        <p class="text-base text-base-content md:text-lg">
          Sélectionnez les partenaires ou les contributeurs à supprimer puis cliquez sur "Supprimer sélection".
        </p>
      </div>
      <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
        <a href="/creation/remerciements" class="btn btn-border btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md">Retour aux remerciements</a>
      </div>
    </div>

    <div
      id="delete-flash-flags"
      data-success={success}
      data-error={error}
      class="hidden"
    ></div>

    <form method="POST" id="deleteForm">
      <div class="mb-6 flex flex-wrap items-center justify-end gap-3">
        <label class="flex items-center gap-2">
          <input type="checkbox" id="selectAll" />
          <span class="text-sm">Tout sélectionner</span>
        </label>
        <button
          type="submit"
          id="bulkDelete"
          class="btn btn-error btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md"
        >
          Supprimer sélection
        </button>
      </div>

      <section class="mb-12">
        <div class="mb-6 flex items-center justify-between gap-4">
          <h2 class="text-2xl font-bold">Partenaires</h2>
        </div>

        {
          partenaires.length === 0 ? (
            <div class="rounded-xl border border-base-300 bg-base-100 p-6 text-base-content/60">
              Aucun partenaire pour le moment.
            </div>
          ) : (
            <>
              <div class="mb-6">
                <label class="form-control w-full gap-2 md:max-w-md">
                  <span class="label-text font-medium">
                    Rechercher un partenaire
                  </span>
                  <input
                    id="partenaires-search-input"
                    type="text"
                    class="input input-bordered w-full"
                    placeholder="Filtrer par nom du partenaire"
                  />
                </label>
              </div>

              <div
                class="grid grid-cols-1 gap-4 md:grid-cols-3 lg:grid-cols-3"
                id="partenaires-grid"
              >
                {partenaires.map((partenaire, partenaireIndex) => (
                  <div
                    data-partenaire-item={partenaireIndex}
                    data-search={partenaire.search}
                    class="space-y-3"
                  >
                    <ItemCard
                      id={partenaire.id}
                      title={partenaire.title}
                      photoUrl={partenaire.photoUrl}
                      showPhotoPlaceholder={true}
                      source="partenaire"
                      authorName={partenaire.authorName}
                      viewUrl={`/creation/remerciements/modifier/${partenaire.id}`}
                      editUrl={`/creation/remerciements/modifier/${partenaire.id}`}
                      showCheckbox={true}
                      checkboxSlot={`<input class="checkbox checkbox-primary shrink-0" type="checkbox" name="ids" id="id_${partenaire.id}" value="${partenaire.id}" data-item-id="${partenaire.id}" data-title="${partenaire.title}" data-updated="${partenaire.updated}" />`}
                      maxHeightContent={true}
                      deleteMode={true}
                    />
                  </div>
                ))}
              </div>

              <SectionPaginator
                itemAttr="data-partenaire-item"
                pageSize={6}
                searchInputId="partenaires-search-input"
                emptyMessage="Aucun partenaire ne correspond à la recherche."
              />
            </>
          )
        }
      </section>

      <section>
        <div class="mb-6 flex items-center justify-between gap-4">
          <h2 class="text-2xl font-bold">Contributeurs</h2>
        </div>

        {
          contributeurs.length === 0 ? (
            <div class="rounded-xl border border-base-300 bg-base-100 p-6 text-base-content/60">
              Aucun contributeur pour le moment.
            </div>
          ) : (
            <>
              <div class="mb-6">
                <label class="form-control w-full gap-2 md:max-w-md">
                  <span class="label-text font-medium">
                    Rechercher un contributeur
                  </span>
                  <input
                    id="contributeurs-search-input"
                    type="text"
                    class="input input-bordered w-full"
                    placeholder="Filtrer par nom, métier ou description"
                  />
                </label>
              </div>

              <div
                class="grid grid-cols-1 gap-4 md:grid-cols-3 lg:grid-cols-3"
                id="contributeurs-grid"
              >
                {contributeurs.map((contributeur, contributeurIndex) => (
                  <div
                    data-contributeur-item={contributeurIndex}
                    data-search={contributeur.search}
                    class="space-y-3"
                  >
                    <ItemCard
                      id={contributeur.id}
                      title={contributeur.title}
                      subtitle={contributeur.subtitle}
                      source="contributeur"
                      authorName={contributeur.authorName}
                      viewUrl={`/creation/remerciements/modifier/${contributeur.id}`}
                      editUrl={`/creation/remerciements/modifier/${contributeur.id}`}
                      showCheckbox={true}
                      checkboxSlot={`<input class="checkbox checkbox-primary shrink-0" type="checkbox" name="ids" id="id_${contributeur.id}" value="${contributeur.id}" data-item-id="${contributeur.id}" data-title="${contributeur.title}" data-updated="${contributeur.updated}" />`}
                      maxHeightContent={true}
                      deleteMode={true}
                    />
                  </div>
                ))}
              </div>

              <SectionPaginator
                itemAttr="data-contributeur-item"
                pageSize={6}
                searchInputId="contributeurs-search-input"
                emptyMessage="Aucun contributeur ne correspond à la recherche."
              />
            </>
          )
        }
      </section>
    </form>
  </div>

  <script>
    import { showAlert, showConfirm } from "../../../../utils/alerts";

    const form = document.getElementById("deleteForm");
    const selectAllCheckbox = document.getElementById("selectAll");

    const updateSelectAllState = () => {
      if (!(selectAllCheckbox instanceof HTMLInputElement)) return;
      const checkboxes = Array.from(
        document.querySelectorAll<HTMLInputElement>('input[name="ids"]'),
      );
      const checkedCount = checkboxes.filter((checkbox) => checkbox.checked).length;

      if (checkboxes.length === 0) {
        selectAllCheckbox.checked = false;
        selectAllCheckbox.indeterminate = false;
        return;
      }

      if (checkedCount === checkboxes.length) {
        selectAllCheckbox.checked = true;
        selectAllCheckbox.indeterminate = false;
        return;
      }

      if (checkedCount > 0) {
        selectAllCheckbox.checked = false;
        selectAllCheckbox.indeterminate = true;
        return;
      }

      selectAllCheckbox.checked = false;
      selectAllCheckbox.indeterminate = false;
    };

    if (selectAllCheckbox instanceof HTMLInputElement) {
      selectAllCheckbox.addEventListener("change", () => {
        const shouldSelect = selectAllCheckbox.checked;
        document.querySelectorAll<HTMLInputElement>('input[name="ids"]').forEach((checkbox) => {
          checkbox.checked = shouldSelect;
        });
        updateSelectAllState();
      });
    }

    document.addEventListener("change", (event) => {
      if (!(event.target instanceof HTMLInputElement)) return;
      if (event.target.name !== "ids") return;
      updateSelectAllState();
    });

    if (form instanceof HTMLFormElement) {
      form.addEventListener("submit", async (event) => {
        const selectedCount = document.querySelectorAll('input[name="ids"]:checked').length;
        if (selectedCount === 0) {
          event.preventDefault();
          showAlert({
            type: "warning",
            message: "Sélectionnez au moins un élément avant de lancer la suppression.",
          });
          return;
        }

        event.preventDefault();
        const confirmed = await showConfirm({
          title: "Confirmer la suppression",
          message: `Confirmez-vous la suppression de ${selectedCount} ${selectedCount > 1 ? "éléments" : "élément"} ? Cette action est irréversible.`,
          type: "warning",
          confirmLabel: "Supprimer",
          cancelLabel: "Annuler",
        });

        if (!confirmed) return;
        form.submit();
      });
    }

    updateSelectAllState();
  </script>
</Layout>
