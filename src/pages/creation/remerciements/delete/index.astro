---
import Layout from "../../../../layouts/Layout-back-office.astro";
import ItemCard from "../../../../components/ItemCard.astro";

let error = "";
let success = "";

// Récupérer la liste des partenaires et contributeurs
let partenairesRaw = [];
let contributeursRaw = [];
try {
  partenairesRaw = await (Astro.locals as any).pb
    .collection("partenaires")
    .getFullList(500, { sort: "-updated" });
} catch (e) {
  console.error("Impossible de récupérer les partenaires:", e);
  error = "Impossible de charger la liste des partenaires.";
}

try {
  contributeursRaw = await (Astro.locals as any).pb
    .collection("contributeurs")
    .getFullList(500, { sort: "-updated" });
} catch (e) {
  console.error("Impossible de récupérer les contributeurs:", e);
  error = "Impossible de charger la liste des contributeurs.";
}

// Mapper les partenaires
const partenaires = partenairesRaw.map((p: any) => {
  const photoUrl = Array.isArray(p.logo) && p.logo.length > 0
    ? (Astro.locals as any).pb.files.getURL(p, p.logo[0])
    : "";
  
  return {
    id: p.id,
    title: p.nom || "Partenaire sans nom",
    photoUrl,
    updated: p.updated,
    type: "partenaire",
    source: "partenaire" as const,
  };
});

// Mapper les contributeurs
const contributeurs = contributeursRaw.map((c: any) => ({
  id: c.id,
  title: c.nom || "Contributeur sans nom",
  subtitle: c.metier || "",
  updated: c.updated,
  type: "contributeur",
  source: "contributeur" as const,
}));

// Combiner et trier
const items = [...partenaires, ...contributeurs].sort(
  (a, b) =>
    new Date(b.updated || 0).getTime() - new Date(a.updated || 0).getTime(),
);

function formatDate(dateStr?: string): string {
  if (!dateStr) return "";
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  } catch {
    return dateStr;
  }
}

// Gestion POST pour suppression multiple
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const ids = formData
      .getAll("ids")
      .map((v) => v.toString())
      .filter(Boolean);

    if (!ids || ids.length === 0) {
      error = "Aucun élément sélectionné.";
    } else {
      const failed: string[] = [];
      for (const id of ids) {
        try {
          // Essayer d'abord partenaires, puis contributeurs
          try {
            await (Astro.locals as any).pb.collection("partenaires").delete(id);
          } catch {
            await (Astro.locals as any).pb.collection("contributeurs").delete(id);
          }
        } catch (e) {
          console.error("Erreur suppression id:", id, e);
          failed.push(id);
        }
      }
      if (failed.length === 0) {
        return Astro.redirect(
          `/creation/remerciements/delete?success=${encodeURIComponent(`${ids.length} élément(s) supprimé(s) avec succès.`)}`,
        );
      } else {
        error = `Échec de la suppression pour ${failed.length} élément(s).`;
      }
    }
  } catch (e) {
    console.error("Erreur lors du POST suppression:", e);
    error = "La suppression a échoué.";
  }
}

// Afficher le message de succès s'il est présent dans les paramètres de requête.
try {
  const s = Astro.url.searchParams.get("success");
  if (s) success = s;
} catch (e) {}
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="mb-0">
        <h1 class="mb-3 text-3xl font-bold text-accent font-poppins md:text-4xl">Supprimer des remerciements</h1>
        <p class="text-base text-base-content md:text-lg">
          Sélectionnez plusieurs partenaires ou contributeurs puis cliquez sur "Supprimer sélection".
        </p>
      </div>
      <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
        <a href="/creation/remerciements" class="btn btn-border btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md">Retour aux remerciements</a>
      </div>
    </div>

    <div
      id="delete-flash-flags"
      data-success={success}
      data-error={error}
      class="hidden"
    ></div>

    <form method="POST" id="deleteForm">
      <div class="mb-4 space-y-4">
        <div class="card rounded-2xl border border-base-300 bg-base-100 shadow-sm">
          <div class="card-body p-4 md:p-6">
            <div class="mb-4">
              <h2 class="card-title text-2xl">Filtrer</h2>
              <p class="mt-1 text-sm text-base-content">
                Filtrez rapidement les partenaires ou contributeurs.
              </p>
            </div>
            <div class="flex flex-col gap-4">
              <div class="w-full">
                <p class="mb-2 text-sm font-medium text-base-content">Recherche</p>
                <input
                  type="text"
                  id="search-input"
                  placeholder="Rechercher par nom..."
                  class="input input-bordered w-full"
                />
              </div>
            </div>
          </div>
        </div>
        <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
          <label class="flex items-center gap-2">
            <input type="checkbox" id="selectAll" />
            <span class="text-sm">Tout sélectionner</span>
          </label>
          <button
            type="submit"
            id="bulkDelete"
            class="btn btn-error btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md"
            >Supprimer sélection</button
          >
        </div>
      </div>

      <div
        id="cards-grid"
        class="grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-5 lg:grid-cols-3 lg:gap-6"
      >
        {
          items.map((item: any) => (
            <ItemCard
              id={item.id}
              title={item.title}
              subtitle={item.subtitle}
              photoUrl={item.photoUrl}
              showPhotoPlaceholder={true}
              source={item.source}
              formattedDate={formatDate(item.updated)}
              viewUrl="/creation/remerciements"
              editUrl="/creation/remerciements"
              showCheckbox={true}
              checkboxSlot={`<input class="checkbox checkbox-primary shrink-0" type="checkbox" name="ids" id="id_${item.id}" value="${item.id}" data-item-id="${item.id}" data-title="${item.title}" data-updated="${item.updated}" />`}
              maxHeightContent={true}
              deleteMode={true}
            />
          ))
        }
      </div>
      <div id="cards-pagination" class="mt-6 flex justify-center"></div>
    </form>
  </div>

  <script>
    import { initDeletePageHandler } from "../../../../utils/deletePageHandler";

    initDeletePageHandler({
      cardSelector: "div[data-item-id]",
      itemSingular: "élément",
      itemPlural: "éléments",
    });
  </script>
</Layout>
