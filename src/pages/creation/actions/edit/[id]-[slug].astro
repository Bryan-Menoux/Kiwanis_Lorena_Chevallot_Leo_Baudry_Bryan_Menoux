            <h4 class="font-semibold">Partie 3</h4>
            <input
              data-prop="titre_partie_3"
              id="input_titre_partie_3"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Titre partie 3"
              value={previewData.titre_partie_3}
            />
            <input
              type="hidden"
              name="titre_partie_3"
              id="hidden_titre_partie_3"
              value={previewData.titre_partie_3}
            />
            <label class="block text-sm font-medium mt-2">Texte partie 3</label>
            <textarea
              data-prop="texte_partie_3"
              id="input_texte_partie_3"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              rows="4">{previewData.texte_partie_3}</textarea
            >
            <input
              type="hidden"
              name="texte_partie_3"
              id="hidden_texte_partie_3"
              value={previewData.texte_partie_3}
            />
            <label class="block text-sm font-medium mt-2">Photo partie 3</label>
            <label
              for="input_photo_partie_3"
              class="cursor-pointer w-full h-36 border-2 border-dashed rounded bg-base-100 flex items-center justify-center text-gray-500"
            >
              <input
                data-prop-file="photo_partie_3"
                type="file"
                name="photo_partie_3"
                id="input_photo_partie_3"
                accept="image/*"
                class="hidden"
              />
              <div id="preview_photo_partie_3" class="mt-2"></div>
              <div
                class="flex flex-col items-center text-center pointer-events-none"
              >
                <img
                  src={imageIcon.src}
                  alt="Icone image"
                  class="h-16 w-16"
                  style="filter:grayscale(100%) brightness(0.5); opacity:0.3;"
                />
                <span class="text-sm">Ajouter une photo</span>
              </div>
            </label>
            {
              actionRecord?.photo_partie_3 && (
                <div class="mt-2" id="existing_photo_partie_3_container">
                  <label class="block text-sm font-medium mb-1">
                    Image actuelle
                  </label>
                  <div class="relative">
                    <button type="button" class="existing-single-remove absolute top-2 right-2 bg-black/60 text-white rounded-full w-6 h-6 flex items-center justify-center" data-prop="photo_partie_3">×</button>
                    <img
                      data-field="photo_partie_3"
                      src={normalizeImageUrl(
                        actionRecord.photo_partie_3,
                        actionRecord,
                        Astro.locals.pb,
                      )}
                      alt="Aperçu photo partie 3"
                      class="w-full h-[25dvh] object-cover rounded"
                    />
                  </div>
                </div>
              )
            }
            <input
              data-prop="description_photo_partie_3"
              id="input_description_photo_partie_3"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              value={previewData.description_photo_partie_3}
            />
            <input
              type="hidden"
              name="description_photo_partie_3"
              id="hidden_description_photo_partie_3"
              value={previewData.description_photo_partie_3}
            />
          </div>

          <div
            class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4"
          >
            <h4 class="font-semibold">Remerciements</h4>
            <input
              data-prop="titre_remerciement"
              id="input_titre_remerciement"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Titre remerciements"
              value={previewData.titre_remerciements}
            />
            <input
              type="hidden"
              name="titre_remerciement"
              id="hidden_titre_remerciement"
              value={previewData.titre_remerciements}
            />
            <label class="block text-sm font-medium mt-2"
              >Description remerciements</label
            >
            <textarea
              data-prop="description_remerciement"
              id="input_description_remerciement"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              rows="3">{previewData.description_remerciements}</textarea
            >
            <input
              type="hidden"
              name="description_remerciement"
              id="hidden_description_remerciement"
              value={previewData.description_remerciements}
            />
          </div>

          <div
            class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4"
          >
            <label class="block text-sm font-medium mb-1">Galerie (max 8)</label
            >
            <label
              for="input_galerie_photos"
              class="cursor-pointer w-full h-36 border-2 border-dashed rounded bg-base-100 flex items-center justify-center text-gray-500"
            >
              <input
                data-prop-file="galerie_photos"
                type="file"
                name="galerie_photos"
                id="input_galerie_photos"
                accept="image/*"
                multiple
                class="hidden"
              />
              <div
                class="flex flex-col items-center text-center pointer-events-none"
              >
                <img
                  src={imageIcon.src}
                  alt="Icone image"
                  class="h-16 w-16"
                  style="filter:grayscale(100%) brightness(0.5); opacity:0.3;"
                />
                <span class="text-sm">Cliquez ou glissez vos photos</span>
                <span class="text-xs text-gray-400">Jusqu'à 8 images</span>
              </div>
            </label>
            <input
              type="hidden"
              id="hidden_galerie_photos"
              name="galerie_photos"
            />
            <input
              type="hidden"
              id="hidden_remove_galerie_photos"
              name="remove_galerie_photos"
            />
            <div id="galleryExisting" class="mt-2 grid grid-cols-4 gap-2"></div>
            <div id="gallerySelected" class="mt-2 grid grid-cols-4 gap-2"></div>
          </div>

          <div class="pt-4">
            <button
              type="submit"
              class="bg-base-100 text-accent px-4 py-2 rounded w-full"
              >{
                idParam ? "Enregistrer les modifications" : "Créer l'action"
              }</button
            >
          </div>
        </form>
      </div>
    </div>

    <div class="w-2/3 px-8">
      <ActionContent action={previewData} />
    </div>
  </div>
  <script
    set:html={`window.__previewData = ${JSON.stringify(previewData).replace(/</g, "\\u003c")};`}
  />

  <script type="module" src={utilUrl}></script>
  <script type="module" src={previewUrl}></script>
  <script type="module" src={galleryUrl}></script>
  <script type="module" src={galleryDisplayUrl}></script>
</Layout>
