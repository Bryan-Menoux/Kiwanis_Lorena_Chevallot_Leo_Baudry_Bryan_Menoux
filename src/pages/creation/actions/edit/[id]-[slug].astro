---
// Page serveur pour créer/éditer une action : logique serveur et rendu.
import Layout from "../../../../layouts/Layout-back-office.astro";
import ActionContent from "../../../../components/ActionContent.astro";
import ActionForm from "../../../../components/ActionForm.astro";
import ActionEditorShell from "../../../../components/actionForm/ActionEditorShell.astro";
import slugify from "slugify";
// Paramètre `id` optionnel provenant de l'URL (utilisé pour l'édition)
const rawIdParam = Astro.params?.id;
const idParam =
  typeof rawIdParam === "string"
    ? (rawIdParam.match(/^[a-zA-Z0-9]{15}/)?.[0] ?? rawIdParam)
    : rawIdParam;

import galleryUrl from "../../../../scripts/gallery.js?url";
import galleryDisplayUrl from "../../../../scripts/gallery-display.js?url";
import utilUrl from "../../../../utils/utilitaires.js?url";
import {
  formatDateForInput,
  normalizeImageUrl,
} from "../../../../utils/utilitaires.js";
import imageIcon from "../../../../assets/image-icon.svg";
import {
  ActionsTypeActionOptions,
  ActionsTypeDeChiffreOptions,
} from "../../../../pocketbase-types";
import previewDefaults from "../../../../scripts/previewDefaults.js";
import {
  getNormalizedSelectedTypeActionValues,
} from "../../../../scripts/actionForm/validation.js";

// Message d'erreur affiché dans le formulaire en cas d'échec serveur
let error: string = "";
// Construit une URL de redirection avec un message de succès uniforme.
const withSuccess = (path: string, message: string) =>
  `${path}?success=${encodeURIComponent(message)}`;
const getPbTypeActionError = (err: any) =>
  err?.response?.data?.data?.type_action ||
  err?.response?.data?.type_action ||
  null;
const EMPTYABLE_FIELDS = new Set([
  "nom_lieu",
  "adresse_lieu",
  "lien_lieu",
  "chiffre",
  "type_de_chiffre",
]);
const PART_NUMBERS = [1, 2, 3];
const isRecordValueFilled = (value: any) =>
  typeof value === "string" ? value.trim() !== "" : Boolean(value);
const isNonEmptyString = (value: FormDataEntryValue | null) =>
  typeof value === "string" && value.trim() !== "";
const hasUploadedFile = (formData: FormData, fieldName: string) => {
  const value = formData.get(fieldName);
  return value instanceof File && value.size > 0;
};
const getNormalizedPreviewImage = (value: any, record: any, pocketbaseClient: any) => {
  const normalized = normalizeImageUrl(value, record, pocketbaseClient);
  if (typeof normalized === "string" && normalized.trim() !== "") {
    return normalized;
  }
  if (typeof value !== "string") return null;
  const raw = value.trim();
  if (!raw) return null;
  if (raw.startsWith("api/")) return `/${raw}`;
  if (
    raw.startsWith("http://") ||
    raw.startsWith("https://") ||
    raw.startsWith("/") ||
    raw.startsWith("data:")
  ) {
    return raw;
  }
  return null;
};
const keepExistingImageFields = (payload: Record<string, any>, record: any) => {
  if (payload.hero === undefined && isRecordValueFilled(record?.hero)) {
    payload.hero = record.hero;
  }
  if (
    payload.photo_partie_1 === undefined &&
    isRecordValueFilled(record?.photo_partie_1)
  ) {
    payload.photo_partie_1 = record.photo_partie_1;
  }
  if (
    payload.photo_partie_2 === undefined &&
    isRecordValueFilled(record?.photo_partie_2)
  ) {
    payload.photo_partie_2 = record.photo_partie_2;
  }
  if (
    payload.photo_partie_3 === undefined &&
    isRecordValueFilled(record?.photo_partie_3)
  ) {
    payload.photo_partie_3 = record.photo_partie_3;
  }
  if (
    payload.galerie_photos === undefined &&
    Array.isArray(record?.galerie_photos) &&
    record.galerie_photos.length > 0
  ) {
    payload.galerie_photos = [...record.galerie_photos];
  }
  return payload;
};
const isFieldRemoved = (formData: FormData, fieldName: string) => {
  const raw = formData.get(`remove_${fieldName}`);
  if (!raw) return false;
  const normalized = raw.toString().trim().toLowerCase();
  return normalized !== "" && normalized !== "0" && normalized !== "false";
};
const hasHeroAfterSubmit = (formData: FormData, record: any) =>
  hasUploadedFile(formData, "hero") ||
  (isRecordValueFilled(record?.hero) && !isFieldRemoved(formData, "hero"));
const hasTitleAfterSubmit = (formData: FormData, record: any) => {
  const titleFromForm = isNonEmptyString(formData.get("titre"));
  const titleFromRecord = isRecordValueFilled(record?.titre);
  return formData.has("titre") ? titleFromForm : titleFromRecord;
};
const hasStartDateAfterSubmit = (formData: FormData, record: any) => {
  const startDateFromForm = isNonEmptyString(formData.get("date_debut"));
  const startDateFromRecord = isRecordValueFilled(record?.date_debut);
  return formData.has("date_debut") ? startDateFromForm : startDateFromRecord;
};
const hasTypeActionAfterSubmit = (formData: FormData, record: any) => {
  const submittedValues = getNormalizedSelectedTypeActionValues(
    formData,
    typeActionOptions,
    7,
  );
  if (submittedValues.length > 0) {
    return true;
  }
  return Array.isArray(record?.type_action) && record.type_action.length > 0;
};
const hasAtLeastOnePartAfterSubmit = (formData: FormData, record: any) =>
  PART_NUMBERS.some((partNumber) => {
    const textKey = `texte_partie_${partNumber}`;
    const photoKey = `photo_partie_${partNumber}`;
    const textFromForm = isNonEmptyString(formData.get(textKey));
    const textFromRecord = isRecordValueFilled(record?.[textKey]);
    const hasText = formData.has(textKey) ? textFromForm : textFromRecord;
    const hasPhoto =
      hasUploadedFile(formData, photoKey) ||
      (isRecordValueFilled(record?.[photoKey]) &&
        !isFieldRemoved(formData, photoKey));
    return hasText || hasPhoto;
  });
const hasDescriptionForPartTitle = (payload: Record<string, any>, partNumber: number) => {
  const textKey = `texte_partie_${partNumber}`;
  const descriptionValue = payload[textKey];
  if (typeof descriptionValue !== "string" || descriptionValue.trim() === "") {
    return false;
  }
  const defaultDescription = Reflect.get(previewDefaults, textKey);
  if (typeof defaultDescription !== "string") {
    return true;
  }
  return descriptionValue.trim() !== defaultDescription.trim();
};
const applyPartTitleRule = (payload: Record<string, any>) => {
  for (const partNumber of PART_NUMBERS) {
    const titleKey = `titre_partie_${partNumber}`;
    if (!hasDescriptionForPartTitle(payload, partNumber)) {
      delete payload[titleKey];
      continue;
    }
    const currentTitleValue = payload[titleKey];
    if (typeof currentTitleValue === "string" && currentTitleValue.trim() !== "") {
      payload[titleKey] = currentTitleValue.trim();
      continue;
    }
    const defaultTitle = Reflect.get(previewDefaults, titleKey);
    if (typeof defaultTitle === "string" && defaultTitle.trim() !== "") {
      payload[titleKey] = defaultTitle.trim();
    }
  }
  return payload;
};
const getMissingRequiredFieldsAfterSubmit = (formData: FormData, record: any) => {
  const missing: string[] = [];

  if (!hasTitleAfterSubmit(formData, record)) {
    missing.push("titre");
  }
  if (!hasStartDateAfterSubmit(formData, record)) {
    missing.push("date de début");
  }
  if (!hasHeroAfterSubmit(formData, record)) {
    missing.push("image de l'en-tête");
  }
  if (!hasTypeActionAfterSubmit(formData, record)) {
    missing.push("type d'action");
  }
  if (!hasAtLeastOnePartAfterSubmit(formData, record)) {
    missing.push("au moins une partie (texte ou photo)");
  }

  return missing;
};

// Récupérer les options de type_de_chiffre depuis le type TypeScript généré
let typeDeChiffreOptions: string[] = ["type de chiffre", ...(Array.isArray(ActionsTypeDeChiffreOptions) ? ActionsTypeDeChiffreOptions : Object.values(ActionsTypeDeChiffreOptions))];
let typeActionOptions: string[] = (Array.isArray(ActionsTypeActionOptions)
  ? ActionsTypeActionOptions
  : Object.values(ActionsTypeActionOptions)).map((opt) => String(opt));

// Placeholder SVG data-URL pour la prévisualisation serveur
const placeholderImg = `data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='400' height='400' viewBox='0 0 400 400'><rect width='100%' height='100%' fill='%23f3f6f7'/><image href='${imageIcon.src}' x='50' y='50' width='300' height='300' preserveAspectRatio='xMidYMid meet' style='opacity:0.95;'/></svg>`;

// Charger l'enregistrement existant lorsque `idParam` est fourni (mode édition)
let actionRecord: any = null;
let actionRecordFromBrouillon = false;
if (idParam) {
  try {
    // Tenter d'abord dans `actions` ; si record non trouvé (404), rechercher dans `brouillons`.
    try {
      actionRecord = await Astro.locals.pb.collection("actions").getOne(idParam);
    } catch (err) {
      // Si la requête vers `actions` échoue (404 ou autre), tenter `brouillons`.
      try {
        actionRecord = await Astro.locals.pb.collection("brouillons").getOne(idParam);
        actionRecordFromBrouillon = true;
      } catch (err2) {
        // Ni actions ni brouillons trouvés : remonter l'erreur originale.
        throw err;
      }
    }
  } catch (e) {
    console.error("Erreur retrieving action:", e);
    error = "Impossible de charger l'action";
  }
}

// Ce bloc normalise les valeurs base de données pour la prévisualisation en direct et les champs du formulaire.
const previewData: any = {
  titre: actionRecord?.titre ?? "Titre de l'action",
  sous_titre: actionRecord?.sous_titre ?? "",
  date_debut: formatDateForInput(actionRecord?.date_debut) || "",
  date_fin: formatDateForInput(actionRecord?.date_fin) || "",
  description_hero: actionRecord?.description_hero ?? "",
  hero:
    getNormalizedPreviewImage(actionRecord?.hero, actionRecord, Astro.locals.pb) ??
    null,
  titre_partie_1: actionRecord?.titre_partie_1 ?? "",
  texte_partie_1: actionRecord?.texte_partie_1 ?? "",
  photo_partie_1:
    getNormalizedPreviewImage(
      actionRecord?.photo_partie_1,
      actionRecord,
      Astro.locals.pb,
    ) ?? null,
  description_photo_partie_1: actionRecord?.description_photo_partie_1 ?? "",
  nom_lieu: actionRecord?.nom_lieu ?? "",
  adresse_lieu: actionRecord?.adresse_lieu ?? "",
  lien_lieu: actionRecord?.lien_lieu ?? "",
  chiffre: actionRecord?.chiffre ?? "",
  type_de_chiffre: actionRecord?.type_de_chiffre ?? "",
  type_action: Array.isArray(actionRecord?.type_action)
    ? actionRecord.type_action
    : [],
  beneficiaire: actionRecord?.beneficiaire ?? "",
  titre_partie_2: actionRecord?.titre_partie_2 ?? "",
  texte_partie_2: actionRecord?.texte_partie_2 ?? "",
  photo_partie_2:
    getNormalizedPreviewImage(
      actionRecord?.photo_partie_2,
      actionRecord,
      Astro.locals.pb,
    ) ?? null,
  description_photo_partie_2: actionRecord?.description_photo_partie_2 ?? "",
  titre_partie_3: actionRecord?.titre_partie_3 ?? "",
  texte_partie_3: actionRecord?.texte_partie_3 ?? "",
  photo_partie_3:
    getNormalizedPreviewImage(
      actionRecord?.photo_partie_3,
      actionRecord,
      Astro.locals.pb,
    ) ?? null,
  description_photo_partie_3: actionRecord?.description_photo_partie_3 ?? "",
  titre_remerciements: actionRecord?.titre_remerciements ?? "",
  description_remerciements: actionRecord?.description_remerciements ?? "",
  galerie_photos:
    actionRecord?.galerie_photos && actionRecord.galerie_photos.length > 0
      ? actionRecord?.galerie_photos.map(
          (p: any) =>
            getNormalizedPreviewImage(p, actionRecord, Astro.locals.pb),
        ).filter((p: any) => typeof p === "string" && p.trim() !== "")
      : [],
};
 // Placeholder partagé (source unique injecté côté serveur depuis `previewDefaults.js`)
const previewPlaceholder: any = {
  ...previewDefaults,
  ...previewData,
  hero: previewData.hero ?? null,
  photo_partie_1: previewData.photo_partie_1 ?? null,
  photo_partie_2: previewData.photo_partie_2 ?? null,
  photo_partie_3: previewData.photo_partie_3 ?? null,
};
// Gestion de la soumission du formulaire côté serveur
// Si `idParam` est présent : mise à jour, sinon création.
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    // La valeur du slug sera générée plus tard quand le titre sera connu ; on
    // la déclare ici pour éviter des erreurs TypeScript dans la branche de publication rapide.
    let slug: string = "";
    const publishRequested = formData.get("publish_action")?.toString() === "true";
    const action = formData.get("_action")?.toString();
    const requiresCompleteAction =
      action !== "delete" && (!actionRecordFromBrouillon || publishRequested);

    if (requiresCompleteAction) {
      const missingFields = getMissingRequiredFieldsAfterSubmit(
        formData,
        actionRecord,
      );
      if (missingFields.length > 0) {
        throw new Error(
          `Informations obligatoires manquantes: ${missingFields.join(", ")}.`,
        );
      }
    }

    // Diagnostic local: utile pour inspecter rapidement le payload brut du formulaire.
    try {
      const entries = [];
      for (const e of formData.entries()) {
        const [k, v] = e;
        if (v instanceof File) {
          entries.push({ key: k, isFile: true, name: v.name, size: v.size });
        } else {
          const s = String(v).slice(0, 200);
          entries.push({ key: k, isFile: false, valueSample: s });
        }
      }
    } catch (e) {
      // Ce diagnostic ne doit jamais bloquer le flux métier.
    }

    // Prise en charge de la suppression envoyée par POST depuis la liste.
    if (action === "delete" && idParam && typeof idParam === "string") {
      try {
        if (actionRecordFromBrouillon) {
          // supprimer le brouillon
          await Astro.locals.pb.collection("brouillons").delete(String(idParam));
          return Astro.redirect(withSuccess("/creation/brouillons", "Brouillon supprimé"));
        }

        // suppression classique d'une action
        await Astro.locals.pb.collection("actions").delete(idParam);
        return Astro.redirect(withSuccess("/creation/actions", "Action supprimée"));
      } catch (e) {
        // On laisse l'exécution continuer pour remonter vers le flux standard.
      }
    }

    // Publication directe depuis la liste (sans charger tout le formulaire d'édition)
    if (
      publishRequested &&
      actionRecordFromBrouillon &&
      typeof idParam === "string" &&
      !formData.has("titre")
    ) {
      // Vérifier que tous les champs obligatoires sont présents avant de publier
      const missingFields = getMissingRequiredFieldsAfterSubmit(
        formData,
        actionRecord,
      );
      if (missingFields.length > 0) {
        // Rediriger vers la page d'édition du brouillon avec un message d'erreur
        const errorMessage = `Informations obligatoires manquantes pour la publication: ${missingFields.join(", ")}.`;
        return Astro.redirect(
          `/creation/actions/${idParam}-${actionRecord?.slug || "brouillon"}?error=${encodeURIComponent(errorMessage)}`,
        );
      }

      const draftId = idParam;
      const publishSlug = slugify(
        actionRecord?.titre ?? actionRecord?.slug ?? "action",
        {
          lower: true,
          strict: true,
        },
      );
      const publishPayload: any = {};
      // Liste blanche explicite: seuls ces champs sont copiés vers la collection `actions`.
      const allowedKeys = [
        "adresse_lieu",
        "beneficiaire",
        "chiffre",
        "date_debut",
        "date_fin",
        "description_hero",
        "description_photo_partie_1",
        "description_photo_partie_2",
        "description_photo_partie_3",
        "description_remerciements",
        "galerie_photos",
        "hero",
        "lien_lieu",
        "nom_lieu",
        "photo_partie_1",
        "photo_partie_2",
        "photo_partie_3",
        "sous_titre",
        "texte_partie_1",
        "texte_partie_2",
        "texte_partie_3",
        "titre",
        "titre_partie_1",
        "titre_partie_2",
        "titre_partie_3",
        "titre_remerciements",
        "type_de_chiffre",
      ];
      for (const key of allowedKeys) {
        if (actionRecord?.[key] !== undefined && actionRecord?.[key] !== null) {
          publishPayload[key] = actionRecord[key];
        }
      }
      publishPayload.slug = publishSlug;
      applyPartTitleRule(publishPayload);

      const publishedAction = await Astro.locals.pb
        .collection("actions")
        .create(publishPayload);
      await Astro.locals.pb.collection("brouillons").delete(draftId);

      return Astro.redirect(
        withSuccess(
          `/creation/actions/${publishedAction.id}-${publishSlug}`,
          "Brouillon publié",
        ),
      );
    }

    // Vérifier que le titre est fourni
    const titre = formData.get("titre")?.toString();
    if (!titre || titre.trim() === "") {
      throw new Error("Le titre est obligatoire");
    }

    // Générer le slug
    slug = slugify(titre, { lower: true, strict: true });

    // Préparer les données pour PocketBase
    const data: any = { slug };
    const selectedTypeActions = getNormalizedSelectedTypeActionValues(
      formData,
      typeActionOptions,
      7,
    );

    // Copier les champs texte (ignorer fichiers et flags 'remove_')
    for (const [key, value] of formData.entries()) {
      if (value instanceof File) continue; // Gérer les fichiers séparément
      if (
        key === "galerie_photos" ||
        key === "remove_galerie_photos" ||
        key.startsWith("remove_")
      )
        continue;
      if (key === "type_action") {
        // Le champ `type_action` n'existe pas dans la collection `brouillons`.
        if (actionRecordFromBrouillon && !publishRequested) {
          continue;
        }
        try {
          const parsed = JSON.parse(value.toString());
          data[key] = Array.isArray(parsed)
            ? parsed
              .map((item) => String(item).trim())
              .filter((item) => item && typeActionOptions.includes(item))
              .slice(0, 7)
            : [];
        } catch (e) {
          data[key] = [];
        }
        continue;
      }
      const stringValue = value.toString().trim();
      if (key === "chiffre") {
        if (stringValue === "") {
          data[key] = "";
        } else {
          const parsedNumber = Number(stringValue);
          data[key] = Number.isFinite(parsedNumber) ? parsedNumber : "";
        }
        continue;
      }
      if (key === "type_de_chiffre" && stringValue === "type de chiffre") {
        data[key] = "";
        continue;
      }
      if (EMPTYABLE_FIELDS.has(key)) {
        data[key] = stringValue;
        continue;
      }
      if (stringValue !== "") {
        data[key] = stringValue;
      }
    }
    if (!actionRecordFromBrouillon || publishRequested) {
      data.type_action = selectedTypeActions;
    }

    if (requiresCompleteAction && (!Array.isArray(data.type_action) || data.type_action.length === 0)) {
      throw new Error("Au moins un type d'action est obligatoire.");
    }

    // Si l'UI a envoyé des flags `remove_{field}`, s'assurer d'envoyer
    // explicitement une valeur vide pour le champ afin que PocketBase
    // supprime le fichier côté serveur.
    const emptyImageFields: string[] = [];
    for (const [key, value] of formData.entries()) {
      if (typeof key === 'string' && key.startsWith('remove_')) {
        const vStr = value?.toString?.();
        if (vStr) {
          const field = key.replace(/^remove_/, '');
          emptyImageFields.push(field);
          // Forcer la clé à une chaîne vide : PocketBase prendra en compte
          // la valeur vide pour effacer le champ fichier
          data[field] = '';
        }
      }
    }

    // Gérer les fichiers : ignorer les champs marqués pour suppression.
    // EXCEPTION : si un nouveau fichier est fourni pour un champ marqué remove_, le fichier prend la priorité.
    const files: any = {};
    for (const [key, value] of formData.entries()) {
      if (value instanceof File && value.size > 0) {
        const idx = emptyImageFields.indexOf(key);
        if (idx !== -1) {
          // nouveau fichier fourni : annuler la suppression
          emptyImageFields.splice(idx, 1);
          delete data[key];
        }
        if (key === "galerie_photos") {
          // Galerie : collecter les fichiers dans un tableau
          if (!files[key]) {
            files[key] = [];
          }
          files[key].push(value);
        } else {
          // Fichiers simples (image unique)
          files[key] = value;
        }
      }
    }

    if (!idParam && files.galerie_photos && files.galerie_photos.length) {
      delete data.galerie_photos;
    }

    if (idParam) {
      // Mise à jour : ne remplacer les images uniques que si nouvel upload.
      // Galerie : n'inclure la galerie que si elle a été modifiée.
      let removedList: string[] = [];
      try {
        const rawRemoved =
          formData.get("remove_galerie_photos")?.toString() || "";
        removedList = rawRemoved ? JSON.parse(rawRemoved) : [];
      } catch (e) {
        removedList = [];
      }

      const existingFiles = Array.isArray(actionRecord?.galerie_photos)
        ? actionRecord.galerie_photos
        : [];
      const newFiles = Array.isArray(files.galerie_photos)
        ? files.galerie_photos
        : [];

      const galleryWasModified =
        (removedList && removedList.length > 0) ||
        (newFiles && newFiles.length > 0);

      // Retirer `galerie_photos` de `files` pour éviter la propagation involontaire.
      if (files.galerie_photos) delete files.galerie_photos;

      const payload: any = applyPartTitleRule({ ...data, ...files });

      if (galleryWasModified) {
        const keepFiles = existingFiles.filter((fn: any) => {
          const url = normalizeImageUrl(fn, actionRecord, Astro.locals.pb);
          return !(removedList || []).includes(url);
        });

        const combinedGallery = (keepFiles || []).concat(newFiles);
        // "" si galerie complètement vidée, sinon tableau des fichiers restants.
        payload.galerie_photos = combinedGallery.length ? combinedGallery : "";
      }

      // Si le record provient d'un brouillon, mettre à jour la collection `brouillons`.
      if (actionRecordFromBrouillon) {
        if (publishRequested) {
          const publishPayload: any = keepExistingImageFields(
            applyPartTitleRule({ ...payload }),
            actionRecord,
          );
          if (Object.prototype.hasOwnProperty.call(publishPayload, "type")) {
            delete publishPayload.type;
          }
          const publishedAction = await Astro.locals.pb
            .collection("actions")
            .create(publishPayload);
          await Astro.locals.pb.collection("brouillons").delete(idParam);

          return Astro.redirect(
            withSuccess(
              `/creation/actions/${publishedAction.id}-${slug}`,
              "Brouillon publié",
            ),
          );
        }

        // assurer que le type reste 'action' pour que les liens redirigent correctement
        payload.type = 'action';
        // Sécurité : ne jamais pousser `type_action` vers `brouillons`.
        if (Object.prototype.hasOwnProperty.call(payload, "type_action")) {
          delete payload.type_action;
        }

        // Copier les références de fichiers existantes depuis le brouillon si aucun upload n'a été fait.
        // IMPORTANT : utiliser la règle "undefined seulement" pour ne pas écraser '' (suppression intentionnelle).
        keepExistingImageFields(payload, actionRecord);

        await Astro.locals.pb.collection("brouillons").update(idParam, payload);

        return Astro.redirect(
          withSuccess(`/creation/brouillons/${idParam}-${slug}`, "Brouillon mis à jour"),
        );
      }

      // Mise à jour classique d'une action
      try {
        await Astro.locals.pb.collection("actions").update(idParam, payload);
      } catch (updateErr: any) {
        // On enrichit l'erreur `type_action` pour faciliter le débogage côté back-office.
        const typeActionErr = getPbTypeActionError(updateErr);
        if (typeActionErr) {
          const details = typeof typeActionErr === "object"
            ? JSON.stringify(typeActionErr)
            : String(typeActionErr);
          throw new Error(
            `Le champ "type_action" a été refusé par PocketBase: ${details}`,
          );
        }
        throw updateErr;
      }

      return Astro.redirect(
        withSuccess(`/creation/actions/${idParam}-${slug}`, "Action mise à jour"),
      );
    } else {
      // Création
      const createPayload = applyPartTitleRule({
        ...data,
        ...files,
      });
      const newAction = await Astro.locals.pb.collection("actions").create({
        ...createPayload,
      });
      return Astro.redirect(
        withSuccess(`/creation/actions/${newAction.id}-${slug}`, "Action créée avec succès"),
      );
    }
  } catch (err) {
    console.error("Erreur lors de la création:", err);
    try {
      const details = (err as any)?.response?.data;
      if (details) {
        console.error("Détails PocketBase:", JSON.stringify(details, null, 2));
      }
    } catch (logErr) {}
    error =
      err instanceof Error ? err.message : "Une erreur inconnue est survenue";
  }
}

