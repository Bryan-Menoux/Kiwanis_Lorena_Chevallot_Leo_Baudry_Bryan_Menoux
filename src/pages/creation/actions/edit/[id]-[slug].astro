// Page serveur pour créer/éditer une action — logique serveur et rendu.
import Layout from "../../../../layouts/Layout-back-office.astro";
import ActionContent from "../../../../components/ActionContent.astro";
import slugify from "slugify";
// Paramètre `id` optionnel provenant de l'URL (utilisé pour l'édition)
const idParam = Astro.params?.id;
import previewUrl from "../../../../scripts/preview.js?url";
import galleryUrl from "../../../../scripts/gallery.js?url";
import galleryDisplayUrl from "../../../../scripts/gallery-display.ts?url";
import utilUrl from "../../../../utils/utilitaires.js?url";
import {
  formatDateForInput,
  normalizeImageUrl,
} from "../../../../utils/utilitaires.js";
import imageIcon from "../../../../assets/image-icon.svg";
import { ActionsTypeDeChiffreOptions } from "../../../../pocketbase-types";

// Message d'erreur affiché dans le formulaire en cas d'échec serveur
let error: string = "";

// On récupère le options `type_de_chiffre`
let typeDeChiffreOptions: string[] = Object.values(ActionsTypeDeChiffreOptions);

// Placeholder SVG data-URL pour la prévisualisation serveur
const placeholderImg = `data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='400' height='400' viewBox='0 0 400 400'><rect width='100%' height='100%' fill='%23f3f6f7'/><image href='${imageIcon.src}' x='50' y='50' width='300' height='300' preserveAspectRatio='xMidYMid meet' style='opacity:0.95;'/></svg>`;

// Charger l'enregistrement existant lorsque `idParam` est fourni (mode édition)
let actionRecord: any = null;
if (idParam) {
  try {
    actionRecord = await Astro.locals.pb.collection("actions").getOne(idParam);
    
  } catch (e) {
    console.error("Erreur retrieving action:", e);
    // message utilisateur succinct
    error = "Impossible de charger l'action";
  }
}

const previewData: any = {
  titre: actionRecord?.titre ?? "Titre de l'action",
  sous_titre: actionRecord?.sous_titre ?? "",
  date_debut: formatDateForInput(actionRecord?.date_debut) || "",
  date_fin: formatDateForInput(actionRecord?.date_fin) || "",
  description_hero: actionRecord?.description_hero ?? "",
  hero:
    normalizeImageUrl(actionRecord?.hero, actionRecord, Astro.locals.pb) ??
    placeholderImg,
  titre_partie_1: actionRecord?.titre_partie_1 ?? "",
  texte_partie_1: actionRecord?.texte_partie_1 ?? "",
  photo_partie_1:
    normalizeImageUrl(
      actionRecord?.photo_partie_1,
      actionRecord,
      Astro.locals.pb,
    ) ?? placeholderImg,
  description_photo_partie_1: actionRecord?.description_photo_partie_1 ?? "",
  nom_lieu: actionRecord?.nom_lieu ?? "",
  adresse_lieu: actionRecord?.adresse_lieu ?? "",
  lien_lieu: actionRecord?.lien_lieu ?? "",
  chiffre: actionRecord?.chiffre ?? "",
  type_de_chiffre:
    actionRecord?.type_de_chiffre ?? typeDeChiffreOptions[0] ?? "",
  beneficiaire: actionRecord?.beneficiaire ?? "",
  titre_partie_2: actionRecord?.titre_partie_2 ?? "",
  texte_partie_2: actionRecord?.texte_partie_2 ?? "",
  photo_partie_2:
    normalizeImageUrl(
      actionRecord?.photo_partie_2,
      actionRecord,
      Astro.locals.pb,
    ) ?? placeholderImg,
  description_photo_partie_2: actionRecord?.description_photo_partie_2 ?? "",
  titre_partie_3: actionRecord?.titre_partie_3 ?? "",
  texte_partie_3: actionRecord?.texte_partie_3 ?? "",
  photo_partie_3:
    normalizeImageUrl(
      actionRecord?.photo_partie_3,
      actionRecord,
      Astro.locals.pb,
    ) ?? placeholderImg,
  description_photo_partie_3: actionRecord?.description_photo_partie_3 ?? "",
  titre_remerciements: actionRecord?.titre_remerciements ?? "",
  description_remerciements: actionRecord?.description_remerciements ?? "",
  galerie_photos:
    actionRecord?.galerie_photos && actionRecord.galerie_photos.length > 0
      ? actionRecord.galerie_photos.map(
          (p: any) =>
            normalizeImageUrl(p, actionRecord, Astro.locals.pb) ??
            placeholderImg,
        )
      : [placeholderImg, placeholderImg, placeholderImg],
};

// Gestion de la soumission du formulaire côté serveur
// Si `idParam` présent -> mise à jour, sinon création.
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
      try {
      const entries = [];
      for (const e of formData.entries()) {
        const [k, v] = e;
        if (v instanceof File) {
          entries.push({ key: k, isFile: true, name: v.name, size: v.size });
        } else {
          const s = String(v).slice(0, 200);
          entries.push({ key: k, isFile: false, valueSample: s });
        }
      }
    } catch (e) {
      // ignore serialization diagnostics
    }

    // Support suppression envoyée par POST depuis la liste
    const action = formData.get("_action")?.toString();
    if (action === "delete" && idParam) {
      try {
        await Astro.locals.pb.collection("actions").delete(idParam);
      } catch (e) {
        console.error("Erreur suppression action:", e);
      }
      return Astro.redirect("/creation/actions?success=Action supprimée");
    }

    // Vérifier que le titre est fourni
    const titre = formData.get("titre")?.toString();
    if (!titre || titre.trim() === "") {
      throw new Error("Le titre est obligatoire");
    }

    // Générer le slug
    const slug = slugify(titre, { lower: true, strict: true });

    // Préparer les données pour PocketBase
    const data: any = { slug };

    // Copier les champs texte (ignorer fichiers et flags 'remove_')
    for (const [key, value] of formData.entries()) {
      if (value instanceof File) continue; // Gérer les fichiers séparément
      if (
        key === "galerie_photos" ||
        key === "remove_galerie_photos" ||
        key.startsWith("remove_")
      )
        continue;
      const stringValue = value.toString().trim();
      if (stringValue !== "") {
        data[key] = stringValue;
      }
    }

    // Si l'UI a envoyé des flags `remove_{field}`, s'assurer d'envoyer
    // explicitement une valeur vide pour le champ afin que PocketBase
    // supprime le fichier côté serveur.
    for (const [key, value] of formData.entries()) {
      if (typeof key === 'string' && key.startsWith('remove_')) {
        const vStr = value?.toString?.();
        if (vStr) {
          const field = key.replace(/^remove_/, '');
          // forcer la clé à une chaîne vide — PocketBase prendra en compte
          // la valeur vide pour effacer le champ fichier
          data[field] = '';
        }
      }
    }

    // Gérer les fichiers
    const files: any = {};
    for (const [key, value] of formData.entries()) {
      if (value instanceof File && value.size > 0) {
        if (key === "galerie_photos") {
          // Galerie : collecter les fichiers dans un tableau
          if (!files[key]) {
            files[key] = [];
          }
          files[key].push(value);
        } else {
          // Fichiers simples (image unique)
          files[key] = value;
        }
      }
    }

    if (!idParam && files.galerie_photos && files.galerie_photos.length) {
      delete data.galerie_photos;
    }

    if (idParam) {
      // Mise à jour : ne remplacer les images uniques que si nouvel upload
      // Galerie : n'inclure la galerie que si elle a été modifiée
      let removedList: string[] = [];
      try {
        const rawRemoved =
          formData.get("remove_galerie_photos")?.toString() || "";
        removedList = rawRemoved ? JSON.parse(rawRemoved) : [];
      } catch (e) {
        removedList = [];
      }

      const existingFiles = Array.isArray(actionRecord?.galerie_photos)
        ? actionRecord.galerie_photos
        : [];
      const newFiles = Array.isArray(files.galerie_photos)
        ? files.galerie_photos
        : [];

      const galleryWasModified =
        (removedList && removedList.length > 0) ||
        (newFiles && newFiles.length > 0);

      // Retirer `galerie_photos` de `files` pour éviter propagation involontaire
      if (files.galerie_photos) delete files.galerie_photos;

      const payload: any = { ...data, ...files };

      if (galleryWasModified) {
        const keepFiles = existingFiles.filter((fn: any) => {
          const url = normalizeImageUrl(fn, actionRecord, Astro.locals.pb);
          return !(removedList || []).includes(url);
        });

        const combinedGallery = (keepFiles || []).concat(newFiles);
        // [] si galerie vidée
        payload.galerie_photos = combinedGallery.length ? combinedGallery : [];
      }

      await Astro.locals.pb.collection("actions").update(idParam, payload);

      return Astro.redirect(
        `/creation/actions/${idParam}-${slug}?success=Action mise à jour`,
      );
    } else {
      // création
      const newAction = await Astro.locals.pb.collection("actions").create({
        ...data,
        ...files,
      });
      return Astro.redirect(
        `/creation/actions/${newAction.id}-${slug}?success=Action créée avec succès`,
      );
    }
  } catch (err) {
    console.error("Erreur lors de la création:", err);
    // Afficher l'erreur au formulaire
    error =
      err instanceof Error ? err.message : "Une erreur inconnue est survenue";
  }
}
