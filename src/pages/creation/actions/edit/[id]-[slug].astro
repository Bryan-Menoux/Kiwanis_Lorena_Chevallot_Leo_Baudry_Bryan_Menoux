  <script type="module" src={utilUrl}></script>
  <script type="module" src={galleryUrl}></script>
  <script type="module" src={galleryDisplayUrl}></script>
  
  <script>
    import { showAlert } from "../../../../utils/alerts";
    
    // Affiche une alerte d'erreur de validation si elle vient de la page de liste
    const params = new URLSearchParams(window.location.search);
    const validationError = params.get("validation_error");
    
    if (validationError) {
      showAlert({
        type: "error",
        message: `Publication impossible : ${validationError}`,
      });
      
      // Nettoie l'URL pour éviter que l'alerte se réaffiche au rechargement
      window.history.replaceState({}, document.title, window.location.pathname);
    }
  </script>
