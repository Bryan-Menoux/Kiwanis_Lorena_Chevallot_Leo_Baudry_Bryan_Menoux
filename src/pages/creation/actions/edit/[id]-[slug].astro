---
// Page serveur pour crÃ©er/Ã©diter une action â€” logique serveur et rendu.
import Layout from "../../../../layouts/Layout-back-office.astro";
import ActionContent from "../../../../components/ActionContent.astro";
import ActionForm from "../../../../components/ActionForm.astro";
import slugify from "slugify";
// ParamÃ¨tre `id` optionnel provenant de l'URL (utilisÃ© pour l'Ã©dition)
const rawIdParam = Astro.params?.id;
const idParam =
  typeof rawIdParam === "string"
    ? (rawIdParam.match(/^[a-zA-Z0-9]{15}/)?.[0] ?? rawIdParam)
    : rawIdParam;

import galleryUrl from "../../../../scripts/gallery.js?url";
import galleryDisplayUrl from "../../../../scripts/gallery-display.js?url";
import utilUrl from "../../../../utils/utilitaires.js?url";
import {
  formatDateForInput,
  normalizeImageUrl,
} from "../../../../utils/utilitaires.js";
import imageIcon from "../../../../assets/image-icon.svg";
import {
  ActionsTypeActionOptions,
  ActionsTypeDeChiffreOptions,
} from "../../../../pocketbase-types";
import previewDefaults from "../../../../scripts/previewDefaults.js";

// Message d'erreur affichÃ© dans le formulaire en cas d'Ã©chec serveur
let error: string = "";
const withSuccess = (path: string, message: string) =>
  `${path}?success=${encodeURIComponent(message)}`;
const normalizeOptionLabel = (value: string) =>
  /Ãƒ|Ã‚/.test(value) ? Buffer.from(value, "latin1").toString("utf8") : value;
const getPbTypeActionError = (err: any) =>
  err?.response?.data?.data?.type_action ||
  err?.response?.data?.type_action ||
  null;
const EMPTYABLE_FIELDS = new Set([
  "nom_lieu",
  "adresse_lieu",
  "lien_lieu",
  "chiffre",
  "type_de_chiffre",
]);

// RÃ©cupÃ©rer les options de type_de_chiffre depuis le type TypeScript gÃ©nÃ©rÃ©
let typeDeChiffreOptions: string[] = ["type de chiffre", ...(Array.isArray(ActionsTypeDeChiffreOptions) ? ActionsTypeDeChiffreOptions : Object.values(ActionsTypeDeChiffreOptions))];
let typeActionOptions: string[] = (Array.isArray(ActionsTypeActionOptions)
  ? ActionsTypeActionOptions
  : Object.values(ActionsTypeActionOptions)).map((opt) =>
  normalizeOptionLabel(String(opt)),
);

// Placeholder SVG data-URL pour la prÃ©visualisation serveur
const placeholderImg = `data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='400' height='400' viewBox='0 0 400 400'><rect width='100%' height='100%' fill='%23f3f6f7'/><image href='${imageIcon.src}' x='50' y='50' width='300' height='300' preserveAspectRatio='xMidYMid meet' style='opacity:0.95;'/></svg>`;

// Charger l'enregistrement existant lorsque `idParam` est fourni (mode Ã©dition)
let actionRecord: any = null;
let actionRecordFromBrouillon = false;
if (idParam) {
  try {
    // tenter d'abord dans `actions`; si record non trouvÃ© (404), rechercher dans `brouillons`
    try {
      actionRecord = await Astro.locals.pb.collection("actions").getOne(idParam);
    } catch (err) {
      // si la requÃªte vers `actions` Ã©choue (404 ou autre), tenter `brouillons`
      try {
        actionRecord = await Astro.locals.pb.collection("brouillons").getOne(idParam);
        actionRecordFromBrouillon = true;
      } catch (err2) {
        // ni actions ni brouillons trouvÃ©s â€” remonter l'erreur originale
        throw err;
      }
    }
  } catch (e) {
    console.error("Erreur retrieving action:", e);
    error = "Impossible de charger l'action";
  }
}

const previewData: any = {
  titre: actionRecord?.titre ?? "Titre de l'action",
  sous_titre: actionRecord?.sous_titre ?? "",
  date_debut: formatDateForInput(actionRecord?.date_debut) || "",
  date_fin: formatDateForInput(actionRecord?.date_fin) || "",
  description_hero: actionRecord?.description_hero ?? "",
  hero:
    normalizeImageUrl(actionRecord?.hero, actionRecord, Astro.locals.pb) ??
    null,
  titre_partie_1: actionRecord?.titre_partie_1 ?? "",
  texte_partie_1: actionRecord?.texte_partie_1 ?? "",
  photo_partie_1:
    normalizeImageUrl(
      actionRecord?.photo_partie_1,
      actionRecord,
      Astro.locals.pb,
    ) ?? null,
  description_photo_partie_1: actionRecord?.description_photo_partie_1 ?? "",
  nom_lieu: actionRecord?.nom_lieu ?? "",
  adresse_lieu: actionRecord?.adresse_lieu ?? "",
  lien_lieu: actionRecord?.lien_lieu ?? "",
  chiffre: actionRecord?.chiffre ?? "",
  type_de_chiffre: actionRecord?.type_de_chiffre ?? "",
  type_action: Array.isArray(actionRecord?.type_action)
    ? actionRecord.type_action
    : [],
  beneficiaire: actionRecord?.beneficiaire ?? "",
  titre_partie_2: actionRecord?.titre_partie_2 ?? "",
  texte_partie_2: actionRecord?.texte_partie_2 ?? "",
  photo_partie_2:
    normalizeImageUrl(
      actionRecord?.photo_partie_2,
      actionRecord,
      Astro.locals.pb,
    ) ?? null,
  description_photo_partie_2: actionRecord?.description_photo_partie_2 ?? "",
  titre_partie_3: actionRecord?.titre_partie_3 ?? "",
  texte_partie_3: actionRecord?.texte_partie_3 ?? "",
  photo_partie_3:
    normalizeImageUrl(
      actionRecord?.photo_partie_3,
      actionRecord,
      Astro.locals.pb,
    ) ?? null,
  description_photo_partie_3: actionRecord?.description_photo_partie_3 ?? "",
  titre_remerciements: actionRecord?.titre_remerciements ?? "",
  description_remerciements: actionRecord?.description_remerciements ?? "",
  galerie_photos:
    actionRecord?.galerie_photos && actionRecord.galerie_photos.length > 0
      ? actionRecord?.galerie_photos.map(
          (p: any) =>
            normalizeImageUrl(p, actionRecord, Astro.locals.pb) ??
            placeholderImg,
        )
      : [placeholderImg, placeholderImg, placeholderImg],
};
 // Placeholder partagÃ© (source unique injectÃ© cÃ´tÃ© serveur depuis `previewDefaults.js`)
const previewPlaceholder: any = {
  ...previewDefaults,
  ...previewData,
  hero: previewData.hero ?? placeholderImg,
  photo_partie_1: previewData.photo_partie_1 ?? placeholderImg,
  photo_partie_2: previewData.photo_partie_2 ?? placeholderImg,
  photo_partie_3: previewData.photo_partie_3 ?? placeholderImg,
};
// Gestion de la soumission du formulaire cÃ´tÃ© serveur
// Si `idParam` prÃ©sent -> mise Ã  jour, sinon crÃ©ation.
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
      try {
      const entries = [];
      for (const e of formData.entries()) {
        const [k, v] = e;
        if (v instanceof File) {
          entries.push({ key: k, isFile: true, name: v.name, size: v.size });
        } else {
          const s = String(v).slice(0, 200);
          entries.push({ key: k, isFile: false, valueSample: s });
        }
      }
    } catch (e) {
      // ignore serialization diagnostics
    }

    // Support suppression envoyÃ©e par POST depuis la liste
    const action = formData.get("_action")?.toString();
    if (action === "delete" && idParam) {
      try {
        if (actionRecordFromBrouillon) {
          // supprimer le brouillon
          await Astro.locals.pb.collection("brouillons").delete(idParam);
          return Astro.redirect(withSuccess("/creation/brouillons", "Brouillon supprimé"));
        }

        // suppression classique d'une action
        await Astro.locals.pb.collection("actions").delete(idParam);
        return Astro.redirect(withSuccess("/creation/actions", "Action supprimée"));
      } catch (e) {
        // ignore
      }
    }

    // VÃ©rifier que le titre est fourni
    const titre = formData.get("titre")?.toString();
    if (!titre || titre.trim() === "") {
      throw new Error("Le titre est obligatoire");
    }

    // GÃ©nÃ©rer le slug
    const slug = slugify(titre, { lower: true, strict: true });

    // PrÃ©parer les donnÃ©es pour PocketBase
    const data: any = { slug };

    // Copier les champs texte (ignorer fichiers et flags 'remove_')
    for (const [key, value] of formData.entries()) {
      if (value instanceof File) continue; // GÃ©rer les fichiers sÃ©parÃ©ment
      if (
        key === "galerie_photos" ||
        key === "remove_galerie_photos" ||
        key.startsWith("remove_")
      )
        continue;
      if (key === "type_action") {
        // Le champ `type_action` n'existe pas dans la collection `brouillons`.
        if (actionRecordFromBrouillon) {
          continue;
        }
        try {
          const parsed = JSON.parse(value.toString());
          data[key] = Array.isArray(parsed)
            ? parsed
              .map((item) => normalizeOptionLabel(String(item).trim()))
              .filter((item) => item && typeActionOptions.includes(item))
              .slice(0, 7)
            : [];
        } catch (e) {
          data[key] = [];
        }
        continue;
      }
      const stringValue = value.toString().trim();
      if (key === "chiffre") {
        if (stringValue === "") {
          data[key] = "";
        } else {
          const parsedNumber = Number(stringValue);
          data[key] = Number.isFinite(parsedNumber) ? parsedNumber : "";
        }
        continue;
      }
      if (key === "type_de_chiffre" && stringValue === "type de chiffre") {
        data[key] = "";
        continue;
      }
      if (EMPTYABLE_FIELDS.has(key)) {
        data[key] = stringValue;
        continue;
      }
      if (stringValue !== "") {
        data[key] = stringValue;
      }
    }

    // Si l'UI a envoyÃ© des flags `remove_{field}`, s'assurer d'envoyer
    // explicitement une valeur vide pour le champ afin que PocketBase
    // supprime le fichier cÃ´tÃ© serveur.
    const emptyImageFields: string[] = [];
    for (const [key, value] of formData.entries()) {
      if (typeof key === 'string' && key.startsWith('remove_')) {
        const vStr = value?.toString?.();
        if (vStr) {
          const field = key.replace(/^remove_/, '');
          emptyImageFields.push(field);
          // forcer la clÃ© Ã  une chaÃ®ne vide â€” PocketBase prendra en compte
          // la valeur vide pour effacer le champ fichier
          data[field] = '';
        }
      }
    }

    // GÃ©rer les fichiers â€” ignorer les champs marquÃ©s pour suppression
    // EXCEPTION : si un nouveau fichier est fourni pour un champ marquÃ© remove_, le fichier prend la prioritÃ©
    const files: any = {};
    for (const [key, value] of formData.entries()) {
      if (value instanceof File && value.size > 0) {
        const idx = emptyImageFields.indexOf(key);
        if (idx !== -1) {
          // nouveau fichier fourni : annuler la suppression
          emptyImageFields.splice(idx, 1);
          delete data[key];
        }
        if (key === "galerie_photos") {
          // Galerie : collecter les fichiers dans un tableau
          if (!files[key]) {
            files[key] = [];
          }
          files[key].push(value);
        } else {
          // Fichiers simples (image unique)
          files[key] = value;
        }
      }
    }

    if (!idParam && files.galerie_photos && files.galerie_photos.length) {
      delete data.galerie_photos;
    }

    if (idParam) {
      // Mise Ã  jour : ne remplacer les images uniques que si nouvel upload
      // Galerie : n'inclure la galerie que si elle a Ã©tÃ© modifiÃ©e
      let removedList: string[] = [];
      try {
        const rawRemoved =
          formData.get("remove_galerie_photos")?.toString() || "";
        removedList = rawRemoved ? JSON.parse(rawRemoved) : [];
      } catch (e) {
        removedList = [];
      }

      const existingFiles = Array.isArray(actionRecord?.galerie_photos)
        ? actionRecord.galerie_photos
        : [];
      const newFiles = Array.isArray(files.galerie_photos)
        ? files.galerie_photos
        : [];

      const galleryWasModified =
        (removedList && removedList.length > 0) ||
        (newFiles && newFiles.length > 0);

      // Retirer `galerie_photos` de `files` pour Ã©viter propagation involontaire
      if (files.galerie_photos) delete files.galerie_photos;

      const payload: any = { ...data, ...files };

      if (galleryWasModified) {
        const keepFiles = existingFiles.filter((fn: any) => {
          const url = normalizeImageUrl(fn, actionRecord, Astro.locals.pb);
          return !(removedList || []).includes(url);
        });

        const combinedGallery = (keepFiles || []).concat(newFiles);
        // "" si galerie complÃ¨tement vidÃ©e, sinon tableau des fichiers restants
        payload.galerie_photos = combinedGallery.length ? combinedGallery : "";
      }

      // Si le record provient d'un brouillon, on met Ã  jour la collection `brouillons`
      if (actionRecordFromBrouillon) {
        // assurer que le type reste 'action' pour que les liens redirigent correctement
        payload.type = 'action';
        // SÃ©curitÃ©: ne jamais pousser `type_action` vers `brouillons`.
        if (Object.prototype.hasOwnProperty.call(payload, "type_action")) {
          delete payload.type_action;
        }

        // copier les rÃ©fÃ©rences de fichiers existantes depuis le brouillon si aucun upload n'a Ã©tÃ© fait
        // IMPORTANT : utiliser === undefined pour ne pas Ã©craser '' (suppression intentionnelle)
        if (payload.hero === undefined && actionRecord?.hero) payload.hero = actionRecord.hero;
        if (payload.photo_partie_1 === undefined && actionRecord?.photo_partie_1) payload.photo_partie_1 = actionRecord.photo_partie_1;
        if (payload.photo_partie_2 === undefined && actionRecord?.photo_partie_2) payload.photo_partie_2 = actionRecord.photo_partie_2;
        if (payload.photo_partie_3 === undefined && actionRecord?.photo_partie_3) payload.photo_partie_3 = actionRecord.photo_partie_3;
        if (payload.galerie_photos === undefined && Array.isArray(actionRecord?.galerie_photos) && actionRecord.galerie_photos.length) payload.galerie_photos = actionRecord.galerie_photos;

        await Astro.locals.pb.collection("brouillons").update(idParam, payload);

        return Astro.redirect(
          withSuccess(`/creation/brouillons/${idParam}-${slug}`, "Brouillon mis à jour"),
        );
      }

      // Mise Ã  jour classique d'une action
      try {
        await Astro.locals.pb.collection("actions").update(idParam, payload);
      } catch (updateErr: any) {
        const typeActionErr = getPbTypeActionError(updateErr);
        if (typeActionErr) {
          const details = typeof typeActionErr === "object"
            ? JSON.stringify(typeActionErr)
            : String(typeActionErr);
          throw new Error(
            `Le champ "type_action" a Ã©tÃ© refusÃ© par PocketBase: ${details}`,
          );
        }
        throw updateErr;
      }

      return Astro.redirect(
        withSuccess(`/creation/actions/${idParam}-${slug}`, "Action mise à jour"),
      );
    } else {
      // crÃ©ation
      const newAction = await Astro.locals.pb.collection("actions").create({
        ...data,
        ...files,
      });
      return Astro.redirect(
        withSuccess(`/creation/actions/${newAction.id}-${slug}`, "Action créée avec succès"),
      );
    }
  } catch (err) {
    console.error("Erreur lors de la crÃ©ation:", err);
    try {
      const details = (err as any)?.response?.data;
      if (details) {
        console.error("DÃ©tails PocketBase:", JSON.stringify(details, null, 2));
      }
    } catch (logErr) {}
    error =
      err instanceof Error ? err.message : "Une erreur inconnue est survenue";
  }
}

---

<Layout>
  <div class="flex h-fit w-full">
    <div id="sidebar" class="w-1/3 transform -translate-x-full opacity-0 transition-all duration-500 ease-out">
      <div class="h-[105dvh] bg-accent pb-24 rounded-br-box sticky left-0 top-0 overflow-auto p-6">
        <ActionForm
          mode="edit"
          previewPlaceholder={previewPlaceholder}
          previewData={previewData}
          typeDeChiffreOptions={typeDeChiffreOptions}
          typeActionOptions={typeActionOptions}
          imageIcon={imageIcon}
          actionRecord={actionRecord}
        />
      </div>
    </div>

    <div class="w-2/3 px-8">
      <ActionContent
        action={previewPlaceholder}
        forcePreviewLocationSection={true}
      />
    </div>
  </div>
  <script set:html={`window.__previewData = ${JSON.stringify({
    ...previewPlaceholder,
    hero: previewData.hero,
    photo_partie_1: previewData.photo_partie_1,
    photo_partie_2: previewData.photo_partie_2,
    photo_partie_3: previewData.photo_partie_3,
  }).replace(/</g, "\\u003c")};`} />

  <script type="module" src={utilUrl}></script>
  <script type="module" src={galleryUrl}></script>
  <script type="module" src={galleryDisplayUrl}></script>
  <script>
    // faire glisser le panneau latéral depuis la gauche au chargement
    document.addEventListener('DOMContentLoaded', () => {
      const sidebar = document.getElementById('sidebar');
      if (sidebar) {
        sidebar.classList.remove('-translate-x-full', 'opacity-0');
      }
    });
  </script>
</Layout>



