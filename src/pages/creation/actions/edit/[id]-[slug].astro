---
import Layout from "../../../../layouts/Layout-back-office.astro";
import ActionContent from "../../../../components/ActionContent.astro";
import slugify from "slugify";
const idParam = Astro.params?.id;
import previewUrl from "../../../../scripts/preview.js?url";
import galleryUrl from "../../../../scripts/gallery.js?url";
import galleryDisplayUrl from "../../../../scripts/gallery-display.ts?url";
import imageIcon from "../../../../assets/image-icon.svg";
import { ActionsTypeDeChiffreOptions } from "../../../../pocketbase-types";

const id = Astro.locals.pb.authStore.record?.id;
let error: string = "";

// Récupérer les options : priorité aux valeurs utilisées en base, sinon fallback sur l'enum générée.
let typeDeChiffreOptions: string[] = Object.values(ActionsTypeDeChiffreOptions);
try {
  const records: any[] = await Astro.locals.pb
    .collection("actions")
    .getFullList(100);
  const values = Array.from(
    new Set(records.map((r: any) => r?.type_de_chiffre).filter(Boolean)),
  );
  if (values.length > 0) typeDeChiffreOptions = values;
} catch (e) {
  // probable manque de permissions : on laisse le fallback sur l'enum
}

// Placeholder utilisé pour rendre toutes les sections côté serveur afin que le client puisse hydrater la prévisualisation
const placeholderImg = `data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='400' height='400' viewBox='0 0 400 400'><rect width='100%' height='100%' fill='%23f3f6f7'/><image href='${imageIcon.src}' x='50' y='50' width='300' height='300' preserveAspectRatio='xMidYMid meet' style='opacity:0.95;'/></svg>`;

// Fonctions utilitaires
function formatDateForInput(d: any) {
  if (!d) return "";
  try {
    const dt = new Date(d);
    if (isNaN(dt.getTime())) return "";
    return dt.toISOString().slice(0, 10);
  } catch (e) {
    return "";
  }
}

function normalizeImageUrl(v: any, action?: any) {
  if (!v) return null;
  // Si c'est déjà une URL complète (data:, blob:, http(s): ou chemin), la retourner telle quelle
  if (typeof v === 'string' && (v.startsWith('data:') || v.startsWith('blob:') || v.startsWith('http://') || v.startsWith('https://') || v.startsWith('/'))) return v;
  // Si c'est un objet fichier PocketBase ou juste un nom de fichier, utiliser `Astro.locals.pb.files.getURL` quand on a l'action
  try {
    if (action && typeof Astro !== 'undefined' && Astro.locals && Astro.locals.pb && Astro.locals.pb.files && typeof Astro.locals.pb.files.getURL === 'function') {
        // Quand v est un objet, PocketBase stocke parfois les métadonnées sous la forme { filename, ... } ou juste une chaîne de nom de fichier
      const fileRef = (typeof v === 'string') ? v : (v.filename ?? v.id ?? null);
      if (fileRef) return Astro.locals.pb.files.getURL(action, fileRef);
    }
  } catch (e) {
    // revenir à d'autres heuristiques en cas d'échec
  }

  if (typeof v === 'object') {
    if (v.url) return v.url;
    if (v.directUrl) return v.directUrl;
    if (v.filename) return '/' + v.filename;
    return null;
  }

  if (typeof v === 'string') {
    return '/' + v;
  }

  return null;
}

// Charger l'action si on a un id
let actionRecord: any = null;
if (idParam) {
  try {
    actionRecord = await Astro.locals.pb.collection("actions").getOne(idParam);
  } catch (e) {
    console.error("Erreur retrieving action:", e);
    error = "Impossible de charger l'action";
  }
}

const previewData: any = {
  titre: actionRecord?.titre ?? "Titre de l'action",
  sous_titre: actionRecord?.sous_titre ?? "",
  date_debut: formatDateForInput(actionRecord?.date_debut) || "",
  date_fin: formatDateForInput(actionRecord?.date_fin) || "",
  description_hero: actionRecord?.description_hero ?? "",
  hero: normalizeImageUrl(actionRecord?.hero, actionRecord) ?? placeholderImg,
  titre_partie_1: actionRecord?.titre_partie_1 ?? "",
  texte_partie_1: actionRecord?.texte_partie_1 ?? "",
  photo_partie_1: normalizeImageUrl(actionRecord?.photo_partie_1, actionRecord) ?? placeholderImg,
  description_photo_partie_1: actionRecord?.description_photo_partie_1 ?? "",
  nom_lieu: actionRecord?.nom_lieu ?? "",
  adresse_lieu: actionRecord?.adresse_lieu ?? "",
  lien_lieu: actionRecord?.lien_lieu ?? "",
  chiffre: actionRecord?.chiffre ?? "",
  type_de_chiffre: actionRecord?.type_de_chiffre ?? typeDeChiffreOptions[0] ?? "",
  beneficiaire: actionRecord?.beneficiaire ?? "",
  titre_partie_2: actionRecord?.titre_partie_2 ?? "",
  texte_partie_2: actionRecord?.texte_partie_2 ?? "",
  photo_partie_2: normalizeImageUrl(actionRecord?.photo_partie_2, actionRecord) ?? placeholderImg,
  description_photo_partie_2: actionRecord?.description_photo_partie_2 ?? "",
  titre_partie_3: actionRecord?.titre_partie_3 ?? "",
  texte_partie_3: actionRecord?.texte_partie_3 ?? "",
  photo_partie_3: normalizeImageUrl(actionRecord?.photo_partie_3, actionRecord) ?? placeholderImg,
  description_photo_partie_3: actionRecord?.description_photo_partie_3 ?? "",
  titre_remerciements: actionRecord?.titre_remerciements ?? "",
  description_remerciements: actionRecord?.description_remerciements ?? "",
  galerie_photos: (actionRecord?.galerie_photos && actionRecord.galerie_photos.length > 0)
    ? actionRecord.galerie_photos.map((p: any) => normalizeImageUrl(p, actionRecord) ?? placeholderImg)
    : [placeholderImg, placeholderImg, placeholderImg],
};

// Gestion de la soumission du formulaire côté serveur
// Si `idParam` est présent : mise à jour de l'enregistrement existant, sinon création d'un nouvel enregistrement.
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();

    // Support suppression envoyée par POST depuis la liste (no endpoint)
    const action = formData.get('_action')?.toString();
    if (action === 'delete' && idParam) {
      try {
        await Astro.locals.pb.collection('actions').delete(idParam);
      } catch (e) {
        console.error('Erreur suppression action:', e);
      }
      return Astro.redirect('/creation/actions?success=Action supprimée');
    }

    // Vérifier que le titre est fourni
    const titre = formData.get("titre")?.toString();
    if (!titre || titre.trim() === "") {
      throw new Error("Le titre est obligatoire");
    }

    // Générer le slug
    const slug = slugify(titre, { lower: true, strict: true });

    // Préparer les données pour PocketBase
    const data: any = { slug };

    // Récupérer tous les champs texte du formulaire
    // Ignorer les inputs de type fichier et les flags côté client pour suppression (clés commençant par `remove_`)
    // Le traitement de la galerie est géré explicitement plus bas.
    for (const [key, value] of formData.entries()) {
      if (value instanceof File) continue; // Gérer les fichiers séparément
      if (key === 'galerie_photos' || key === 'remove_galerie_photos' || key.startsWith('remove_')) continue;
      const stringValue = value.toString().trim();
      if (stringValue !== "") {
        data[key] = stringValue;
      }
    }

    // Gérer les fichiers
    const files: any = {};
    for (const [key, value] of formData.entries()) {
      if (value instanceof File && value.size > 0) {
        if (key === "galerie_photos") {
          // Pour la galerie, collecter tous les fichiers dans un tableau
          if (!files[key]) {
            files[key] = [];
          }
          files[key].push(value);
        } else {
          // Pour les autres fichiers (images uniques)
          files[key] = value;
        }
      }
    }

    // REMARQUE : nous ne prenons plus en charge la suppression explicite côté client des champs image uniques.
    // Les images ne seront remplacées que lorsque l'utilisateur téléverse un nouveau fichier pour ce champ.

    // If creating a new record and user uploaded files for galerie_photos,
    // remove any hidden `galerie_photos` data (which may contain data-URLs)
    // to avoid passing invalid values to PocketBase. We will rely on the
    // uploaded files in `files.galerie_photos` instead.
    if (!idParam && files.galerie_photos && files.galerie_photos.length) {
      delete data.galerie_photos;
    }

    let savedAction: any = null;
    if (idParam) {
      // update existing: we only replace single-image fields when a new file is uploaded.
      // The `files` object already contains any newly uploaded files; if a field
      // has no uploaded file, we leave it out of the payload so PocketBase keeps
      // the existing value.

      // Gallery handling: only include galerie_photos in the update when the user
      // actually modified the gallery (either removed items or uploaded new files).
      let removedList: string[] = [];
      try {
        const rawRemoved = formData.get("remove_galerie_photos")?.toString() || "";
        removedList = rawRemoved ? JSON.parse(rawRemoved) : [];
      } catch (e) {
        removedList = [];
      }

      const existingFiles = Array.isArray(actionRecord?.galerie_photos) ? actionRecord.galerie_photos : [];
      const newFiles = Array.isArray(files.galerie_photos) ? files.galerie_photos : [];

      const galleryWasModified = (removedList && removedList.length > 0) || (newFiles && newFiles.length > 0);

      // remove galerie_photos from files to avoid spreading it blindly
      if (files.galerie_photos) delete files.galerie_photos;

      const payload: any = { ...data, ...files };

      if (galleryWasModified) {
        const keepFiles = existingFiles.filter((fn: any) => {
          const url = normalizeImageUrl(fn, actionRecord);
          return !(removedList || []).includes(url);
        });

        const combinedGallery = (keepFiles || []).concat(newFiles);
        // Explicit empty array if gallery was cleared
        payload.galerie_photos = combinedGallery.length ? combinedGallery : [];
      }

      savedAction = await Astro.locals.pb.collection("actions").update(idParam, payload);

      return Astro.redirect(`/creation/actions/${idParam}-${slug}?success=Action mise à jour`);
    } else {
      // create new
      const newAction = await Astro.locals.pb.collection("actions").create({
        ...data,
        ...files,
      });
      return Astro.redirect(
        `/creation/actions/${newAction.id}-${slug}?success=Action créée avec succès`,
      );
    }
  } catch (err) {
    console.error("Erreur lors de la création:", err);
    // En cas d'erreur, on continue et affiche le formulaire avec l'erreur
    error =
      err instanceof Error ? err.message : "Une erreur inconnue est survenue";
  }
}
---

<Layout>
  <div class="flex h-fit w-full">
    <div class="w-1/3">
      <div class="h-[105dvh] bg-accent pb-24 rounded-br-box sticky left-0 top-0 overflow-auto p-6">
        <form
          id="leftForm"
          class="space-y-8 text-accent"
          method="POST"
          enctype="multipart/form-data"
        >
          <h1 class="text-3xl font-bold mb-8 mt-32 text-white">
            {idParam ? "Modifier l'action" : "Créer une nouvelle action"}
          </h1>
          {error && <p class="text-red-300 mb-4">{error}</p>}

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <label class="block text-sm font-medium mb-1">Titre</label>
            <input
              data-prop="titre"
              id="input_titre"
              name="titre_local"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              placeholder="Titre de l'action"
              value={previewData.titre}
            />
            <input type="hidden" name="titre" id="hidden_titre" value={previewData.titre} />

            <label class="block text-sm font-medium mb-1">Sous-titre</label>
            <input
              data-prop="sous_titre"
              id="input_sous_titre"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              placeholder="Sous-titre"
              value={previewData.sous_titre}
            />
            <input type="hidden" name="sous_titre" id="hidden_sous_titre" value={previewData.sous_titre} />

            <div class="flex gap-4">
              <div class="w-1/2">
                <label class="text-sm">Date début</label>
                <input
                  data-prop="date_debut"
                  id="input_date_debut"
                  type="date"
                  class="border rounded px-2 py-1 w-full text-black bg-base-100"
                  value={previewData.date_debut}
                />
                <input type="hidden" name="date_debut" id="hidden_date_debut" value={previewData.date_debut} />
              </div>
              <div class="w-1/2">
                <label class="text-sm">Date fin</label>
                <input
                  data-prop="date_fin"
                  id="input_date_fin"
                  type="date"
                  class="border rounded px-2 py-1 w-full text-black bg-base-100"
                  value={previewData.date_fin}
                />
                <input type="hidden" name="date_fin" id="hidden_date_fin" value={previewData.date_fin} />
              </div>
            </div>
          </div>

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <label class="block text-sm font-medium mb-1">Image de l'en-tête</label>
            <label
              for="input_hero_file"
              class="cursor-pointer w-full h-40 border-2 border-dashed rounded bg-base-100 flex items-center justify-center text-gray-500"
            >
              <input
                data-prop-file="hero"
                type="file"
                name="hero"
                id="input_hero_file"
                accept="image/*"
                class="hidden"
              />
              <div id="preview_hero" class="mt-2"></div>
              <div
                class="flex flex-col items-center text-center pointer-events-none"
              >
                <img
                  src={imageIcon.src}
                  alt="Icone image"
                  class="h-16 w-16"
                  style="filter:grayscale(100%) brightness(0.5); opacity:0.3;"
                />
                <span class="text-sm">Cliquez ou glissez l'image ici</span>
                <span class="text-xs text-gray-400">PNG, JPG, GIF</span>
              </div>
            </label>
            {actionRecord?.hero && (
              <div class="mt-2" id="existing_hero_container">
                <label class="block text-sm font-medium mb-1">Image actuelle</label>
                <div class="relative">
                  <img data-field="hero" src={normalizeImageUrl(actionRecord.hero, actionRecord)} alt="Aperçu image hero" class="w-full h-[25dvh] object-cover rounded" />
                </div>
              </div>
            )}
            <label class="block text-sm font-medium mt-2 mb-1"
              >Description image de l'en-tête</label
            >
            <textarea
              data-prop="description_hero"
              id="input_description_hero"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              rows="2">{previewData.description_hero}</textarea>
            <input
              type="hidden"
              name="description_hero"
              id="hidden_description_hero"
              value={previewData.description_hero}
            />
          </div>

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <h4 class="font-semibold">Partie 1</h4>
            <input
              data-prop="titre_partie_1"
              id="input_titre_partie_1"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Titre partie 1"
              value={previewData.titre_partie_1}
            />
            <input
              type="hidden"
              name="titre_partie_1"
              id="hidden_titre_partie_1"
              value={previewData.titre_partie_1}
            />
            <label class="block text-sm font-medium mt-2">Texte partie 1</label>
            <textarea
              data-prop="texte_partie_1"
              id="input_texte_partie_1"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              rows="4">{previewData.texte_partie_1}</textarea>
            <input
              type="hidden"
              name="texte_partie_1"
              id="hidden_texte_partie_1"
              value={previewData.texte_partie_1}
            />
            <label class="block text-sm font-medium mt-2">Photo partie 1</label>
            <label
              for="input_photo_partie_1"
              class="cursor-pointer w-full h-36 border-2 border-dashed rounded bg-base-100 flex items-center justify-center text-gray-500"
            >
              <input
                data-prop-file="photo_partie_1"
                type="file"
                name="photo_partie_1"
                id="input_photo_partie_1"
                accept="image/*"
                class="hidden"
              />
              <div id="preview_photo_partie_1" class="mt-2"></div>
              <div
                class="flex flex-col items-center text-center pointer-events-none"
              >
                <img
                  src={imageIcon.src}
                  alt="Icone image"
                  class="h-16 w-16"
                  style="filter:grayscale(100%) brightness(0.5); opacity:0.3;"
                />
                <span class="text-sm">Ajouter une photo</span>
              </div>
            </label>
            {actionRecord?.photo_partie_1 && (
              <div class="mt-2" id="existing_photo_partie_1_container">
                <label class="block text-sm font-medium mb-1">Image actuelle</label>
                <div class="relative">
                  <img data-field="photo_partie_1" src={normalizeImageUrl(actionRecord.photo_partie_1, actionRecord)} alt="Aperçu photo partie 1" class="w-full h-[25dvh] object-cover rounded" />
                </div>
              </div>
            )}
            <label class="block text-sm font-medium mt-2"
              >Description photo partie 1</label
            >
            <input
              data-prop="description_photo_partie_1"
              id="input_description_photo_partie_1"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              value={previewData.description_photo_partie_1}
            />
            <input
              type="hidden"
              name="description_photo_partie_1"
              id="hidden_description_photo_partie_1"
              value={previewData.description_photo_partie_1}
            />
          </div>

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <h4 class="font-semibold">Lieu / Chiffres / Bénéficiaires</h4>
            <label class="block text-sm font-medium mt-2"
              >Nom du lieu (max 30 caractères)</label
            >
            <input
              data-prop="nom_lieu"
              id="input_nom_lieu"
              name="nom_lieu_local"
              maxlength="30"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Nom du lieu"
            />
            <input type="hidden" name="nom_lieu" id="hidden_nom_lieu" value={previewData.nom_lieu} />
            <label class="block text-sm font-medium mt-2"
              >Adresse du lieu (max 30 caractères)</label
            >
            <input
              data-prop="adresse_lieu"
              id="input_adresse_lieu"
              maxlength="30"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Adresse"
            />
            <input type="hidden" name="adresse_lieu" id="hidden_adresse_lieu" value={previewData.adresse_lieu} />
            <input
              data-prop="lien_lieu"
              id="input_lien_lieu"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Lien Google Maps"
            />
            <input type="hidden" name="lien_lieu" id="hidden_lien_lieu" value={previewData.lien_lieu} />
            <div class="flex gap-2 mt-2">
              <input
                data-prop="chiffre"
                id="input_chiffre"
                type="number"
                class="border rounded px-2 py-1 w-1/2 text-black bg-base-100"
                placeholder="Chiffre"
                value={previewData.chiffre}
              />
              <select
                data-prop="type_de_chiffre"
                id="input_type_de_chiffre"
                class="border rounded px-2 py-1 w-1/2 text-black bg-base-100"
              >
                <option value="">Type</option>
                {
                  typeDeChiffreOptions.map((opt) => (
                    <option value={opt} selected={opt === previewData.type_de_chiffre}>{opt}</option>
                  ))
                }
              </select>
            </div>
            <input type="hidden" name="chiffre" id="hidden_chiffre" value={previewData.chiffre} />
            <input
              type="hidden"
              name="type_de_chiffre"
              id="hidden_type_de_chiffre"
              value={previewData.type_de_chiffre}
            />
            <input
              data-prop="beneficiaire"
              id="input_beneficiaire"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Bénéficiaire"
              value={previewData.beneficiaire}
            />
            <input type="hidden" name="beneficiaire" id="hidden_beneficiaire" value={previewData.beneficiaire} />
          </div>

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <h4 class="font-semibold">Partie 2</h4>
            <input
              data-prop="titre_partie_2"
              id="input_titre_partie_2"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Titre partie 2"
              value={previewData.titre_partie_2}
            />
            <input
              type="hidden"
              name="titre_partie_2"
              id="hidden_titre_partie_2"
              value={previewData.titre_partie_2}
            />
            <label class="block text-sm font-medium mt-2">Texte partie 2</label>
            <textarea
              data-prop="texte_partie_2"
              id="input_texte_partie_2"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              rows="4">{previewData.texte_partie_2}</textarea>
            <input
              type="hidden"
              name="texte_partie_2"
              id="hidden_texte_partie_2"
              value={previewData.texte_partie_2}
            />
            <label class="block text-sm font-medium mt-2">Photo partie 2</label>
            <label
              for="input_photo_partie_2"
              class="cursor-pointer w-full h-36 border-2 border-dashed rounded bg-base-100 flex items-center justify-center text-gray-500"
            >
              <input
                data-prop-file="photo_partie_2"
                type="file"
                name="photo_partie_2"
                id="input_photo_partie_2"
                accept="image/*"
                class="hidden"
              />
              <div id="preview_photo_partie_2" class="mt-2"></div>
              <div
                class="flex flex-col items-center text-center pointer-events-none"
              >
                <img
                  src={imageIcon.src}
                  alt="Icone image"
                  class="h-16 w-16"
                  style="filter:grayscale(100%) brightness(0.5); opacity:0.3;"
                />
                <span class="text-sm">Ajouter une photo</span>
              </div>
            </label>
            {actionRecord?.photo_partie_2 && (
              <div class="mt-2" id="existing_photo_partie_2_container">
                <label class="block text-sm font-medium mb-1">Image actuelle</label>
                <div class="relative">
                  <img data-field="photo_partie_2" src={normalizeImageUrl(actionRecord.photo_partie_2, actionRecord)} alt="Aperçu photo partie 2" class="w-full h-[25dvh] object-cover rounded" />
                </div>
              </div>
            )}
            <input
              data-prop="description_photo_partie_2"
              id="input_description_photo_partie_2"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              value={previewData.description_photo_partie_2}
            />
            <input
              type="hidden"
              name="description_photo_partie_2"
              id="hidden_description_photo_partie_2"
              value={previewData.description_photo_partie_2}
            />
          </div>

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <h4 class="font-semibold">Partie 3</h4>
            <input
              data-prop="titre_partie_3"
              id="input_titre_partie_3"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Titre partie 3"
              value={previewData.titre_partie_3}
            />
            <input
              type="hidden"
              name="titre_partie_3"
              id="hidden_titre_partie_3"
              value={previewData.titre_partie_3}
            />
            <label class="block text-sm font-medium mt-2">Texte partie 3</label>
            <textarea
              data-prop="texte_partie_3"
              id="input_texte_partie_3"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              rows="4">{previewData.texte_partie_3}</textarea>
            <input
              type="hidden"
              name="texte_partie_3"
              id="hidden_texte_partie_3"
              value={previewData.texte_partie_3}
            />
            <label class="block text-sm font-medium mt-2">Photo partie 3</label>
            <label
              for="input_photo_partie_3"
              class="cursor-pointer w-full h-36 border-2 border-dashed rounded bg-base-100 flex items-center justify-center text-gray-500"
            >
              <input
                data-prop-file="photo_partie_3"
                type="file"
                name="photo_partie_3"
                id="input_photo_partie_3"
                accept="image/*"
                class="hidden"
              />
              <div id="preview_photo_partie_3" class="mt-2"></div>
              <div
                class="flex flex-col items-center text-center pointer-events-none"
              >
                <img
                  src={imageIcon.src}
                  alt="Icone image"
                  class="h-16 w-16"
                  style="filter:grayscale(100%) brightness(0.5); opacity:0.3;"
                />
                <span class="text-sm">Ajouter une photo</span>
              </div>
            </label>
            {actionRecord?.photo_partie_3 && (
              <div class="mt-2" id="existing_photo_partie_3_container">
                <label class="block text-sm font-medium mb-1">Image actuelle</label>
                <div class="relative">
                  <img data-field="photo_partie_3" src={normalizeImageUrl(actionRecord.photo_partie_3, actionRecord)} alt="Aperçu photo partie 3" class="w-full h-[25dvh] object-cover rounded" />
                </div>
              </div>
            )}
            <input
              data-prop="description_photo_partie_3"
              id="input_description_photo_partie_3"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              value={previewData.description_photo_partie_3}
            />
            <input
              type="hidden"
              name="description_photo_partie_3"
              id="hidden_description_photo_partie_3"
              value={previewData.description_photo_partie_3}
            />
          </div>

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <h4 class="font-semibold">Remerciements</h4>
            <input
              data-prop="titre_remerciement"
              id="input_titre_remerciement"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Titre remerciements"
              value={previewData.titre_remerciements}
            />
            <input
              type="hidden"
              name="titre_remerciement"
              id="hidden_titre_remerciement"
              value={previewData.titre_remerciements}
            />
            <label class="block text-sm font-medium mt-2"
              >Description remerciements</label
            >
            <textarea
              data-prop="description_remerciement"
              id="input_description_remerciement"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              rows="3">{previewData.description_remerciements}</textarea>
            <input
              type="hidden"
              name="description_remerciement"
              id="hidden_description_remerciement"
              value={previewData.description_remerciements}
            />
          </div>

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <label class="block text-sm font-medium mb-1">Galerie (max 8)</label
            >
            <label
              for="input_galerie_photos"
              class="cursor-pointer w-full h-36 border-2 border-dashed rounded bg-base-100 flex items-center justify-center text-gray-500"
            >
              <input
                data-prop-file="galerie_photos"
                type="file"
                name="galerie_photos"
                id="input_galerie_photos"
                accept="image/*"
                multiple
                class="hidden"
              />
              <div
                class="flex flex-col items-center text-center pointer-events-none"
              >
                <img
                  src={imageIcon.src}
                  alt="Icone image"
                  class="h-16 w-16"
                  style="filter:grayscale(100%) brightness(0.5); opacity:0.3;"
                />
                <span class="text-sm">Cliquez ou glissez vos photos</span>
                <span class="text-xs text-gray-400">Jusqu'à 8 images</span>
              </div>
            </label>
            <input type="hidden" id="hidden_galerie_photos" name="galerie_photos" />
            <input type="hidden" id="hidden_remove_galerie_photos" name="remove_galerie_photos" />
            <div id="galleryExisting" class="mt-2 grid grid-cols-4 gap-2"></div>
            <div id="gallerySelected" class="mt-2 grid grid-cols-4 gap-2"></div>
          </div>

          <div class="pt-4">
            <button
              type="submit"
              class="bg-base-100 text-accent px-4 py-2 rounded w-full"
            >{idParam ? "Enregistrer les modifications" : "Créer l'action"}</button>
          </div>
        </form>
      </div>
    </div>

    <div class="w-2/3 px-8">
      <ActionContent action={previewData} />
    </div>
  </div>
  <script set:html={`window.__previewData = ${JSON.stringify(previewData).replace(/</g, "\\u003c")};`}></script>

  <script type="module" src={previewUrl}></script>
  <script type="module" src={galleryUrl}></script>
  <script type="module" src={galleryDisplayUrl}></script>
</Layout>
