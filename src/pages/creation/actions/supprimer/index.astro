---
import Layout from "../../../../layouts/Layout-back-office.astro";
import ItemCard from "../../../../components/ItemCard.astro";
import slugify from "slugify";
import { formatDateShort } from "../../../../utils/utilitaires.js";
import { getCreationViewUrl } from "../../../../utils/creationRoutes";
import ActionsSearch from "../../../../components/ActionsSearch.astro";
import { normalizeImageUrl } from "../../../../utils/utilitaires.js";
import { ActionsTypeActionOptions } from "../../../../pocketbase-types";

let error = "";
let success = "";

// Récupérer la liste des actions
let actionsRaw = [];
try {
  actionsRaw = await (Astro.locals as any).pb
    .collection("actions")
    .getFullList(500, { sort: "-updated" });
} catch (e) {
  console.error("Impossible de récupérer les actions:", e);
  error = "Impossible de charger la liste des actions.";
}

// Mapper les données essentielles
const actions = actionsRaw.map((a: any) => ({
  id: a.id,
  title: a.titre,
  slug: slugify(a.titre || "", { lower: true, strict: true }),
  subtitle: a.sous_titre,
  updated: a.updated,
  beneficiary: a.beneficiaire,
  type_action: Array.isArray(a.type_action) ? a.type_action.map((value: unknown) => String(value)) : [],
  heroActionUrl: normalizeImageUrl(a.hero, a, Astro.locals.pb, { thumb: "800x0" }) || undefined,
  displayDate: a.date_debut ? formatDateShort(a.date_debut) : "",
  source: "action" as const,
}));

const typeOptions = Array.from(
  new Set(
    (Array.isArray(ActionsTypeActionOptions)
      ? ActionsTypeActionOptions
      : Object.values(ActionsTypeActionOptions)
    ).map((value) => String(value)),
  ),
).sort((a, b) => a.localeCompare(b));

// Gestion POST pour suppression multiple
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    // Récupérer toutes les valeurs des cases à cocher nommées "ids"
    const ids = formData
      .getAll("ids")
      .map((v) => v.toString())
      .filter(Boolean);
    if (!ids || ids.length === 0) {
      error = "Aucune action sélectionnée.";
    } else {
      const failed: string[] = [];
      for (const id of ids) {
        try {
          await (Astro.locals as any).pb.collection("actions").delete(id);
        } catch (e) {
          console.error("Erreur suppression id:", id, e);
          failed.push(id);
        }
      }
      if (failed.length === 0) {
        return Astro.redirect(
          `/creation/actions/supprimer?success=${encodeURIComponent(`${ids.length} action(s) supprimée(s) avec succès.`)}`,
        );
      } else {
        error = `Échec de la suppression pour ${failed.length} action(s).`;
      }
    }
  } catch (e) {
    console.error("Erreur lors du POST suppression:", e);
    error = "La suppression des actions a échoué.";
  }
}

// Afficher le message de succès s'il est présent dans les paramètres de requête.
try {
  const s = Astro.url.searchParams.get("success");
  if (s) success = s;
} catch (e) {}
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    <div
      class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between"
    >
      <div class="mb-0">
        <h1
          class="mb-3 text-3xl font-bold text-accent font-poppins md:text-4xl"
        >
          Supprimer des actions
        </h1>
        <p class="text-base text-base-content md:text-lg">
          Sélectionnez plusieurs actions puis cliquez sur "Supprimer sélection".
        </p>
      </div>
      <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
        <a
          href="/creation/actions"
          class="btn btn-border btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md"
          >Retour aux actions</a
        >
      </div>
    </div>

    <div
      id="delete-flash-flags"
      data-success={success}
      data-error={error}
      class="hidden"
    >
    </div>

    <form method="POST" id="deleteForm">
      <div class="mb-4 space-y-4">
        <div
          class="card rounded-2xl border border-base-300 bg-base-100 shadow-sm"
        >
          <div class="card-body p-4 md:p-6">
            <div class="mb-4">
              <h2 class="card-title text-2xl">Rechercher</h2>
              <p class="mt-1 text-sm text-base-content">
                Filtrez rapidement vos actions puis triez l'affichage.
              </p>
            </div>
            <div class="flex flex-col gap-4">
              <div class="w-full">
                <ActionsSearch embedded={true} typeOptions={typeOptions}>
                  <label
                    slot="secondary-extra"
                    class="form-control w-full gap-1"
                    for="sort-select"
                  >
                    <span
                      class="text-sm! font-medium tracking-wide text-base-content"
                      >Trier par date</span
                    >
                    <select
                      id="sort-select"
                      class="select select-bordered w-full"
                    >
                      <option value="updated_desc">Récent → Ancien</option>
                      <option value="updated_asc">Ancien → Récent</option>
                    </select>
                  </label>
                </ActionsSearch>
              </div>
            </div>
          </div>
        </div>
        <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
          <label class="flex items-center gap-2">
            <input type="checkbox" id="selectAll" />
            <span class="text-sm">Tout sélectionner</span>
          </label>
          <button
            type="submit"
            id="bulkDelete"
            class="btn btn-error btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md"
            >Supprimer sélection</button
          >
        </div>
      </div>

      <div
        id="cards-grid"
        class="grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-5 lg:grid-cols-3 lg:gap-6"
      >
        {
          actions.map((action: any) => (
            <ItemCard
              id={action.id}
              title={action.title}
              slug={action.slug}
              source={action.source}
              photoUrl={action.heroActionUrl}
              photoClass="h-56 md:h-64 object-cover! px-0! "
              photoLoading="lazy"
              photoFetchPriority="low"
              showPhotoPlaceholder={true}
              subtitle={action.subtitle}
              beneficiary={action.beneficiary}
              formattedDate={action.displayDate}
              viewUrl={getCreationViewUrl("action", action.id, action.slug)}
              editUrl={getCreationViewUrl("action", action.id, action.slug)}
              showCheckbox={true}
              checkboxSlot={`<input class="checkbox checkbox-primary shrink-0" type="checkbox" name="ids" id="id_${action.id}" value="${action.id}" data-item-id="${action.id}" data-title="${action.title}" data-beneficiary="${action.beneficiary || ""}" data-types="${(Array.isArray(action.type_action) ? action.type_action : []).join("||")}" data-updated="${action.updated}" data-updated-ts="${new Date(action.updated || 0).getTime()}" />`}
              maxHeightContent={true}
              deleteMode={true}
            />
          ))
        }
      </div>
      <div id="cards-pagination" class="mt-6 flex justify-center"></div>
    </form>
  </div>

  <script>
    import { initDeletePageHandler } from "../../../../utils/deletePageHandler";

    initDeletePageHandler({
      cardSelector: "div[data-item-id]",
      itemSingular: "action",
      itemPlural: "actions",
      sortSelectSelector: "#sort-select",
    });
  </script>
</Layout>
