---
import Layout from "../../../layouts/Layout.astro";

import ActionContent from "../../../components/ActionContent.astro";
import backArrow from "../../../assets/back-arrow.svg";

const id = Astro.params.id;
let slug = Astro.params.slug
const normalizedId =
  typeof id === "string" ? (id.match(/^[a-zA-Z0-9]{15}/)?.[0] ?? id) : id;
const successMessage = (Astro.url.searchParams.get("success") || "").trim();
let action = null;
try {
  action = await Astro.locals.pb.collection("actions").getOne(normalizedId!);
} catch (err) {
  const isNotFound = (err instanceof Error && err.message?.includes("The requested resource wasn't found")) || ((err as any)?.response?.status === 404);
  if (isNotFound) {
    const message = 'Action introuvable (identifiant: ' + normalizedId + ')';
    return new Response(`<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Action introuvable</title><style>body{background:#0b1220;color:#e6eef8;font-family:system-ui,-apple-system,Segoe UI,Roboto,'Helvetica Neue',Arial;padding:40px}a{color:#9fe7c4}</style></head><body><h1>Action introuvable</h1><p>${message}</p><p><a href="/creation/actions">Retour aux actions</a></p></body></html>`, { status: 404, headers: { 'Content-Type': 'text/html' } });
  }
  throw err;
}
---

<Layout>
  {
    successMessage && (
      <div
        id="action-success-flag"
        data-message={successMessage}
        class="hidden"
      />
    )
  }
  <a
    href="/actions"
    class="hidden fixed px-4 py-3 min-h-11 lg:flex items-center justify-center z-50 bg-base-100 bg-opacity-80 rounded-box text-sm lg:text-base lg:left-[2%] lg:top-[12%]"
  >
    <img
      src={backArrow.src}
      alt="Retour aux actions"
      loading="lazy"
      class="inline-block mr-2 invert w-4 h-4 md:w-5 md:h-5"
     decoding="async" />Retour aux actions</a
  >
  <div class="flex w-full justify-between mb-8 mt-24 px-4">
    <a href="/actions" class="flex lg:hidden items-center text-sm">
    <img
      src={backArrow.src}
      alt="Retour aux actions"
      loading="lazy"
      class="inline-block mr-2 invert w-4 h-4 md:w-5 md:h-5"
     decoding="async" />Retour aux actions</a
  >
  
  <a href={`/creation/actions/edit/${id}-${slug}`} class="flex lg:hidden items-center text-sm w-fit btn btn-accent">
    Modifier l'action</a
  >
  </div>
  <a
    href={`/creation/actions/edit/${id}-${slug}`}
    class="hidden fixed px-4 py-3 min-h-11 lg:flex items-center justify-center z-50 bg-opacity-80 rounded-box text-sm lg:text-base lg:right-[2%] lg:top-[12%] btn btn-accent"
  >
    Modifier l'action</a
  >
  <ActionContent action={action} />

  <script>
    import { showAlert } from "../../../utils/alerts";

    const successFlag = document.getElementById("action-success-flag");
    if (successFlag instanceof HTMLElement) {
      const message = (successFlag.dataset.message || "").trim();
      if (message) {
        showAlert({
          type: "success",
          message,
        });

        const url = new URL(window.location.href);
        url.searchParams.delete("success");
        window.history.replaceState({}, "", url.toString());
      }
    }
  </script>
</Layout>
