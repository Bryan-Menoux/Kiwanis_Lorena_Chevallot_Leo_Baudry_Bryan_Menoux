---
import Layout from "../../../../layouts/Layout-back-office.astro";
import slugify from "slugify";
import { formatDateShort } from "../../../../utils/utilitaires.js";
import ActionsSearch from "../../../../components/ActionsSearch.astro";

let error = "";
let success = "";

// Récupérer la liste des actions
let actionsRaw = [];
try {
  actionsRaw = await (Astro.locals as any).pb
    .collection("actions")
    .getFullList(500, { sort: "-updated" });
} catch (e) {
  console.error("Impossible de récupérer les actions:", e);
  error = "Impossible de charger la liste des actions";
}

// Mapper les données essentielles
const actions = actionsRaw.map((a: any) => ({
  id: a.id,
  titre: a.titre,
  slug: slugify(a.titre || "", { lower: true, strict: true }),
  sous_titre: a.sous_titre,
  updated: a.updated,
  beneficiaire: a.beneficiaire,
  type_de_chiffre: a.type_de_chiffre,
}));

// Gestion POST pour suppression multiple
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    // Récupérer toutes les valeurs des cases à cocher nommées "ids"
    const ids = formData
      .getAll("ids")
      .map((v) => v.toString())
      .filter(Boolean);
    if (!ids || ids.length === 0) {
      error = "Aucun élément sélectionné";
    } else {
      const failed: string[] = [];
      for (const id of ids) {
        try {
          await (Astro.locals as any).pb.collection("actions").delete(id);
        } catch (e) {
          console.error("Erreur suppression id:", id, e);
          failed.push(id);
        }
      }
      if (failed.length === 0) {
        return Astro.redirect(
          `/creation/actions/delete?success=${encodeURIComponent(`${ids.length} action(s) supprimée(s)`)}`,
        );
      } else {
        error = `Échec suppression pour ${failed.length} élément(s)`;
      }
    }
  } catch (e) {
    console.error("Erreur lors du POST suppression:", e);
    error = "Erreur lors de la suppression";
  }
}

// Afficher le message de succès s'il est présent dans la query.
try {
  const s = Astro.url.searchParams.get("success");
  if (s) success = s;
} catch (e) {}
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="mb-0">
        <h1 class="mb-3 text-3xl font-bold text-accent font-poppins md:text-4xl">Supprimer des actions</h1>
        <p class="text-base text-base-content md:text-lg">
          Selectionnez plusieurs actions puis cliquez sur "Supprimer selection".
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-3 lg:justify-end">
        <a href="/creation/actions" class="btn btn-border btn-sm rounded-full w-full md:w-fit md:btn-md">Retour aux actions</a>
      </div>
    </div>

    <div
      id="delete-flash-flags"
      data-success={success}
      data-error={error}
      class="hidden"
    ></div>

    <form method="POST" id="deleteForm">
      <div class="mb-4 space-y-4">
        <div class="card rounded-2xl border border-base-300 bg-base-100 shadow-sm">
          <div class="card-body p-4 md:p-6">
            <div class="mb-4">
              <h2 class="card-title text-2xl">Rechercher</h2>
              <p class="mt-1 text-sm text-base-content">
                Filtrez rapidement vos actions puis triez l'affichage.
              </p>
            </div>
            <div class="flex flex-col gap-4">
              <div class="w-full">
                <p class="mb-2 text-sm font-medium text-base-content">Filtres</p>
                <ActionsSearch embedded={true}>
                  <label slot="secondary-extra" class="form-control w-full gap-1" for="sort-select">
                    <span class="text-xs font-medium uppercase tracking-wide text-base-content">Trier par date</span>
                    <select id="sort-select" class="select select-bordered w-full">
                      <option value="updated_desc">Recent -> Ancien</option>
                      <option value="updated_asc">Ancien -> Recent</option>
                    </select>
                  </label>
                </ActionsSearch>
              </div>
            </div>
          </div>
        </div>
        <div class="flex flex-col gap-2 select-none sm:flex-row sm:items-center sm:justify-between">
          <label class="flex items-center gap-2">
            <input type="checkbox" id="selectAll" />
            <span class="text-sm">Tout selectionner</span>
          </label>
          <button
            type="submit"
            id="bulkDelete"
            class="btn btn-error btn-sm rounded-full md:btn-md w-full sm:w-auto"
            >Supprimer selection</button
          >
        </div>
      </div>

      <div
        id="cards-grid"
        class="grid grid-cols-1 gap-4 md:grid-cols-2 md:gap-5 lg:grid-cols-3 lg:gap-6"
      >
        {
          actions.map((a: any) => (
            <label
              class="flex min-h-55 flex-col justify-between gap-4 rounded-xl border border-base-300 bg-base-100 p-4 shadow-sm md:p-5 lg:p-6"
              for={`id_${a.id}`}
              data-action-id={a.id}
              data-action-slug={a.slug}
              data-title={a.titre}
              data-type={a.type_de_chiffre}
              data-beneficiary={a.beneficiaire}
              data-updated={a.updated}
            >
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <input
                    class="checkbox checkbox-primary mt-1 shrink-0"
                    type="checkbox"
                    name="ids"
                    id={`id_${a.id}`}
                    value={a.id}
                  />
                  <h3 class="wrap-break-word text-xl font-bold leading-tight md:text-2xl">
                    {a.titre}
                  </h3>
                </div>
                {a.sous_titre && (
                  <p class="text-sm leading-relaxed wrap-break-word text-base-content/75">
                    {a.sous_titre}
                  </p>
                )}
                {a.beneficiaire && (
                  <p class="text-sm leading-relaxed wrap-break-word text-base-content/75">
                    {a.beneficiaire}
                  </p>
                )}
                <p class="text-xs leading-tight text-base-content">
                  {a.updated ? formatDateShort(a.updated) : ""}
                </p>
              </div>
              <div class="flex justify-end">
                <a
                  class="btn btn-sm btn-ghost w-full sm:w-auto"
                  href={`/actions/${a.id}-${a.slug}`}
                >
                  Voir
                </a>
              </div>
            </label>
          ))
        }
      </div>
      <div id="cards-pagination" class="mt-6 flex justify-center"></div>
    </form>
  </div>

  <script>
    import { showAlert, showConfirm } from "../../../../utils/alerts";

    // Recherche, filtres et tri côté client + sélection globale + suppression par carte.
    document.addEventListener("DOMContentLoaded", () => {
      const flashFlags = document.getElementById("delete-flash-flags");
      if (flashFlags instanceof HTMLElement) {
        const successMessage = flashFlags.dataset.success || "";
        const errorMessage = flashFlags.dataset.error || "";
        if (successMessage) {
          showAlert({
            type: "success",
            message: successMessage,
          });
        }
        if (errorMessage) {
          showAlert({
            type: "error",
            message: errorMessage,
          });
        }
      }

      const selectAll = document.getElementById("selectAll");
      const form = document.getElementById("deleteForm");
      const grid = document.getElementById("cards-grid");
      const sortSelect = document.getElementById("sort-select");

      if (!(form instanceof HTMLFormElement) || !(grid instanceof HTMLElement)) return;

      const g = grid;
      let bypassConfirmSubmit = false;

      form.addEventListener("submit", async (event) => {
        if (bypassConfirmSubmit) {
          bypassConfirmSubmit = false;
          return;
        }

        event.preventDefault();

        const selected = g.querySelectorAll(
          'input[type="checkbox"][name="ids"]:checked',
        ).length;

        if (selected === 0) {
          showAlert({
            type: "warning",
            message: "Sélectionnez au moins une action à supprimer.",
          });
          return;
        }

        const confirmed = await showConfirm({
          title: "Supprimer des actions",
          message: `Confirmer la suppression de ${selected} élément(s) ?`,
          type: "warning",
          confirmLabel: "Supprimer",
          cancelLabel: "Annuler",
        });

        if (!confirmed) return;

        bypassConfirmSubmit = true;
        if (typeof form.requestSubmit === "function") {
          form.requestSubmit();
        } else {
          form.submit();
        }
      });

      // Récupérer toutes les cartes (instantané initial).
      const allCards = Array.from(
        g.querySelectorAll("label[data-action-id]"),
      ) as HTMLElement[];
      let currentSearch = "";
      let currentBenef = "";
      const PAGE_SIZE = 9;
      let currentPage = 1;
      const pagination = document.getElementById("cards-pagination");

      function renderPagination(totalPages: number) {
        if (!(pagination instanceof HTMLElement)) return;
        if (totalPages <= 1) {
          pagination.innerHTML = "";
          return;
        }
        const pageButtons = Array.from({ length: totalPages }, (_, index) => {
          const pageNumber = index + 1;
          const activeClass = pageNumber === currentPage ? "btn-accent" : "btn-ghost";
          return `<button type="button" class="btn btn-sm ${activeClass}" data-page-action="go" data-page="${pageNumber}">${pageNumber}</button>`;
        }).join("");

        pagination.innerHTML = `
          <div class="flex flex-wrap items-center justify-center gap-2">
            <button type="button" class="btn btn-sm btn-ghost" data-page-action="prev" ${currentPage === 1 ? "disabled" : ""}>Precedent</button>
            ${pageButtons}
            <button type="button" class="btn btn-sm btn-ghost" data-page-action="next" ${currentPage === totalPages ? "disabled" : ""}>Suivant</button>
          </div>
        `;
      }

      function updateView() {
        const q = (currentSearch || "").toLowerCase().trim();
        const benef = (currentBenef || "").toLowerCase().trim();
        const sort = (sortSelect instanceof HTMLSelectElement) ? sortSelect.value : "updated_desc";

        let visible = allCards.filter((card) => {
          const title = (card.dataset.title || "").toLowerCase();
          const t = (card.dataset.type || "").toLowerCase();
          const b = (card.dataset.beneficiary || "").toLowerCase();
          const upd = card.dataset.updated ? new Date(card.dataset.updated) : null;
          
          if (benef && benef !== "" && !b.includes(benef)) return false;
          if (q && q !== "" && !title.includes(q)) return false;
          // Filtrage par date non implémenté pour l'instant.
          return true;
        });

        visible.sort((a, b) => {
          const da = new Date(a.dataset.updated || "0").getTime();
          const db = new Date(b.dataset.updated || "0").getTime();
          return sort === "updated_asc" ? da - db : db - da;
        });

        const totalPages = Math.max(1, Math.ceil(visible.length / PAGE_SIZE));
        if (currentPage > totalPages) currentPage = totalPages;
        if (currentPage < 1) currentPage = 1;
        const startIndex = (currentPage - 1) * PAGE_SIZE;
        const pageItems = visible.slice(startIndex, startIndex + PAGE_SIZE);

        // Vider puis réinsérer les cartes visibles dans l'ordre.
        g.innerHTML = "";
        pageItems.forEach((c) => g.appendChild(c));
        renderPagination(totalPages);
      }

      // Écouter les mises à jour de filtres du composant ActionsSearch.
      document.addEventListener('actions-filter-change', (ev: any) => {
        const d = ev.detail || {};
        currentSearch = d.search || "";
        currentBenef = d.beneficiary || "";
        currentPage = 1;
        updateView();
      });

      pagination?.addEventListener("click", (event) => {
        const target = event.target instanceof HTMLElement
          ? event.target.closest("[data-page-action]")
          : null;
        if (!(target instanceof HTMLElement)) return;

        const action = target.getAttribute("data-page-action");
        const q = (currentSearch || "").toLowerCase().trim();
        const benef = (currentBenef || "").toLowerCase().trim();
        const totalItems = allCards.filter((card) => {
          const title = (card.dataset.title || "").toLowerCase();
          const b = (card.dataset.beneficiary || "").toLowerCase();
          if (benef && benef !== "" && !b.includes(benef)) return false;
          if (q && q !== "" && !title.includes(q)) return false;
          return true;
        }).length;
        const totalPages = Math.max(1, Math.ceil(totalItems / PAGE_SIZE));

        if (action === "prev") {
          currentPage = Math.max(1, currentPage - 1);
        } else if (action === "next") {
          currentPage = Math.min(totalPages, currentPage + 1);
        } else if (action === "go") {
          const nextPage = Number(target.getAttribute("data-page") || "1");
          if (!Number.isNaN(nextPage)) {
            currentPage = Math.min(totalPages, Math.max(1, nextPage));
          }
        } else {
          return;
        }

        updateView();
      });

      // Rendu initial.
      updateView();

      if (sortSelect instanceof HTMLSelectElement) {
        sortSelect.addEventListener("change", () => {
          currentPage = 1;
          updateView();
        });
      }

      // Sélectionner uniquement les cases visibles.
      if (selectAll instanceof HTMLInputElement) {
        selectAll.addEventListener("change", () => {
          const checked = selectAll.checked;
          const inputs = g.querySelectorAll(
            'input[type="checkbox"][name="ids"]',
          );
          inputs.forEach((cb) => {
            if (cb instanceof HTMLInputElement) cb.checked = checked;
          });
        });
      }

      // Aucun bouton de suppression unitaire sur cette page ; la suppression groupée est gérée par le formulaire.
    });
  </script>
</Layout>
