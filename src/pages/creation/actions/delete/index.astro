---
import Layout from "../../../../layouts/Layout-back-office.astro";
import slugify from "slugify";
import ActionsSearch from "../../../../components/ActionsSearch.astro";

let error = "";
let success = "";

// Récupérer la liste des actions
let actionsRaw = [];
try {
  actionsRaw = await (Astro.locals as any).pb
    .collection("actions")
    .getFullList(500, { sort: "-updated" });
} catch (e) {
  console.error("Impossible de récupérer les actions:", e);
  error = "Impossible de charger la liste des actions";
}

// Mapper les données essentielles
const actions = actionsRaw.map((a: any) => ({
  id: a.id,
  titre: a.titre,
  slug: slugify(a.titre || "", { lower: true, strict: true }),
  sous_titre: a.sous_titre,
  updated: a.updated,
  beneficiaire: a.beneficiaire,
  type_de_chiffre: a.type_de_chiffre,
}));

// Gestion POST pour suppression multiple
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    // Récupère toutes les valeurs des checkboxes nommées "ids"
    const ids = formData
      .getAll("ids")
      .map((v) => v.toString())
      .filter(Boolean);
    if (!ids || ids.length === 0) {
      error = "Aucun élément sélectionné";
    } else {
      const failed: string[] = [];
      for (const id of ids) {
        try {
          await (Astro.locals as any).pb.collection("actions").delete(id);
        } catch (e) {
          console.error("Erreur suppression id:", id, e);
          failed.push(id);
        }
      }
      if (failed.length === 0) {
        return Astro.redirect(
          `/creation/actions/delete?success=${encodeURIComponent(`${ids.length} action(s) supprimée(s)`)}`,
        );
      } else {
        error = `Échec suppression pour ${failed.length} élément(s)`;
      }
    }
  } catch (e) {
    console.error("Erreur lors du POST suppression:", e);
    error = "Erreur lors de la suppression";
  }
}

// Afficher message success si présent dans query
try {
  const s = Astro.url.searchParams.get("success");
  if (s) success = s;
} catch (e) {}
---

<Layout>
  <div class="container mx-auto px-6 py-12 my-20">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-4xl font-bold">Supprimer des actions</h1>
        <p class="text-sm text-base-content/70 mt-2">
          Sélectionnez plusieurs actions puis cliquez sur "Supprimer sélection".
        </p>
      </div>
      <div>
        <a href="/creation/actions" class="btn">Retour</a>
      </div>
    </div>

    {success && <div class="alert alert-success mb-4">{success}</div>}
    {error && <div class="alert alert-error mb-4">{error}</div>}

    <form method="POST" id="deleteForm">
      <div class="mb-4 flex-col gap-8">
        <div class="flex items-center gap-4 w-full mb-4">
          <ActionsSearch />
          <select id="sort-select" class="select select-bordered w-44">
            <option value="updated_desc">Date ↓</option>
            <option value="updated_asc">Date ↑</option>
          </select>
        </div>
        <div class="flex items-center gap-3">
          <label class="flex items-center gap-2">
            <input type="checkbox" id="selectAll" />
            <span class="text-sm">Tout sélectionner</span>
          </label>
          <button
            type="submit"
            id="bulkDelete"
            class="btn btn-error"
            onclick="return confirm('Confirmer la suppression des éléments sélectionnés ?')"
            >Supprimer sélection</button
          >
        </div>
      </div>

      <div
        id="cards-grid"
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
      >
        {
          actions.map((a: any) => (
            <label
              class="bg-base-100 border border-base-300 rounded-xl p-6 shadow-sm min-h-[140px] flex flex-col justify-between"
              for={`id_${a.id}`}
              data-action-id={a.id}
              data-action-slug={a.slug}
              data-title={a.titre}
              data-type={a.type_de_chiffre}
              data-beneficiary={a.beneficiaire}
              data-updated={a.updated}
            >
              <div>
                <div class="flex items-start">
                  <input
                    class="checkbox checkbox-primary mt-1 mr-4"
                    type="checkbox"
                    name="ids"
                    id={`id_${a.id}`}
                    value={a.id}
                  />
                  <h3 class="text-2xl md:text-2xl font-bold leading-tight mr-4 truncate">
                    {a.titre}
                  </h3>
                </div>
                <p class="text-sm text-base-content/70 mt-3 mb-2 truncate">
                  {a.sous_titre}
                </p>

                <p class="text-sm text-base-content/70 mb-4">
                  {a.beneficiaire}
                </p>
                <p class="text-xs text-base-content/60 mb-2">
                  {a.updated
                    ? new Date(a.updated).toLocaleDateString("fr-FR", {
                        day: "numeric",
                        month: "short",
                        year: "numeric",
                      })
                    : ""}
                </p>
              </div>
              <div class="flex items-center justify-end gap-3">
                <a
                  class="text-sm text-base-content hover:underline"
                  href={`/actions/${a.id}-${a.slug}`}
                >
                  Voir
                </a>
                
              </div>
            </label>
          ))
        }
      </div>
    </form>
  </div>

  <script>
    // Recherche, filtres et tri côté client + select all + suppression par carte
    document.addEventListener("DOMContentLoaded", () => {
      const selectAll = document.getElementById("selectAll");
      const form = document.getElementById("deleteForm");
      const grid = document.getElementById("cards-grid");
      const sortSelect = document.getElementById("sort-select");

      if (!(form instanceof HTMLFormElement) || !(grid instanceof HTMLElement)) return;

      const g = grid;

      // Collect all cards (initial snapshot)
      const allCards = Array.from(
        g.querySelectorAll("label[data-action-id]"),
      ) as HTMLElement[];
      let currentSearch = "";
      let currentBenef = "";

      function updateView() {
        const q = (currentSearch || "").toLowerCase().trim();
        const benef = (currentBenef || "").toLowerCase().trim();
        const sort = (sortSelect instanceof HTMLSelectElement) ? sortSelect.value : "updated_desc";

        let visible = allCards.filter((card) => {
          const title = (card.dataset.title || "").toLowerCase();
          const t = (card.dataset.type || "").toLowerCase();
          const b = (card.dataset.beneficiary || "").toLowerCase();
          const upd = card.dataset.updated ? new Date(card.dataset.updated) : null;
          
          if (benef && benef !== "" && !b.includes(benef)) return false;
          if (q && q !== "" && !title.includes(q)) return false;
          // Date filtering not implemented yet
          return true;
        });

        visible.sort((a, b) => {
          const da = new Date(a.dataset.updated || "0").getTime();
          const db = new Date(b.dataset.updated || "0").getTime();
          return sort === "updated_asc" ? da - db : db - da;
        });

        // Clear and re-append visible cards in order
        g.innerHTML = "";
        visible.forEach((c) => g.appendChild(c));
      }

      // Listen for filter updates from the ActionsSearch component
      document.addEventListener('actions-filter-change', (ev: any) => {
        const d = ev.detail || {};
        currentSearch = d.search || "";
        currentBenef = d.beneficiary || "";
        updateView();
      });

      // Initial render
      updateView();

      if (sortSelect instanceof HTMLSelectElement) sortSelect.addEventListener("change", () => updateView());

      // Select only visible checkboxes
      if (selectAll instanceof HTMLInputElement) {
        selectAll.addEventListener("change", () => {
          const checked = selectAll.checked;
          const inputs = g.querySelectorAll(
            'input[type="checkbox"][name="ids"]',
          );
          inputs.forEach((cb) => {
            if (cb instanceof HTMLInputElement) cb.checked = checked;
          });
        });
      }

      // No individual delete buttons on this page; bulk delete handled by the form
    });
  </script>
</Layout>
