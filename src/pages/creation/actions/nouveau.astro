---
import Layout from "../../../layouts/Layout-back-office.astro";
import ActionContent from "../../../components/ActionContent.astro";
import ActionForm from "../../../components/ActionForm.astro";
import ActionEditorShell from "../../../components/actionForm/ActionEditorShell.astro";
import slugify from "slugify";
import {
  ActionsTypeActionOptions,
  ActionsTypeDeChiffreOptions,
} from "../../../pocketbase-types";
import previewDefaults from "../../../scripts/previewDefaults.js";
import {
  buildWordLimitMessage,
  getNormalizedSelectedTypeActionValues,
  getOverLimitPartTextFieldsAfterSubmit,
} from "../../../scripts/actionForm/validation.js";
const previewDefaultsMap = previewDefaults as Record<string, unknown>;

let error: string = "";
// Champs autorisés à être explicitement vides (on évite de les "drop" au trim).
const EMPTYABLE_FIELDS = new Set([
  "nom_lieu",
  "adresse_lieu",
  "lien_lieu",
  "chiffre",
  "type_de_chiffre",
]);
const PART_NUMBERS = [1, 2, 3];

const isNonEmptyString = (value: FormDataEntryValue | null) =>
  typeof value === "string" && value.trim() !== "";

const hasUploadedFile = (formData: FormData, fieldName: string) => {
  const value = formData.get(fieldName);
  return value instanceof File && value.size > 0;
};

const hasAtLeastOnePartContent = (formData: FormData) =>
  PART_NUMBERS.some((partNumber) => {
    const textKey = `texte_partie_${partNumber}`;
    const photoKey = `photo_partie_${partNumber}`;
    return isNonEmptyString(formData.get(textKey)) || hasUploadedFile(formData, photoKey);
  });

const hasDescriptionForPartTitle = (payload: Record<string, any>, partNumber: number) => {
  const textKey = `texte_partie_${partNumber}`;
  const descriptionValue = payload[textKey];
  if (typeof descriptionValue !== "string" || descriptionValue.trim() === "") {
    return false;
  }
  const defaultDescription = previewDefaultsMap[textKey];
  if (typeof defaultDescription !== "string") {
    return true;
  }
  return descriptionValue.trim() !== defaultDescription.trim();
};

const applyPartTitleRule = (payload: Record<string, any>) => {
  for (const partNumber of PART_NUMBERS) {
    const titleKey = `titre_partie_${partNumber}`;
    if (!hasDescriptionForPartTitle(payload, partNumber)) {
      delete payload[titleKey];
      continue;
    }
    const currentTitleValue = payload[titleKey];
    if (typeof currentTitleValue === "string" && currentTitleValue.trim() !== "") {
      payload[titleKey] = currentTitleValue.trim();
      continue;
    }
    const defaultTitle = previewDefaultsMap[titleKey];
    if (typeof defaultTitle === "string" && defaultTitle.trim() !== "") {
      payload[titleKey] = defaultTitle.trim();
    }
  }
  return payload;
};

const getMissingRequiredFields = (formData: FormData) => {
  const missing: string[] = [];

  if (!isNonEmptyString(formData.get("titre"))) {
    missing.push("titre");
  }
  if (!isNonEmptyString(formData.get("date_debut"))) {
    missing.push("date de début");
  }
  if (!hasUploadedFile(formData, "hero")) {
    missing.push("image de l'en-tête");
  }
  if (getNormalizedSelectedTypeActionValues(formData, typeActionOptions, 7).length === 0) {
    missing.push("type d'action");
  }
  if (!hasAtLeastOnePartContent(formData)) {
    missing.push("au moins une partie (texte ou photo)");
  }

  return missing;
};

// Récupérer les options de type_de_chiffre depuis le type TypeScript généré
let typeDeChiffreOptions: string[] = ["type de chiffre", ...(Array.isArray(ActionsTypeDeChiffreOptions) ? ActionsTypeDeChiffreOptions : Object.values(ActionsTypeDeChiffreOptions))];
let typeActionOptions: string[] = (Array.isArray(ActionsTypeActionOptions)
  ? ActionsTypeActionOptions
  : Object.values(ActionsTypeActionOptions)).map((opt) => String(opt));

// Placeholder partagé (source unique injectée côté serveur depuis `previewDefaults.js`)
const previewPlaceholder: any = {
  ...previewDefaults,
};
// Gestion de la soumission du formulaire côté serveur (création)
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();

    // Détecter si l'utilisateur veut enregistrer en brouillon
    const saveAs = formData.get("save_as")?.toString();
    const discardDraft = formData.get("discard_draft")?.toString() === "true";
    const isAutosave = formData.get("autosave")?.toString() === "true";
    const draftId = formData.get("draft_id")?.toString()?.trim() || "";
    const isBrouillon = saveAs === "brouillon" || isAutosave;

    if (discardDraft) {
      if (draftId) {
        try {
          await Astro.locals.pb.collection("brouillons").delete(draftId);
        } catch (discardErr: any) {
          if (discardErr?.status !== 404) {
            throw discardErr;
          }
        }
      }

      if (isAutosave) {
        return new Response(
          JSON.stringify({ ok: true, discarded: true, draftId: "" }),
          {
            headers: { "Content-Type": "application/json" },
          },
        );
      }

      return Astro.redirect("/creation/actions?success=Brouillon%20supprim%C3%A9");
    }

    if (!isBrouillon) {
      const missingFields = getMissingRequiredFields(formData);
      if (missingFields.length > 0) {
        throw new Error(
          `Informations obligatoires manquantes: ${missingFields.join(", ")}.`,
        );
      }
    }

    if (!isBrouillon) {
      const overLimitPartTexts = getOverLimitPartTextFieldsAfterSubmit(
        formData,
        null,
        70,
      );
      if (overLimitPartTexts.length > 0) {
        throw new Error(buildWordLimitMessage(overLimitPartTexts, 70));
      }
    }

    // Titre (pour les brouillons le titre n'est pas obligatoire)
    const titre = formData.get("titre")?.toString();
    if (!isBrouillon && (!titre || titre.trim() === "")) {
      throw new Error("Le titre est obligatoire");
    }

    // Générer le slug
    const slug = titre ? slugify(titre, { lower: true, strict: true }) : "";

    // Préparer les données pour PocketBase
    const data: any = {};
    const selectedTypeActions = getNormalizedSelectedTypeActionValues(
      formData,
      typeActionOptions,
      7,
    );
    // Première passe: champs texte/JSON (sans fichiers).
    for (const [key, value] of formData.entries()) {
      if (value instanceof File) continue;
      if (
        key === "galerie_photos" ||
        key.startsWith("remove_") ||
        key === "save_as" ||
        key === "publish_action" ||
        key === "draft_id" ||
        key === "autosave"
      ) continue;
      if (key === "type_action") {
        if (isBrouillon) {
          // La collection brouillons ne porte pas ce champ.
          continue;
        }
        try {
          // On protège la donnée: parse JSON, nettoyage, whitelist, limite à 7.
          const parsed = JSON.parse(value.toString());
          data[key] = Array.isArray(parsed)
            ? parsed
              .map((item) => String(item).trim())
              .filter((item) => item && typeActionOptions.includes(item))
              .slice(0, 7)
            : [];
        } catch (e) {
          data[key] = [];
        }
        continue;
      }
      const s = value?.toString?.()?.trim?.() ?? "";
      if (key === "chiffre") {
        // "chiffre" reste numérique si possible, sinon chaîne vide.
        if (s === "") {
          data[key] = "";
        } else {
          const parsedNumber = Number(s);
          data[key] = Number.isFinite(parsedNumber) ? parsedNumber : "";
        }
        continue;
      }
      if (key === "type_de_chiffre" && s === "type de chiffre") {
        data[key] = "";
        continue;
      }
      if (EMPTYABLE_FIELDS.has(key)) {
        data[key] = s;
        continue;
      }
      if (s) data[key] = s;
    }
    if (!isBrouillon) {
      data.type_action = selectedTypeActions;
    }

    // Gérer les fichiers
    if (!isBrouillon && (!Array.isArray(data.type_action) || data.type_action.length === 0)) {
      throw new Error("Au moins un type d'action est obligatoire.");
    }

    const files: any = {};
    // Deuxième passe: fichiers uploadés.
    for (const [key, value] of formData.entries()) {
      if (value instanceof File && value.size > 0) {
        if (key === "galerie_photos") {
          // La galerie accepte plusieurs fichiers.
          if (!files[key]) files[key] = [];
          files[key].push(value);
        } else {
          // Les autres champs image sont mono-fichier.
          files[key] = value;
        }
      }
    }

    // Créer le record
    if (isBrouillon) {
      const draftSlug = slug || "brouillon";
      // On garde type="action" pour réutiliser le même flux de back-office.
      const draftTypeAction = selectedTypeActions[0] ?? "";
      const draftPayload = applyPartTitleRule({
        ...data,
        slug: draftSlug,
        type: "action",
        type_actions: draftTypeAction,
        ...files,
      });
      let savedDraft;
      let isNewDraft = false;
      if (draftId) {
        try {
          savedDraft = await Astro.locals.pb
            .collection("brouillons")
            .update(draftId, draftPayload);
        } catch (draftUpdateErr: any) {
          if (draftUpdateErr?.status !== 404) {
            throw draftUpdateErr;
          }
          isNewDraft = true;
          savedDraft = await Astro.locals.pb
            .collection("brouillons")
            .create(draftPayload);
        }
      } else {
        isNewDraft = true;
        savedDraft = await Astro.locals.pb
          .collection("brouillons")
          .create(draftPayload);
      }

      if (isAutosave) {
        return new Response(
          JSON.stringify({
            ok: true,
            draftId: savedDraft.id,
            slug: draftSlug,
            isNewDraft,
          }),
          {
            headers: { "Content-Type": "application/json" },
          },
        );
      }

      return Astro.redirect(
        `/creation/brouillons/${savedDraft.id}-${draftSlug}?success=${encodeURIComponent("Brouillon créé")}`
      );
    }

    const payload = applyPartTitleRule({ ...data, slug, ...files });
    const newAction = await Astro.locals.pb.collection("actions").create(payload);
    return Astro.redirect(`/creation/actions/${newAction.id}-${slug}`);
  } catch (err) {
    console.error("Erreur lors de la création:", err);
    error = err instanceof Error ? err.message : "Une erreur inconnue est survenue";
  }
}

---

<Layout>
  <ActionEditorShell>
    <Fragment slot="form">
      <ActionForm
        mode="create"
        previewPlaceholder={previewPlaceholder}
        typeDeChiffreOptions={typeDeChiffreOptions}
        typeActionOptions={typeActionOptions}
        error={error}
        uiMode="mobile-wizard"
        initialStep={1}
        recordKey="new"
      />
    </Fragment>
    <Fragment slot="preview">
      <div class="lg:py-20">
        <ActionContent
          action={previewPlaceholder}
          forcePreviewLocationSection={true}
        />
      </div>
    </Fragment>
  </ActionEditorShell>

  <script set:html={`window.__previewData = ${JSON.stringify(previewPlaceholder).replace(/</g, "\\" + "u003c")};`} />
  <script>
    import "../../../scripts/gallery.js";
    import "../../../scripts/gallery-display.js";
  </script>
</Layout>
