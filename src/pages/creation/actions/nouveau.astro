---
import Layout from "../../../layouts/Layout-back-office.astro";
import Action from "../../../components/Action.astro";
import slugify from "slugify";

const id = Astro.locals.pb.authStore.record?.id;
let error: string = "";

// Gestion de la soumission du formulaire côté serveur
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();

    // Vérifier que le titre est fourni
    const titre = formData.get("titre")?.toString();
    if (!titre || titre.trim() === "") {
      throw new Error("Le titre est obligatoire");
    }

    // Générer le slug
    const slug = slugify(titre, { lower: true, strict: true });

    // Préparer les données pour PocketBase
    const data: any = { slug };

    // Récupérer tous les champs texte du formulaire
    for (const [key, value] of formData.entries()) {
      if (value instanceof File) continue; // Gérer les fichiers séparément
      const stringValue = value.toString().trim();
      if (stringValue !== "") {
        data[key] = stringValue;
      }
    }

    // Gérer les fichiers
    const files: any = {};
    for (const [key, value] of formData.entries()) {
      if (value instanceof File && value.size > 0) {
        if (key === "galerie_photos") {
          // Pour la galerie, collecter tous les fichiers dans un tableau
          if (!files[key]) {
            files[key] = [];
          }
          files[key].push(value);
        } else {
          // Pour les autres fichiers (images uniques)
          files[key] = value;
        }
      }
    }

    // Créer l'action dans PocketBase
    const newAction = await Astro.locals.pb.collection("actions").create({
      ...data,
      ...files,
    });

    // Rediriger vers la page d'édition avec un message de succès
    return Astro.redirect(
      `/creation/actions/${newAction.id}-${slug}?success=Action créée avec succès`,
    );
  } catch (err) {
    console.error("Erreur lors de la création:", err);
    // En cas d'erreur, on continue et affiche le formulaire avec l'erreur
    error =
      err instanceof Error ? err.message : "Une erreur inconnue est survenue";
  }
}
---

<Layout>
  <div class="flex h-fit w-full">
    <div class="h-screen w-1/3 bg-accent sticky left-0 top-0 flex items-center justify-center">
      <div class="text-white text-center px-4">
        <h1 class="text-3xl font-bold mb-4">Créer une nouvelle action</h1>
        <p class="mb-6">
          Remplissez le formulaire pour créer une nouvelle action.
        </p>
        
        <div class="text-left">
          <h3 class="text-lg font-semibold mb-3">Guide rapide :</h3>
          <ul class="space-y-2 text-sm">
            <li><strong>1. Titre et date :</strong> Commencez par le titre principal et la date.</li>
            <li><strong>2. Image hero :</strong> Ajoutez une belle image d'en-tête.</li>
            <li><strong>3. Contenu :</strong> Rédigez les 3 sections avec textes et photos.</li>
            <li><strong>4. Détails :</strong> Lieu, chiffres et bénéficiaires.</li>
            <li><strong>5. Remerciements :</strong> Section de remerciements.</li>
            <li><strong>6. Galerie :</strong> Photos supplémentaires.</li>
            <li><strong>7. Publier :</strong> Cliquez sur "Créer l'action".</li>
          </ul>
        </div>

        <div class="text-left mt-6 px-4">
          <h3 class="text-lg font-semibold mb-2">Astuces</h3>
          <p class="text-sm mb-1">
            Vous n'êtes pas obligé de remplir tous les champs.
          </p>
          <p class="text-sm">
            Seuls les champs remplis seront enregistrés, les autres seront
            ignorés.
          </p>
        </div>

        {error && <p class="text-red-300 mb-4 mt-4">{error}</p>}
      </div>
    </div>
    <div class="max-w-2/3 ml-auto p-8">
      <Action />
    </div>
  </div>
</Layout>
