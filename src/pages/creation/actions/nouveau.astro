---
import Layout from "../../../layouts/Layout-back-office.astro";
import ActionContent from "../../../components/ActionContent.astro";
import slugify from "slugify";
import previewUrl from "../../../scripts/preview.js?url";
import galleryUrl from "../../../scripts/gallery.js?url";
import galleryDisplayUrl from "../../../scripts/gallery-display.ts?url";
import imageIcon from "../../../assets/image-icon.svg";
import { ActionsTypeDeChiffreOptions } from "../../../pocketbase-types";

const id = Astro.locals.pb.authStore.record?.id;
let error: string = "";

// Récupérer les options : priorité aux valeurs utilisées en base, sinon fallback sur l'enum générée.
let typeDeChiffreOptions: string[] = Object.values(ActionsTypeDeChiffreOptions);
try {
  const records: any[] = await Astro.locals.pb
    .collection("actions")
    .getFullList(100);
  const values = Array.from(
    new Set(records.map((r: any) => r?.type_de_chiffre).filter(Boolean)),
  );
  if (values.length > 0) typeDeChiffreOptions = values;
} catch (e) {
  // probable manque de permissions : on laisse le fallback sur l'enum
}

// Placeholder utilisé pour rendre toutes les sections côté serveur afin que le client puisse hydrater la prévisualisation
const placeholderImg =
  "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='800' height='400'><rect width='100%' height='100%' fill='%23e5e7eb'/><text x='50%' y='50%' dominant-baseline='middle' text-anchor='middle' fill='%23888' font-size='24'>Image</text></svg>";
const previewPlaceholder: any = {
  titre: "Titre de l'action — Exemple: Nettoyage de parc",
  sous_titre: "Sous-titre d'exemple pour présenter rapidement l'action",
  date_debut: "2026-03-01",
  date_fin: "2026-03-02",
  description_hero: "Une courte description de l'image hero.",
  hero: placeholderImg,
  titre_partie_1: "Présentation",
  texte_partie_1:
    "Court paragraphe d'exemple expliquant la première partie.\nDeuxième ligne d'exemple.",
  photo_partie_1: placeholderImg,
  description_photo_partie_1: "Description de la photo partie 1",
  nom_lieu: "Salle communautaire Exemple",
  adresse_lieu: "12 rue Exemple, 75000 Ville",
  lien_lieu: "https://maps.google.com/",
  chiffre: "150",
  type_de_chiffre: typeDeChiffreOptions[0] ?? "dépenses",
  beneficiaire: "Association Exemple",
  titre_partie_2: "Activités",
  texte_partie_2: "Texte d'exemple pour la partie 2.",
  photo_partie_2: placeholderImg,
  description_photo_partie_2: "Description photo partie 2",
  titre_partie_3: "Résultats",
  texte_partie_3: "Texte d'exemple pour la partie 3.",
  photo_partie_3: placeholderImg,
  description_photo_partie_3: "Description photo partie 3",
  titre_remerciements: "Remerciements",
  description_remerciements: "Merci aux bénévoles et partenaires.",
  galerie_photos: [placeholderImg, placeholderImg, placeholderImg],
};

// Gestion de la soumission du formulaire côté serveur
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();

    // Vérifier que le titre est fourni
    const titre = formData.get("titre")?.toString();
    if (!titre || titre.trim() === "") {
      throw new Error("Le titre est obligatoire");
    }

    // Générer le slug
    const slug = slugify(titre, { lower: true, strict: true });

    // Préparer les données pour PocketBase
    const data: any = { slug };

    // Récupérer tous les champs texte du formulaire
    for (const [key, value] of formData.entries()) {
      if (value instanceof File) continue; // Gérer les fichiers séparément
      const stringValue = value.toString().trim();
      if (stringValue !== "") {
        data[key] = stringValue;
      }
    }

    // Gérer les fichiers
    const files: any = {};
    for (const [key, value] of formData.entries()) {
      if (value instanceof File && value.size > 0) {
        if (key === "galerie_photos") {
          // Pour la galerie, collecter tous les fichiers dans un tableau
          if (!files[key]) {
            files[key] = [];
          }
          files[key].push(value);
        } else {
          // Pour les autres fichiers (images uniques)
          files[key] = value;
        }
      }
    }

    // Ensure we don't accidentally send client-side gallery JSON/data-URLs
    // to PocketBase. For creation we rely on uploaded File objects in `files.galerie_photos`.
    if (Object.prototype.hasOwnProperty.call(data, 'galerie_photos')) {
      delete data.galerie_photos;
    }

    // Créer l'action dans PocketBase
    const newAction = await Astro.locals.pb.collection("actions").create({
      ...data,
      ...files,
    });

    // Rediriger vers la page d'édition avec un message de succès
    return Astro.redirect(
      `/creation/actions/${newAction.id}-${slug}?success=Action créée avec succès`,
    );
  } catch (err) {
    console.error("Erreur lors de la création:", err);
    // En cas d'erreur, on continue et affiche le formulaire avec l'erreur
    error =
      err instanceof Error ? err.message : "Une erreur inconnue est survenue";
  }
}
---

<Layout>
  <div class="flex h-fit w-full">
    <div class="w-1/3">
      <div class="h-[105dvh] bg-accent pb-24 sticky left-0 top-0 overflow-auto p-6">
        <form
          id="leftForm"
          class="space-y-8 text-accent"
          method="POST"
          enctype="multipart/form-data"
        >
          <h1 class="text-3xl font-bold mb-8 mt-32 text-white">
            Créer une nouvelle action
          </h1>
          {error && <p class="text-red-300 mb-4">{error}</p>}

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <label class="block text-sm font-medium mb-1">Titre</label>
            <input
              data-prop="titre"
              id="input_titre"
              name="titre_local"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              placeholder="Titre de l'action"
            />
            <input type="hidden" name="titre" id="hidden_titre" />

            <label class="block text-sm font-medium mb-1">Sous-titre</label>
            <input
              data-prop="sous_titre"
              id="input_sous_titre"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              placeholder="Sous-titre"
            />
            <input type="hidden" name="sous_titre" id="hidden_sous_titre" />

            <div class="flex gap-4">
              <div class="w-1/2">
                <label class="text-sm">Date début</label>
                <input
                  data-prop="date_debut"
                  id="input_date_debut"
                  type="date"
                  class="border rounded px-2 py-1 w-full text-black bg-base-100"
                />
                <input type="hidden" name="date_debut" id="hidden_date_debut" />
              </div>
              <div class="w-1/2">
                <label class="text-sm">Date fin</label>
                <input
                  data-prop="date_fin"
                  id="input_date_fin"
                  type="date"
                  class="border rounded px-2 py-1 w-full text-black bg-base-100"
                />
                <input type="hidden" name="date_fin" id="hidden_date_debut" />
              </div>
            </div>
          </div>

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <label class="block text-sm font-medium mb-1">Image de l'en-tête</label>
            <label
              for="input_hero_file"
              class="cursor-pointer w-full h-40 border-2 border-dashed rounded bg-base-100 flex items-center justify-center text-gray-500"
            >
              <input
                data-prop-file="hero"
                type="file"
                name="hero"
                id="input_hero_file"
                accept="image/*"
                class="hidden"
              />
              <div
                class="flex flex-col items-center text-center pointer-events-none"
              >
                <img src={imageIcon.src} alt="Icone image" class="h-16 w-16 " style="filter:grayscale(100%) brightness(0.5); opacity:0.3;">
                <span class="text-sm">Cliquez ou glissez l'image ici</span>
                <span class="text-xs text-gray-400">PNG, JPG, GIF</span>
              </div>
            </label>
            <div id="preview_hero" class="mt-2"></div>
            <label class="block text-sm font-medium mt-2 mb-1">Description image de l'en-tête</label>
            <textarea
              data-prop="description_hero"
              id="input_description_hero"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              rows="2"></textarea>
            <input
              type="hidden"
              name="description_hero"
              id="hidden_description_hero"
            />
          </div>

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <h4 class="font-semibold">Partie 1</h4>
            <input
              data-prop="titre_partie_1"
              id="input_titre_partie_1"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Titre partie 1"
            />
            <input
              type="hidden"
              name="titre_partie_1"
              id="hidden_titre_partie_1"
            />
            <label class="block text-sm font-medium mt-2">Texte partie 1</label>
            <textarea
              data-prop="texte_partie_1"
              id="input_texte_partie_1"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              rows="4"></textarea>
            <input
              type="hidden"
              name="texte_partie_1"
              id="hidden_texte_partie_1"
            />
            <label class="block text-sm font-medium mt-2">Photo partie 1</label>
            <label
              for="input_photo_partie_1"
              class="cursor-pointer w-full h-36 border-2 border-dashed rounded bg-base-100 flex items-center justify-center text-gray-500"
            >
              <input
                data-prop-file="photo_partie_1"
                type="file"
                name="photo_partie_1"
                id="input_photo_partie_1"
                accept="image/*"
                class="hidden"
              />
              <div
                class="flex flex-col items-center text-center pointer-events-none"
              >
                <img src={imageIcon.src} alt="Icone image" class="h-16 w-16 " style="filter:grayscale(100%) brightness(0.5); opacity:0.3;">
                <span class="text-sm">Ajouter une photo</span>
              </div>
            </label>
            <div id="preview_photo_partie_1" class="mt-2"></div>
            <label class="block text-sm font-medium mt-2">Description photo partie 1</label>
            <input
              data-prop="description_photo_partie_1"
              id="input_description_photo_partie_1"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
            />
            <input
              type="hidden"
              name="description_photo_partie_1"
              id="hidden_description_photo_partie_1"
            />
          </div>

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <h4 class="font-semibold">Lieu / Chiffres / Bénéficiaires</h4>
            <label class="block text-sm font-medium mt-2"
              >Nom du lieu (max 30 caractères)</label
            >
            <input
              data-prop="nom_lieu"
              id="input_nom_lieu"
              name="nom_lieu_local"
              maxlength="30"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Nom du lieu"
            />
            <input type="hidden" name="nom_lieu" id="hidden_nom_lieu" />
            <label class="block text-sm font-medium mt-2"
              >Adresse du lieu (max 30 caractères)</label
            >
            <input
              data-prop="adresse_lieu"
              id="input_adresse_lieu"
              maxlength="30"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Adresse"
            />
            <input type="hidden" name="adresse_lieu" id="hidden_adresse_lieu" />
            <input
              data-prop="lien_lieu"
              id="input_lien_lieu"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Lien Google Maps"
            />
            <input type="hidden" name="lien_lieu" id="hidden_lien_lieu" />
            <div class="flex gap-2 mt-2">
              <input
                data-prop="chiffre"
                id="input_chiffre"
                type="number"
                class="border rounded px-2 py-1 w-1/2 text-black bg-base-100"
                placeholder="Chiffre"
              />
              <select
                data-prop="type_de_chiffre"
                id="input_type_de_chiffre"
                class="border rounded px-2 py-1 w-1/2 text-black bg-base-100"
              >
                <option value="">Type</option>
                {
                  typeDeChiffreOptions.map((opt) => (
                    <option value={opt}>{opt}</option>
                  ))
                }
              </select>
            </div>
            <input type="hidden" name="chiffre" id="hidden_chiffre" />
            <input
              type="hidden"
              name="type_de_chiffre"
              id="hidden_type_de_chiffre"
            />
            <input
              data-prop="beneficiaire"
              id="input_beneficiaire"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Bénéficiaire"
            />
            <input type="hidden" name="beneficiaire" id="hidden_beneficiaire" />
          </div>

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <h4 class="font-semibold">Partie 2</h4>
            <input
              data-prop="titre_partie_2"
              id="input_titre_partie_2"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Titre partie 2"
            />
            <input
              type="hidden"
              name="titre_partie_2"
              id="hidden_titre_partie_2"
            />
            <label class="block text-sm font-medium mt-2">Texte partie 2</label>
            <textarea
              data-prop="texte_partie_2"
              id="input_texte_partie_2"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              rows="4"></textarea>
            <input
              type="hidden"
              name="texte_partie_2"
              id="hidden_texte_partie_2"
            />
            <label class="block text-sm font-medium mt-2">Photo partie 2</label>
            <label
              for="input_photo_partie_2"
              class="cursor-pointer w-full h-36 border-2 border-dashed rounded bg-base-100 flex items-center justify-center text-gray-500"
            >
              <input
                data-prop-file="photo_partie_2"
                type="file"
                name="photo_partie_2"
                id="input_photo_partie_2"
                accept="image/*"
                class="hidden"
              />
              <div
                class="flex flex-col items-center text-center pointer-events-none"
              >
                <img src={imageIcon.src} alt="Icone image" class="h-16 w-16 " style="filter:grayscale(100%) brightness(0.5); opacity:0.3;">
                <span class="text-sm">Ajouter une photo</span>
              </div>
            </label>
            <div id="preview_photo_partie_2" class="mt-2"></div>
            <input
              data-prop="description_photo_partie_2"
              id="input_description_photo_partie_2"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
            />
            <input
              type="hidden"
              name="description_photo_partie_2"
              id="hidden_description_photo_partie_2"
            />
          </div>

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <h4 class="font-semibold">Partie 3</h4>
            <input
              data-prop="titre_partie_3"
              id="input_titre_partie_3"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Titre partie 3"
            />
            <input
              type="hidden"
              name="titre_partie_3"
              id="hidden_titre_partie_3"
            />
            <label class="block text-sm font-medium mt-2">Texte partie 3</label>
            <textarea
              data-prop="texte_partie_3"
              id="input_texte_partie_3"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              rows="4"></textarea>
            <input
              type="hidden"
              name="texte_partie_3"
              id="hidden_texte_partie_3"
            />
            <label class="block text-sm font-medium mt-2">Photo partie 3</label>
            <label
              for="input_photo_partie_3"
              class="cursor-pointer w-full h-36 border-2 border-dashed rounded bg-base-100 flex items-center justify-center text-gray-500"
            >
              <input
                data-prop-file="photo_partie_3"
                type="file"
                name="photo_partie_3"
                id="input_photo_partie_3"
                accept="image/*"
                class="hidden"
              />
              <div
                class="flex flex-col items-center text-center pointer-events-none"
              >
                <img src={imageIcon.src} alt="Icone image" class="h-16 w-16 " style="filter:grayscale(100%) brightness(0.5); opacity:0.3;">
                <span class="text-sm">Ajouter une photo</span>
              </div>
            </label>
            <div id="preview_photo_partie_3" class="mt-2"></div>
            <input
              data-prop="description_photo_partie_3"
              id="input_description_photo_partie_3"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
            />
            <input
              type="hidden"
              name="description_photo_partie_3"
              id="hidden_description_photo_partie_3"
            />
          </div>

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <h4 class="font-semibold">Remerciements</h4>
            <input
              data-prop="titre_remerciement"
              id="input_titre_remerciement"
              class="w-full border rounded px-2 py-1 mt-2 text-black bg-base-100"
              placeholder="Titre remerciements"
            />
            <input
              type="hidden"
              name="titre_remerciement"
              id="hidden_titre_remerciement"
            />
            <label class="block text-sm font-medium mt-2"
              >Description remerciements</label
            >
            <textarea
              data-prop="description_remerciement"
              id="input_description_remerciement"
              class="w-full border rounded px-2 py-1 text-black bg-base-100"
              rows="3"></textarea>
            <input
              type="hidden"
              name="description_remerciement"
              id="hidden_description_remerciement"
            />
          </div>

          <div class="p-4 bg-base-200 rounded-lg border border-base-300 space-y-4">
            <label class="block text-sm font-medium mb-1">Galerie (max 8)</label>
            <label
              for="input_galerie_photos"
              class="cursor-pointer w-full h-36 border-2 border-dashed rounded bg-base-100 flex items-center justify-center text-gray-500"
            >
              <input
                data-prop-file="galerie_photos"
                type="file"
                name="galerie_photos"
                id="input_galerie_photos"
                accept="image/*"
                multiple
                class="hidden"
              />
              <div
                class="flex flex-col items-center text-center pointer-events-none"
              >
                <img src={imageIcon.src} alt="Icone image" class="h-16 w-16 " style="filter:grayscale(100%) brightness(0.5); opacity:0.3;">
                <span class="text-sm">Cliquez ou glissez vos photos</span>
                <span class="text-xs text-gray-400">Jusqu'à 8 images</span>
              </div>
            </label>
            <input type="hidden" id="hidden_galerie_photos" name="galerie_photos" />
            <input type="hidden" id="hidden_remove_galerie_photos" name="remove_galerie_photos" />
            <div id="galleryExisting" class="mt-2 grid grid-cols-4 gap-2"></div>
            <div id="gallerySelected" class="mt-2 grid grid-cols-4 gap-2"></div>
          </div>

          <div class="pt-4">
            <button
              type="submit"
              class="bg-base-100 text-accent px-4 py-2 rounded w-full"
              >Créer l'action</button
            >
          </div>
        </form>
      </div>
    </div>

    <div class="w-2/3 px-8">
      <ActionContent action={previewPlaceholder} />
    </div>
  </div>
<script
  set:html={`window.__previewData = ${JSON.stringify(previewPlaceholder).replace(/</g, "\\u003c")};`}
></script>

<script type="module" src={previewUrl}></script>
<script type="module" src={galleryUrl}></script>
<script type="module" src={galleryDisplayUrl}></script>

</Layout>
