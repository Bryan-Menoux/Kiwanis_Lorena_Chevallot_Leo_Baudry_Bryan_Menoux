---
import Layout from "../../../layouts/Layout-back-office.astro";
import slugify from "slugify";
import ActionsSearch from "../../../components/ActionsSearch.astro";
import SearchActions from "../../../components/SearchActions.astro";
import utilUrl from "../../../utils/utilitaires.js?url";
import { formatDateShort } from "../../../utils/utilitaires.js";
import { ActionsTypeActionOptions } from "../../../pocketbase-types";

interface ActionItem {
  id: string;
  titre: string;
  slug: string;
  source: "action" | "brouillon";
  sous_titre?: string;
  hero?: string;
  updated?: string;
  date_debut?: string;
  date_fin?: string;
  beneficiaire?: string;
  type_de_chiffre?: string;
  type_action?: string[];
}

const actionsRaw: any[] = await Astro.locals.pb
  .collection("actions")
  .getFullList(200, { sort: "-updated" });
const brouillonsRaw: any[] = await Astro.locals.pb
  .collection("brouillons")
  .getFullList(200, {
    sort: "-updated",
    filter: 'type = "action"',
  });

const actions: ActionItem[] = [
  ...actionsRaw.map((a) => ({
  id: a.id,
  titre: a.titre,
  slug: slugify(a.titre || "", { lower: true, strict: true }),
  source: "action" as const,
  sous_titre: a.sous_titre,
  hero: a.hero,
  updated: a.updated,
  date_debut: a.date_debut,
  date_fin: a.date_fin,
  beneficiaire: a.beneficiaire,
  type_de_chiffre: a.type_de_chiffre,
  type_action: a.type_action,
  })),
  ...brouillonsRaw.map((b) => ({
    id: b.id,
    titre: b.titre || "Brouillon sans titre",
    slug: slugify(b.titre || "brouillon", { lower: true, strict: true }),
    source: "brouillon" as const,
    sous_titre: b.sous_titre,
    hero: b.hero,
    updated: b.updated,
    date_debut: b.date_debut,
    date_fin: b.date_fin,
    beneficiaire: b.beneficiaire,
    type_de_chiffre: b.type_de_chiffre,
    type_action: [],
  })),
].sort(
  (a, b) => new Date(b.updated || 0).getTime() - new Date(a.updated || 0).getTime(),
);

const stats = { total: actions.length };

// build filter options
const yearSet = new Set<string>();
actions.forEach((a) => {
  const d = a.date_debut || a.date_fin;
  if (d) {
    const y = new Date(d).getFullYear().toString();
    yearSet.add(y);
  }
});
const yearOptions = Array.from(yearSet).sort((a, b) => b.localeCompare(a));
const typeOptions = Object.values(ActionsTypeActionOptions);

// Lecture des query params pour initialiser les filtres
const params = Astro.url.searchParams;
const q = (params.get("q") || "").trim();

const allActions = actions;
---

<Layout>
  <div class="container mx-auto px-6 py-12 my-20">
    <div
      class="flex flex-col md:flex-row justify-between items-start gap-6 mb-8"
    >
      <div class="flex-1">
        <h1 class="text-5xl md:text-6xl font-extrabold leading-tight">
          Actions
        </h1>
        <p class="text-base text-base-content/70 mt-2">
          Gérez vos actions — rechercher, filtrer et modifier rapidement.
        </p>
      </div>
      <div class="flex items-center gap-4">
        <a href="/actions" class="btn btn-ghost">Voir le site</a>
        <a
          href="/creation/actions/nouveau"
          class="btn btn-accent btn-md shadow-lg rounded-full"
          >Créer une action</a
        >
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 items-start mb-8">
      <div
        class="p-4 bg-base-100 rounded-lg h-full max-h-full flex items-center gap-4 border border-base-300"
      >
        <p class="text-sm text-base-content/70">
          Nombre d'actions total - <span class="text-accent font-bold text-2xl!"
            >{stats.total}</span
          >
        </p>
      </div>
      <div class="md:col-span-3 flex items-center gap-4">
        <SearchActions
          value={q}
          yearOptions={yearOptions}
          typeOptions={typeOptions}
        />
        <select id="sort-select" class="select select-bordered w-44">
          <option value="updated_desc">Récent → Ancien</option>
          <option value="updated_asc">Ancien → Récent</option>
        </select>
      </div>
    </div>

    <div id="pages-container" class="mb-8" data-initial-search={q}>
      <!-- rendu initial fait côté serveur -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          actions.map((a) => (
            <div
              class="bg-base-100 border border-base-300 rounded-xl p-6 shadow-sm min-h-35 flex flex-col justify-between"
              data-action-id={a.id}
              data-action-slug={a.slug}
              data-source={a.source}
              data-title={a.titre}
              data-type={a.type_de_chiffre}
            >
              <div>
                <div class="flex items-start">
                  <h3 class="text-2xl md:text-2xl font-bold leading-tight mr-4 truncate">
                    {a.titre}
                  </h3>
                  {
                    a.source === "brouillon" && (
                      <span class="badge badge-secondary text-secondary-content shrink-0">Brouillon</span>
                    )
                  }
                </div>
                {
                  (a.sous_titre || a.beneficiaire) ? (
                    <div class="mt-2 space-y-1.5">
                      {a.sous_titre && (
                        <div>
                          <p class="text-[11px] uppercase tracking-wide text-base-content/45">
                            Sous-titre
                          </p>
                          <p class="text-sm text-base-content/75 truncate leading-tight">
                            {a.sous_titre}
                          </p>
                        </div>
                      )}
                      {a.beneficiaire && (
                        <div>
                          <p class="text-[11px] uppercase tracking-wide text-base-content/45">
                            Bénéficiaire
                          </p>
                          <p class="text-sm text-base-content/75 leading-tight">
                            {a.beneficiaire}
                          </p>
                        </div>
                      )}
                      <div>
                        <p class="text-[11px] uppercase tracking-wide text-base-content/45">
                          Mis à jour
                        </p>
                        <p class="text-xs text-base-content/65 leading-tight">
                          {a.updated ? formatDateShort(a.updated) : ""}
                        </p>
                      </div>
                    </div>
                  ) : (
                    <div class="mt-2 space-y-1">
                      <p class="text-[11px] uppercase tracking-wide text-base-content/45">
                        Mis à jour
                      </p>
                      <p class="text-xs text-base-content/65 leading-tight">
                        {a.updated ? formatDateShort(a.updated) : ""}
                      </p>
                    </div>
                  )
                }
              </div>
              <div class="flex items-center justify-end gap-3">
                {
                  a.source === "action" ? (
                    <a
                      class="text-sm text-base-content hover:underline"
                      href={`/actions/${a.id}-${a.slug}`}
                    >
                      Voir
                    </a>
                  ) : (
                    <a
                      class="text-sm text-base-content hover:underline"
                      href={`/creation/brouillons/${a.id}-${a.slug}`}
                    >
                      Voir
                    </a>
                  )
                }
                <a
                  class="btn btn-sm btn-outline rounded-full"
                  href={`/creation/actions/edit/${a.id}-${a.slug}`}
                >
                  Modifier
                </a>
                {
                  a.source === "brouillon" && (
                    <form
                      method="POST"
                      action={`/creation/actions/edit/${a.id}-${a.slug}`}
                      class="inline"
                    >
                      <input type="hidden" name="publish_action" value="true" />
                      <button
                        type="submit"
                        class="btn btn-sm btn-accent rounded-full"
                      >
                        Publier
                      </button>
                    </form>
                  )
                }
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</Layout>

<script type="module" src={utilUrl}></script>
<script define:vars={{ allActions, q }}>
  const actions = allActions;
  let currentSearch = q || "";
  let currentBeneficiary = "";

  function formatDate(d) {
    if (!d) return "";
    if (
      typeof window !== "undefined" &&
      window.dateUtils &&
      typeof window.dateUtils.formatDateShort === "function"
    ) {
      try {
        return window.dateUtils.formatDateShort(d);
      } catch (e) {}
    }
    return new Date(d).toLocaleDateString("fr-FR", {
      day: "numeric",
      month: "short",
      year: "numeric",
    });
  }

  function getViewUrl(id, slug, source) {
    if (source === "brouillon") return `/creation/brouillons/${id}-${slug}`;
    return `/actions/${id}-${slug}`;
  }
  function getEditUrl(id, slug) {
    return `/creation/actions/edit/${id}-${slug}`;
  }

  function filterActions(search, beneficiary, year, type) {
    let filtered = actions.slice();
    if (typeof console !== "undefined" && console.debug)
      console.debug("filterActions input", { search, beneficiary, year, type });
    if (beneficiary && beneficiary !== "")
      filtered = filtered.filter((a) =>
        (a.beneficiaire || "")
          .toLowerCase()
          .includes(beneficiary.toLowerCase()),
      );
    if (search && search !== "")
      filtered = filtered.filter((a) =>
        (a.titre || "").toLowerCase().includes(search.toLowerCase()),
      );
    if (year && year !== "") {
      filtered = filtered.filter((a) => {
        const d = a.date_debut || a.date_fin;
        if (!d) return false;
        return new Date(d).getFullYear().toString() === year;
      });
    }
    if (type && type !== "") {
      filtered = filtered.filter((a) => {
        // type may come from a.type_action or type_de_chiffre, adjust as necessary
        const arr = a.type_action || [];
        return arr.includes(type);
      });
    }
    if (typeof console !== "undefined" && console.debug)
      console.debug("filterActions result count", filtered.length);
    return filtered;
  }

  function renderActions(list) {
    const container = document.getElementById("pages-container");
    if (!container) return;
    if (list.length === 0) {
      container.innerHTML = `<div class="text-center py-12"><p class="text-base-content/60 mb-4">Aucune action trouvée</p></div>`;
      return;
    }
    const html = `
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          ${list
            .map(
              (a) => `
                    <div class="card bg-base-100 border" data-action-id="${a.id}" data-action-slug="${a.slug}" data-source="${a.source}">
              <div class="card-body p-4">
                <div class="flex justify-between items-start mb-2">
                  <h3 class="card-title text-lg truncate">${a.titre}</h3>${a.source === 'brouillon' ? '<span class="badge badge-secondary text-secondary-content">Brouillon</span>' : ''}
                  </div>
                  ${
                    (a.sous_titre && String(a.sous_titre).trim() !== '') ||
                    (a.beneficiaire && String(a.beneficiaire).trim() !== '')
                      ? `
                  <div class="mt-2 space-y-1.5">
                    ${a.sous_titre ? `<div><p class="text-[11px] uppercase tracking-wide text-base-content/45">Sous-titre</p><p class="text-sm text-base-content/75 truncate leading-tight">${a.sous_titre}</p></div>` : ''}
                    ${a.beneficiaire ? `<div><p class="text-[11px] uppercase tracking-wide text-base-content/45">Bénéficiaire</p><p class="text-sm text-base-content/75 leading-tight">${a.beneficiaire}</p></div>` : ''}
                    <div><p class="text-[11px] uppercase tracking-wide text-base-content/45">Mis à jour</p><p class="text-xs text-base-content/65 leading-tight">${a.updated ? formatDate(a.updated) : ""}</p></div>
                  </div>
                  `
                      : `
                  <div class="mt-2 space-y-1">
                    <p class="text-[11px] uppercase tracking-wide text-base-content/45">Mis à jour</p>
                    <p class="text-xs text-base-content/65 leading-tight">${a.updated ? formatDate(a.updated) : ""}</p>
                  </div>
                  `
                  }
                  <div class="card-actions justify-end mt-4">
                    <a class="btn btn-sm" href="${getViewUrl(a.id, a.slug, a.source)}">Voir</a>
                                <a class="btn btn-sm" href="${getEditUrl(a.id, a.slug)}">Modifier</a>
                                ${a.source === 'brouillon' ? `<form method="POST" action="${getEditUrl(a.id, a.slug)}" class="inline"><input type="hidden" name="publish_action" value="true" /><button type="submit" class="btn btn-sm btn-accent">Publier</button></form>` : ''}
                </div>
              </div>
            </div>
				`,
            )
            .join("")}
			</div>
		`;
    container.innerHTML = html;
  }

  document.addEventListener("DOMContentLoaded", () => {
    const pagesContainer = document.getElementById("pages-container");
    let currentSearch = pagesContainer?.dataset.initialSearch || "";
    let currentYear = "";
    let currentType = "";

    // Listen for the reusable search component events
    const sortSelect = document.getElementById("sort-select");

    function applyAndRender() {
      let filtered = filterActions(currentSearch, currentBeneficiary, currentYear, currentType);
      const sort =
        sortSelect instanceof HTMLSelectElement
          ? sortSelect.value
          : "updated_desc";
      filtered.sort((a, b) => {
        const da = new Date(a.updated || 0).getTime();
        const db = new Date(b.updated || 0).getTime();
        return sort === "updated_asc" ? da - db : db - da;
      });
      renderActions(filtered);
    }

    function handleFilters(d) {
      currentSearch = d.search || "";
      currentBeneficiary = d.beneficiary || "";
      currentYear = d.year || "";
      currentType = d.type || "";
      applyAndRender();
    }

    document.addEventListener("actions-filter-change", (ev) => {
      handleFilters(ev.detail || {});
    });
    document.addEventListener("search-actions-change", (ev) => {
      handleFilters(ev.detail || {});
    });

    // initial render based on server-side params
    if (sortSelect instanceof HTMLSelectElement)
      sortSelect.addEventListener("change", applyAndRender);
    applyAndRender();

    // No individual delete buttons on this page; bulk delete handled by the form
  });
</script>
