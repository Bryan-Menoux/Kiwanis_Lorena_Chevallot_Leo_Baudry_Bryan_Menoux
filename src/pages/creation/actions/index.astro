---
import Layout from "../../../layouts/Layout-back-office.astro";
import slugify from "slugify";
import ActionsSearch from "../../../components/ActionsSearch.astro";
import FormSubmitOverlay from "../../../components/FormSubmitOverlay.astro";
import { formatDateShort } from "../../../utils/utilitaires.js";
import { ActionsTypeActionOptions } from "../../../pocketbase-types";

interface ActionItem {
  id: string;
  titre: string;
  slug: string;
  source: "action" | "brouillon";
  sous_titre?: string;
  hero?: string;
  updated?: string;
  date_debut?: string;
  date_fin?: string;
  beneficiaire?: string;
  type_de_chiffre?: string;
  type_action?: string[];
}

const actionsRaw: any[] = await Astro.locals.pb
  .collection("actions")
  .getFullList(200, { sort: "-updated" });
const brouillonsRaw: any[] = await Astro.locals.pb
  .collection("brouillons")
  .getFullList(200, {
    sort: "-updated",
    filter: 'type = "action"',
  });

const actions: ActionItem[] = [
  ...actionsRaw.map((a) => ({
    id: a.id,
    titre: a.titre,
    slug: slugify(a.titre || "", { lower: true, strict: true }),
    source: "action" as const,
    sous_titre: a.sous_titre,
    hero: a.hero,
    updated: a.updated,
    date_debut: a.date_debut,
    date_fin: a.date_fin,
    beneficiaire: a.beneficiaire,
    type_de_chiffre: a.type_de_chiffre,
    type_action: a.type_action,
  })),
  ...brouillonsRaw.map((b) => ({
    id: b.id,
    titre: b.titre || "Brouillon sans titre",
    slug: slugify(b.titre || "brouillon", { lower: true, strict: true }),
    source: "brouillon" as const,
    sous_titre: b.sous_titre,
    hero: b.hero,
    updated: b.updated,
    date_debut: b.date_debut,
    date_fin: b.date_fin,
    beneficiaire: b.beneficiaire,
    type_de_chiffre: b.type_de_chiffre,
    type_action: [],
  })),
].sort(
  (a, b) =>
    new Date(b.updated || 0).getTime() - new Date(a.updated || 0).getTime(),
);

const stats = { total: actions.length };

// Construire les options de filtres
const yearSet = new Set<string>();
actions.forEach((a) => {
  const d = a.date_debut || a.date_fin;
  if (d) {
    const y = new Date(d).getFullYear().toString();
    yearSet.add(y);
  }
});
const yearOptions = Array.from(yearSet).sort((a, b) => b.localeCompare(a));
const typeOptions = Object.values(ActionsTypeActionOptions);

// Lecture des paramètres de requête pour initialiser les filtres
const params = Astro.url.searchParams;
const q = (params.get("q") || "").trim();

const allActions = actions;
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    <div
      class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between"
    >
      <div class="mb-0">
        <h1
          class="mb-3 text-3xl font-bold text-accent font-poppins md:text-4xl"
        >
          Actions
        </h1>
        <p class="text-base text-base-content/70 md:text-lg">
          Gérez vos actions, recherchez, filtrez et modifiez rapidement.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-3 lg:justify-end">
        <a href="/actions" class="btn btn-border btn-sm rounded-full md:btn-md"
          >Voir le site</a
        >
        <a
          href="/creation/actions/nouveau"
          class="btn btn-accent btn-sm rounded-full md:btn-md"
          >Creer une action</a
        >
      </div>
    </div>

    <div class="grid grid-cols-1 gap-4 mb-12">
      <div class="card bg-base-100 shadow-md">
        <div class="card-body text-center p-4">
          <div class="text-4xl! font-bold text-base-content">{stats.total}</div>
          <div class="text-base-content">Actions</div>
        </div>
      </div>
    </div>

    <div
      class="card mb-8 rounded-2xl border border-base-300 bg-base-100 shadow-sm"
    >
      <div class="card-body p-4 md:p-6">
        <div class="mb-4">
          <h2 class="card-title text-2xl">Rechercher</h2>
          <p class="mt-1 text-base-content/60">
            Filtrez rapidement vos actions puis triez l'affichage.
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <div class="w-full">
            <p class="mb-2 font-medium text-base-content/70">Filtres</p>
            <ActionsSearch
              value={q}
              yearOptions={yearOptions}
              typeOptions={typeOptions}
              embedded={true}
            >
              <label
                slot="secondary-extra"
                class="form-control w-full gap-1"
                for="sort-select"
              >
                <span
                  class="text-xs font-medium uppercase tracking-wide text-base-content/60"
                  >Trier par date</span
                >
                <select id="sort-select" class="select select-bordered w-full">
                  <option value="updated_desc">Recent -> Ancien</option>
                  <option value="updated_asc">Ancien -> Recent</option>
                </select>
              </label>
            </ActionsSearch>
          </div>
        </div>
      </div>
    </div>

    <div id="pages-container" class="mb-8" data-initial-search={q}>
      <!-- rendu initial fait côté serveur -->
      <div
        class="grid grid-cols-1 gap-4 md:grid-cols-2 md:gap-5 lg:grid-cols-3 lg:gap-6"
      >
        {
          actions.map((a) => (
            <div
              class="flex min-h-55 flex-col justify-between gap-4 rounded-xl border border-base-300 bg-base-100 p-4 shadow-sm md:p-5 lg:p-6"
              data-action-id={a.id}
              data-action-slug={a.slug}
              data-source={a.source}
              data-title={a.titre}
              data-type={a.type_de_chiffre}
            >
              <div class="space-y-3">
                <div class="flex items-start justify-between gap-3">
                  <h3 class="wrap-break-word text-xl font-bold leading-tight md:text-2xl">
                    {a.titre}
                  </h3>
                  {a.source === "brouillon" && (
                    <span class="badge badge-secondary text-secondary-content shrink-0">
                      Brouillon
                    </span>
                  )}
                </div>
                {a.sous_titre && (
                  <p class=" leading-relaxed wrap-break-word text-base-content/75">
                    {a.sous_titre}
                  </p>
                )}
                {a.beneficiaire && (
                  <p class=" leading-relaxed wrap-break-word text-base-content/75">
                    {a.beneficiaire}
                  </p>
                )}
                <p class="text-xs leading-tight text-base-content/60">
                  {a.updated ? formatDateShort(a.updated) : ""}
                </p>
              </div>
              <div class="grid grid-cols-2 gap-2 md:flex md:flex-row md:items-center md:justify-end">
                {a.source === "action" ? (
                  <a
                    class="btn btn-sm btn-ghost action-btn-text w-full md:w-auto"
                    href={`/actions/${a.id}-${a.slug}`}
                  >
                    Voir
                  </a>
                ) : (
                  <a
                    class="btn btn-sm btn-ghost action-btn-text w-full md:w-auto"
                    href={`/creation/brouillons/${a.id}-${a.slug}`}
                  >
                    Voir
                  </a>
                )}
                <a
                  class="btn btn-sm btn-accent action-btn-text w-full rounded-full md:w-auto"
                  href={`/creation/actions/edit/${a.id}-${a.slug}`}
                >
                  Modifier
                </a>
                {a.source === "brouillon" && (
                  <form
                    method="POST"
                    action={`/creation/actions/edit/${a.id}-${a.slug}`}
                    data-publish-action-form="true"
                    class="col-span-2 w-full md:w-auto"
                  >
                    <input type="hidden" name="publish_action" value="true" />
                    <button
                      type="submit"
                      class="btn btn-sm btn-accent action-btn-text w-full rounded-full md:w-auto"
                    >
                      Publier
                    </button>
                  </form>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
  <FormSubmitOverlay
    formSelector='form[data-publish-action-form="true"]'
    message="Publication en cours..."
  />
</Layout>

<script>
  import "../../../utils/utilitaires.js";
  import "../../../utils/scroll.js";
  import { showConfirm } from "../../../utils/alerts";

  // Attribut HTML temporaire utilise pour eviter une boucle
  // (submit -> confirm -> requestSubmit -> submit -> confirm ...).
  const PUBLISH_CONFIRMED_ATTR = "data-publish-confirmed";
  // Extension du type Window pour stocker un etat global de binding.
  type PublishWindowState = Window & {
    __kcPublishActionConfirmBound?: boolean;
  };
  const globalWindow = window as PublishWindowState;

  // Garde idempotente: le listener global "submit" ne doit etre attache qu'une seule fois.
  if (!globalWindow.__kcPublishActionConfirmBound) {
    globalWindow.__kcPublishActionConfirmBound = true;

    // Delegation globale: on intercepte tous les submit puis on filtre.
    document.addEventListener("submit", (event) => {
      const target = event.target;

      // On ne traite que les formulaires.
      if (!(target instanceof HTMLFormElement)) return;

      // On ne traite que les formulaires de publication marques explicitement.
      if (target.getAttribute("data-publish-action-form") !== "true") return;

      // Si un submit a deja ete confirme juste avant, on laisse passer
      // et on nettoie le marqueur pour les soumissions futures.
      const alreadyConfirmed =
        target.getAttribute(PUBLISH_CONFIRMED_ATTR) === "true";
      if (alreadyConfirmed) {
        target.removeAttribute(PUBLISH_CONFIRMED_ATTR);
        return;
      }

      // Bloque le submit natif tant que l'utilisateur n'a pas confirme.
      event.preventDefault();
      const submitter = event.submitter;

      // Demande de confirmation utilisateur.
      void showConfirm({
        title: "Publier l'action",
        message:
          "Confirmez-vous la publication de ce brouillon ? Cette action sera visible sur le site.",
        type: "warning",
        confirmLabel: "Publier",
        cancelLabel: "Annuler",
      }).then((confirmed) => {
        // Si annule: on ne fait rien.
        if (!confirmed) return;

        // Marque ce submit comme deja confirme pour eviter la boucle.
        target.setAttribute(PUBLISH_CONFIRMED_ATTR, "true");

        // Rejoue le submit en conservant le bouton declencheur si disponible.
        // Cela preserve le comportement natif (name/value du bouton, etc.).
        if (
          submitter instanceof HTMLButtonElement ||
          submitter instanceof HTMLInputElement
        ) {
          target.requestSubmit(submitter);
          return;
        }

        // Fallback si aucun submitter exploitable.
        target.requestSubmit();
      });
    });
  }
</script>
<script define:vars={{ allActions, q }}>
  // Dataset injecte cote serveur (Astro define:vars).
  const actions = allActions;

  // Etat UI courant des filtres/pagination.
  let currentBeneficiary = "";
  const PAGE_SIZE = 9;
  let currentPage = 1;
  let filteredActions = actions.slice();

  // Au changement de page, recentre la vue sur le haut de la liste paginee.
  const scrollTopOnPageChange = () => {
  const globalScrollUtils = window.scrollUtils;
    if (globalScrollUtils && typeof globalScrollUtils.scrollToTarget === "function") {
      globalScrollUtils.scrollToTarget("#pages-container");
      return;
    }

    // Fallback DOM standard.
    const listRoot = document.getElementById("pages-container");
    if (listRoot instanceof HTMLElement) {
      listRoot.scrollIntoView({ behavior: "smooth", block: "start" });
      return;
    }

    // Dernier fallback.
    window.scrollTo({ top: 0, behavior: "smooth" });
  };

  // Formate une date pour affichage humain.
  function formatDate(d) {
    if (!d) return "";
    if (
      typeof window !== "undefined" &&
      window.dateUtils &&
      typeof window.dateUtils.formatDateShort === "function"
    ) {
      try {
        // Utilitaire global centralise (format homogène dans le projet).
        return window.dateUtils.formatDateShort(d);
      } catch (e) {}
    }
    // Repli natif si utilitaire indisponible.
    return new Date(d).toLocaleDateString("fr-FR", {
      day: "numeric",
      month: "short",
      year: "numeric",
    });
  }

  // URL de consultation selon la source (action publiee vs brouillon).
  function getViewUrl(id, slug, source) {
    if (source === "brouillon") return `/creation/brouillons/${id}-${slug}`;
    return `/actions/${id}-${slug}`;
  }

  // URL d'edition (toujours vers l'editeur action).
  function getEditUrl(id, slug) {
    return `/creation/actions/edit/${id}-${slug}`;
  }

  // Construit le HTML de pagination.
  function renderPagination(totalPages, page) {
    if (totalPages <= 1) return "";
    const pageButtons = Array.from({ length: totalPages }, (_, index) => {
      const pageNumber = index + 1;
      const activeClass = pageNumber === page ? "btn-accent" : "btn-ghost";
      return `<button type="button" class="btn btn-sm ${activeClass}" data-page-action="go" data-page="${pageNumber}">${pageNumber}</button>`;
    }).join("");

    return `
      <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
        <button type="button" class="btn btn-sm btn-ghost" data-page-action="prev" ${page === 1 ? "disabled" : ""}>Precedent</button>
        ${pageButtons}
        <button type="button" class="btn btn-sm btn-ghost" data-page-action="next" ${page === totalPages ? "disabled" : ""}>Suivant</button>
      </div>
    `;
  }

  function filterActions(search, beneficiary, year, type) {
    // On part toujours de la liste complete, puis on applique des filtres cumulables.
    let filtered = actions.slice();

    // Logs de debug utilises pendant l'ajustement des filtres.
    if (typeof console !== "undefined" && console.debug)
      console.debug("filterActions input", { search, beneficiary, year, type });

    // Filtre par beneficiaire (sous-chaine, insensible a la casse).
    if (beneficiary && beneficiary !== "")
      filtered = filtered.filter((a) =>
        (a.beneficiaire || "")
          .toLowerCase()
          .includes(beneficiary.toLowerCase()),
      );

    // Filtre texte sur le titre.
    if (search && search !== "")
      filtered = filtered.filter((a) =>
        (a.titre || "").toLowerCase().includes(search.toLowerCase()),
      );

    // Filtre par annee extraite de date_debut ou date_fin.
    if (year && year !== "") {
      filtered = filtered.filter((a) => {
        const d = a.date_debut || a.date_fin;
        if (!d) return false;
        return new Date(d).getFullYear().toString() === year;
      });
    }

    // Filtre par type metier.
    if (type && type !== "") {
      filtered = filtered.filter((a) => {
        // Le type peut venir de `a.type_action` ou de `type_de_chiffre` ; ajuster si nécessaire.
        const arr = a.type_action || [];
        return arr.includes(type);
      });
    }

    // Log de sortie.
    if (typeof console !== "undefined" && console.debug)
      console.debug("filterActions result count", filtered.length);
    return filtered;
  }

  // Rend la grille + la pagination a partir d'une liste deja filtree.
  function renderActions(list) {
    const container = document.getElementById("pages-container");
    if (!container) return;

    // Etat vide.
    if (list.length === 0) {
      container.innerHTML = `<div class="text-center py-12"><p class="text-base-content/60 mb-4">Aucune action trouvée</p></div>`;
      currentPage = 1;
      return;
    }

    // Calcule les bornes de pagination.
    const totalPages = Math.max(1, Math.ceil(list.length / PAGE_SIZE));
    if (currentPage > totalPages) currentPage = totalPages;
    if (currentPage < 1) currentPage = 1;
    const startIndex = (currentPage - 1) * PAGE_SIZE;
    const pageItems = list.slice(startIndex, startIndex + PAGE_SIZE);

    // Construit le HTML des cartes + controles de pagination.
    const html = `
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 md:gap-5 lg:grid-cols-3 lg:gap-6">
          ${pageItems
            .map(
              (a) => `
                    <div class="flex min-h-55 flex-col justify-between gap-4 rounded-xl border border-base-300 bg-base-100 p-4 shadow-sm md:p-5 lg:p-6" data-action-id="${a.id}" data-action-slug="${a.slug}" data-source="${a.source}">
              <div class="space-y-3">
                <div class="flex items-start justify-between gap-3">
                  <h3 class="wrap-break-word text-xl font-bold leading-tight md:text-2xl">${a.titre}</h3>
                  ${a.source === "brouillon" ? '<span class="badge badge-secondary text-secondary-content shrink-0">Brouillon</span>' : ""}
                </div>
                ${a.sous_titre ? `<p class=" leading-relaxed wrap-break-word text-base-content/75">${a.sous_titre}</p>` : ""}
                ${a.beneficiaire ? `<p class=" leading-relaxed wrap-break-word text-base-content/75">${a.beneficiaire}</p>` : ""}
                <p class="text-xs leading-tight text-base-content/60">${a.updated ? formatDate(a.updated) : ""}</p>
              </div>
              <div class="grid grid-cols-2 gap-2 md:flex md:flex-row md:items-center md:justify-end">
                <a class="btn btn-sm btn-ghost action-btn-text w-full md:w-auto" href="${getViewUrl(a.id, a.slug, a.source)}">Voir</a>
                <a class="btn btn-sm btn-accent action-btn-text w-full rounded-full md:w-auto" href="${getEditUrl(a.id, a.slug)}">Modifier</a>
                ${a.source === "brouillon" ? `<form method="POST" action="${getEditUrl(a.id, a.slug)}" data-publish-action-form="true" class="col-span-2 w-full md:w-auto"><input type="hidden" name="publish_action" value="true" /><button type="submit" class="btn btn-sm btn-accent action-btn-text w-full rounded-full md:w-auto">Publier</button></form>` : ""}
              </div>
            </div>
        `,
            )
            .join("")}
      </div>
      ${renderPagination(totalPages, currentPage)}
    `;

    // Injection DOM finale.
    container.innerHTML = html;
  }

  // Point d'entree client: branche tous les listeners UI.
  document.addEventListener("DOMContentLoaded", () => {
    const pagesContainer = document.getElementById("pages-container");

    // Valeurs initiales derivees du SSR.
    let currentSearch = pagesContainer?.dataset.initialSearch || "";
    let currentYear = "";
    let currentType = "";

    // Select de tri (date desc/asc).
    const sortSelect = document.getElementById("sort-select");

    // Fonction centrale: filtre -> tri -> rendu.
    function applyAndRender() {
      let filtered = filterActions(
        currentSearch,
        currentBeneficiary,
        currentYear,
        currentType,
      );
      const sort =
        sortSelect instanceof HTMLSelectElement
          ? sortSelect.value
          : "updated_desc";

      // Tri final par date de mise a jour.
      filtered.sort((a, b) => {
        const da = new Date(a.updated || 0).getTime();
        const db = new Date(b.updated || 0).getTime();
        return sort === "updated_asc" ? da - db : db - da;
      });
      filteredActions = filtered;
      renderActions(filteredActions);
    }

    // Applique les filtres recus depuis les evenements custom.
    function handleFilters(d) {
      currentSearch = d.search || "";
      currentBeneficiary = d.beneficiary || "";
      currentYear = d.year || "";
      currentType = d.type || "";
      currentPage = 1;
      applyAndRender();
    }

    // Gestion des clics de pagination (delegation).
    pagesContainer?.addEventListener("click", (event) => {
      const target =
        event.target instanceof HTMLElement
          ? event.target.closest("[data-page-action]")
          : null;
      if (!(target instanceof HTMLElement)) return;

      const action = target.getAttribute("data-page-action");
      const totalPages = Math.max(
        1,
        Math.ceil(filteredActions.length / PAGE_SIZE),
      );
      const previousPage = currentPage;

      // Routeur d'actions pagination.
      if (action === "prev") {
        currentPage = Math.max(1, currentPage - 1);
      } else if (action === "next") {
        currentPage = Math.min(totalPages, currentPage + 1);
      } else if (action === "go") {
        const nextPage = Number(target.getAttribute("data-page") || "1");
        if (!Number.isNaN(nextPage)) {
          currentPage = Math.min(totalPages, Math.max(1, nextPage));
        }
      } else {
        return;
      }

      if (currentPage !== previousPage) {
        // Evite un defilement inutile si la page ne change pas.
        scrollTopOnPageChange();
      }
      renderActions(filteredActions);
    });

    // Reagit aux changements emis par les composants de recherche.
    document.addEventListener("actions-filter-change", (ev) => {
      handleFilters(ev.detail || {});
    });
    document.addEventListener("search-actions-change", (ev) => {
      handleFilters(ev.detail || {});
    });

    // Tri: declenche un rerender a chaque changement.
    if (sortSelect instanceof HTMLSelectElement) {
      sortSelect.addEventListener("change", () => {
        currentPage = 1;
        applyAndRender();
      });
    }

    // Rendu initial base sur l'etat de depart SSR.
    applyAndRender();

    // Note: suppression unitaire absente ici; la suppression groupee est geree ailleurs.
  });
</script>

<style is:global>
  a.action-btn-text,
  button.action-btn-text {
    font-size: 1rem !important;
    font-weight: 700 !important;
    line-height: 1.5rem !important;
    font-family: inherit !important;
    letter-spacing: normal !important;
    text-transform: none !important;
  }
</style>
