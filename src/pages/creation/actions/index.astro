---
import Layout from "../../../layouts/Layout-back-office.astro";
import slugify from "slugify";
import ActionsSearch from "../../../components/ActionsSearch.astro";
import FormSubmitOverlay from "../../../components/FormSubmitOverlay.astro";
import { formatDateShort } from "../../../utils/utilitaires.js";
import { ActionsTypeActionOptions } from "../../../pocketbase-types";
import { showConfirm } from "../../../utils/alerts";
import { renderPagination } from "../../../utils/renderPagination";
import { initPublishHandlers } from "../../../utils/formHandlers";
import { ListingPageManager } from "../../../utils/listingPageManager";
import { renderCards, createActionCardRenderer } from "../../../utils/cardRenderer";

// Types et interfaces

// Interface locale correspondant aux données après transformation
interface ActionItem {
  id: string;
  title: string;
  slug: string;
  source: "action" | "brouillon";
  subtitle?: string;
  hero?: string;
  updated?: string;
  startDate?: string;
  endDate?: string;
  beneficiary?: string;
  actionType?: string[];
  missingRequiredFields?: string[];
}

// Constantes et fonctions utilitaires

const PART_NUMBERS = [1, 2, 3];

const isValid = (value: unknown): boolean => {
  if (typeof value === "string") return value.trim() !== "";
  return Boolean(value);
};

const hasAtLeastOnePart = (record: Record<string, any>): boolean =>
  PART_NUMBERS.some((num) => {
    const textKey = `texte_partie_${num}`;
    const photoKey = `photo_partie_${num}`;
    return isValid(record?.[textKey]) || isValid(record?.[photoKey]);
  });

const getMissingRequiredFields = (record: Record<string, any>): string[] => {
  const missing: string[] = [];
  if (!isValid(record?.titre)) missing.push("titre");
  if (!isValid(record?.date_debut)) missing.push("date de début");
  if (!isValid(record?.hero)) missing.push("image de l'en-tête");
  
  const hasActionType = Array.isArray(record?.type_action) && record.type_action.length > 0;
  if (!hasActionType) missing.push("type d'action");
  
  if (!hasAtLeastOnePart(record)) missing.push("au moins une partie (texte ou photo)");
  
  return missing;
};

// Récupération des données

const actionsRaw: any[] = await Astro.locals.pb
  .collection("actions")
  .getFullList(200, { sort: "-updated" });

const brouillonsRaw: any[] = await Astro.locals.pb
  .collection("brouillons")
  .getFullList(200, {
    sort: "-updated",
    filter: 'type = "action"',
  });

// Transformation des données

const actions: ActionItem[] = [
  ...actionsRaw.map((a) => ({
    id: a.id,
    title: a.titre,
    slug: slugify(a.titre || "", { lower: true, strict: true }),
    source: "action" as const,
    subtitle: a.sous_titre,
    hero: a.hero,
    updated: a.updated,
    startDate: a.date_debut,
    endDate: a.date_fin,
    beneficiary: a.beneficiaire,
    actionType: a.type_action,
  })),
  ...brouillonsRaw.map((b) => ({
    id: b.id,
    title: b.titre || "Brouillon sans titre",
    slug: slugify(b.titre || "brouillon", { lower: true, strict: true }),
    source: "brouillon" as const,
    subtitle: b.sous_titre,
    hero: b.hero,
    updated: b.updated,
    startDate: b.date_debut,
    endDate: b.date_fin,
    beneficiary: b.beneficiaire,
    actionType: [],
    missingRequiredFields: getMissingRequiredFields(b),
  })),
].sort(
  (a, b) =>
    new Date(b.updated || 0).getTime() - new Date(a.updated || 0).getTime(),
);

const stats = { total: actions.length };

// Construction des options de filtres

const anneesDisponibles = new Set<string>();
actions.forEach((a) => {
  const date = a.startDate || a.endDate;
  if (date) {
    const année = new Date(date).getFullYear().toString();
    anneesDisponibles.add(année);
  }
});

const yearOptions = Array.from(anneesDisponibles).sort((a, b) => b.localeCompare(a));
const typeOptions = Object.values(ActionsTypeActionOptions);

// Lecture des paramètres d'URL

const paramètresUrl = Astro.url.searchParams;
const termeRecherche = (paramètresUrl.get("q") || "").trim();
const allActions = actions;
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    {/* Titre et boutons d'action */}
    <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="mb-0">
        <h1 class="mb-3 text-3xl font-bold text-accent font-poppins md:text-4xl">
          Actions
        </h1>
        <p class="text-base text-base-content/70 md:text-lg">
          Gérez vos actions, recherchez, filtrez et modifiez rapidement.
        </p>
      </div>
      <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
        <a href="/actions" class="btn btn-border btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md">
          Voir le site
        </a>
        <a href="/creation/actions/nouveau" class="btn btn-accent btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md">
          Créer une action
        </a>
      </div>
    </div>

    {/* Statistique */}
    <div class="grid grid-cols-1 gap-4 mb-12">
      <div class="card bg-base-100 shadow-md">
        <div class="card-body text-center p-4">
          <div class="text-4xl! font-bold text-base-content">{stats.total}</div>
          <div class="text-base-content">Actions</div>
        </div>
      </div>
    </div>

    {/* Section de recherche et filtres */}
    <div class="card mb-8 rounded-2xl border border-base-300 bg-base-100 shadow-sm">
      <div class="card-body p-4 md:p-6">
        <div class="mb-4">
          <h2 class="card-title text-2xl">Rechercher</h2>
          <p class="mt-1 text-base-content/60">
            Filtrez rapidement vos actions puis triez l'affichage.
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <div class="w-full">
            <ActionsSearch
              value={termeRecherche}
              yearOptions={yearOptions}
              typeOptions={typeOptions}
              showStatus={true}
              statusOptions={["all", "brouillon"]}
              embedded={true}
            >
              <label
                slot="secondary-extra"
                class="form-control w-full gap-1"
                for="tri-select"
              >
                <span class="text-sm! font-medium tracking-wide text-base-content">
                  Trier par date
                </span>
                <select id="tri-select" class="select select-bordered w-full">
                  <option value="récent">Récent → Ancien</option>
                  <option value="ancien">Ancien → Récent</option>
                </select>
              </label>
            </ActionsSearch>
          </div>
        </div>
      </div>
    </div>

    {/* Conteneur de grille paginée */}
    <div id="conteneur-actions" class="mb-8" data-initial-search={termeRecherche}>
      <!-- Rendu par JavaScript côté client -->
    </div>
  </div>

  <FormSubmitOverlay
    formSelector='form[data-publish-action-form="true"]'
    message="Publication en cours..."
  />
</Layout>

<script>
  import "../../../utils/utilitaires.js";
  import "../../../utils/scroll.js";
  import { showConfirm } from "../../../utils/alerts";
  import { renderPagination } from "../../../utils/renderPagination";
  import { initPublishHandlers } from "../../../utils/formHandlers";
  import { ListingPageManager } from "../../../utils/listingPageManager";
  import { renderCards, createActionCardRenderer } from "../../../utils/cardRenderer";

  // Initialize publish handlers
  initPublishHandlers(
    { formSelector: 'form[data-publish-action-form="true"]' },
    showConfirm
  );

  // Get the data from the script tag
  const dataScript = document.querySelector('script[data-actions-data]');
  const allActions = JSON.parse(dataScript?.getAttribute('data-actions-data') || '[]');
  const q = dataScript?.getAttribute('data-search-term') || '';

  // ============================================
  // Initialisation du gestionnaire de liste
  // ============================================

  const manager = new ListingPageManager(allActions, {
    containerId: "conteneur-actions",
    sortSelectId: "tri-select",
    pageSize: 9,
  }, q);

  const container = document.getElementById("conteneur-actions");
  const cardRenderer = createActionCardRenderer();

  // ============================================
  // Fonction de rendu
  // ============================================

  const render = () => {
    if (!container) return;

    const { items, totalPages, currentPage, hasItems } = manager.getPaginationData();

    if (!hasItems) {
      manager.renderEmpty();
      return;
    }

    const cardsHtml = renderCards(items, {
      ...cardRenderer,
      formattedDateGetter: (item) => manager.getFormattedDates(item).updated,
    });
    const paginationHtml = renderPagination(totalPages, currentPage);

    container.innerHTML = `
      <div class="grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-5 lg:grid-cols-3 lg:gap-6">
        ${cardsHtml}
      </div>
      ${paginationHtml}
    `;
  };

  // ============================================
  // Initialisation des event listeners
  // ============================================

  manager.initPaginationListeners(render);
  manager.initFilterListeners(render);
  manager.initSortListener(render);

  // Rendu initial
  render();
</script>

<script type="application/json" data-actions-data={JSON.stringify(allActions)} data-search-term={termeRecherche}></script>
