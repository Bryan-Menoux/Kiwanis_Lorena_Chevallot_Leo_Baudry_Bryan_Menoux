---
import Layout from "../../../../layouts/Layout-back-office.astro";
import ItemCard from "../../../../components/ItemCard.astro";
import ActionsSearch from "../../../../components/ActionsSearch.astro";
import { generateSlug } from "../../../../utils/editPageHandler";
import { getCreationViewUrl } from "../../../../utils/creationRoutes";

let error = "";
let success = "";

let produitsRaw = [];
try {
  produitsRaw = await (Astro.locals as any).pb
    .collection("produits")
    .getFullList(500, { sort: "-updated" });
} catch (e) {
  console.error("Impossible de récupérer les produits :", e);
  error = "Impossible de charger la liste des produits.";
}

const produits = produitsRaw.map((p: any) => {
  const photoUrl = Array.isArray(p.photo) && p.photo.length > 0
    ? (Astro.locals as any).pb.files.getURL(p, p.photo[0])
    : "";
  
  return {
    id: p.id,
    title: p.titre || "Produit sans titre",
    slug: generateSlug(p.titre || "") || "produit",
    subtitle: p.description || "",
    photoUrl,
    price: typeof p.prix === "number" ? p.prix : undefined,
    updated: p.updated,
    source: "produit" as const,
  };
});

function formatDate(dateStr?: string): string {
  if (!dateStr) return "";
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  } catch {
    return dateStr;
  }
}

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const ids = formData
      .getAll("ids")
      .map((value) => value.toString())
      .filter(Boolean);

    if (!ids.length) {
      error = "Aucun produit sélectionné.";
    } else {
      const failed: string[] = [];

      for (const id of ids) {
        try {
          await (Astro.locals as any).pb.collection("produits").delete(id);
        } catch (e) {
          console.error("Erreur lors de la suppression du produit :", id, e);
          failed.push(id);
        }
      }

      if (failed.length === 0) {
        return Astro.redirect(
          `/creation/produits/delete?success=${encodeURIComponent(`${ids.length} produit(s) supprimé(s) avec succès.`)}`,
        );
      }

      error = `Échec de la suppression pour ${failed.length} produit(s).`;
    }
  } catch (e) {
    console.error("Erreur lors du POST de suppression des produits :", e);
    error = "La suppression des produits a échoué.";
  }
}

try {
  const successParam = Astro.url.searchParams.get("success");
  if (successParam) success = successParam;
} catch {}
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="mb-0">
        <h1 class="mb-3 text-3xl font-bold text-accent font-poppins md:text-4xl">
          Supprimer des produits
        </h1>
        <p class="text-base text-base-content md:text-lg">
          Sélectionnez plusieurs produits puis cliquez sur "Supprimer sélection".
        </p>
      </div>
      <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
        <a
          href="/creation/produits"
          class="btn btn-border btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md"
        >
          Retour aux produits
        </a>
      </div>
    </div>

    <div
      id="delete-flash-flags"
      data-success={success}
      data-error={error}
      class="hidden"
    ></div>

    <form method="POST" id="deleteForm">
      <div class="mb-4 space-y-4">
        <div class="card rounded-2xl border border-base-300 bg-base-100 shadow-sm">
          <div class="card-body p-4 md:p-6">
            <div class="mb-4">
              <h2 class="card-title text-2xl">Filtrer</h2>
              <p class="mt-1 text-sm text-base-content">
                Filtrez rapidement vos produits.
              </p>
            </div>
            <ActionsSearch embedded={true} showBeneficiary={false} />
          </div>
        </div>

        <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
          <label class="flex items-center gap-2">
            <input type="checkbox" id="selectAll" />
            <span class="text-sm">Tout sélectionner</span>
          </label>
          <button
            type="submit"
            id="bulkDelete"
            class="btn btn-error btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md"
          >
            Supprimer sélection
          </button>
        </div>
      </div>

      <div
        id="cards-grid"
        class="grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-5 lg:grid-cols-3 lg:gap-6"
      >
        {
          produits.map((produit: any) => (
            <ItemCard
              id={produit.id}
              title={produit.title}
              slug={produit.slug}
              source={produit.source}
              subtitle={produit.subtitle}
              photoUrl={produit.photoUrl}
              showPhotoPlaceholder={true}
              price={produit.price}
              formattedDate={formatDate(produit.updated)}
              viewUrl={getCreationViewUrl("produit", produit.id, produit.slug)}
              editUrl={getCreationViewUrl("produit", produit.id, produit.slug)}
              showCheckbox={true}
              checkboxSlot={`<input class="checkbox checkbox-primary shrink-0" type="checkbox" name="ids" id="id_${produit.id}" value="${produit.id}" data-item-id="${produit.id}" data-title="${produit.title}" data-updated="${produit.updated}" />`}
              maxHeightContent={true}
              deleteMode={true}
            />
          ))
        }
      </div>
      <div id="cards-pagination" class="mt-6 flex justify-center"></div>
    </form>
  </div>

  <script>
    import { initDeletePageHandler } from "../../../../utils/deletePageHandler";

    initDeletePageHandler({
      cardSelector: "div[data-item-id]",
      itemSingular: "produit",
      itemPlural: "produits",
    });
  </script>
</Layout>
