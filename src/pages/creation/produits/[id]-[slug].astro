---
import Layout from "../../../layouts/Layout-back-office.astro";

const id = Astro.params.id;
const produit = await Astro.locals.pb.collection("produits").getOne(id!);

const photoUrls = Array.isArray(produit.photo)
  ? produit.photo.map((fileName: string) => Astro.locals.pb.files.getURL(produit, fileName))
  : [];

const formattedPrice =
  typeof produit.prix === "number"
    ? new Intl.NumberFormat("fr-FR", {
        style: "currency",
        currency: "EUR",
      }).format(produit.prix)
    : "";
---

<Layout>
  <div class="container mx-auto my-16 px-4 py-8 md:my-32">
    <div class="mb-8 flex flex-col gap-3">
      <h1 class="font-poppins text-3xl font-bold text-accent md:text-4xl">
        {produit.titre}
      </h1>
      {formattedPrice && (
        <p class="text-lg font-semibold text-base-content">{formattedPrice}</p>
      )}
      {produit.description && (
        <p class="max-w-3xl whitespace-pre-line text-base-content/80">
          {produit.description}
        </p>
      )}
    </div>

    {photoUrls.length > 0 && (
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
        {photoUrls.map((photoUrl, index) => (
          <figure class="overflow-hidden rounded-2xl border border-base-300 bg-base-100 shadow-sm">
            <img
              src={photoUrl}
              alt={`Photo du produit ${index + 1}`}
              class="h-72 w-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </figure>
        ))}
      </div>
    )}
  </div>
</Layout>
