---
import Layout from "../../../layouts/Layout-back-office.astro";
import ItemCard from "../../../components/ItemCard.astro";
import slugify from "slugify";
import FormSubmitOverlay from "../../../components/FormSubmitOverlay.astro";
import { getCreationEditUrl, getCreationViewUrl } from "../../../utils/creationRoutes";

interface ProductItem {
  id: string;
  title: string;
  slug: string;
  source: "produit";
  updated?: string;
  photoUrl?: string;
  price?: number;
}

const produitsRaw: any[] = await Astro.locals.pb
  .collection("produits")
  .getFullList(200, { sort: "-updated" });
const produits: ProductItem[] = [
  ...produitsRaw.map((p) => {
    const photoUrl = Array.isArray(p.photo) && p.photo.length > 0
      ? (Astro.locals as any).pb.files.getURL(p, p.photo[0])
      : "";
    
    return {
      id: p.id,
      title: p.titre,
      slug: slugify(p.titre || "", { lower: true, strict: true }),
      source: "produit" as const,
      updated: p.updated,
      photoUrl,
      price: typeof p.prix === "number" ? p.prix : undefined,
    };
  }),
].sort(
  (a, b) =>
    new Date(b.updated || 0).getTime() - new Date(a.updated || 0).getTime(),
);

const stats = { total: produits.length };

function formatDate(dateStr?: string): string {
  if (!dateStr) return "";
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  } catch {
    return dateStr;
  }
}
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    {/* Titre et boutons d'action */}
    <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="mb-0">
        <h1 class="mb-3 text-3xl font-bold text-accent font-poppins md:text-4xl">
          Produits
        </h1>
        <p class="text-base text-base-content/70 md:text-lg">
          Gérez vos produits, recherchez, filtrez et modifiez rapidement.
        </p>
      </div>
      <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
        <a href="/creation/produits/delete" class="btn btn-border btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md">
          Supprimer des produits
        </a>
        <a href="/creation/produits/nouveau" class="btn btn-accent btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md">
          Créer un produit
        </a>
      </div>
    </div>

    {/* Statistique */}
    <div class="grid grid-cols-1 gap-4 mb-12">
      <div class="card bg-base-100 shadow-md">
        <div class="card-body text-center p-4">
          <div class="text-4xl! font-bold text-base-content">{stats.total}</div>
          <div class="text-base-content">Produits</div>
        </div>
      </div>
    </div>

    {/* Grille de produits */}
    <div class="grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-5 lg:grid-cols-3 lg:gap-6">
      {produits.map((produit) => (
        <ItemCard
          id={produit.id}
          title={produit.title}
          slug={produit.slug}
          source={produit.source}
          photoUrl={produit.photoUrl}
          showPhotoPlaceholder={true}
          price={produit.price}
          formattedDate={formatDate(produit.updated)}
          viewUrl={getCreationViewUrl("produit", produit.id, produit.slug)}
          editUrl={getCreationEditUrl("produit", produit.id, produit.slug)}
          showDeleteButton={true}
        />
      ))}
    </div>

    {produits.length === 0 && (
      <div class="text-center py-12">
        <p class="text-base-content/60">Aucun produit trouvé</p>
      </div>
    )}
  </div>

  <FormSubmitOverlay
    formSelector='form[data-publish-produit-form="true"]'
    message="Publication en cours..."
  />
</Layout>

<script>
  import { initPublishHandlers } from "../../../utils/formHandlers";
  import { showConfirm } from "../../../utils/alerts";

  // Initialize publish handlers
  initPublishHandlers(
    { formSelector: 'form[data-publish-produit-form="true"]' },
    showConfirm
  );
</script>
