---
import Layout from "../../layouts/Layout-back-office.astro";
import ActionsSearch from "../../components/ActionsSearch.astro";
import { formatDateWithTime } from "../../utils/utilitaires.js";
import {
  getCreationDashboardEditUrl,
  getCreationDashboardViewUrl,
} from "../../utils/creationRoutes";
import {
  computeCreationDashboardStats,
  mapCreationDashboardPages,
  type CreationDashboardPage,
} from "../../services/creationDashboard";
import { normalizeSearchTerm } from "../../utils/searchNormalization";

const currentUser = Astro.locals.pb.authStore.model;
const isAdmin = currentUser?.administrateur === true;
const currentUserId = typeof currentUser?.id === "string" ? currentUser.id : "";

const actions = isAdmin
  ? await Astro.locals.pb.collection('actions').getFullList(200, { sort: '-updated', expand: 'cree_par' })
  : [];
const projets = isAdmin
  ? await Astro.locals.pb.collection('projets').getFullList(200, { sort: '-updated', expand: 'cree_par' })
  : [];
const produits = isAdmin
  ? await Astro.locals.pb.collection('produits').getFullList(200, { sort: '-updated', expand: 'cree_par' })
  : [];
const brouillonsRaw = await Astro.locals.pb.collection('brouillons').getFullList(200, {
  sort: '-updated',
  expand: 'cree_par',
});
const brouillons = isAdmin
  ? brouillonsRaw
  : brouillonsRaw.filter((draft: any) => String(draft?.cree_par || "") === currentUserId);

const pages: CreationDashboardPage[] = mapCreationDashboardPages({
  actions,
  projets,
  produits,
  brouillons,
});

// Utilisation de l'utilitaire partagé

function getStatusBadge(status: CreationDashboardPage["status"]) {
  if (status === 'actions') return { label: 'Actions', className: 'badge badge-success' };
  if (status === 'projets') return { label: 'Projets', className: 'badge badge-primary' };
  if (status === 'produits') return { label: 'Produits', className: 'badge badge-secondary' };
  if (status === 'brouillon') return { label: 'Brouillon', className: 'badge badge-ghost' };
  return { label: status, className: 'badge' };
}

function getEditUrl(status: CreationDashboardPage["status"], id: string, slug: string): string {
  return getCreationDashboardEditUrl(status, id, slug);
}

function getViewUrl(status: CreationDashboardPage["status"], id: string, slug: string): string {
  return getCreationDashboardViewUrl(status, id, slug);
}

// Lecture des paramètres de requête (recherche via GET)
const params = Astro.url.searchParams;
const q = (params.get('q') || '').trim();
const status = params.get('status') || 'all';

// Filtrage côté serveur (pour l'initialisation)
let list = pages.slice();
if (status && status !== 'all') list = list.filter(p => p.status === status);
if (q) {
  const token = normalizeSearchTerm(q);
  list = list.filter((p) =>
    normalizeSearchTerm(p.title || "").includes(token) ||
    normalizeSearchTerm(p.slug || "").includes(token),
  );
}
// tri par updatedAt desc
list.sort((a,b) => new Date(b.updatedAt).getTime() - new Date(a.updatedAt).getTime());
// Limiter à 9
const recent = list.slice(0,9);
const stats = computeCreationDashboardStats(pages);

// Données pour le JavaScript côté client
const allPages = pages;

if (Astro.request.method === "POST") {
  let expectsJson = false;

  try {
    const contentType = (Astro.request.headers.get("content-type") || "").toLowerCase();
    expectsJson = contentType.includes("application/json");

    let action = "";
    let id = "";
    let statusValue = "";

    if (expectsJson) {
      const body = await Astro.request.json();
      action = String(body?._action || "").trim();
      id = String(body?.id || "").trim();
      statusValue = String(body?.status || "").trim();
    } else {
      const formData = await Astro.request.formData();
      action = formData.get("_action")?.toString().trim() || "";
      id = formData.get("id")?.toString().trim() || "";
      statusValue = formData.get("status")?.toString().trim() || "";
    }

    if (action !== "delete") {
      throw new Error("Action invalide.");
    }

    if (!id || !statusValue) {
      throw new Error("Element introuvable.");
    }

    const statusKey = statusValue.toLowerCase();
    const collectionMap: Record<string, string> = {
      actions: "actions",
      projets: "projets",
      produits: "produits",
      brouillon: "brouillons",
      brouillons: "brouillons",
    };
    const collection = collectionMap[statusKey];

    if (!collection) {
      throw new Error("Type d'element invalide.");
    }

    if (!isAdmin) {
      if (collection !== "brouillons") {
        throw new Error("Seul un administrateur peut supprimer ce contenu.");
      }

      const draft = await Astro.locals.pb.collection("brouillons").getOne(id);
      if (String(draft?.cree_par || "") !== currentUserId) {
        throw new Error("Vous ne pouvez supprimer que vos propres brouillons.");
      }
    }

    await Astro.locals.pb.collection(collection).delete(id);

    if (expectsJson) {
      return new Response(JSON.stringify({ success: true }), {
        status: 200,
        headers: { "Content-Type": "application/json" },
      });
    }

    return Astro.redirect(
      "/creation?success=" + encodeURIComponent("Element supprime avec succes."),
    );
  } catch (caughtError) {
    const errorMessage =
      caughtError instanceof Error
        ? caughtError.message
        : "La suppression a echoue.";

    if (expectsJson) {
      return new Response(
        JSON.stringify({ success: false, error: errorMessage }),
        {
          status: 400,
          headers: { "Content-Type": "application/json" },
        },
      );
    }

    return Astro.redirect(
      "/creation?error=" + encodeURIComponent(errorMessage),
    );
  }
}
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    <!-- Header -->
    <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="mb-0">
        <h1 class="mb-3 text-3xl font-bold text-accent font-poppins md:text-4xl">Mes Pages</h1>
        <p class="text-base text-base-content/70 md:text-lg">Bienvenue dans votre tableau de bord de gestion</p>
      </div>
      <div class="grid w-full grid-cols-1 gap-3 [@media(min-width:420px)]:grid-cols-2 md:flex md:w-auto md:flex-wrap md:items-center md:justify-end">
        <!-- voir la page des actions -->
        <a href="/actions" class="btn btn-border btn-sm rounded-full w-full md:w-fit md:flex-initial md:btn-md whitespace-nowrap">Voir les actions</a>
        <a href="/creation/actions/nouveau" class="btn btn-accent btn-sm rounded-full w-full md:w-fit md:flex-initial md:btn-md whitespace-nowrap">Créer une action</a>
      </div>
    </div>

    <!-- Statistiques -->
    <div class="mb-12 grid grid-cols-2 gap-3 md:grid-cols-2 md:gap-4 lg:grid-cols-5">
      <div class="card col-span-2 border border-base-300 bg-base-100 shadow-sm lg:col-span-1">
        <div class="card-body items-center justify-center gap-1 text-center p-3 sm:p-4 md:p-5">
          <div class="text-3xl! sm:text-4xl! md:text-5xl! leading-none font-bold text-base-content">{stats.total}</div>
          <div class="text-xs md:text-sm font-medium text-base-content/80">Total</div>
        </div>
      </div>
      <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body items-center justify-center gap-1 text-center p-3 sm:p-4 md:p-5">
          <div class="text-3xl! sm:text-4xl! md:text-5xl! leading-none font-bold text-base-content">{stats.actions}</div>
          <div class="text-xs md:text-sm font-medium text-base-content/80">Actions</div>
        </div>
      </div>
      <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body items-center justify-center gap-1 text-center p-3 sm:p-4 md:p-5">
          <div class="text-3xl! sm:text-4xl! md:text-5xl! leading-none font-bold text-base-content">{stats.projets}</div>
          <div class="text-xs md:text-sm font-medium text-base-content/80">Projets</div>
        </div>
      </div>
      <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body items-center justify-center gap-1 text-center p-3 sm:p-4 md:p-5">
          <div class="text-3xl! sm:text-4xl! md:text-5xl! leading-none font-bold text-base-content">{stats.produits}</div>
          <div class="text-xs md:text-sm font-medium text-base-content/80">Produits</div>
        </div>
      </div>
      <div class="card border border-base-300 bg-base-100 shadow-sm">
        <div class="card-body items-center justify-center gap-1 text-center p-3 sm:p-4 md:p-5">
          <div class="text-3xl! sm:text-4xl! md:text-5xl! leading-none font-bold text-base-content">{stats.brouillons}</div>
          <div class="text-xs md:text-sm font-medium text-base-content/80">Brouillons</div>
        </div>
      </div>
    </div>

    <!-- Recherche et filtres -->
    <div class="card bg-base-100 border border-base-300 shadow-sm mb-8 rounded-2xl">
      <div class="card-body p-4 md:p-6">
        <div class="mb-4">
          <h2 class="card-title text-2xl">Rechercher</h2>
          <p class="mt-1 text-sm text-base-content/60">
            Filtrez rapidement vos pages puis triez l'affichage.
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <div class="w-full">
            <h3 class="mb-2">Filtres</h3>
            <ActionsSearch showStatus={true} value={q} statusOptions={["all","actions","projets","produits","brouillon"]} embedded={true}>
              <label slot="secondary-extra" class="form-control w-full gap-1" for="sort-select">
                <span class="text-sm! font-medium tracking-wide text-base-content">Trier par date</span>
                <select id="sort-select" class="select select-bordered w-full">
                  <option value="updated_desc">Récent → Ancien</option>
                  <option value="updated_asc">Ancien → Récent</option>
                </select>
              </label>
            </ActionsSearch>
          </div>
        </div>
      </div>
    </div>

    <!-- Pages récentes -->
    <section class="mb-8">
        <div class="flex justify-between items-center mb-6">
          <h2 class="card-title">Pages récentes</h2>
        </div>

        <div id="pages-container">
          {recent.length === 0 ? (
            <div class="text-center py-12">
              <p class="text-base-content/60 mb-4">Aucune page disponible pour le moment.</p>
            </div>
          ) : (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {recent.map((page) => {
                const badge = getStatusBadge(page.status);
                return (
                  <div class="card bg-base-100 border" data-page-id={page.id}>
                    <div class="card-body p-4">
                      <div class="flex justify-between items-start mb-2">
                        <h3 class="card-title text-lg">{page.title}</h3>
                        <span class={`badge ${badge.className}`}>{badge.label}</span>
                      </div>
                      <p class="text-sm text-base-content/60 mb-2">Par {page.authorName}</p>
                      <p class="text-sm text-base-content/60">{page.displayDate || formatDateWithTime(page.updatedAt)}</p>
                      <div class="card-actions justify-end mt-4">
                        <button
                          type="button"
                          class="btn btn-sm btn-error text-sm! font-normal! normal-case! rounded-full"
                          data-page-delete-btn
                          data-page-id={page.id}
                          data-page-title={page.title}
                          data-page-status={page.status}
                        >
                          Supprimer
                        </button>
                        <a href={getViewUrl(page.status, page.id, page.slug)} class="btn btn-sm btn-ghost text-sm! font-normal! normal-case!">Voir</a>
                        <a href={getEditUrl(page.status, page.id, page.slug)} class="btn btn-sm btn-accent text-sm! font-normal! normal-case!">Modifier</a>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
    </section>
  </div>
</Layout>

<script>
  import "../../utils/utilitaires.js";
  import "../../utils/scroll.js";
  import { renderPagination } from "../../utils/renderPagination";
  import {
    getCreationDashboardEditUrl,
    getCreationDashboardViewUrl,
  } from "../../utils/creationRoutes";
  (window as any).renderPagination = renderPagination;
  (window as any).creationRouteHelpers = {
    getCreationDashboardEditUrl,
    getCreationDashboardViewUrl,
  };
</script>
<script define:vars={{ allPages, q, status }}>
  import { normalizeSearchTerm } from "../../utils/searchNormalization";

  // Données et fonctions utilitaires
  const pages = allPages;
  let currentSearch = q;
  let currentStatus = status;
  let currentBenef = '';
  // Garder en mémoire l'ordre de tri choisi (par défaut décroissant)
  let currentSort = 'updated_desc';
  const PAGE_SIZE = 9;
  let currentPage = 1;
  let filteredPagesCache = pages.slice();

  function computeTotalPages(totalItems, pageSize) {
    const safeTotalItems = Number.isFinite(Number(totalItems)) ? Number(totalItems) : 0;
    const safePageSize =
      Number.isFinite(Number(pageSize)) && Number(pageSize) > 0 ? Number(pageSize) : 1;
    return Math.max(1, Math.ceil(safeTotalItems / safePageSize));
  }

  function computeNextPage(current, totalPages, action, targetPage) {
    const safeTotalPages =
      Number.isFinite(Number(totalPages)) && Number(totalPages) > 0
        ? Math.floor(Number(totalPages))
        : 1;
    const safeCurrent =
      Number.isFinite(Number(current)) && Number(current) > 0
        ? Math.min(safeTotalPages, Math.floor(Number(current)))
        : 1;

    if (action === "prev") return Math.max(1, safeCurrent - 1);
    if (action === "next") return Math.min(safeTotalPages, safeCurrent + 1);
    if (action === "go") {
      const parsed = Number(targetPage ?? "1");
      if (Number.isNaN(parsed)) return safeCurrent;
      return Math.min(safeTotalPages, Math.max(1, Math.floor(parsed)));
    }
    return safeCurrent;
  }

  function getCreationScrollOffset() {
    const header =
      document.getElementById("creation-header") ||
      document.getElementById("main-header") ||
      document.querySelector("header.fixed.top-0") ||
      document.querySelector("header");

    const headerOffset =
      header instanceof HTMLElement ? header.offsetHeight + 16 : 16;
    const minimumViewportOffset = Math.round(window.innerHeight * 0.15);
    return Math.max(headerOffset, minimumViewportOffset);
  }

  // Au changement de page, on remonte en douceur vers le haut de la liste (et non en haut du document).
  const scrollTopOnPageChange = () => {
    const globalScrollUtils = window.scrollUtils;
    if (globalScrollUtils && typeof globalScrollUtils.scrollToTarget === "function") {
      globalScrollUtils.scrollToTarget("#pages-container", {
        offset: -getCreationScrollOffset(),
      });
      return;
    }
    const listRoot = document.getElementById("pages-container");
    if (listRoot instanceof HTMLElement) {
      const targetTop =
        window.scrollY + listRoot.getBoundingClientRect().top - getCreationScrollOffset();
      window.scrollTo({ top: Math.max(0, targetTop), behavior: "smooth" });
      return;
    }
    window.scrollTo({ top: 0, behavior: "smooth" });
  };

  function formatDate(d) {
    if (!d) return "";
    if (typeof window !== 'undefined' && window.dateUtils && typeof window.dateUtils.formatDateWithTime === 'function') {
      try { return window.dateUtils.formatDateWithTime(d); } catch (e) {}
    }
    return new Date(d).toLocaleString('fr-FR', { dateStyle: 'medium', timeStyle: 'short' });
  }

  function getEditUrl(status, id, slug) {
    const helpers = window.creationRouteHelpers || {};
    return typeof helpers.getCreationDashboardEditUrl === "function"
      ? helpers.getCreationDashboardEditUrl(status, id, slug)
      : "/creation";
  }

  function getViewUrl(status, id, slug) {
    const helpers = window.creationRouteHelpers || {};
    return typeof helpers.getCreationDashboardViewUrl === "function"
      ? helpers.getCreationDashboardViewUrl(status, id, slug)
      : getEditUrl(status, id, slug);
  }

  function getStatusBadge(status) {
    if (status === 'actions') return { label: 'Actions', className: 'badge-success' };
    if (status === 'projets') return { label: 'Projets', className: 'badge-primary' };
    if (status === 'produits') return { label: 'Produits', className: 'badge-secondary' };
    if (status === 'brouillon') return { label: 'Brouillon', className: 'badge-ghost' };
    return { label: status, className: 'badge' };
  }

  function filterPages(search, statusFilter, benef, sort = 'updated_desc') {
    let filtered = pages.slice();

    // Filtre par statut
    if (statusFilter && statusFilter !== 'all') {
      filtered = filtered.filter(p => p.status === statusFilter);
    }

    // Filtre par recherche
    if (search) {
      const token = normalizeSearchTerm(search);
      filtered = filtered.filter((p) =>
        normalizeSearchTerm(p.title).includes(token) ||
        normalizeSearchTerm(p.slug).includes(token),
      );
    }

    // Filtre par bénéficiaire (seulement pour les actions)
    if (benef) {
      const benefToken = normalizeSearchTerm(benef);
      filtered = filtered.filter(
        (p) =>
          p.status === 'actions' &&
          normalizeSearchTerm(p.beneficiary || '').includes(benefToken),
      );
    }

    // Tri par date selon l'ordre sélectionné
    filtered.sort((a, b) => {
      const da = new Date(a.updatedAt).getTime();
      const db = new Date(b.updatedAt).getTime();
      return sort === 'updated_asc' ? da - db : db - da;
    });

    // Renvoyer tous les resultats (pagination client ensuite)
    return filtered;
  }

  function renderPages(filteredPages) {
    const container = document.getElementById('pages-container');
    if (!(container instanceof HTMLElement)) return;

    if (filteredPages.length === 0) {
      container.innerHTML = `
        <div class="text-center py-12">
          <p class="text-base-content/60 mb-4">Aucune page disponible pour le moment.</p>
        </div>
      `;
      currentPage = 1;
    } else {
      const totalPages = computeTotalPages(filteredPages.length, PAGE_SIZE);
      if (currentPage > totalPages) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;
      const startIndex = (currentPage - 1) * PAGE_SIZE;
      const pageItems = filteredPages.slice(startIndex, startIndex + PAGE_SIZE);

      const pagesHtml = `
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          ${pageItems.map(page => {
            const badge = getStatusBadge(page.status);
            return `
              <div class="card bg-base-100 border" data-page-id="${page.id}">
                <div class="card-body p-4">
                  <div class="flex justify-between items-start mb-2">
                    <h3 class="card-title text-lg">${page.title}</h3>
                    <span class="badge ${badge.className}">${badge.label}</span>
                  </div>
                  <p class="text-sm text-base-content/60 mb-2">Par ${page.authorName}</p>
                  <p class="text-sm text-base-content/60">${formatDate(page.updatedAt)}</p>
                  <div class="card-actions justify-end mt-4">
                    <button
                      type="button"
                      class="btn btn-sm btn-error text-sm! font-normal! normal-case! rounded-full"
                      data-page-delete-btn
                      data-page-id="${page.id}"
                      data-page-title="${page.title}"
                      data-page-status="${page.status}"
                    >
                      Supprimer
                    </button>
                    <a href="${getViewUrl(page.status, page.id, page.slug)}" class="btn btn-sm btn-ghost text-sm! font-normal! normal-case!">Voir</a>
                    <a href="${getEditUrl(page.status, page.id, page.slug)}" class="btn btn-sm btn-accent text-sm! font-normal! normal-case!">Modifier</a>
                  </div>
                </div>
              </div>
            `;
          }).join('')}
        </div>
        ${(window.renderPagination || function() { return ''; })(totalPages, currentPage)}
      `;
      container.innerHTML = pagesHtml;
    }
  }

  // Initialisation
  const initCreationIndexHandlers = () => {
    const pagesContainer = document.getElementById('pages-container');

    pagesContainer?.addEventListener('click', (event) => {
      const deleteButton = event.target instanceof HTMLElement
        ? event.target.closest('[data-page-delete-btn]')
        : null;

      if (deleteButton instanceof HTMLElement) {
        event.preventDefault();
        event.stopPropagation();

        const itemTitle = deleteButton.getAttribute('data-page-title') || 'cet élément';
        const itemStatus = deleteButton.getAttribute('data-page-status');
        if (!itemStatus) return;

        const confirmDelete = window.KiwanisAlert?.confirm
          ? window.KiwanisAlert.confirm({
              title: "Supprimer",
              message: `Supprimer "${itemTitle}" ?`,
              confirmLabel: "Supprimer",
              cancelLabel: "Annuler",
              type: "warning",
            })
          : Promise.resolve(window.confirm(`Supprimer "${itemTitle}" ?`));

        void confirmDelete.then(async (confirmed) => {
          if (!confirmed) return;

          const pageId = deleteButton.getAttribute("data-page-id") || "";
          if (!pageId) return;

          try {
            const response = await fetch(window.location.pathname, {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                "X-Requested-With": "XMLHttpRequest",
              },
              body: JSON.stringify({
                _action: "delete",
                id: pageId,
                status: itemStatus,
              }),
            });

            if (!response.ok) {
              const payload = await response.json().catch(() => null);
              const serverMessage =
                payload && typeof payload.error === "string"
                  ? payload.error
                  : "La suppression a echoue.";
              throw new Error(serverMessage);
            }

            const nextUrl = new URL(window.location.href);
            nextUrl.searchParams.set("success", "Element supprime avec succes.");
            window.location.href = `${nextUrl.pathname}?${nextUrl.searchParams.toString()}`;
          } catch (error) {
            const message =
              error instanceof Error ? error.message : "La suppression a echoue.";

            if (window.KiwanisAlert?.show) {
              window.KiwanisAlert.show({
                message,
                type: "error",
              });
            } else {
              window.alert(message);
            }
          }
        });
        return;
      }

      const target = event.target instanceof HTMLElement
        ? event.target.closest('[data-page-action]')
        : null;
      if (!(target instanceof HTMLElement)) return;

      const action = target.getAttribute('data-page-action');
      const totalPages = computeTotalPages(filteredPagesCache.length, PAGE_SIZE);
      const previousPage = currentPage;
      currentPage = computeNextPage(
        currentPage,
        totalPages,
        action,
        target.getAttribute("data-page"),
      );

      if (currentPage !== previousPage) {
        // Défile uniquement si la page visible a réellement changé.
        scrollTopOnPageChange();
      }
      renderPages(filteredPagesCache);
    });

    // Écouter les événements partagés d'ActionsSearch
    document.addEventListener('actions-filter-change', (ev) => {
      const d = ev.detail || {};
      currentSearch = d.search || '';
      currentBenef = d.beneficiary || '';
      // Préférer le statut fourni s'il existe, sinon conserver l'existant.
      if (typeof d.status !== 'undefined') currentStatus = d.status || 'all';
      currentPage = 1;
      filteredPagesCache = filterPages(currentSearch, currentStatus, currentBenef, currentSort);
      renderPages(filteredPagesCache);
    });

    // rendu initial et affichage des filtres actifs
    // Lire la valeur initiale du tri si présente
    const sortSelect = document.getElementById('sort-select');
    if (sortSelect instanceof HTMLSelectElement) {
      currentSort = sortSelect.value;
      sortSelect.addEventListener('change', () => {
        currentSort = sortSelect.value;
        currentPage = 1;
        filteredPagesCache = filterPages(currentSearch, currentStatus, currentBenef, currentSort);
        renderPages(filteredPagesCache);
      });
    }
    filteredPagesCache = filterPages(currentSearch, currentStatus, currentBenef, currentSort);
    renderPages(filteredPagesCache);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCreationIndexHandlers, { once: true });
  } else {
    initCreationIndexHandlers();
  }
</script>



