---
import Layout from "../../layouts/Layout-back-office.astro";
import ActionsSearch from "../../components/ActionsSearch.astro";
import slugify from 'slugify';

interface Page {
  id: string;
  title: string;
  slug: string;
  status: 'actions' | 'projets' | 'produits' | 'draft';
  updatedAt: string;
  authorName: string;
  beneficiary?: string;
}

const actions = await Astro.locals.pb.collection('actions').getFullList(200, { sort: '-updated' });
const projets = await Astro.locals.pb.collection('projets').getFullList(200, { sort: '-updated' });
const produits = await Astro.locals.pb.collection('produits').getFullList(200, { sort: '-updated' });
const brouillons = await Astro.locals.pb.collection('brouillons').getFullList(200, { sort: '-updated' });

// Combiner toutes les pages des différentes collections
const pages: Page[] = [
  ...actions.map(action => ({
    id: action.id,
    title: action.titre,
    slug: slugify(action.titre, { lower: true, strict: true }),
    status: 'actions' as const,
    updatedAt: action.updated,
    authorName: 'Admin', // Valeur par défaut
    beneficiary: action.beneficiaire
  })),
  ...projets.map(projet => ({
    id: projet.id,
    title: projet.titre,
    slug: slugify(projet.titre, { lower: true, strict: true }),
    status: 'projets' as const,
    updatedAt: projet.updated,
    authorName: 'Admin' // Valeur par défaut
  })),
  ...produits.map(produit => ({
    id: produit.id,
    title: produit.titre,
    slug: slugify(produit.titre, { lower: true, strict: true }),
    status: 'produits' as const,
    updatedAt: produit.updated,
    authorName: 'Admin' // Valeur par défaut
  })),
  ...brouillons.map(brouillon => ({
    id: brouillon.id,
    title: brouillon.titre,
    slug: slugify(brouillon.titre, { lower: true, strict: true }),
    status: 'draft' as const,
    updatedAt: brouillon.updated,
    authorName: 'Admin' // Valeur par défaut
  }))
];

// Simple fake DB: only pages (id, title, slug, status, updatedAt, authorName)
const db: { pages: Page[] } = {
  pages: pages
};

function formatDate(d: string): string {
  return new Date(d).toLocaleString('fr-FR', { dateStyle: 'medium', timeStyle: 'short' });
}

function getStatusBadge(status: Page['status']) {
  if (status === 'actions') return { label: 'Actions', className: 'badge badge-success' };
  if (status === 'projets') return { label: 'Projets', className: 'badge badge-primary' };
  if (status === 'produits') return { label: 'Produits', className: 'badge badge-secondary' };
  if (status === 'draft') return { label: 'Brouillon', className: 'badge badge-ghost' };
  return { label: status, className: 'badge' };
}

function getEditUrl(status: Page['status'], id: string, slug: string): string {
  if (status === 'actions') return `/creation/actions/edit/${id}-${slug}`;
  if (status === 'projets') return `/creation/projets/${id}-${slug}`;
  if (status === 'produits') return `/creation/produits/${id}-${slug}`;
  if (status === 'draft') return `/creation/brouillons/${id}-${slug}`;
  return `/creation/pages/${id}-${slug}`;
}

function getViewUrl(status: Page['status'], id: string, slug: string): string {
  if (status === 'actions') return `/actions/${id}-${slug}`;
  if (status === 'projets') return `/projets/${id}-${slug}`;
  if (status === 'produits') return `/produits/${id}-${slug}`;
  return getEditUrl(status, id, slug);
}

function computeStats(pages: Page[]): { actions: number; projets: number; produits: number; drafts: number; total: number; } {
  return {
    actions: pages.filter(p => p.status === 'actions').length,
    projets: pages.filter(p => p.status === 'projets').length,
    produits: pages.filter(p => p.status === 'produits').length,
    drafts: pages.filter(p => p.status === 'draft').length,
    total: pages.length
  };
}

// Lecture des query params (recherche via GET)
const params = Astro.url.searchParams;
const q = (params.get('q') || '').trim();
const status = params.get('status') || 'all';

// Filtrage côté serveur (pour l'initialisation)
let list = db.pages.slice();
if (status && status !== 'all') list = list.filter(p => p.status === status);
if (q) {
  const token = q.toLowerCase();
  list = list.filter(p => p.title.toLowerCase().includes(token) || p.slug.toLowerCase().includes(token));
}
// tri par updatedAt desc
list.sort((a,b) => new Date(b.updatedAt).getTime() - new Date(a.updatedAt).getTime());
// limiter à 6
const recent = list.slice(0,6);
const stats = computeStats(db.pages);

// Données pour le JavaScript côté client
const allPages = db.pages;
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-32">
    <!-- Header -->
    <div class="flex justify-between ">
        <div class="flex flex-col mb-12">
      <h1 class="text-4xl font-bold text-primary mb-4 font-poppins">Mes Pages</h1>
      <p class="text-lg text-base-content/70">Bienvenue dans votre tableau de bord de gestion</p>
    </div>
    <div class="flex items-center gap-4">
        <!-- voir la page des actions -->
        <a href="/actions" class="btn btn-border">Voir les actions</a>
        <a href="/creation/actions/nouveau" class="btn btn-primary">Créer une action</a>
    </div>
    </div>

    <!-- Statistiques -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-12">
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body text-center p-4">
          <div class="text-2xl font-bold text-base-content">{stats.total}</div>
          <div class="text-sm text-base-content/70">Total</div>
        </div>
      </div>
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body text-center p-4">
          <div class="text-2xl font-bold text-base-content">{stats.actions}</div>
          <div class="text-sm text-base-content/70">Actions</div>
        </div>
      </div>
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body text-center p-4">
          <div class="text-2xl font-bold text-base-content">{stats.projets}</div>
          <div class="text-sm text-base-content/70">Projets</div>
        </div>
      </div>
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body text-center p-4">
          <div class="text-2xl font-bold text-base-content">{stats.produits}</div>
          <div class="text-sm text-base-content/70">Produits</div>
        </div>
      </div>
      <div class="card bg-base-100 shadow-sm">
        <div class="card-body text-center p-4">
          <div class="text-2xl font-bold text-base-content">{stats.drafts}</div>
          <div class="text-sm text-base-content/70">Brouillons</div>
        </div>
      </div>
    </div>

    <!-- Recherche et filtres -->
    <div class="card bg-base-100 shadow-sm mb-8">
      <div class="card-body">
        <h2 class="card-title mb-4">Rechercher</h2>

        <div id="active-filters" class="hidden alert alert-info mb-4 w-full relative items-center justify-between">
          <div class="flex items-center w-full pr-12">
            <div class="flex gap-2" id="filter-badges"></div>
          </div>
          <button id="clear-filters" class="btn btn-ghost btn-sm absolute right-0 top-1/2 -translate-y-1/2">Effacer</button>
        </div>

        <div class="flex flex-col md:flex-row gap-4">
          <ActionsSearch showStatus={true} value={q} statusOptions={["all","actions","projets","produits","draft"]} />
        </div>
      </div>
    </div>

    <!-- Pages récentes -->
    <div class="card bg-base-100 shadow-sm">
      <div class="card-body">
        <div class="flex justify-between items-center mb-6">
          <h2 class="card-title">Pages récentes</h2>
          <a href="/creation/pages" class="btn btn-ghost">Voir tout</a>
        </div>

        <div id="pages-container">
          {recent.length === 0 ? (
            <div class="text-center py-12">
              <p class="text-base-content/60 mb-4">Aucune page trouvée</p>
              <button id="clear-filters-empty" class="btn btn-primary hidden">Effacer les filtres</button>
            </div>
          ) : (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {recent.map((page) => {
                const badge = getStatusBadge(page.status);
                return (
                  <div class="card bg-base-100 border" data-page-id={page.id}>
                    <div class="card-body p-4">
                      <div class="flex justify-between items-start mb-2">
                        <h3 class="card-title text-lg">{page.title}</h3>
                        <span class={`badge ${badge.className}`}>{badge.label}</span>
                      </div>
                      <p class="text-sm text-base-content/60 mb-2">/{page.slug}</p>
                      <p class="text-sm text-base-content/60 mb-2">Par {page.authorName}</p>
                      <p class="text-sm text-base-content/60">{formatDate(page.updatedAt)}</p>
                      <div class="card-actions justify-end mt-4">
                        <a href={getViewUrl(page.status, page.id, page.slug)} class="btn btn-sm">Voir</a>
                        <a href={getEditUrl(page.status, page.id, page.slug)} class="btn btn-sm">Modifier</a>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ allPages, q, status }}>
  // Données et fonctions utilitaires
  const pages = allPages;
  let currentSearch = q;
  let currentStatus = status;
  let currentBenef = '';

  function formatDate(d) {
    return new Date(d).toLocaleString('fr-FR', { dateStyle: 'medium', timeStyle: 'short' });
  }

  function getEditUrl(status, id, slug) {
    if (status === 'actions') return `/creation/actions/edit/${id}-${slug}`;
    if (status === 'projets') return `/creation/projets/${id}-${slug}`;
    if (status === 'produits') return `/creation/produits/${id}-${slug}`;
    if (status === 'draft') return `/creation/brouillons/${id}-${slug}`;
    return `/creation/pages/${id}-${slug}`;
  }

  function getViewUrl(status, id, slug) {
    if (status === 'actions') return `/actions/${id}-${slug}`;
    if (status === 'projets') return `/projets/${id}-${slug}`;
    if (status === 'produits') return `/produits/${id}-${slug}`;
    return getEditUrl(status, id, slug);
  }

  function getStatusBadge(status) {
    if (status === 'actions') return { label: 'Actions', className: 'badge-success' };
    if (status === 'projets') return { label: 'Projets', className: 'badge-primary' };
    if (status === 'produits') return { label: 'Produits', className: 'badge-secondary' };
    if (status === 'draft') return { label: 'Brouillon', className: 'badge-ghost' };
    return { label: status, className: 'badge' };
  }

  function filterPages(search, statusFilter, benef) {
    let filtered = pages.slice();

    // Filtre par statut
    if (statusFilter && statusFilter !== 'all') {
      filtered = filtered.filter(p => p.status === statusFilter);
    }

    // Filtre par recherche
    if (search) {
      const token = search.toLowerCase();
      filtered = filtered.filter(p =>
        p.title.toLowerCase().includes(token) ||
        p.slug.toLowerCase().includes(token)
      );
    }

    // Filtre par bénéficiaire (seulement pour les actions)
    if (benef) {
      const benefToken = benef.toLowerCase();
      filtered = filtered.filter(p =>
        p.status === 'actions' && (p.beneficiary || '').toLowerCase().includes(benefToken)
      );
    }

    // Tri par date décroissante
    filtered.sort((a, b) => new Date(b.updatedAt).getTime() - new Date(a.updatedAt).getTime());

    // Limiter à 6 résultats
    return filtered.slice(0, 6);
  }

  function updateActiveFilters(search, statusFilter) {
    const activeFiltersEl = document.getElementById('active-filters');
    const filterBadgesEl = document.getElementById('filter-badges');

    if (search || (statusFilter && statusFilter !== 'all')) {
      activeFiltersEl.classList.remove('hidden');
      activeFiltersEl.classList.add('flex');
      filterBadgesEl.innerHTML = '';

      if (search) {
        const badge = document.createElement('span');
        badge.className = 'badge';
        badge.textContent = `Recherche: "${search}"`;
        filterBadgesEl.appendChild(badge);
      }

      if (statusFilter && statusFilter !== 'all') {
        const statusLabel = statusFilter === 'actions' ? 'Actions' :
                           statusFilter === 'projets' ? 'Projets' :
                           statusFilter === 'produits' ? 'Produits' :
                           statusFilter === 'draft' ? 'Brouillons' : statusFilter;
        const badge = document.createElement('span');
        badge.className = 'badge';
        badge.textContent = `Type: ${statusLabel}`;
        filterBadgesEl.appendChild(badge);
      }
    } else {
      activeFiltersEl.classList.add('hidden');
      activeFiltersEl.classList.remove('flex');
    }
  }

  function renderPages(filteredPages) {
    const container = document.getElementById('pages-container');

    if (filteredPages.length === 0) {
      container.innerHTML = `
        <div class="text-center py-12">
          <p class="text-base-content/60 mb-4">Aucune page trouvée</p>
          <button id="clear-filters-empty" class="btn btn-primary">Effacer les filtres</button>
        </div>
      `;

      // Réattacher l'événement pour effacer les filtres
      document.getElementById('clear-filters-empty').addEventListener('click', () => {
        const root = document.querySelector('.actions-search');
        if (root instanceof HTMLElement) {
          const si = root.querySelector('#search-input');
          const st = root.querySelector('#status-select');
          if (si instanceof HTMLInputElement) si.value = '';
          if (st instanceof HTMLSelectElement) st.value = 'all';
          document.dispatchEvent(new CustomEvent('actions-filter-change', { detail: { search: '', status: 'all' } }));
        } else {
          currentSearch = '';
          currentStatus = 'all';
          updateActiveFilters(currentSearch, currentStatus);
          renderPages(filterPages(currentSearch, currentStatus));
        }
      });
    } else {
      const pagesHtml = `
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          ${filteredPages.map(page => {
            const badge = getStatusBadge(page.status);
            return `
              <div class="card bg-base-100 border" data-page-id="${page.id}">
                <div class="card-body p-4">
                  <div class="flex justify-between items-start mb-2">
                    <h3 class="card-title text-lg">${page.title}</h3>
                    <span class="badge ${badge.className}">${badge.label}</span>
                  </div>
                  <p class="text-sm text-base-content/60 mb-2">/${page.slug}</p>
                  <p class="text-sm text-base-content/60 mb-2">Par ${page.authorName}</p>
                  <p class="text-sm text-base-content/60">${formatDate(page.updatedAt)}</p>
                  <div class="card-actions justify-end mt-4">
                    <a href="${getViewUrl(page.status, page.id, page.slug)}" class="btn btn-sm">Voir</a>
                    <a href="${getEditUrl(page.status, page.id, page.slug)}" class="btn btn-sm">Modifier</a>
                  </div>
                </div>
              </div>
            `;
          }).join('')}
        </div>
      `;
      container.innerHTML = pagesHtml;
    }
  }

  // Initialisation
  document.addEventListener('DOMContentLoaded', () => {
    const clearFiltersBtn = document.getElementById('clear-filters');

    // Listen to the shared ActionsSearch events
    document.addEventListener('actions-filter-change', (ev) => {
      const d = ev.detail || {};
      currentSearch = d.search || '';
      currentBenef = d.beneficiary || '';
      // prefer status if provided, else keep existing
      if (typeof d.status !== 'undefined') currentStatus = d.status || 'all';
      updateActiveFilters(currentSearch, currentStatus);
      renderPages(filterPages(currentSearch, currentStatus, currentBenef));
    });

    // initial render and active filters
    updateActiveFilters(currentSearch, currentStatus);
    renderPages(filterPages(currentSearch, currentStatus, currentBenef));

    clearFiltersBtn.addEventListener('click', () => {
      // Reset component inputs if present
      const root = document.querySelector('.actions-search');
      if (root instanceof HTMLElement) {
        const si = root.querySelector('#search-input');
        const st = root.querySelector('#status-select');
        if (si instanceof HTMLInputElement) si.value = '';
        if (st instanceof HTMLSelectElement) st.value = 'all';
        // emit cleared state
        document.dispatchEvent(new CustomEvent('actions-filter-change', { detail: { search: '', status: 'all' } }));
      } else {
        // fallback
        currentSearch = '';
        currentBenef = '';
        currentStatus = 'all';
        updateActiveFilters(currentSearch, currentStatus);
        renderPages(filterPages(currentSearch, currentStatus, currentBenef));
      }
    });
  });
</script>