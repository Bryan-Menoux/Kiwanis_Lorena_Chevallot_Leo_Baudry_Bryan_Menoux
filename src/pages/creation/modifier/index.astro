---
import Layout from "../../../layouts/Layout-back-office.astro";
import { Collections, type HerosResponse } from "../../../pocketbase-types";

const pageOptions = [
  { value: "index", label: "Page d'accueil" },
  { value: "actions", label: "Actions" },
  { value: "membres", label: "Membres" },
  { value: "projets", label: "Projets" },
  { value: "produits", label: "Produits" },
  { value: "recrutement", label: "Recrutement" },
  { value: "remerciements", label: "Remerciements" },
] as const;

const asText = (value: FormDataEntryValue | null): string =>
  typeof value === "string" ? value.trim() : "";

const getPageLabel = (value: string): string =>
  pageOptions.find((page) => page.value === value)?.label || value;

const redirectWith = (type: "success" | "error", message: string) =>
  Astro.redirect(`/creation/modifier?${type}=${encodeURIComponent(message)}`);

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const intent = asText(formData.get("intent"));
    const id = asText(formData.get("id"));
    const nomPage = asText(formData.get("nom_page")).toLowerCase();
    const image = formData.get("image");

    if (intent !== "update") {
      throw new Error("Action inconnue.");
    }
    if (!id) {
      throw new Error("Hero introuvable.");
    }
    if (!nomPage) {
      throw new Error("Le nom de page est obligatoire.");
    }
    if (!(image instanceof File) || image.size <= 0) {
      throw new Error("Veuillez sélectionner une image.");
    }

    await Astro.locals.pb.collection(Collections.Heros).update(id, {
      nom_page: nomPage,
      image,
    });

    return redirectWith("success", "Hero modifié avec succès.");
  } catch (error) {
    const message =
      error instanceof Error ? error.message : "Une erreur est survenue.";
    return redirectWith("error", message);
  }
}

const heroRecords = await Astro.locals.pb
  .collection(Collections.Heros)
  .getFullList<HerosResponse>(200, { sort: "nom_page" });

const heros = heroRecords.map((hero) => ({
  id: hero.id,
  nomPage: hero.nom_page || "",
  pageLabel: getPageLabel(hero.nom_page || ""),
  imageUrl: hero.image ? Astro.locals.pb.files.getURL(hero, hero.image) : "",
}));

const success = (Astro.url.searchParams.get("success") || "").trim();
const error = (Astro.url.searchParams.get("error") || "").trim();
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    <h1>Images des entêtes</h1>

    {
      success && (
        <div id="hero-success-flag" data-message={success} class="hidden" />
      )
    }
    {error && <div id="hero-error-flag" data-message={error} class="hidden" />}

    {
      heros.length === 0 ? (
        <div class="rounded-2xl border border-base-300 bg-base-100 p-8 text-base-content/60">
          Aucun hero enregistré pour le moment.
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
          {heros.map((hero) => (
            <article class="space-y-4">
              <h2 class="text-2xl font-bold text-base-content">
                {hero.pageLabel}
              </h2>

              <div class="relative overflow-hidden rounded-2xl border border-base-300 bg-base-100 shadow-sm">
                {hero.imageUrl ? (
                  <img
                    src={hero.imageUrl}
                    alt={`Hero ${hero.pageLabel}`}
                    class="h-72 w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
              ) : (
                <div class="flex h-72 items-center justify-center text-sm text-base-content/50">
                  Aucune image
                </div>
              )}

              <div
                class="pointer-events-none absolute bottom-0 right-0 translate-y-1/2 translate-x-1/2 w-[40dvw] h-[40dvw] rounded-full bg-[radial-gradient(circle,rgba(0,0,0,0.9)_0%,rgba(0,0,0,0.64)_28%,rgba(0,0,0,0.26)_50%,rgba(0,0,0,0.01)_62%,transparent_100%)]"
                aria-hidden="true"
              ></div>

              <button
                type="button"
                class="btn btn-block w-fit boder border-accent rounded-full absolute bottom-4 right-4 px-5 md:px-6"
                data-open-hero-modal={hero.id}
              >
                Modifier
              </button>
              </div>

              <dialog id={`hero-modal-${hero.id}`} class="modal">
                <div class="modal-box max-w-xl">
                  <form method="dialog">
                    <button
                      type="submit"
                      class="btn btn-sm btn-circle btn-ghost absolute right-3 top-3"
                      aria-label={`Fermer la modification de ${hero.pageLabel}`}
                    >
                      ✕
                    </button>
                  </form>

                  <h2 class="text-2xl font-bold">{hero.pageLabel}</h2>
                  <p class="mt-2 text-sm text-base-content/70">
                    Remplacez l'image hero de cette page.
                  </p>

                  <form
                    method="POST"
                    enctype="multipart/form-data"
                    class="mt-6 space-y-4"
                  >
                    <input type="hidden" name="intent" value="update" />
                    <input type="hidden" name="id" value={hero.id} />
                    <input type="hidden" name="nom_page" value={hero.nomPage} />

                    <label class="form-control gap-2">
                      <span class="label-text font-medium">Nouvelle image</span>
                      <input
                        type="file"
                        name="image"
                        accept="image/*"
                        class="file-input file-input-bordered w-full"
                        required
                      />
                    </label>

                    <div class="flex justify-end gap-3 pt-2">
                      <button
                        type="button"
                        class="btn btn-ghost rounded-full"
                        data-close-hero-modal={hero.id}
                      >
                        Annuler
                      </button>
                      <button type="submit" class="btn btn-accent rounded-full">
                        Enregistrer
                      </button>
                    </div>
                  </form>
                </div>
                <form method="dialog" class="modal-backdrop">
                  <button type="submit">close</button>
                </form>
              </dialog>
            </article>
          ))}
        </div>
      )
    }
  </div>
</Layout>

<script>
  import { showAlert } from "../../../utils/alerts";

  document.addEventListener("click", (event) => {
    const openButton =
      event.target instanceof HTMLElement
        ? event.target.closest("[data-open-hero-modal]")
        : null;
    if (openButton instanceof HTMLButtonElement) {
      const heroId = openButton.dataset.openHeroModal || "";
      const dialog = document.getElementById(`hero-modal-${heroId}`);
      if (dialog instanceof HTMLDialogElement) {
        dialog.showModal();
      }
      return;
    }

    const closeButton =
      event.target instanceof HTMLElement
        ? event.target.closest("[data-close-hero-modal]")
        : null;
    if (closeButton instanceof HTMLButtonElement) {
      const heroId = closeButton.dataset.closeHeroModal || "";
      const dialog = document.getElementById(`hero-modal-${heroId}`);
      if (dialog instanceof HTMLDialogElement) {
        dialog.close();
      }
    }
  });

  const successFlag = document.getElementById("hero-success-flag");
  const errorFlag = document.getElementById("hero-error-flag");

  if (successFlag instanceof HTMLElement) {
    const message = (successFlag.dataset.message || "").trim();
    if (message) {
      showAlert({ type: "success", message });
      const url = new URL(window.location.href);
      url.searchParams.delete("success");
      window.history.replaceState({}, "", url.toString());
    }
  }

  if (errorFlag instanceof HTMLElement) {
    const message = (errorFlag.dataset.message || "").trim();
    if (message) {
      showAlert({ type: "error", message });
      const url = new URL(window.location.href);
      url.searchParams.delete("error");
      window.history.replaceState({}, "", url.toString());
    }
  }
</script>
