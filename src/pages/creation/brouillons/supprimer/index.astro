---
import Layout from "../../../../layouts/Layout-back-office.astro";
import ItemCard from "../../../../components/ItemCard.astro";
import ActionsSearch from "../../../../components/ActionsSearch.astro";
import slugify from "slugify";
import { normalizeImageUrl } from "../../../../utils/utilitaires.js";
import { getDraftEditUrl, getDraftViewUrl } from "../../../../utils/creationRoutes";

let error = "";
let success = "";
const currentUser = Astro.locals.pb.authStore.model;
const isAdmin = currentUser?.administrateur === true;
const currentUserId = typeof currentUser?.id === "string" ? currentUser.id : "";

let brouillonsRaw: any[] = [];
try {
  brouillonsRaw = await (Astro.locals as any).pb
    .collection("brouillons")
    .getFullList(500, {
      sort: "-updated",
    });
} catch (e) {
  console.error("Impossible de récupérer les brouillons:", e);
  error = "Impossible de charger la liste des brouillons.";
}

if (!isAdmin) {
  brouillonsRaw = brouillonsRaw.filter(
    (draft) => String(draft?.cree_par || "") === currentUserId,
  );
}

const brouillons = brouillonsRaw.map((brouillon) => {
  const title = brouillon.titre || "Brouillon sans titre";
  const slug = slugify(title || "", { lower: true, strict: true }) || "brouillon";

  return {
    id: brouillon.id,
    title,
    slug,
    subtitle:
      brouillon.sous_titre ||
      brouillon.nom_lieu ||
      brouillon.beneficiaire ||
      brouillon.description_hero ||
      "",
    updated: brouillon.updated,
    source: "brouillon" as const,
    photoUrl:
      normalizeImageUrl(brouillon.hero, brouillon, Astro.locals.pb) ||
      normalizeImageUrl(brouillon.photo_partie_1, brouillon, Astro.locals.pb) ||
      normalizeImageUrl(
        Array.isArray(brouillon.galerie_photos) && brouillon.galerie_photos.length
          ? brouillon.galerie_photos[0]
          : "",
        brouillon,
        Astro.locals.pb,
      ) ||
      "",
  };
  });

function formatDate(dateStr?: string): string {
  if (!dateStr) return "";
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString("fr-FR", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  } catch {
    return dateStr;
  }
}

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const ids = formData
      .getAll("ids")
      .map((value) => value.toString())
      .filter(Boolean);

    if (!ids.length) {
      error = "Aucun brouillon sélectionné.";
    } else {
      const failed: string[] = [];

      for (const id of ids) {
        try {
          if (!isAdmin) {
            const draft = await (Astro.locals as any).pb.collection("brouillons").getOne(id);
            if (String(draft?.cree_par || "") !== currentUserId) {
              throw new Error("Vous ne pouvez supprimer que vos propres brouillons.");
            }
          }
          await (Astro.locals as any).pb.collection("brouillons").delete(id);
        } catch (e) {
          console.error("Erreur lors de la suppression du brouillon :", id, e);
          failed.push(id);
        }
      }

      if (failed.length === 0) {
        return Astro.redirect(
          `/creation/brouillons/supprimer?success=${encodeURIComponent(`${ids.length} brouillon(s) supprimé(s) avec succès.`)}`,
        );
      }

      error = `Échec de la suppression pour ${failed.length} brouillon(s).`;
    }
  } catch (e) {
    console.error("Erreur lors du POST de suppression des brouillons :", e);
    error = "La suppression des brouillons a échoué.";
  }
}

try {
  const successParam = Astro.url.searchParams.get("success");
  if (successParam) success = successParam;
} catch {}
---

<Layout>
  <div class="container mx-auto px-4 py-8 my-16 md:my-32">
    <div class="mb-10 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="mb-0">
        <h1 class="mb-3 text-3xl font-bold text-accent font-poppins md:text-4xl">
          Supprimer des brouillons d'actions
        </h1>
        <p class="text-base text-base-content md:text-lg">
          Sélectionnez plusieurs brouillons d'actions puis cliquez sur "Supprimer sélection".
        </p>
      </div>
      <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
        <a
          href="/creation"
          class="btn btn-border btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md"
        >
          Retour à la création
        </a>
      </div>
    </div>

    <div
      id="delete-flash-flags"
      data-success={success}
      data-error={error}
      class="hidden"
    />

    <form method="POST" id="deleteForm">
      <div class="mb-4 space-y-4">
        <div class="card rounded-2xl border border-base-300 bg-base-100 shadow-sm">
          <div class="card-body p-4 md:p-6">
            <div class="mb-4">
              <h2 class="card-title text-2xl">Filtrer</h2>
              <p class="mt-1 text-sm text-base-content">
                Filtrez rapidement vos brouillons d'actions.
              </p>
            </div>
            <ActionsSearch embedded={true} showBeneficiary={false} />
          </div>
        </div>

        <div class="w-full flex flex-wrap items-center gap-3 md:justify-end">
          <label class="flex items-center gap-2">
            <input type="checkbox" id="selectAll" />
            <span class="text-sm">Tout sélectionner</span>
          </label>
          <button
            type="submit"
            id="bulkDelete"
            class="btn btn-error btn-sm rounded-full flex-1 w-full md:flex-initial md:w-fit md:btn-md"
          >
            Supprimer sélection
          </button>
        </div>
      </div>

      {
        brouillons.length === 0 ? (
          <div class="rounded-2xl border border-base-300 bg-base-100 p-6 text-base-content/70 shadow-sm">
            Aucun brouillon disponible pour le moment.
          </div>
        ) : (
          <div
            id="cards-grid"
            class="grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-5 lg:grid-cols-3 lg:gap-6"
          >
            {
              brouillons.map((brouillon) => (
                <ItemCard
                  id={brouillon.id}
                  title={brouillon.title}
                  slug={brouillon.slug}
                  source={brouillon.source}
                  isDraft={true}
                  subtitle={brouillon.subtitle}
                  photoUrl={brouillon.photoUrl}
                  showPhotoPlaceholder={true}
                  formattedDate={formatDate(brouillon.updated)}
                  viewUrl={getDraftViewUrl(brouillon.id, brouillon.slug)}
                  editUrl={getDraftEditUrl(brouillon.id, brouillon.slug)}
                  showCheckbox={true}
                  checkboxSlot={`<input class="checkbox checkbox-primary shrink-0" type="checkbox" name="ids" id="id_${brouillon.id}" value="${brouillon.id}" data-item-id="${brouillon.id}" data-title="${brouillon.title}" data-updated="${brouillon.updated}" />`}
                  maxHeightContent={true}
                  deleteMode={true}
                />
              ))
            }
          </div>
        )
      }
      <div id="cards-pagination" class="mt-6 flex justify-center"></div>
    </form>
  </div>

  <script>
    import { initDeletePageHandler } from "../../../../utils/deletePageHandler";

    initDeletePageHandler({
      cardSelector: "div[data-item-id]",
      itemSingular: "brouillon",
      itemPlural: "brouillons",
    });
  </script>
</Layout>
