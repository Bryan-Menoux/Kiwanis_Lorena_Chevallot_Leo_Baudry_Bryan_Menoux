---
import Layout from "../layouts/Layout.astro";
import DiagArrow from "../components/DiagArrow.astro";
import shapes from "../assets/contact/shapes.svg";

const contactEmail = "kiwanisfeminin.montbeliard@gmail.com";
const contactPhone = "06 49 72 92 58";
const contactTelHref = "tel:+33649729258";
const contactAddress = "76 bis faubourg de Besancon, 25200 Montbeliard";
const facebookUrl = "https://www.facebook.com/profile.php?id=61575848495298";
---

<Layout>
  <Fragment slot="head">
    <title>Contact | Kiwanis Pays de Montbeliard</title>
    <meta
      name="description"
      content="Contactez le Kiwanis Pays de Montbeliard pour toute question, proposition de partenariat ou demande d'information."
    />
  </Fragment>

  <div class="flex flex-col gap-14 md:gap-16 lg:gap-20 max-w-[85dvw]! md:max-w-[80dvw]! mx-auto my-24 md:my-32 lg:my-40">
    <section class="flex flex-col gap-4 md:gap-6">
      <h1>Nous contacter</h1>
      <h3>Echanger avec le Kiwanis feminin Pays de Montbeliard</h3>
      <p class="max-w-3xl">
        Une question, besoin d&apos;informations ou envie de proposer un projet ou un
        partenariat ? Utilisez le formulaire de contact ou les coordonnees ci-dessous,
        nous reviendrons vers vous rapidement.
      </p>
    </section>

    <section class="rounded-box bg-base-200 p-2 md:p-3">
      <div class="grid grid-cols-1 gap-2 md:gap-3 lg:grid-cols-2">
        <aside class="relative overflow-hidden rounded-box bg-accent p-6 md:p-8 lg:p-10 text-accent-content">
          <img
            src={shapes.src}
            alt=""
            aria-hidden="true"
            class="pointer-events-none absolute -bottom-2 -right-2 w-64 md:w-80 opacity-90"
            loading="lazy"
            decoding="async"
          />

          <div class="relative z-10 flex h-full flex-col gap-8">
            <h2 class="text-white">Informations de contact</h2>

            <div class="flex flex-col gap-6">
              <div class="flex items-start gap-4">
                <svg viewBox="0 0 24 24" class="mt-1 h-6 w-6 shrink-0 fill-current text-white" aria-hidden="true">
                  <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1-.24 11.72 11.72 0 0 0 3.67.59 1 1 0 0 1 1 1V21a1 1 0 0 1-1 1A17 17 0 0 1 2 4a1 1 0 0 1 1-1h3.47a1 1 0 0 1 1 1 11.72 11.72 0 0 0 .59 3.67 1 1 0 0 1-.24 1z"></path>
                </svg>
                <a href={contactTelHref} class="hover:opacity-80 transition-opacity">{contactPhone}</a>
              </div>

              <div class="flex items-start gap-4">
                <svg viewBox="0 0 24 24" class="mt-1 h-6 w-6 shrink-0 fill-current text-white" aria-hidden="true">
                  <path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5L4 8V6l8 5 8-5z"></path>
                </svg>
                <a href={`mailto:${contactEmail}`} class="break-all hover:opacity-80 transition-opacity">
                  {contactEmail}
                </a>
              </div>

              <div class="flex items-start gap-4">
                <svg viewBox="0 0 24 24" class="mt-1 h-6 w-6 shrink-0 fill-current text-white" aria-hidden="true">
                  <path d="M12 2a8 8 0 0 0-8 8c0 5.65 7.25 11.37 7.56 11.61a.7.7 0 0 0 .88 0C12.75 21.37 20 15.65 20 10a8 8 0 0 0-8-8zm0 11.5a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7z"></path>
                </svg>
                <p>{contactAddress}</p>
              </div>
            </div>

            <div class="mt-auto flex flex-col gap-4">
              <p>Suivez-nous aussi sur les reseaux !</p>
              <a
                href={facebookUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-outline w-fit border-white/30 text-white hover:bg-white/10 hover:text-white"
              >
                Facebook
                <DiagArrow class="h-3 w-auto" />
              </a>
            </div>
          </div>
        </aside>

        <form data-contact-form class="rounded-box bg-base-100 p-6 md:p-8 lg:p-10 shadow-md flex flex-col gap-6">
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <label class="form-control w-full gap-2">
              <span class="label-text text-base-content/60">Prenom</span>
              <input type="text" name="firstName" autocomplete="given-name" class="input input-bordered w-full" />
            </label>

            <label class="form-control w-full gap-2">
              <span class="label-text text-base-content/60">Nom</span>
              <input type="text" name="lastName" autocomplete="family-name" class="input input-bordered w-full" />
            </label>
          </div>

          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <label class="form-control w-full gap-2">
              <span class="label-text text-base-content/60">Email</span>
              <input type="email" name="email" autocomplete="email" class="input input-bordered w-full" />
            </label>

            <label class="form-control w-full gap-2">
              <span class="label-text text-base-content/60">Numero de telephone</span>
              <input type="tel" name="phone" autocomplete="tel" class="input input-bordered w-full" />
            </label>
          </div>

          <label class="form-control w-full gap-2">
            <span class="label-text text-base-content/60">Message</span>
            <textarea name="message" class="textarea textarea-bordered h-28 w-full resize-y"></textarea>
          </label>

          <label class="form-control w-full gap-2">
            <span class="label-text text-base-content/60">Ajouter des photos (optionnel)</span>
            <div
              data-photo-dropzone
              role="button"
              tabindex="0"
              aria-label="Ajouter des photos"
              class="flex min-h-14 cursor-pointer items-center justify-center gap-3 rounded-box border border-dashed border-base-content/30 bg-base-100 px-4 text-center transition-colors hover:border-accent/50 focus:outline-none focus:ring-2 focus:ring-accent/30"
            >
              <svg viewBox="0 0 24 24" class="h-5 w-5 shrink-0 fill-current text-base-content/50" aria-hidden="true">
                <path d="M14 3v2h3.59L7.29 15.29l1.42 1.42L19 6.41V10h2V3z"></path>
                <path d="M5 5h6V3H3v8h2z"></path>
                <path d="M19 19H5V9H3v12h18V11h-2z"></path>
              </svg>
              <span class="text-sm text-base-content/60">Cliquez pour ajouter des photos ou glissez-deposez</span>
              <input data-photo-input type="file" name="photos" accept="image/*" multiple class="sr-only" />
            </div>
            <p data-photo-summary class="text-sm text-base-content/60">Aucune image ajoutee</p>
            <ul data-photo-list class="flex flex-col gap-2"></ul>
          </label>

          <div class="flex justify-end">
            <button type="button" class="btn btn-accent w-full md:w-fit px-8">
              Envoyer
            </button>
          </div>
        </form>
      </div>
    </section>

    <section class="rounded-box bg-base-100 p-6 md:p-8 lg:p-10 shadow-md flex flex-col gap-6">
      <h2>Contactez-nous autrement</h2>
      <p class="max-w-3xl">
        Vous pouvez aussi nous ecrire par courrier ou deposer un mot dans notre boite
        aux lettres a l&apos;adresse de notre siege : 76 bis faubourg de Besancon,
        25200 Montbeliard.
      </p>
      <p class="max-w-3xl">
        Il est egalement possible de nous joindre par telephone au {contactPhone}
        mais aussi via l&apos;adresse mail : {contactEmail}
      </p>
    </section>
  </div>

  <script>
    const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
    if (form) {
      const photoInput = form.querySelector<HTMLInputElement>("[data-photo-input]");
      const dropzone = form.querySelector<HTMLElement>("[data-photo-dropzone]");
      const summary = form.querySelector<HTMLElement>("[data-photo-summary]");
      const list = form.querySelector<HTMLUListElement>("[data-photo-list]");

      let selectedFiles: File[] = [];

      const formatSize = (bytes: number): string => {
        if (bytes < 1024) return `${bytes} o`;
        if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} Ko`;
        return `${(bytes / (1024 * 1024)).toFixed(1)} Mo`;
      };

      const getFileKey = (file: File): string =>
        `${file.name}-${file.size}-${file.lastModified}`;

      const syncInputFiles = (): void => {
        if (!photoInput) return;
        const dataTransfer = new DataTransfer();
        selectedFiles.forEach((file: File) => dataTransfer.items.add(file));
        photoInput.files = dataTransfer.files;
      };

      const renderSelectedFiles = (): void => {
        if (!summary || !list) return;

        if (selectedFiles.length === 0) {
          summary.textContent = "Aucune image ajoutee";
          list.innerHTML = "";
          return;
        }

        summary.textContent =
          selectedFiles.length === 1
            ? "1 image ajoutee"
            : `${selectedFiles.length} images ajoutees`;

        list.innerHTML = selectedFiles
          .map(
            (file: File, index: number) => `
              <li class="flex items-center justify-between rounded-box bg-base-200 px-3 py-2">
                <div class="min-w-0">
                  <p class="truncate text-sm text-base-content">${file.name}</p>
                  <p class="text-xs text-base-content/60">${formatSize(file.size)}</p>
                </div>
                <button type="button" data-remove-photo="${index}" class="btn btn-ghost btn-xs">Retirer</button>
              </li>
            `,
          )
          .join("");
      };

      const addFiles = (incoming: FileList | File[]): void => {
        const imageFiles = Array.from(incoming).filter((file: File) =>
          file.type.startsWith("image/"),
        );

        const knownKeys = new Set(selectedFiles.map((file: File) => getFileKey(file)));

        imageFiles.forEach((file: File) => {
          const fileKey = getFileKey(file);
          if (!knownKeys.has(fileKey)) {
            knownKeys.add(fileKey);
            selectedFiles.push(file);
          }
        });

        syncInputFiles();
        renderSelectedFiles();
      };

      if (photoInput) {
        photoInput.addEventListener("change", () => {
          if (photoInput.files) {
            addFiles(photoInput.files);
          }
        });
      }

      if (dropzone && photoInput) {
        dropzone.addEventListener("keydown", (event: KeyboardEvent) => {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            photoInput.click();
          }
        });

        const onDragOver = (event: DragEvent): void => {
          event.preventDefault();
          dropzone.classList.add("border-accent");
          dropzone.classList.add("bg-base-200");
        };

        const onDragLeave = (event: DragEvent): void => {
          event.preventDefault();
          dropzone.classList.remove("border-accent");
          dropzone.classList.remove("bg-base-200");
        };

        dropzone.addEventListener("dragenter", onDragOver);
        dropzone.addEventListener("dragover", onDragOver);
        dropzone.addEventListener("dragleave", onDragLeave);
        dropzone.addEventListener("drop", (event: DragEvent) => {
          event.preventDefault();
          dropzone.classList.remove("border-accent");
          dropzone.classList.remove("bg-base-200");

          if (event.dataTransfer?.files?.length) {
            addFiles(event.dataTransfer.files);
          }
        });
      }

      if (list) {
        list.addEventListener("click", (event: MouseEvent) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;

          const removeIndex = target.getAttribute("data-remove-photo");
          if (removeIndex === null) return;

          const index = Number(removeIndex);
          if (Number.isNaN(index)) return;

          selectedFiles = selectedFiles.filter((_: File, fileIndex: number) => fileIndex !== index);
          syncInputFiles();
          renderSelectedFiles();
        });
      }
    }
  </script>
</Layout>
