---
import Layout from "../layouts/Layout-login.astro";
import shapesLeft from "../assets/login-page/shapes-left.svg";
import shapesRight from "../assets/login-page/shapes-right.svg";
import logo from "../assets/logo-kiwanis-full.svg";
import backArrow from "../assets/back-arrow.svg";
import userIcon from "../assets/login-page/user.svg";
import lockIcon from "../assets/login-page/lock.svg";

// Si l'utilisateur est déjà connecté, le rediriger vers la page d'accueil
console.log("[CONNEXION] Vérification si utilisateur déjà connecté...");
console.log("[CONNEXION] authStore.isValid:", Astro.locals.pb.authStore.isValid);
if (Astro.locals.pb.authStore.isValid) {
  console.log("[CONNEXION] Utilisateur déjà connecté, redirection vers /");
  Astro.response.status = 302;
  Astro.response.headers.set("Location", "/");
}


let userVerificated = true;
let serverMessage = "";

const isPostForm =
  Astro.request.method === "POST" &&
  Astro.request.headers.get("content-type")?.includes("form");

console.log("[CONNEXION] Méthode requête:", Astro.request.method);
console.log("[CONNEXION] isPostForm:", isPostForm);

if (isPostForm) {
  console.log("[CONNEXION] ===== DÉBUT TENTATIVE CONNEXION =====");
  try {
    const data = await Astro.request.formData();
    const email = data.get("email")?.toString() ?? "";
    const password = data.get("password")?.toString() ?? "";

    console.log("[CONNEXION] Email reçu:", email);
    console.log("[CONNEXION] Mot de passe reçu: (longueur:", password.length, ")");
    console.log("[CONNEXION] Tentative authWithPassword...");

    await Astro.locals.pb.collection("users").authWithPassword(email, password);
    
    console.log("[CONNEXION] ✓ Authentification réussie");

    const user = Astro.locals.pb.authStore.model;
    console.log("[CONNEXION] Utilisateur récupéré:", user);
    console.log("[CONNEXION] User ID:", user?.id);
    console.log("[CONNEXION] User verified:", user?.verified);

    if (!user?.verified) {
      console.log("[CONNEXION] ✗ Utilisateur non vérifié");
      Astro.locals.pb.authStore.clear();
      userVerificated = false;
      serverMessage =
        "Vous devez attendre la vérification de votre compte par un administrateur.";
      throw new Error("not_verified");
    }

    console.log("[CONNEXION] ✓ Utilisateur vérifié");
    console.log("[CONNEXION] Export du cookie d'authentification...");
    const cookie = Astro.locals.pb.authStore.exportToCookie();
    console.log("[CONNEXION] Cookie:", cookie);
    
    Astro.response.headers.append(
      "set-cookie",
      cookie,
    );
    console.log("[CONNEXION] ✓ Cookie défini dans les headers");
    console.log("[CONNEXION] Redirection vers /");
    
    Astro.response.status = 302;
    Astro.response.headers.set("Location", "/");
  } catch (error) {
    console.log("[CONNEXION] ✗ ERREUR:", error);
    console.log("[CONNEXION] Message erreur:", (error as Error).message);
    console.log("[CONNEXION] Stack:", (error as Error).stack);
    
    if (userVerificated === true) {
      userVerificated = false;
      serverMessage = "Échec de la connexion. Vérifiez vos identifiants.";
    }
    console.log("[CONNEXION] Message final:", serverMessage);
  }
  console.log("[CONNEXION] ===== FIN TENTATIVE CONNEXION =====");
}
---

<Layout>
  <div
    class="absolute top-8 left-8 flex items-center text-white hover:underline z-10"
  >
    <img src={backArrow.src} aria-hidden="true" />
    <a href="/" class="text-white ml-2">Retour à l'accueil</a>
  </div>
  <img
    src={shapesLeft.src}
    aria-hidden="true"
    class="absolute left-0 bottom-0 w-[50dvw] lg:w-[25dvw] select-none"
    draggable="false"
  />
  <img
    src={shapesRight.src}
    aria-hidden="true"
    class="absolute right-0 top-0 w-[70dvw] md:w-[50dvw] lg:w-[40dvw] select-none"
    draggable="false"
  />

  <div
    class="absolute -translate-x-1/2 -translate-y-1/2 left-1/2 top-1/2 flex flex-col lg:flex-row gap-4 md:gap-16 justify-center items-center z-10"
  >
    <img
      src={logo.src}
      alt="Logo Kiwanis Pays de Montbéliard"
      class="md:w-[30dvw] lg:w-[15dvw]"
    />
    <div class="lg:max-w-[20dvw]">
      <div
        id="auth-flags"
        data-user-verificated={String(userVerificated)}
        data-message={serverMessage}
        class="hidden"
      >
      </div>

      <form method="POST" class="flex flex-col w-full relative">
        <div
          id="errorText"
          class="absolute left-0 right-0 text-sm text-start font-semibold opacity-0 pointer-events-none"
          style="bottom: calc(100% + 0.5rem);"
        >
        </div>

        <div class="relative my-2">
          <img
            src={userIcon.src}
            alt=""
            class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 opacity-70"
          />
          <input
            type="email"
            name="email"
            placeholder="Adresse e-mail"
            class="input input-bordered w-full pl-10 bg-transparent border-gray-200 text-gray-200"
          />
        </div>
        <div class="relative my-2">
          <img
            src={lockIcon.src}
            alt=""
            class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 opacity-70"
          />
          <input
            type="password"
            name="password"
            placeholder="Mot de passe"
            class="input input-bordered w-full pl-10 bg-transparent border-gray-200 text-gray-200"
          />
        </div>

        <button
          class="btn btn-primary rounded-lg! bg-white text-primary w-full mt-4"
          >Se connecter</button
        >
      </form>
      <div
        class="flex justify-between w-full mt-4 text-sm text-white gap-x-4 flex-wrap md:flex-row"
      >
        <a href="/inscription">S'inscrire</a>
        <a href="/mot-de-passe-oublie">Mot de passe oublié ?</a>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";

  console.log("[CONNEXION CLIENT] Script client chargé");

  const errorText = document.getElementById("errorText");
  const flags = document.getElementById("auth-flags");

  console.log("[CONNEXION CLIENT] errorText element:", errorText);
  console.log("[CONNEXION CLIENT] flags element:", flags);

  function showError(message: string, type = "error") {
    console.log("[CONNEXION CLIENT] showError appelé - message:", message, "type:", type);
    if (!errorText) {
      console.log("[CONNEXION CLIENT] ✗ errorText est null, impossible d'afficher l'erreur");
      return;
    }

    gsap.killTweensOf(errorText);
    gsap.set(errorText, { opacity: 0, y: 60 });

    errorText.classList.remove("text-red-500", "text-secondary");
    errorText.classList.add(
      type === "warning" ? "text-secondary" : "text-red-500",
    );

    errorText.textContent = message;
    errorText.style.pointerEvents = "auto";

    console.log("[CONNEXION CLIENT] Classes ajoutées:", errorText.className);
    console.log("[CONNEXION CLIENT] Animation en cours...");

    requestAnimationFrame(() => {
      gsap.to(errorText, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: "power2.out",
      });
      console.log("[CONNEXION CLIENT] Animation terminée");
    });
  }

  // Afficher les erreurs injectées par le serveur au chargement de la page
  if (flags) {
    const userVerificated = flags.dataset.userVerificated === "true";
    const message = flags.dataset.message || "";

    console.log("[CONNEXION CLIENT] Flags détectés");
    console.log("[CONNEXION CLIENT] userVerificated:", userVerificated);
    console.log("[CONNEXION CLIENT] message:", message);

    if (!userVerificated) {
      console.log("[CONNEXION CLIENT] Affichage de l'erreur de vérification");
      showError(
        message ||
          "Veuillez vérifier votre adresse e-mail avant de vous connecter.",
        "warning",
      );
    }
  } else {
    console.log("[CONNEXION CLIENT] Aucun flags détectés");
  }

  // Bonus: Logger les events du formulaire
  const form = document.querySelector('form');
  if (form) {
    console.log("[CONNEXION CLIENT] Formulaire trouvé, ajout des listeners");
    form.addEventListener('submit', (e) => {
      const formData = new FormData(form);
      const email = formData.get('email');
      const password = formData.get('password');
      console.log("[CONNEXION CLIENT] Formulaire soumis - email:", email, "password longueur:", (password as string).length);
    });
  }
</script>