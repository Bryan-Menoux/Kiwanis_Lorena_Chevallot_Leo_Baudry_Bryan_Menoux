---
import Layout from "../layouts/Layout-login.astro";

import shapesLeft from "../assets/login-page/shapes-left.svg";
import shapesRight from "../assets/login-page/shapes-right.svg";
import logo from "../assets/logo-kiwanis-full.svg";
import backArrow from "../assets/back-arrow.svg";
import userIcon from "../assets/login-page/user.svg";
import lockIcon from "../assets/login-page/lock.svg";

// Si l'utilisateur est déjà connecté, le rediriger vers la page d'accueil
if (Astro.locals.pb.authStore.isValid) {
  Astro.response.status = 302;
  Astro.response.headers.set("Location", "/");
}


let userVerificated = true;
let serverMessage = "";

const isPostForm =
  Astro.request.method === "POST" &&
  Astro.request.headers.get("content-type")?.includes("form");


if (isPostForm) {
  try {
    const data = await Astro.request.formData();
    const email = data.get("email")?.toString() ?? "";
    const password = data.get("password")?.toString() ?? "";

    await Astro.locals.pb.collection("users").authWithPassword(email, password);
    
    const user = Astro.locals.pb.authStore.model;

    if (!user?.verified) {
      Astro.locals.pb.authStore.clear();
      userVerificated = false;
      serverMessage =
        "Votre compte n'est pas encore vérifié. Un administrateur doit valider votre inscription avant la connexion.";
      throw new Error("not_verified");
    }

    const cookie = Astro.locals.pb.authStore.exportToCookie();
    
    Astro.response.headers.append(
      "set-cookie",
      cookie,
    );
    
    // destination finale : soit le paramètre redirect, sinon la racine
    let dest = "/";
    const redirectParam = data.get("redirect")?.toString();
    if (redirectParam) {
      try {
        // protéger contre les redirections externes
        const u = new URL(redirectParam, Astro.request.url);
        if (u.origin === new URL(Astro.request.url).origin) {
          dest = u.pathname + u.search;
        }
      } catch {}
    }
    Astro.response.status = 302;
    Astro.response.headers.set("Location", dest);
  } catch (error) {
    
    if (userVerificated === true) {
      userVerificated = false;
      serverMessage =
        "Connexion impossible. Vérifiez votre adresse e-mail et votre mot de passe.";
    }
  }
}
---

<Layout>
  <div
    class="absolute top-8 left-8 flex items-center text-white hover:underline z-10"
  >
    <img src={backArrow.src} alt="" loading="eager" aria-hidden="true"  decoding="async" />
    <a href="/" class="text-white ml-2">Retour à l'accueil</a>
  </div>
  <img
    src={shapesLeft.src}
    alt=""
    loading="eager"
    aria-hidden="true"
    class="absolute left-0 bottom-0 w-[50dvw] lg:w-[25dvw] select-none"
    draggable="false"
   decoding="async" />
  <img
    src={shapesRight.src}
    alt=""
    loading="eager"
    aria-hidden="true"
    class="absolute right-0 top-0 w-[70dvw] md:w-[50dvw] lg:w-[40dvw] select-none"
    draggable="false"
   decoding="async" />

  <div
    class="absolute -translate-x-1/2 -translate-y-1/2 left-1/2 top-1/2 flex flex-col lg:flex-row gap-4 md:gap-16 justify-center items-center z-10"
  >
    <img
      src={logo.src}
      alt="Logo Kiwanis Pays de Montbéliard"
      loading="eager"
      class="md:w-[30dvw] lg:w-[15dvw]"
     decoding="async" />
    <div class="w-fit min-w-[70dvw] md:min-w-[60dvw] lg:min-w-[20dvw] lg:max-w-[60dvw]">
      <div
        id="auth-flags"
        data-user-verificated={String(userVerificated)}
        data-message={serverMessage}
        class="hidden"
      >
      </div>

      <form method="POST" class="flex flex-col w-full relative">
        <!-- garder l'URL de redirection si fournie -->
        <input type="hidden" name="redirect" value={Astro.url.searchParams.get("redirect") ?? ""} />
        <div class="relative my-2">
          <img
            src={userIcon.src}
            alt=""
            loading="eager"
            class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 opacity-70"
           decoding="async" />
          <input
            type="email"
            name="email"
            placeholder="Adresse e-mail"
            class="input input-bordered w-full pl-10 bg-transparent border-gray-200 text-gray-200"
          />
        </div>
        <div class="relative my-2">
          <img
            src={lockIcon.src}
            alt=""
            loading="eager"
            class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 opacity-70"
           decoding="async" />
          <input
            type="password"
            name="password"
            placeholder="Mot de passe"
            class="input input-bordered w-full pl-10 bg-transparent border-gray-200 text-gray-200"
          />
        </div>

        <button
          class="btn btn-primary rounded-lg! bg-white text-primary w-full mt-4 lg:mt-8"
          >Se connecter</button
        >
      </form>
      <div
        class="flex justify-between w-full mt-4 text-sm text-white gap-x-4 flex-wrap md:flex-row"
      >
        <a href="/inscription">S'inscrire</a>
        <a href="/mot-de-passe-oublie">Mot de passe oublié ?</a>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { showAlert } from "../utils/alerts";

  const flags = document.getElementById("auth-flags");

  type AuthAlertType = "error" | "warning" | "success" | "info";

  function showError(message: string, type: AuthAlertType = "error") {
    showAlert({
      message,
      type,
    });
  }

  // Affiche les erreurs injectées par le serveur au chargement de la page
  if (flags) {
    const userVerificated = flags.dataset.userVerificated === "true";
    const message = flags.dataset.message || "";

    if (!userVerificated) {
      showError(
        message ||
          "Votre compte n'est pas encore vérifié. Vérifiez votre adresse e-mail, puis attendez la validation d'un administrateur.",
        "warning",
      );
    }
  } else {
    showError("Une erreur est survenue lors du chargement de la page de connexion.");
  }

  // Bonus : journalise les événements du formulaire
  const form = document.querySelector('form');
  if (form) {
    form.addEventListener('submit', (e) => {
      const formData = new FormData(form);
      const email = formData.get('email');
      const password = formData.get('password');
    });
  }
</script>
