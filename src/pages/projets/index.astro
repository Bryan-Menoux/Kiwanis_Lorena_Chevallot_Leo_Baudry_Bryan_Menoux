---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import slugify from "slugify";
import { formatDateShort } from "../../utils/utilitaires.js";
import HeroActions from "../../assets/projects-page/hero-project-page.png";
import HeroActionsMobile from "../../assets/projects-page/hero-project-page.png";
import HeroActionsTablet from "../../assets/projects-page/hero-project-page.png";
import { getImage } from "astro:assets";

const lcpMobile = await getImage({ src: HeroActionsMobile, format: "png", width: 440, quality: 80 });
const lcpTablet = await getImage({ src: HeroActionsTablet, format: "png", width: 1280, quality: 80 });
const lcpDesktop = await getImage({ src: HeroActions, format: "png", width: 1600, quality: 80 });

const projects = await Astro.locals.pb.collection("projets").getFullList();
console.log(projects);

import DiagArrow from "../../components/DiagArrow.astro";
---

<Layout>
  <Fragment slot="head">
    <link rel="preload" as="image" href={lcpMobile.src} type="image/png" media="(max-width: 767px)" fetchpriority="high" />
    <link rel="preload" as="image" href={lcpTablet.src} type="image/png" media="(min-width: 768px) and (max-width: 1023px)" fetchpriority="high" />
    <link rel="preload" as="image" href={lcpDesktop.src} type="image/png" media="(min-width: 1024px)" fetchpriority="high" />
  </Fragment>
  <Hero
    image={HeroActions}
    title="Kiwanis Pays de Montbéliard"
    subtitle="Servir les enfants du monde, au cœur de notre territoire"
  />

  <section class="min-h-[80dvh] h-[520dvh] bg-red-600 w-full mt-64 flex">
    <div class="w-1/2 min-h-[80dvh] rounded-tr-box rounded-br-box bg-accent flex flex-col justify-between items-center px-8 py-16 text-base-100 sticky top-[15dvh] self-start">
      <div class="flex flex-col gap-8">
        <p class="text-sm font-bold" >Prochaines actions</p>
      <h2 class="text-5xl!">Découvrez nos projets futurs !</h2>
      <p>Découvrez les initiatives que nous préparons avec nos partenaires pour répondre à des besoins concrets sur le territoire. Chaque projet est pensé pour créer du lien, soutenir des publics fragilisés et renforcer la solidarité locale, avec des actions claires, des objectifs simples et un impact réel.</p>
      </div>
      <a href="/actions" class="btn btn-block flex items-center gap-2 uppercase w-fit self-end" >Découvrez nos actions passées <DiagArrow class="h-3 w-auto invert" /></a>
    </div>
    <div class="w-1/2 min-h-fit bg-blue-600 flex flex-col gap-16 px-16 py-32">
      <div class="w-full h-[50dvh] bg-base-100 shadow-2xl rounded-box px-16 py-8"><h2>test</h2></div>
      <div class="w-full h-[50dvh] bg-base-100 shadow-2xl rounded-box px-16 py-8"><h2>test</h2></div>
      <div class="w-full h-[50dvh] bg-base-100 shadow-2xl rounded-box px-16 py-8"><h2>test</h2></div>
      <div class="w-full h-[50dvh] bg-base-100 shadow-2xl rounded-box px-16 py-8"><h2>test</h2></div>
      <div class="w-full h-[50dvh] bg-base-100 shadow-2xl rounded-box px-16 py-8"><h2>test</h2></div>
      <div class="w-full h-[50dvh] bg-base-100 shadow-2xl rounded-box px-16 py-8"><h2>test</h2></div>
      <div class="w-full h-[50dvh] bg-base-100 shadow-2xl rounded-box px-16 py-8"><h2>test</h2></div>
      <div class="w-full h-[50dvh] bg-base-100 shadow-2xl rounded-box px-16 py-8"><h2>test</h2></div>
    </div>

  </section>
</Layout>
