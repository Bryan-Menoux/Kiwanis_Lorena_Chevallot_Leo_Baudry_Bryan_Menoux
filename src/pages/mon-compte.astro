---
import Layout from "../layouts/Layout.astro";
import AccountSection from "../components/Account-section.astro";
import VerificationSection from "../components/Verification-Account-section.astro";
import HelpAccountSection from "../components/Help-Account-section.astro";
import ModificationSection from "../components/Modification-Account-section.astro";
import user from "../assets/user.svg";
import circleCheck from "../assets/circle-check.svg";
import help from "../assets/help.svg";
import edit from "../assets/edit.svg";
import logout from "../assets/logout.svg";

// Vérifier si l'utilisateur est authentifié, sinon rediriger vers la connexion
if (!Astro.locals.pb.authStore.isValid) {
  return Astro.redirect("/connexion");
}

const currentUser = Astro.locals.pb.authStore.model;

// Si l'utilisateur n'existe pas ou n'est pas vérifié, nettoyer la session et rediriger
if (!currentUser || !currentUser.verified) {
  Astro.locals.pb.authStore.clear();
  return Astro.redirect("/connexion");
}

const isAdmin = currentUser.administrateur === true;
let users: any[] = [];

// Si admin, récupérer la liste complète des utilisateurs pour les vérifications
if (isAdmin) {
  users = await Astro.locals.pb.collection("users").getFullList();
}

const success = Astro.url.searchParams.get("success") === "true";

// Construire les éléments de navigation selon le rôle de l'utilisateur
const navItems = [
  { id: "my-account", label: "Mon compte", icon: user },
  ...(isAdmin ? [
    { id: "verifications", label: "Vérifications", icon: circleCheck },
    { id: "modifications", label: "Modifications", icon: edit },
  ] : []),
  { id: "help", label: "Aide", icon: help },
];
---

<Layout>
  <nav class="hidden lg:block bg-white rounded-box p-4 fixed top-1/2 w-56 left-4 -translate-y-1/2 z-50 shadow-lg">
    <ul class="space-y-2">
      {navItems.map((item, i) => (
        <li>
          <a
            href={`#${item.id}`}
            class={`nav-link flex items-center gap-3 px-4 py-3 rounded-lg transition-colors ${i === 0 ? 'bg-accent text-white' : 'hover:bg-base-200'}`}
            data-section={item.id}
          >
            <img src={item.icon.src} class={`w-6 h-6 ${i === 0 ? 'filter brightness-0 invert' : ''}`} />
            <span>{item.label}</span>
          </a>
        </li>
      ))}
      <li class="pt-4 border-t">
        <button id="logout-btn" class="w-full flex items-center gap-3 px-4 py-3 rounded-lg bg-accent text-white hover:bg-accent-focus transition-colors">
          <img src={logout.src} class="w-6 h-6 filter brightness-0 invert" />
          <span>Déconnexion</span>
        </button>
      </li>
    </ul>
  </nav>

  <nav class="lg:hidden bg-white fixed bottom-0 left-0 w-full z-50 shadow-lg border-t">
    <ul class="flex justify-around py-2 relative">
      <div id="mobile-indicator" class="absolute bottom-0 h-1 bg-accent rounded-t-full transition-all duration-300" style={`width: ${100 / navItems.length}%; left: 0;`}></div>
      {navItems.map((item, i) => (
        <li class="flex-1">
          <a
            href={`#${item.id}`}
            class={`nav-link-mobile flex flex-col items-center gap-1 p-2 ${i === 0 ? 'text-accent' : 'text-base-content'}`}
            data-section={item.id}
          >
            <img src={item.icon.src} class={`w-6 h-6 ${i === 0 ? 'opacity-100' : 'opacity-60'}`} />
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="flex flex-1 w-full overflow-x-auto snap-x snap-mandatory scroll-smooth" id="content-container">
    {navItems.map((item) => (
      <section class="min-w-full snap-start" id={item.id}>
        {item.id === "my-account" ? (
          <AccountSection success={success} />
        ) : item.id === "verifications" ? (
          <VerificationSection users={users} isAdmin={isAdmin} currentUserId={currentUser.id} />
        ) : item.id === "modifications" ? (
          <ModificationSection />
        ) : (
          <HelpAccountSection />
        )}
      </section>
    ))}
  </div>
</Layout>
<style>
  #content-container {
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
  }
</style>

<script>
  import gsap from "gsap";
  import { initVerifications } from "../scripts/verification-handlers.js";
  import { initModifications } from "../scripts/modification-handlers.js";

  const container = document.getElementById("content-container");
  const navLinks = document.querySelectorAll(".nav-link");
  const navLinksMobile = document.querySelectorAll(".nav-link-mobile");
  const mobileIndicator = document.getElementById("mobile-indicator");
  let currentSection = 0;

  // Met à jour la position de l'indicateur mobile selon l'index de la section
  function updateMobileIndicator(index: number) {
    if (!mobileIndicator || navLinksMobile.length === 0) return;
    const itemWidth = 100 / navLinksMobile.length;
    mobileIndicator.style.width = `${itemWidth}%`;
    mobileIndicator.style.left = `${itemWidth * index}%`;
  }

  // Définit la section active en mettant à jour les styles pour desktop et mobile
  function setActive(index: number) {
    currentSection = index;
    updateMobileIndicator(index);
    
    // Appliquer les styles pour la navigation desktop
    navLinks.forEach((link, i) => {
      const isActive = i === index;
      link.classList.toggle("bg-accent", isActive);
      link.classList.toggle("text-white", isActive);
      link.classList.toggle("hover:bg-base-200", !isActive);
      const img = link.querySelector("img");
      if (img) {
        img.classList.toggle("filter", isActive);
        img.classList.toggle("brightness-0", isActive);
        img.classList.toggle("invert", isActive);
      }
    });

    // Appliquer les styles pour la navigation mobile
    navLinksMobile.forEach((link, i) => {
      const isActive = i === index;
      link.classList.toggle("text-accent", isActive);
      link.classList.toggle("text-base-content", !isActive);
      const img = link.querySelector("img");
      if (img) {
        img.classList.toggle("opacity-100", isActive);
        img.classList.toggle("opacity-60", !isActive);
      }
    });
  }

  // Gérer les clics sur les liens de navigation pour scroller vers la section
  [...navLinks, ...navLinksMobile].forEach((link, i) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const sectionId = (link as HTMLElement).dataset.section;
      const section = document.getElementById(sectionId!);
      if (section && container) {
        // Scroller vers le haut de la page pour éviter de perdre l'utilisateur
        window.scrollTo({ top: 0, behavior: "smooth" });
        // Scroller horizontalement vers la section
        container.scrollTo({ left: section.offsetLeft, behavior: "smooth" });
        setActive(i % navLinks.length);
      }
    });
  });

  // Détecter le scroll manuel et mettre à jour la section active
  if (container) {
    let timeout: number;
    container.addEventListener("scroll", () => {
      clearTimeout(timeout);
      timeout = window.setTimeout(() => {
        const scrollLeft = container.scrollLeft;
        const width = container.offsetWidth;
        const index = Math.round(scrollLeft / width);
        setActive(index);
      }, 100);
    });
  }

  updateMobileIndicator(0);

  initVerifications();

  // Gérer la déconnexion
