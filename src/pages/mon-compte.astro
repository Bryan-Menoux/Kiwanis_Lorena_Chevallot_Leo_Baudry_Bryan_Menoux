---
// Importation des composants et ressources nécessaires pour la page
import Layout from "../layouts/Layout.astro";
import AccountSection from "../components/Account-section.astro";
import VerificationSection from "../components/Verification-Account-section.astro";
import HelpAccountSection from "../components/Help-Account-section.astro";
import user from "../assets/user.svg";
import circleCheck from "../assets/circle-check.svg";
import help from "../assets/help.svg";
import { getUnverifiedUsers } from "../lib/pocketbase.mjs";

// Récupération des utilisateurs non vérifiés pour la section admin
let unverifiedUsers: any[] = [];
try {
  const users = await getUnverifiedUsers() as any[];
  unverifiedUsers = users || [];
} catch (error: unknown) {
  unverifiedUsers = [];
}

// Définition des éléments de navigation pour la page de compte
// La visibilité de "verifications" est gérée dynamiquement côté client selon les permissions
const navItems = [
  { id: "my-account", label: "Mon compte", icon: user, active: true, marginTop: false, show: true },
  { id: "verifications", label: "Vérifications", icon: circleCheck, active: false, marginTop: false, show: false },
  { id: "help", label: "Aide", icon: help, active: false, marginTop: true, show: true }
] as const;
---
<Layout>
  <!-- Navigation latérale fixe pour accéder aux différentes sections du compte -->
  <nav
    class="bg-white rounded-box p-6 fixed top-1/2 left-4 -translate-y-1/2 z-50 shadow-lg"
    aria-label="Navigation de compte"
  >
    <ul class="flex flex-col gap-4 items-center relative">
      <!-- Indicateur visuel qui suit l'élément actif dans la navigation -->
      <div 
        id="nav-indicator" 
        class="btn btn-accent absolute h-13 rounded-box px-4 py-2 flex items-center" 
        style="pointer-events: none; width: 190px; left: 0; top: 0;"
        aria-hidden="true"
      ></div>
      {navItems.map((item) => (
        <li 
          class:list={[
            "flex items-center gap-4 min-w-full cursor-pointer transition-colors duration-300 px-4 relative nav-item h-13",
            { "nav-item-active": item.active, "mt-8": item.marginTop },
            item.show === false ? "hidden" : ""
          ]}
          role="tab"
          aria-selected={item.active}
          data-section={item.id}
        >
          <div class="w-10 h-10 icon-accent" style={`--icon-url: url(${item.icon.src})`}></div>
          <a href={`#${item.id}`}>{item.label}</a>
        </li>
      ))}
    </ul>
  </nav>
  <!-- Contenu principal avec défilement horizontal pour les sections -->
  <main
    class="flex flex-1 w-full h-fit overflow-x-scroll scrollbar-hide scroll-smooth snap-x snap-mandatory"
    id="content-container"
    role="tabpanel"
  >
    {navItems.map((item) => (
      <section 
        class:list={[
          "min-w-full h-full snap-start",
          item.show === false ? "hidden" : ""
        ]}
        id={item.id}
      >
        {item.id === "my-account" ? <AccountSection /> : item.id === "verifications" ? <VerificationSection unverifiedUsers={unverifiedUsers as any[]} /> : <HelpAccountSection />}
      </section>
    ))}
  </main>
</Layout>
<!-- Styles pour l'indicateur de navigation et les éléments actifs -->
<style>
  #nav-indicator {
    will-change: transform;
    z-index: 0;
  }
  .nav-item {
    z-index: 20;
  }
  .nav-item-active a {
    color: white;
  }
  .nav-item-active .icon-accent {
    filter: brightness(0) invert(1);
  }
</style>
<script>
  // Importation de la bibliothèque d'animation GSAP
  import gsap from 'gsap';
  
  // Récupération des éléments DOM nécessaires pour la navigation
  const indicator = document.getElementById('nav-indicator');
  const navList = indicator?.parentElement;
  const navItems = document.querySelectorAll<HTMLElement>('.nav-item');
  const contentContainer = document.getElementById('content-container');
  const sections = document.querySelectorAll<HTMLElement>('main section');
  
  // Vérification que tous les éléments requis sont présents
  if (!indicator || !navList || !contentContainer) throw new Error('Required elements not found');
  
  // Configuration des animations rapides pour l'indicateur
  const quickTo = {
    x: gsap.quickTo(indicator, 'x', { duration: 0.25, ease: 'power2.out' }),
    y: gsap.quickTo(indicator, 'y', { duration: 0.25, ease: 'power2.out' }),
    width: gsap.quickTo(indicator, 'width', { duration: 0.25, ease: 'power2.out' }),
    height: gsap.quickTo(indicator, 'height', { duration: 0.25, ease: 'power2.out' })
  };
  
  // Variables pour gérer l'état du défilement
  let isScrolling = false;
  let scrollTimeout: ReturnType<typeof setTimeout>;
  
  // Met à jour l'état actif des éléments de navigation
  function updateActiveState(item: HTMLElement) {
    navItems.forEach(nav => {
      nav.classList.remove('nav-item-active');
      nav.setAttribute('aria-selected', 'false');
    });
    item.classList.add('nav-item-active');
    item.setAttribute('aria-selected', 'true');
  }
  
  // Déplace l'indicateur vers l'élément de navigation spécifié
  function moveIndicator(item: HTMLElement, instant = false) {
    if (!navList) return;
    const listRect = navList.getBoundingClientRect();
    const itemRect = item.getBoundingClientRect();
    const x = itemRect.left - listRect.left;
    const y = itemRect.top - listRect.top;
    if (instant) {
      gsap.set(indicator, { x, y, width: itemRect.width, height: itemRect.height });
    } else {
      quickTo.x(x);
      quickTo.y(y);
      quickTo.width(itemRect.width);
      quickTo.height(itemRect.height);
    }
    updateActiveState(item);
  }
  
  // Gestion des clics sur les éléments de navigation
  navItems.forEach(navItem => {
    navItem.addEventListener('click', (e) => {
      e.preventDefault();
      const sectionId = navItem.dataset.section;
      const section = sectionId && document.getElementById(sectionId);
      if (section) {
        isScrolling = true;
        clearTimeout(scrollTimeout);
        moveIndicator(navItem);
        contentContainer.scrollTo({
          left: section.offsetLeft,
          behavior: 'smooth'
        });
        scrollTimeout = setTimeout(() => { isScrolling = false; }, 800);
      }
    });
  });
  
  // Observateur pour détecter quelle section est visible lors du défilement
  const observer = new IntersectionObserver((entries) => {
    if (isScrolling) return;
    const visibleEntries = entries.filter(entry => {
      const section = entry.target as HTMLElement;
      return !section.classList.contains('hidden') && entry.isIntersecting && entry.intersectionRatio > 0.8;
    });
    if (visibleEntries.length === 0) return;
    let mostVisible = visibleEntries[0];
    visibleEntries.forEach(entry => {
      if (entry.intersectionRatio > mostVisible.intersectionRatio) {
        mostVisible = entry;
      }
    });
    const navItem = Array.from(navItems).find(
      item => item.dataset.section === mostVisible.target.id
    );
    if (navItem && mostVisible.target.id !== 'my-account') {
      moveIndicator(navItem);
    }
  }, { 
    root: contentContainer, 
    threshold: [0.8, 0.9, 1]
  });
  sections.forEach(section => observer.observe(section));
  
  // Initialisation de l'indicateur sur l'élément actif au chargement
  setTimeout(() => {
    const myAccountItem = document.querySelector<HTMLElement>('.nav-item[data-section="my-account"]');
    if (myAccountItem) {
      navItems.forEach(nav => {
        nav.classList.remove('nav-item-active');
        nav.setAttribute('aria-selected', 'false');
      });
      myAccountItem.classList.add('nav-item-active');
      myAccountItem.setAttribute('aria-selected', 'true');
      moveIndicator(myAccountItem, true);
    }
  }, 100);
  
  // Gestion du redimensionnement de la fenêtre pour ajuster l'indicateur
  let resizeTimeout: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      const active = document.querySelector<HTMLElement>('.nav-item-active:not(.hidden)') || 
                    document.querySelector<HTMLElement>('.nav-item:not(.hidden)') || 
                    navItems[0];
      moveIndicator(active, true);
    }, 150);
  });
  
  // Vérification des droits d'administrateur pour afficher la section de vérifications
  import { pb } from "../lib/pocketbase.mjs";
  
  (async () => {
    console.log('[DEBUG] Starting admin verification check');
    try {
      // Attendez que PocketBase soit initialisé et que le DOM soit prêt
      await new Promise(resolve => setTimeout(resolve, 500));
      
      // Récupérez l'utilisateur depuis localStorage pour avoir l'ID
      const authData = localStorage.getItem('pocketbase_auth');
      console.log('[DEBUG] Auth data from localStorage:', authData ? 'present' : 'null');
      
      if (!authData) {
        console.log('[DEBUG] No auth data found, exiting');
        return;
      }
      
      const parsed = JSON.parse(authData);
      const userId = parsed?.record?.id;
      console.log('[DEBUG] Parsed user ID:', userId);
      
      if (!userId) {
        console.log('[DEBUG] No user ID found, exiting');
        return;
      }
      
      // Récupérez les données complètes de l'utilisateur via l'endpoint API serveur
      console.log('[DEBUG] Making API call to /api/get-user-full');
      try {
        const response = await fetch('/api/get-user-full', {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${pb.authStore.token}`
          },
          body: JSON.stringify({ userId }),
        });

        console.log('[DEBUG] API response status:', response.status);
        if (!response.ok) {
          console.log('[DEBUG] API response not ok, throwing error');
          throw new Error('Erreur lors de la récupération du user');
        }

        const data = await response.json();
        console.log('[DEBUG] API response data:', data);
        const fullUser = data.user;
        console.log('[DEBUG] Full user data:', fullUser);
        
        const isAdmin = fullUser.administrateur === true;
        const isVerified = fullUser.verified === true;
        console.log('[DEBUG] User admin status:', isAdmin, 'verified status:', isVerified);
        
        if (isAdmin && isVerified) {
          console.log('[DEBUG] User is admin and verified, showing verification section');
          const verifNavItem = document.querySelector<HTMLElement>('.nav-item[data-section="verifications"]');
          const verificationSection = document.getElementById('verifications');
          
          if (verifNavItem && verifNavItem.classList.contains('hidden')) {
            verifNavItem.classList.remove('hidden');
            gsap.fromTo(verifNavItem, { opacity: 0, x: -20 }, { opacity: 1, x: 0, duration: 0.5, ease: 'power2.out' });
          }
          if (verificationSection && verificationSection.classList.contains('hidden')) {
            verificationSection.classList.remove('hidden');
            gsap.fromTo(verificationSection, { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', delay: 0.1 });
          }
        } else {
          console.log('[DEBUG] User is not admin and verified, hiding verification section');
          const verifNavItem = document.querySelector<HTMLElement>('.nav-item[data-section="verifications"]');
          const verificationSection = document.getElementById('verifications');
          if (verifNavItem) verifNavItem.classList.add('hidden');
          if (verificationSection) verificationSection.classList.add('hidden');
        }
      } catch (apiError) {
        console.log('[DEBUG] API error:', apiError);
        // En cas d'erreur, masquer les éléments pour sécurité
        const verifNavItem = document.querySelector<HTMLElement>('.nav-item[data-section="verifications"]');
        const verificationSection = document.getElementById('verifications');
        if (verifNavItem) verifNavItem.classList.add('hidden');
        if (verificationSection) verificationSection.classList.add('hidden');
      }
    } catch (error) {
      console.log('[DEBUG] General error in admin check:', error);
      // En cas d'erreur, masquer les éléments de vérification pour sécurité
      const verifNavItem = document.querySelector<HTMLElement>('.nav-item[data-section="verifications"]');
      const verificationSection = document.getElementById('verifications');
      if (verifNavItem) verifNavItem.classList.add('hidden');
      if (verificationSection) verificationSection.classList.add('hidden');
    }
  })();
</script>
