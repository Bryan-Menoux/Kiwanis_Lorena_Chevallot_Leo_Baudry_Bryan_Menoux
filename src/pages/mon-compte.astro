---
import Layout from "../layouts/Layout.astro";
import AccountSection from "../components/Account-section.astro";
import VerificationSection from "../components/Verification-Account-section.astro";
import HelpAccountSection from "../components/Help-Account-section.astro";
import ModificationSection from "../components/Modification-Account-section.astro";
import user from "../assets/user.svg";
import circleCheck from "../assets/circle-check.svg";
import help from "../assets/help.svg";
import edit from "../assets/edit.svg";
import { capitalizeName } from "../utils/utilitaires.js";

// Vérification de l'authentification utilisateur
if (!Astro.locals.pb.authStore.isValid) {
  return Astro.redirect("/connexion");
}

const currentUser = Astro.locals.pb.authStore.model;

if (!currentUser || !currentUser.verified) {
  Astro.locals.pb.authStore.clear();
  return Astro.redirect("/connexion");
}

const isPostForm =
  Astro.request.method === "POST" &&
  Astro.request.headers.get("content-type")?.includes("form");

// Fonction pour gérer les actions d'administration des utilisateurs
async function handleVerificationAction(
  userId: string,
  action: string,
  rejectedById: string,
) {
  switch (action) {
    case "approve":
      await Astro.locals.pb.collection("users").update(userId, {
        verified: true,
        rejected: false,
        rejectionDate: null,
        rejectedBy: null,
      });
      break;

    case "reject":
      const now = new Date().toISOString();
      await Astro.locals.pb.collection("users").update(userId, {
        verified: false,
        rejected: true,
        rejectionDate: now,
        rejectedBy: rejectedById,
      });

      break;

    case "unreject":
      await Astro.locals.pb.collection("users").update(userId, {
        verified: false,
        rejected: false,
        rejectionDate: null,
        rejectedBy: null,
      });
      break;

    case "unverify":
      await Astro.locals.pb.collection("users").update(userId, {
        verified: false,
        rejected: false,
        rejectionDate: null,
        rejectedBy: null,
      });
      break;

    default:
      console.warn(`Action inconnue: ${action}`);
  }
}

// Gestion des requêtes POST (mises à jour profil et actions admin)
if (isPostForm) {
  try {
    const data = await Astro.request.formData();

    const formSource = data.get("formSource") as string;

    if (formSource === "verification") {
      const userId = data.get("userId") as string;
      const action = data.get("action") as string;

      try {
        await handleVerificationAction(userId, action, currentUser.id);

        const isAjax =
          Astro.request.headers.get("X-Requested-With") === "XMLHttpRequest";

        if (isAjax) {
          return new Response(
            JSON.stringify({
              success: true,
              action,
              userId,
              message: `Action ${action} effectuée avec succès`,
            }),
            {
              status: 200,
              headers: { "Content-Type": "application/json" },
            },
          );
        }

        const baseUrl = new URL(Astro.request.url);
        const cleanUrl = `${baseUrl.origin}${baseUrl.pathname}#verifications`;
        return Astro.redirect(cleanUrl, 303);
      } catch (error) {
        console.error("Erreur lors de l'action de vérification:", error);

        const isAjax =
          Astro.request.headers.get("X-Requested-With") === "XMLHttpRequest";
        if (isAjax) {
          return new Response(
            JSON.stringify({
              success: false,
              error: error instanceof Error ? error.message : "Erreur inconnue",
            }),
            {
              status: 500,
              headers: { "Content-Type": "application/json" },
            },
          );
        }
        throw error;
      }
    } else if (formSource === "modification") {
      const userId = data.get("userId") as string;
      const name = (data.get("name") as string) || "";
      const email = (data.get("email") as string) || "";

      // Met en majuscule la première lettre de chaque mot du nom
      const capitalizedName = capitalizeName(name);

      try {
        await Astro.locals.pb.collection("users").update(userId, { name: capitalizedName, email });

        const isAjax = Astro.request.headers.get("X-Requested-With") === "XMLHttpRequest";
        if (isAjax) {
          return new Response(
            JSON.stringify({ success: true, name: capitalizedName, email }),
            {
              status: 200,
              headers: { "Content-Type": "application/json" },
            },
          );
        }
      } catch (error) {
        const isAjax = Astro.request.headers.get("X-Requested-With") === "XMLHttpRequest";
        if (isAjax) {
          return new Response(
            JSON.stringify({
              success: false,
              error: error instanceof Error ? error.message : "Erreur inconnue",
            }),
            {
              status: 500,
              headers: { "Content-Type": "application/json" },
            },
          );
        }
        throw error;
      }
    } else if (Astro.locals.pb.authStore.isValid && currentUser!.verified) {
      const firstName = (data.get("firstName") as string) || "";
      const lastName = (data.get("lastName") as string) || "";
      const name = `${firstName} ${lastName}`.trim();
      const email = (data.get("email") as string) || "";

      // Met en majuscule la première lettre de chaque mot du nom
      const capitalizedName = capitalizeName(name);

      const oldPassword = (data.get("oldPassword") as string) || "";
      const newPassword = (data.get("newPassword") as string) || "";
      const newPasswordConfirm =
        (data.get("newPasswordConfirm") as string) || "";

      const updateData: any = {};
      if (capitalizedName) {
        updateData.name = capitalizedName;
      }
      if (email) {
        updateData.email = email;
      }

      let passwordChanged = false;
      if (oldPassword && newPassword && newPasswordConfirm) {
        if (newPassword !== newPasswordConfirm) {
          throw new Error(
            "Le nouveau mot de passe et sa confirmation ne correspondent pas.",
          );
        }
        updateData.oldPassword = oldPassword;
        updateData.password = newPassword;
        updateData.passwordConfirm = newPasswordConfirm;
        passwordChanged = true;
      }

      if (Object.keys(updateData).length > 0) {
        try {
          await Astro.locals.pb.collection("users").update(currentUser!.id, updateData);
        } catch (error) {
          console.error(
            passwordChanged
              ? "Erreur PocketBase lors de la mise à jour du mot de passe et/ou profil:"
              : "Erreur PocketBase lors de la mise à jour du profil:",
            error,
          );
          throw new Error(
            passwordChanged
              ? "Échec de la mise à jour du mot de passe et/ou profil."
              : "Échec de la mise à jour du profil."
          );
        }
      }

      return Astro.redirect("/mon-compte?success=true", 303);
    }
  } catch (error) {
    console.error("Erreur lors de la mise à jour du profil:", error);
  }
}

const isAdmin = currentUser.administrateur === true;
let users: any[] = [];

if (isAdmin) {
  users = await Astro.locals.pb.collection("users").getFullList();
}

const success = Astro.url.searchParams.get("success") === "true";

// Configuration de la navigation
const navItems = [
  {
    id: "my-account",
    label: "Mon compte",
    icon: user,
    active: true,
    marginTop: false,
    show: true,
  },
  {
    id: "verifications",
    label: "Vérifications",
    icon: circleCheck,
    active: false,
    marginTop: false,
    show: isAdmin,
  },
  {
    id: "modifications",
    label: "Modifications",
    icon: edit,
    active: false,
    marginTop: false,
    show: isAdmin,
  },
  {
    id: "help",
    label: "Aide",
    icon: help,
    active: false,
    marginTop: true,
    show: true,
  },
] as const;
---

<Layout>
  <!-- Navigation latérale du compte utilisateur -->
  <nav
    class="bg-white rounded-box p-6 fixed top-1/2 left-4 -translate-y-1/2 z-50 shadow-lg"
    aria-label="Navigation de compte"
  >
    <ul class="flex flex-col gap-4 items-center relative w-full">
      <div
        id="nav-indicator"
        class="btn btn-accent absolute rounded-box px-4 py-2 flex items-center"
        style="pointer-events: none; width: 190px; left: 0; top: 0; height: 3.25rem;"
        aria-hidden="true"
      >
      </div>
      {
        navItems.map((item) => (
          <li
            class:list={[
              "flex items-center gap-4 min-w-full cursor-pointer transition-colors duration-300 px-4 relative nav-item h-13",
              { "nav-item-active": item.active, "mt-8": item.marginTop },
              item.show === false ? "hidden" : "",
            ]}
            role="tab"
            aria-selected={item.active}
            data-section={item.id}
          >
            {item.icon && (
              <div
                class="w-10 h-10 icon-accent"
                style={`--icon-url: url(${item.icon.src})`}
              />
            )}
            <a href={`#${item.id}`}>{item.label}</a>
          </li>
        ))
      }
      <li
        class="flex items-center gap-4 min-w-full cursor-pointer transition-colors duration-300 px-4 relative nav-item h-13 mt-8 btn btn-accent rounded-md!"
      >
        <button id="logout-btn" class="w-full text-left">Déconnexion</button>
      </li>
    </ul>
  </nav>
  <!-- Contenu principal avec sections -->
  <div
    class="flex flex-1 w-full h-fit overflow-x-scroll scrollbar-hide scroll-smooth snap-x snap-mandatory"
    id="content-container"
    role="tabpanel"
  >
    {
      navItems.map((item) => (
        <section
          class:list={[
            "min-w-full h-full snap-start",
            item.show === false ? "hidden" : "",
          ]}
          id={item.id}
        >
          {item.id === "my-account" ? (
            <AccountSection success={success} />
          ) : item.id === "verifications" ? (
            <VerificationSection
              users={users as any[]}
              isAdmin={isAdmin}
              currentUserId={currentUser.id}
            />
          ) : item.id === "modifications" ? (
            <ModificationSection />
          ) : (
            <HelpAccountSection />
          )}
        </section>
      ))
    }
  </div>
</Layout>
<style>
  /* Styles pour la navigation */
  #nav-indicator {
    will-change: transform;
    z-index: 0;
  }
  .nav-item {
    z-index: 20;
  }
  .nav-item-active a {
    color: white;
  }
  .nav-item-active .icon-accent {
    filter: brightness(0) invert(1);
  }
</style>
<script>
  // Animation de la navigation
  import gsap from "gsap";

  const indicator = document.getElementById("nav-indicator");
  const navItems = document.querySelectorAll(".nav-item");
  const container = document.getElementById("content-container");

  if (!indicator || !container || !navItems.length) {
  } else {
    const moveIndicator = (item: Element, instant = false) => {
      const rect = item.getBoundingClientRect();
      const parent = item.parentElement?.getBoundingClientRect();
      if (!parent) return;
      const x = rect.left - parent.left;
      const y = rect.top - parent.top;

      if (instant) {
        gsap.set(indicator, { x, y, width: rect.width, height: rect.height });
      } else {
        gsap.to(indicator, {
          x,
          y,
          width: rect.width,
          height: rect.height,
          duration: 0.25,
        });
      }

      navItems.forEach((i) => i.classList.remove("nav-item-active"));
      item.classList.add("nav-item-active");
    };

    navItems.forEach((item) => {
      item.addEventListener("click", async (e) => {
        e.preventDefault();
        const id = (item as HTMLElement).dataset.section;
        if (!id) return;

        // Recharger les données
        await reloadAllSections();

        // Récupérer la section mise à jour
        const section = document.getElementById(id);
        if (!section) return;

        moveIndicator(item);
        container.scrollTo({ left: section.offsetLeft, behavior: "smooth" });
      });
    });

    // Fonction pour recharger toutes les sections
    async function reloadAllSections() {
      try {
        const response = await fetch(window.location.pathname);
        if (response.ok) {
          const html = await response.text();
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          // Liste des IDs des sections
          const sectionIds = ['my-account', 'verifications', 'modifications', 'help'];
          sectionIds.forEach(id => {
            const newSection = doc.querySelector(`#${id}`);
            if (newSection) {
              const oldSection = document.querySelector(`#${id}`);
              if (oldSection) oldSection.replaceWith(newSection);
            }
          });
        }
      } catch (error) {
        console.error('Erreur lors du rechargement des sections:', error);
      }
    }
  }
</script>
