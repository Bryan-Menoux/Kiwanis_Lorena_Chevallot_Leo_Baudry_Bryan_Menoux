---
import Layout from "../layouts/Layout.astro";
import AccountSection from "../components/Account-section.astro";
import VerificationSection from "../components/Verification-Account-section.astro";
import HelpAccountSection from "../components/Help-Account-section.astro";
import ModificationSection from "../components/Modification-Account-section.astro";
import user from "../assets/user.svg";
import circleCheck from "../assets/circle-check.svg";
import help from "../assets/help.svg";
import edit from "../assets/edit.svg";
import { capitalizeName } from "../utils/utilitaires.js";

// Vérification de l'authentification utilisateur
if (!Astro.locals.pb.authStore.isValid) {
  return Astro.redirect("/connexion");
}

const currentUser = Astro.locals.pb.authStore.model;

if (!currentUser || !currentUser.verified) {
  Astro.locals.pb.authStore.clear();
  return Astro.redirect("/connexion");
}

const isAdmin = currentUser.administrateur === true;
let users: any[] = [];

if (isAdmin) {
  users = await Astro.locals.pb.collection("users").getFullList();
}

const success = Astro.url.searchParams.get("success") === "true";

// Configuration de la navigation
const navItems = [
  {
    id: "my-account",
    label: "Mon compte",
    icon: user,
    active: true,
    marginTop: false,
    show: true,
  },
  {
    id: "verifications",
    label: "Vérifications",
    icon: circleCheck,
    active: false,
    marginTop: false,
    show: isAdmin,
  },
  {
    id: "modifications",
    label: "Modifications",
    icon: edit,
    active: false,
    marginTop: false,
    show: isAdmin,
  },
  {
    id: "help",
    label: "Aide",
    icon: help,
    active: false,
    marginTop: true,
    show: true,
  },
] as const;
---

<Layout>
  <!-- Navigation latérale du compte utilisateur -->
  <nav
    class="bg-white rounded-box p-6 fixed top-1/2 left-4 -translate-y-1/2 z-50 shadow-lg"
    aria-label="Navigation de compte"
  >
    <ul class="flex flex-col gap-4 items-center relative w-full">
      <div
        id="nav-indicator"
        class="btn btn-accent absolute rounded-box px-4 py-2 flex items-center"
        style="pointer-events: none; width: 190px; left: 0; top: 0; height: 3.25rem;"
        aria-hidden="true"
      >
      </div>
      {
        navItems.map((item) => (
          <li
            class:list={[
              "flex items-center gap-4 min-w-full cursor-pointer transition-colors duration-300 px-4 relative nav-item h-13",
              { "nav-item-active": item.active, "mt-8": item.marginTop },
              item.show === false ? "hidden" : "",
            ]}
            role="tab"
            aria-selected={item.active}
            data-section={item.id}
          >
            {item.icon && (
              <div
                class="w-10 h-10 icon-accent"
                style={`--icon-url: url(${item.icon.src})`}
              />
            )}
            <a href={`#${item.id}`}>{item.label}</a>
          </li>
        ))
      }
      <li
        class="flex items-center gap-4 min-w-full cursor-pointer transition-colors duration-300 px-4 relative nav-item h-13 mt-8 btn btn-accent rounded-md!"
      >
        <button id="logout-btn" class="w-full text-left">Déconnexion</button>
      </li>
    </ul>
  </nav>
  <!-- Contenu principal avec sections -->
  <div
    class="flex flex-1 w-full h-fit overflow-x-scroll scrollbar-hide scroll-smooth snap-x snap-mandatory"
    id="content-container"
    role="tabpanel"
  >
    {
      navItems.map((item) => (
        <section
          class:list={[
            "min-w-full h-full snap-start",
            item.show === false ? "hidden" : "",
          ]}
          id={item.id}
        >
          {item.id === "my-account" ? (
            <AccountSection success={success} />
          ) : item.id === "verifications" ? (
            <VerificationSection
              users={users as any[]}
              isAdmin={isAdmin}
              currentUserId={currentUser.id}
            />
          ) : item.id === "modifications" ? (
            <ModificationSection />
          ) : (
            <HelpAccountSection />
          )}
        </section>
      ))
    }
  </div>
</Layout>
<style>
  /* Styles pour la navigation */
  #nav-indicator {
    will-change: transform;
    z-index: 0;
  }
  .nav-item {
    z-index: 20;
  }
  .nav-item-active a {
    color: white;
  }
  .nav-item-active .icon-accent {
    filter: brightness(0) invert(1);
  }
</style>
<script>
  // Animation de la navigation
  import gsap from "gsap";
  import { initVerifications } from "../scripts/verification-handlers.js";

  const indicator = document.getElementById("nav-indicator");
  const navItems = document.querySelectorAll(".nav-item");
  const container = document.getElementById("content-container");

  if (!indicator || !container || !navItems.length) {
  } else {
    const moveIndicator = (item: Element, instant = false) => {
      const rect = item.getBoundingClientRect();
      const parent = item.parentElement?.getBoundingClientRect();
      if (!parent) return;
      const x = rect.left - parent.left;
      const y = rect.top - parent.top;

      if (instant) {
        gsap.set(indicator, { x, y, width: rect.width, height: rect.height });
      } else {
        gsap.to(indicator, {
          x,
          y,
          width: rect.width,
          height: rect.height,
          duration: 0.25,
        });
      }

      navItems.forEach((i) => i.classList.remove("nav-item-active"));
      item.classList.add("nav-item-active");
    };

    navItems.forEach((item) => {
      item.addEventListener("click", async (e) => {
        e.preventDefault();
        const id = (item as HTMLElement).dataset.section;
        if (!id) return;

        const now = Date.now();
        if (lastReloaded.has(id) && now - lastReloaded.get(id)! < 3000) {
          // Aller directement à la section sans recharger
          const section = document.getElementById(id);
          if (!section) return;
          moveIndicator(item);
          container.scrollTo({ left: section.offsetLeft, behavior: "smooth" });
          return;
        }
        lastReloaded.set(id, now);

        // Recharger uniquement la section ciblée
        await reloadSection(id);

        // Récupérer la section mise à jour
        const section = document.getElementById(id);
        if (!section) return;

        moveIndicator(item);
        container.scrollTo({ left: section.offsetLeft, behavior: "smooth" });
      });
    });

    // Observer pour détecter quand une section entre dans la vue lors du scroll manuel
    const lastReloaded = new Map<string, number>();
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(async (entry) => {
        if (entry.isIntersecting) {
          const sectionId = entry.target.id;
          const now = Date.now();
          if (lastReloaded.has(sectionId) && now - lastReloaded.get(sectionId)! < 5000) {
            return; // Éviter le rechargement en boucle
          }
          lastReloaded.set(sectionId, now);
          await reloadSection(sectionId);
        }
      });
    }, { root: container, threshold: 0.8 });

    // Observer toutes les sections initiales
    document.querySelectorAll('section').forEach(section => {
      observer.observe(section);
    });

    // Fonction pour recharger une section spécifique
    async function reloadSection(sectionId: string) {
      try {
        const cachedHash = sessionStorage.getItem(`hash-${sectionId}`);
        
        // Vérifier d'abord si les données ont changé
        const checkResponse = await fetch(
          `/api/check-section?section=${sectionId}&hash=${cachedHash || ''}`
        );
        
        if (!checkResponse.ok) return;
        
        const { hash, changed } = await checkResponse.json();
        sessionStorage.setItem(`hash-${sectionId}`, hash);

        // Seulement si changé, recharger la section
        if (!changed) {
          console.log(`Section #${sectionId} inchangée, pas de rechargement.`);
          return;
        }

        const response = await fetch(window.location.pathname);
        if (response.ok) {
          const html = await response.text();
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const newSection = doc.querySelector(`#${sectionId}`);
          
          if (newSection) {
            const oldSection = document.querySelector(`#${sectionId}`);
            if (oldSection) {
              oldSection.replaceWith(newSection);
              observer.observe(newSection);
              console.log(`Section #${sectionId} mise à jour.`);
              if (sectionId === 'verifications') {
                initVerifications();
              }
            }
          }
        }
      } catch (error) {
        console.error(`Erreur lors du rechargement de la section ${sectionId}:`, error);
      }
    }
  }

  // Init verifications if present
  initVerifications();
</script>
