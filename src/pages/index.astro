---
import Layout from "../layouts/Layout.astro";
import { getImage } from "astro:assets";
import heroLandingfinal from "../assets/landing-page/hero-landing-final.png";
import heroLandingfinalMobile from "../assets/landing-page/hero-landing-final-mobile.png";
import heroLandingfinalTablet from "../assets/landing-page/hero-landing-final-tablette.png";
import Hero from "../components/Hero.astro";
import landing1 from "../assets/landing-page/landing-1.webp";
import HomeCarousel from "../components/Home-carousel.astro";
import DiagArrow from "../components/DiagArrow.astro";
import kiwanismembres1 from "../assets/landing-page/kiwanismembres1.webp";
import rollUp from "../assets/landing-page/rollup-kiwanis-pays-de-montbeliard.webp";
import fanion from "../assets/landing-page/fanion.webp";
import why1 from "../assets/landing-page/why-1.webp";
import why2 from "../assets/landing-page/why-2.webp";
import why3 from "../assets/landing-page/why-3.webp";
import HomePartner from "../components/Home-partner.astro";

const lcpMobile = await getImage({
  src: heroLandingfinalMobile,
  format: "webp",
  width: 440,
  quality: 68,
});
const lcpTablet = await getImage({
  src: heroLandingfinalTablet,
  format: "webp",
  width: 1280,
  quality: 72,
});
const lcpDesktopMd = await getImage({
  src: heroLandingfinal,
  format: "webp",
  width: 1440,
  quality: 80,
});
const lcpDesktop = await getImage({
  src: heroLandingfinal,
  format: "webp",
  width: 1840,
  quality: 80,
});

// landing-1 / membres : col 2fr dans grid [3fr_2fr], 85vw mobile → ~29vw desktop (~420px à 1440px)
const landing1Sm = await getImage({
  src: landing1,
  width: 350,
  format: "webp",
});
const landing1Lg = await getImage({
  src: landing1,
  width: 640,
  format: "webp",
});
const membersPhotoXs = await getImage({
  src: kiwanismembres1,
  width: 350,
  format: "webp",
});
const membersPhotoSm = await getImage({
  src: kiwanismembres1,
  width: 480,
  format: "webp",
});
const membersPhotoLg = await getImage({
  src: kiwanismembres1,
  width: 640,
  format: "webp",
});
// rollup / fanion : 2 images côte à côte, max-w-[40dvw] → 20vw desktop
const rollUpSm = await getImage({ src: rollUp, width: 280, format: "webp" });
const rollUpLg = await getImage({ src: rollUp, width: 480, format: "webp" });
const fanionSm = await getImage({ src: fanion, width: 280, format: "webp" });
const fanionLg = await getImage({ src: fanion, width: 480, format: "webp" });
// why images : col 1fr dans grid [1fr_1fr], 85vw mobile → 40vw desktop
const why1Sm = await getImage({ src: why1, width: 480, format: "webp" });
const why1Lg = await getImage({ src: why1, width: 640, format: "webp" });
const why2Sm = await getImage({ src: why2, width: 480, format: "webp" });
const why2Lg = await getImage({ src: why2, width: 640, format: "webp" });
const why3Sm = await getImage({ src: why3, width: 480, format: "webp" });
const why3Lg = await getImage({ src: why3, width: 640, format: "webp" });

const mapGoogleUrl =
  "https://maps.google.com/?q=76+bis+faubourg+de+Besan%C3%A7on%2C+25200+Montb%C3%A9liard";
const mapAddress = "76 bis faubourg de Besançon, 25200 Montbéliard";
---

<Layout loadPoppinsFont={false} includeManifest={false}>
  <Fragment slot="head">
    <link
      rel="preload"
      as="image"
      href={lcpMobile.src}
      type="image/webp"
      media="(max-width: 767px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href={lcpTablet.src}
      type="image/webp"
      media="(min-width: 768px) and (max-width: 1023px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href={lcpDesktop.src}
      imagesrcset={`${lcpDesktopMd.src} 1440w, ${lcpDesktop.src} 1840w`}
      imagesizes="95vw"
      type="image/webp"
      media="(min-width: 1024px)"
      fetchpriority="high"
    />
  </Fragment>
  <Hero
    image={heroLandingfinal}
    title="Kiwanis Pays de Montbéliard"
    subtitle="Servir les enfants du monde, au cœur de notre territoire"
  />
  <!-- Section qui sommes nous -->
  <div
    class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-8 lg:gap-32 min-h-[40dvh] max-w-[85dvw]! md:max-w-[80dvw]! mx-auto my-20 md:my-24 lg:my-32"
  >
    <div class="flex flex-col gap-6 md:gap-8 lg:mt-8">
      <div class="flex flex-col gap-2 md:gap-4">
        <h2>Qui sommes nous ?</h2>
        <h3 class="mb-2">
          Un club-service de bénévoles au service des enfants
        </h3>
      </div>
      <p>
        Le Kiwanis Pays de Montbéliard est un club service de 15 bénévoles
        engagées pour les enfants et les jeunes du territoire. Nous faisons
        partie du Kiwanis International, fondé en 1915, un réseau mondial
        présent dans plus de 85 pays avec près de 7 500 clubs.
      </p>
      <p>
        Guidés par notre devise <span class="font-bold"
          >« Le monde de demain sera fait par les enfants d’aujourd’hui »</span
        >, nous accompagnons les jeunes et leur offrons de nouvelles
        perspectives.
      </p>
    </div>
    <div
      class="flex flex-col w-full mx-auto max-h-none md:max-h-[40dvh] lg:max-h-[60dvh] max-w-full"
    >
      <div
        class="home-landing-photo w-full aspect-565/569 overflow-hidden rounded-box mx-auto"
      >
        <img
          src={landing1Lg.src}
          srcset={`${landing1Sm.src} 350w, ${landing1Lg.src} 640w`}
          sizes="(min-width: 1024px) 29vw, 85vw"
          alt="Photographie de membres du Kiwanis aux 12 coups de Midi"
          loading="lazy"
          fetchpriority="low"
          decoding="async"
          class="block h-full w-full object-cover"
          width={landing1Lg.attributes.width}
          height={landing1Lg.attributes.height}
        />
      </div>
      <p class="text-sm mt-2">Le Kiwanis Féminin aux 12 coups de Midi</p>
    </div>
  </div>

  <div class="defer-render h-fit">
    <HomeCarousel />
  </div>

  <!-- Section Membres -->
  <div
    class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-8 lg:gap-32 md:min-h-[40dvh] max-w-[85dvw]! md:max-w-[80dvw]! mx-auto my-20 md:my-24 lg:my-32"
  >
    <div class="flex flex-col gap-6 md:gap-8 lg:mt-8">
      <div class="flex flex-col gap-2 md:gap-4">
        <h2>Nos membres</h2>
      </div>
      <p>
        Créé par Marie France ZUSATZ et charté le 22 septembre 2019, notre club
        réunit 14 femmes aux parcours variés, unies par l’envie d’agir pour les
        autres, et notamment pour les enfants.
      </p>
      <p>
        Nous appartenons à la division 933, qui regroupe 5 clubs en Franche
        Comté, rattachée au district France Monaco. Notre fonctionnement repose
        sur la bienveillance et le respect, chacune peut s’exprimer et trouver
        sa place au sein d’un cadre commun qui nous permet d’avancer ensemble,
        en restant fidèles aux valeurs que nous défendons.
      </p>
      <p>
        <span class="highlight">Notre règle d’or</span> : « Faites à autrui ce que
        vous voudriez qu’il vous soit fait. »
      </p>
      <a href="/membres" class="btn btn-accent w-fit px-8 py-6 mt-auto self-end"
        >Voir tous les membres <DiagArrow /></a
      >
    </div>
    <div
      class="flex flex-col w-full mx-auto max-h-none md:max-h-[40dvh] lg:max-h-[60dvh] max-w-full"
    >
      <div
        class="home-members-photo flex-1 overflow-hidden rounded-box mx-auto w-full"
      >
        <img
          src={membersPhotoLg.src}
          srcset={`${membersPhotoXs.src} 350w, ${membersPhotoSm.src} 480w, ${membersPhotoLg.src} 640w`}
          sizes="(min-width: 1024px) 29vw, 85vw"
          alt="Photographie des membres du groupe Kiwanis Pays de Montbéliard"
          loading="lazy"
          fetchpriority="low"
          class="block h-full w-full object-cover"
          width={membersPhotoLg.attributes.width}
          height={membersPhotoLg.attributes.height}
          decoding="async"
        />
      </div>
      <p class="text-sm mt-2">
        Les membres du groupe Kiwanis Pays de Montbéliard.
      </p>
    </div>
  </div>

  <!-- Section nous retrouver -->

  <div
    class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-8 lg:gap-32 max-w-[85dvw]! md:max-w-[80dvw]! mx-auto my-20 md:my-24 lg:my-32"
  >
    <div class="flex flex-col gap-8">
      <h2>Nous retrouver</h2>
      <p>
        Le Kiwanis Pays de Montbéliard est implanté au centre-ville, avec un
        siège social situé au <span class="font-bold"
          >76 bis faubourg de Besançon.</span
        >
      </p>
      <p>
        Nous nous réunissons régulièrement, notamment le premier mardi de chaque
        mois, pour préparer nos projets, suivre les actions en cours et
        accueillir les personnes souhaitant découvrir le club.
      </p>
      <p>
        Vous souhaitez participer à une réunion, rejoindre le Kiwanis ou
        proposer un partenariat ou un projet en faveur des enfants ? N'hésitez
        pas à nous contacter via la page Contact du site.
      </p>
      <a href="/contact" class="btn btn-accent w-fit px-8 py-6 mt-auto self-end"
        >Nous contacter<DiagArrow /></a
      >
    </div>

    <div
      class="relative h-full min-h-96 md:min-h-fit rounded-box! overflow-hidden border border-base-300/60 bg-base-200/50"
      data-map-loader
    >
      <!-- Placeholder visible avant chargement -->
      <div
        data-map-placeholder
        class="flex h-full min-h-96 flex-col items-center justify-center gap-3 px-6 py-8 text-center"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-10 h-10 text-accent opacity-70"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-2.034 3.97-5.122 3.97-9.077a8.25 8.25 0 00-16.5 0c0 3.955 2.026 7.043 3.97 9.077a19.58 19.58 0 002.683 2.282 16.975 16.975 0 001.144.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z"
            clip-rule="evenodd"></path>
        </svg>
        <p class="font-semibold text-sm">{mapAddress}</p>
        <a
          href={mapGoogleUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-accent btn-sm px-5">Ouvrir dans Google Maps ↗</a
        >
      </div>
      <!-- Conteneur Leaflet -->
      <div
        data-map-target
        class="hidden w-full h-full"
        style="min-height:24rem;"
      >
      </div>
      <!-- Bouton overlay affiché une fois la carte chargée -->
      <a
        data-map-gmaps-btn
        href={mapGoogleUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden absolute bottom-3 right-3 btn btn-accent px-8 py-6 shadow-md z-1000"
      >
        Voir sur Google Maps ↗
      </a>
    </div>
  </div>

  <!-- Section banderole -->
  <div
    class="flex flex-col max-w-[85dvw]! md:max-w-[80dvw]! mx-auto my-20 md:my-24 lg:my-32 gap-4"
  >
    <div
      class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-8 lg:gap-16 min-h-[40dvh]"
    >
      <div class="flex flex-col gap-8 justify-center items-center">
        <h3 class="font-bold">
          Le fanion et le roll-up qui nous accompagnent lors de chaque action et
          événement.
        </h3>
        <a
          href={rollUp.src}
          download="roll-up-kiwanis-pays-de-montbeliard.png"
          class="btn btn-accent w-fit px-8 py-6"
          >Télécharger notre roll-up<DiagArrow /></a
        >
      </div>
      <div class="flex gap-8 w-full mx-auto justify-center items-center">
        <img
          src={rollUpLg.src}
          srcset={`${rollUpSm.src} 280w, ${rollUpLg.src} 480w`}
          sizes="(min-width: 1024px) 18vw, 38vw"
          alt="Photographie du rollup du kiwanis pays de montbéliard"
          loading="lazy"
          fetchpriority="low"
          class="flex-1 h-auto object-contain w-fit max-w-[40dvw] lg:w-1/2 max-h-[50dvh] lg:max-h-[65dvh]"
          width={rollUpLg.attributes.width}
          height={rollUpLg.attributes.height}
          decoding="async"
        />
        <img
          src={fanionLg.src}
          srcset={`${fanionSm.src} 280w, ${fanionLg.src} 480w`}
          sizes="(min-width: 1024px) 18vw, 38vw"
          alt="Photographie du fanion du kiwanis pays de montbéliard"
          loading="lazy"
          fetchpriority="low"
          class="flex-1 h-auto object-contain w-fit max-w-[40dvw] lg:w-1/2 max-h-[50dvh] lg:max-h-[65dvh] mix-blend-multiply"
          width={fanionLg.attributes.width}
          height={fanionLg.attributes.height}
          decoding="async"
        />
      </div>
    </div>
  </div>

  <!-- Section pourquoi soutenir -->
  <div
    class="flex flex-col max-w-[85dvw]! md:max-w-[80dvw]! mx-auto my-20 md:my-24 lg:my-32 gap-8 lg:gap-24"
  >
    <div class="flex flex-col gap-2 md:gap-4">
      <h2>Pourquoi soutenir le Kiwanis féminin Pays de Montbéliard ?</h2>
      <p>
        Soutenir le Kiwanis féminin Pays de Montbéliard, c'est donner un coup de
        pouce à un club de 16 bénévoles qui agit depuis 2019 pour les enfants du
        Pays de Montbéliard.
      </p>
    </div>
    <div
      class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-8 lg:gap-16 min-h-[40dvh]"
    >
      <div class="flex flex-col gap-4 mt-6">
        <h3>Des effets concrets pour les enfants d'ici</h3>
        <p>
          Votre soutien permet de financer des projets concrets pour les enfants
          du Pays de Montbéliard, comme des actions menées avec des écoles, des
          associations locales ou des familles, et contribue directement à
          améliorer leur quotidien.
        </p>
      </div>
      <div class="flex flex-col w-full mx-auto md:max-w-full h-fit">
        <img
          src={why1Lg.src}
          srcset={`${why1Sm.src} 480w, ${why1Lg.src} 640w`}
          sizes="(min-width: 1024px) 40vw, 85vw"
          alt="Photographie de collégiens avec les kiwaniens"
          loading="lazy"
          fetchpriority="low"
          class="w-full flex-1 object-cover rounded-box min-h-[30dvh] md:min-h-[40dvh]"
          width={why1Lg.attributes.width}
          height={why1Lg.attributes.height}
          decoding="async"
        />
      </div>
    </div>
    <div
      class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-8 lg:gap-16 min-h-[40dvh]"
    >
      <div
        class="flex flex-col w-full mx-auto lg:max-w-full order-2 lg:order-1"
      >
        <img
          src={why2Lg.src}
          srcset={`${why2Sm.src} 480w, ${why2Lg.src} 640w`}
          sizes="(min-width: 1024px) 40vw, 85vw"
          alt="Photographie des Kiwaniens avec Loïc Ballet"
          loading="lazy"
          fetchpriority="low"
          class="w-full flex-1 object-cover rounded-box min-h-[30dvh] md:min-h-[40dvh]"
          width={why2Lg.attributes.width}
          height={why2Lg.attributes.height}
          decoding="async"
        />
      </div>
      <div class="flex flex-col gap-4 mt-6 order-1 lg:order-2">
        <h3>Plusieurs façons de vous engager à nos côtés</h3>
        <p>
          Entreprises, commerces, collectivités ou particuliers, chacun peut
          s'engager à sa manière, par un don, un partenariat, des lots ou la
          mise à disposition de produits ou de services. Quel que soit le
          format, votre soutien renforce nos actions en faveur des enfants.
        </p>
      </div>
    </div>
    <div
      class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-8 lg:gap-16 min-h-[40dvh]"
    >
      <div class="flex flex-col gap-4 mt-6">
        <h3>Un cadre clair pour votre contribution</h3>
        <p>
          Les cotisations de nos membres assurent le fonctionnement du club. Les
          recettes des événements et les dons sont entièrement dédiés aux
          projets pour les enfants. Votre soutien finance des actions concrètes,
          directement sur le terrain.
        </p>
      </div>
      <div class="flex flex-col w-full mx-auto md:max-w-full">
        <img
          src={why3Lg.src}
          srcset={`${why3Sm.src} 480w, ${why3Lg.src} 640w`}
          sizes="(min-width: 1024px) 40vw, 85vw"
          alt="Photographie des Kiwaniens"
          loading="lazy"
          fetchpriority="low"
          class="w-full flex-1 object-cover rounded-box min-h-[30dvh] md:min-h-[40dvh]"
          width={why3Lg.attributes.width}
          height={why3Lg.attributes.height}
          decoding="async"
        />
      </div>
    </div>
  </div>

  <HomePartner />
  <script>
    // CSS Leaflet inliné dans le bundle → 0 requête réseau supplémentaire
    import leafletCss from "leaflet/dist/leaflet.css?inline";

    const root = document.querySelector<HTMLElement>("[data-map-loader]");
    if (root) {
      const target = root.querySelector<HTMLElement>("[data-map-target]");
      const placeholder = root.querySelector<HTMLElement>(
        "[data-map-placeholder]",
      );
      const gmapsBtn = root.querySelector<HTMLElement>("[data-map-gmaps-btn]");
      let loaded = false;

      const loadMap = async () => {
        if (loaded || !target) return;
        loaded = true;
        observer?.disconnect();

        // Injecter le CSS depuis le bundle (pas de requête CDN)
        if (!document.getElementById("leaflet-css")) {
          const style = document.createElement("style");
          style.id = "leaflet-css";
          style.textContent = leafletCss;
          document.head.appendChild(style);
        }

        // Import dynamique du JS Leaflet (chunk séparé, chargé à la demande)
        const { default: L } = await import("leaflet");

        placeholder?.remove();
        target.classList.remove("hidden");

        // Marqueur SVG inline → supprime 3 requêtes (marker-icon ×2 + shadow)
        const pinIcon = L.divIcon({
          html: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 25 41" width="25" height="41">
            <path d="M12.5 0C5.6 0 0 5.6 0 12.5 0 21.9 12.5 41 12.5 41S25 21.9 25 12.5C25 5.6 19.4 0 12.5 0z" fill="#e03c31"/>
            <circle cx="12.5" cy="12.5" r="5" fill="white"/>
          </svg>`,
          className: "",
          iconSize: [25, 41],
          iconAnchor: [12, 41],
          popupAnchor: [1, -34],
        });

        const map = L.map(target, { scrollWheelZoom: false }).setView(
          [47.5098546, 6.781242],
          16,
        );
        L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
          maxZoom: 19,
          attribution:
            '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        }).addTo(map);
        L.marker([47.5098546, 6.781242], { icon: pinIcon })
          .addTo(map)
          .bindPopup(
            "<b>Kiwanis Pays de Montbéliard</b><br>76 bis faubourg de Besançon, 25200 Montbéliard",
          )
          .openPopup();
        setTimeout(() => map.invalidateSize(), 50);
        gmapsBtn?.classList.remove("hidden");
      };

      // Charge au survol (desktop) ou au toucher (mobile)
      root.addEventListener("mouseenter", loadMap, { once: true });
      root.addEventListener("touchstart", loadMap, {
        once: true,
        passive: true,
      });
      // Charge avant que la carte soit réellement visible.
      const observer = new IntersectionObserver(
        (entries) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            void loadMap();
          }
        },
        { threshold: 0, rootMargin: "800px 0px 800px 0px" },
      );
      observer.observe(root);
    }
  </script>
  <style>
    @media (max-width: 767px) {
      .home-landing-photo {
        width: min(100%, 350px);
        aspect-ratio: 350 / 323;
      }

      .home-members-photo {
        width: min(100%, 350px);
        aspect-ratio: 350 / 353;
      }
    }
  </style>
</Layout>
