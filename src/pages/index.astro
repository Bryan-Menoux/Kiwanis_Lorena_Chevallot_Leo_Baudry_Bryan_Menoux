---
import Layout from "../layouts/Layout.astro";
import { Image, getImage } from "astro:assets";
import heroLandingfinal from "../assets/landing-page/hero-landing-final.png";
import heroLandingfinalMobile from "../assets/landing-page/hero-landing-final-mobile.png";
import heroLandingfinalTablet from "../assets/landing-page/hero-landing-final-tablette.png";
import Hero from "../components/Hero.astro";
import landing1 from "../assets/landing-page/landing-1.png";
import HomeCarousel from "../components/Home-carousel.astro";
import DiagArrow from "../components/DiagArrow.astro";
import kiwanismembres1 from "../assets/landing-page/kiwanismembres1.png";
import rollUp from "../assets/landing-page/rollup-kiwanis-pays-de-montbeliard.png";
import fanion from "../assets/landing-page/fanion.png";
import why1 from "../assets/landing-page/why-1.png";
import why2 from "../assets/landing-page/why-2.png";
import why3 from "../assets/landing-page/why-3.png";
import HomePartner from "../components/Home-partner.astro";

const lcpMobile = await getImage({ src: heroLandingfinalMobile, format: "webp", width: 440, quality: 74 });
const lcpTablet = await getImage({ src: heroLandingfinalTablet, format: "webp", width: 1024, quality: 18 });
const lcpDesktop = await getImage({ src: heroLandingfinal, format: "webp", width: 1600, quality: 19 });

const mapEmbedUrl =
  "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2694.976201081879!2d6.781242576695513!3d47.5098546946529!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x479216ec97288eb1%3A0x14b7da3408d3161f!2s76%20Fbg%20de%20Besan%C3%A7on%2C%2025200%20Montb%C3%A9liard!5e0!3m2!1sfr!2sfr!4v1768495883263!5m2!1sfr!2sfr";
const mapAddress = "76 bis faubourg de Besançon, 25200 Montbéliard";
---

<Layout includeAlertProvider={false} loadPoppinsFont={false} includeManifest={false}>
  <Fragment slot="head">
    <link rel="preload" as="image" href={lcpMobile.src} type="image/webp" media="(max-width: 767px)" fetchpriority="high" />
    <link rel="preload" as="image" href={lcpTablet.src} type="image/webp" media="(min-width: 768px) and (max-width: 1023px)" fetchpriority="high" />
    <link rel="preload" as="image" href={lcpDesktop.src} type="image/webp" media="(min-width: 1024px)" fetchpriority="high" />
  </Fragment>
  <Hero
    image={heroLandingfinal}
    title="Kiwanis Pays de Montbéliard"
    subtitle="Servir les enfants du monde, au cœur de notre territoire"
  />
  <!-- Section qui sommes nous -->
  <div
    class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-8 lg:gap-32 min-h-[40dvh] max-w-[85dvw]! md:max-w-[80dvw]! mx-auto my-32"
  >
    <div class="flex flex-col gap-6 md:gap-8 lg:mt-8">
      <div class="flex flex-col gap-2 md:gap-4">
        <h2>Qui sommes nous ?</h2>
        <h3 class="mb-2">
          Un club-service de bénévoles au service des enfants
        </h3>
      </div>
      <p>
        Le Kiwanis Pays de Montbéliard est un club service de 15 bénévoles
        engagées pour les enfants et les jeunes du territoire. Nous faisons
        partie du Kiwanis International, fondé en 1915, un réseau mondial
        présent dans plus de 85 pays avec près de 7 500 clubs.
      </p>
      <p>
        Guidés par notre devise <span class="font-bold"
          >« Le monde de demain sera fait par les enfants d’aujourd’hui »</span
        >, nous accompagnons les jeunes et leur offrons de nouvelles
        perspectives.
      </p>
    </div>
    <div
      class="flex flex-col w-full mx-auto max-h-[40dvh] lg:max-h-[60dvh] max-w-full"
    >
      <div class="w-full aspect-565/569 overflow-hidden rounded-box">
        <Image
          src={landing1}
          alt="Photographie de membres du Kiwanis aux 12 coups de Midi"
          loading="lazy"
          fetchpriority="low"
          quality={80}
          decoding="async"
          class="block h-full w-full object-cover"
        />
      </div>
      <p class="text-sm mt-2">Le Kiwanis Féminin aux 12 coups de Midi</p>
    </div>
  </div>

  <div class="defer-render">
    <HomeCarousel />

  <!-- Section Membres -->
  <div
    class="grid grid-cols-1 lg:grid-cols-[3fr_2fr] gap-8 lg:gap-32 min-h-[40dvh] max-w-[85dvw]! md:max-w-[80dvw]! mx-auto my-32"
  >
    <div class="flex flex-col gap-6 md:gap-8 lg:mt-8">
      <div class="flex flex-col gap-2 md:gap-4">
        <h2>Nos membres</h2>
      </div>
      <p>
        Créé par Marie France ZUSATZ et charté le 22 septembre 2019, notre club
        réunit 14 femmes aux parcours variés, unies par l’envie d’agir pour les
        autres, et notamment pour les enfants.
      </p>
      <p>
        Nous appartenons à la division 933, qui regroupe 5 clubs en Franche
        Comté, rattachée au district France Monaco. Notre fonctionnement repose
        sur la bienveillance et le respect, chacune peut s’exprimer et trouver
        sa place au sein d’un cadre commun qui nous permet d’avancer ensemble,
        en restant fidèles aux valeurs que nous défendons.
      </p>
      <p>
        <span class="highlight">Notre règle d’or</span> : « Fais à autrui ce que tu
        voudrais qu’il te fasse. »
      </p>
      <a href="/membres" class="btn btn-accent w-fit px-8 py-6 mt-auto self-end"
        >Voir tous les membres <DiagArrow /></a
      >
    </div>
    <div
      class="flex flex-col w-full mx-auto max-h-[40dvh] lg:max-h-[60dvh] max-w-full"
    >
      <Image
        src={kiwanismembres1}
        alt="Photographie des membres du groupe Kiwanis Pays de Montbéliard"
        layout="constrained"
        fit="cover"
        sizes="(min-width: 1024px) 34vw, 80vw"
        quality={80}
        loading="lazy"
        fetchpriority="low"
        class="w-full max-h-full flex-1 object-cover rounded-box"
      />
      <p class="text-sm mt-2">
        Les membres du groupe Kiwanis Pays de Montbéliard.
      </p>
    </div>
  </div>

  <!-- Section nous retrouver -->

  <div
    class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-8 lg:gap-32 max-w-[85dvw]! md:max-w-[80dvw]! mx-auto my-32"
  >
    <div class="flex flex-col gap-8">
      <h2>Nous retrouver</h2>
      <p>
        Le Kiwanis Pays de Montbéliard est implanté au centre-ville, avec un
        siège social situé au <span class="font-bold"
          >76 bis faubourg de Besançon.</span
        >
      </p>
      <p>
        Nous nous réunissons régulièrement, notamment le premier mardi de chaque
        mois, pour préparer nos projets, suivre les actions en cours et
        accueillir les personnes souhaitant découvrir le club.
      </p>
      <p>
        Vous souhaitez participer à une réunion, rejoindre le Kiwanis ou
        proposer un partenariat ou un projet en faveur des enfants ? N'hésitez
        pas à nous contacter via la page Contact du site.
      </p>
      <a href="/contact" class="btn btn-accent w-fit px-8 py-6 mt-auto self-end"
        >Nous contacter<DiagArrow /></a
      >
    </div>

    <div
      class="relative h-full min-h-96 md:min-h-fit rounded-box! overflow-hidden border border-base-300/60 bg-base-200/50"
      data-map-loader
      data-map-src={mapEmbedUrl}
    >
      <div
        data-map-placeholder
        class="flex h-full min-h-56 flex-col items-center justify-center gap-4 px-6 py-8 text-center"
      >
        <p class="text-sm text-base-content/80 md:text-base">
          Carte non chargee automatiquement pour limiter les requetes externes.
        </p>
        <button type="button" data-map-trigger class="btn btn-accent px-6 py-3">
          Afficher la carte
        </button>
      </div>
      <iframe
        data-map-target
        title={`Carte interactive de ${mapAddress}`}
        class="hidden w-full h-full min-h-56"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
      <noscript>
        <iframe
          src={mapEmbedUrl}
          class="block w-full min-h-56"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </noscript>
    </div>
  </div>

  <!-- Section banderole -->
  <div
    class="flex flex-col max-w-[85dvw]! md:max-w-[80dvw]! mx-auto my-16 gap-4"
  >
    <div
      class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-8 lg:gap-16 min-h-[40dvh]"
    >
      <div class="flex flex-col gap-8 justify-center items-center">
        <h3 class="font-bold">
          Le fanion et le roll-up qui nous accompagnent lors de chaque action et
          événement.
        </h3>
        <a
          href={rollUp.src}
          download="roll-up-kiwanis-pays-de-montbeliard.png"
          class="btn btn-accent w-fit px-8 py-6"
          >Télécharger notre roll-up<DiagArrow /></a
        >
      </div>
      <div class="flex gap-8 w-full mx-auto justify-center items-center">
        <Image
          src={rollUp}
          alt="Photographie du rollup du kiwanis pays de montbéliard"
          layout="constrained"
          fit="contain"
          sizes="(min-width: 1024px) 20vw, 40vw"
          quality={80}
          loading="lazy"
          fetchpriority="low"
          class="flex-1 h-auto object-contain w-fit max-w-[40dvw] lg:w-1/2 max-h-[50dvh] lg:max-h-[65dvh]"
        />
        <Image
          src={fanion}
          alt="Photographie du fanion du kiwanis pays de montbéliard"
          layout="constrained"
          fit="contain"
          sizes="(min-width: 1024px) 20vw, 40vw"
          quality={80}
          loading="lazy"
          fetchpriority="low"
          class="flex-1 h-auto object-contain w-fit max-w-[40dvw] lg:w-1/2 max-h-[50dvh] lg:max-h-[65dvh] mix-blend-multiply"
        />
      </div>
    </div>
  </div>

  <!-- Section pourquoi soutenir -->
  <div
    class="flex flex-col max-w-[85dvw]! md:max-w-[80dvw]! mx-auto my-32 gap-8 lg:gap-24"
  >
    <div class="flex flex-col gap-2 md:gap-4">
      <h2>Pourquoi soutenir le Kiwanis féminin Pays de Montbéliard ?</h2>
      <p>
        Soutenir le Kiwanis féminin Pays de Montbéliard, c'est donner un coup de
        pouce à un club de 16 bénévoles qui agit depuis 2019 pour les enfants du
        Pays de Montbéliard.
      </p>
    </div>
    <div
      class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-8 lg:gap-16 min-h-[40dvh]"
    >
      <div class="flex flex-col gap-4 mt-6">
        <h3>Des effets concrets pour les enfants d'ici</h3>
        <p>
          Votre soutien permet de financer des projets concrets pour les enfants
          du Pays de Montbéliard, comme des actions menées avec des écoles, des
          associations locales ou des familles, et contribue directement à
          améliorer leur quotidien.
        </p>
      </div>
      <div class="flex flex-col w-full mx-auto md:max-w-full h-fit">
        <Image
          src={why1}
          alt="Photographie de collégiens avec les kiwaniens"
          layout="constrained"
          fit="cover"
          sizes="(min-width: 1024px) 40vw, 80vw"
          quality={80}
          loading="lazy"
          fetchpriority="low"
          class="w-full flex-1 object-cover rounded-box min-h-[30dvh] md:min-h-[40dvh]"
        />
      </div>
    </div>
    <div
      class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-8 lg:gap-16 min-h-[40dvh]"
    >
      <div class="flex-col w-full mx-auto lg:max-w-full hidden lg:flex">
        <Image
          src={why2}
          alt="Photographie des Kiwaniens avec Loïc Ballet"
          layout="constrained"
          fit="cover"
          sizes="(min-width: 1024px) 40vw, 80vw"
          quality={68}
          loading="lazy"
          fetchpriority="low"
          class="w-full flex-1 object-cover rounded-box min-h-[30dvh] md:min-h-[40dvh]"
        />
      </div>
      <div class="flex flex-col gap-4 mt-6">
        <h3>Plusieurs façons de vous engager à nos côtés</h3>
        <p>
          Entreprises, commerces, collectivités ou particuliers, chacun peut
          s'engager à sa manière, par un don, un partenariat, des lots ou la
          mise à disposition de produits ou de services. Quel que soit le
          format, votre soutien renforce nos actions en faveur des enfants.
        </p>
      </div>
      <div class="flex flex-col w-full mx-auto lg:max-w-full lg:hidden">
        <Image
          src={why2}
          alt="Photographie des Kiwaniens avec Loïc Ballet"
          layout="constrained"
          fit="cover"
          sizes="(min-width: 1024px) 40vw, 80vw"
          quality={68}
          loading="lazy"
          fetchpriority="low"
          class="w-full flex-1 object-cover rounded-box min-h-[30dvh] md:min-h-[40dvh]"
        />
      </div>
    </div>
    <div
      class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-8 lg:gap-16 min-h-[40dvh]"
    >
      <div class="flex flex-col gap-4 mt-6">
        <h3>Un cadre clair pour votre contribution</h3>
        <p>
          Les cotisations de nos membres assurent le fonctionnement du club. Les
          recettes des événements et les dons sont entièrement dédiés aux
          projets pour les enfants. Votre soutien finance des actions concrètes,
          directement sur le terrain.
        </p>
      </div>
      <div class="flex flex-col w-full mx-auto md:max-w-full">
        <Image
          src={why3}
          alt="Photographie des Kiwaniens"
          layout="constrained"
          fit="cover"
          sizes="(min-width: 1024px) 40vw, 80vw"
          quality={68}
          loading="lazy"
          fetchpriority="low"
          class="w-full flex-1 object-cover rounded-box min-h-[30dvh] md:min-h-[40dvh]"
        />
      </div>
    </div>
  </div>

    <HomePartner />
  </div>

  <script>
    document.querySelectorAll<HTMLElement>("[data-map-loader]").forEach((root) => {
      if (root.dataset.mapBound === "true") return;
      root.dataset.mapBound = "true";

      const target = root.querySelector<HTMLIFrameElement>("[data-map-target]");
      const trigger = root.querySelector<HTMLButtonElement>("[data-map-trigger]");
      const placeholder = root.querySelector<HTMLElement>("[data-map-placeholder]");
      const mapSrc = root.dataset.mapSrc;

      if (!target || !mapSrc) return;
      let observer: IntersectionObserver | null = null;

      const loadMap = () => {
        if (root.dataset.mapLoaded === "true") return;

        root.dataset.mapLoaded = "true";
        target.src = mapSrc;
        target.classList.remove("hidden");
        placeholder?.remove();
        observer?.disconnect();
        observer = null;
      };

      if ("IntersectionObserver" in window) {
        observer = new IntersectionObserver(
          (entries) => {
            const entry = entries[0];
            if (!entry?.isIntersecting) return;
            loadMap();
          },
          {
            root: null,
            rootMargin: "600px 0px",
            threshold: 0,
          },
        );
        observer.observe(root);
      }

      root.addEventListener("focusin", loadMap, { once: true });
      trigger?.addEventListener("click", loadMap, { once: true });
    });
  </script>
</Layout>
