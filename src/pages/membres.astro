---
import { getImage } from "astro:assets";
import PocketBase from "pocketbase";
import HeroMembresMobile from "../assets/members-page/hero-member-mobile.png";
import HeroMembresTablet from "../assets/members-page/hero-member-tablette.png";
import HeroMembres from "../assets/members-page/hero-member.png";
import membersTree from "../assets/members-page/kiwanis-membres-arbre.webp";
import members1 from "../assets/members-page/members-1.webp";
import members2 from "../assets/members-page/members-2.webp";
import DiagArrow from "../components/DiagArrow.astro";
import Hero from "../components/Hero.astro";
import MembersGrid from "../components/Members-grid.astro";
import Layout from "../layouts/Layout.astro";
import {
  Collections,
  MembresRoleOptions,
  type MembresResponse,
} from "../pocketbase-types";

const lcpMobile = await getImage({
  src: HeroMembresMobile,
  format: "webp",
  width: 440,
  quality: 68,
});
const lcpTablet = await getImage({
  src: HeroMembresTablet,
  format: "webp",
  width: 1280,
  quality: 72,
});
const lcpDesktopMd = await getImage({
  src: HeroMembres,
  format: "webp",
  width: 1440,
  quality: 80,
});
const lcpDesktop = await getImage({
  src: HeroMembres,
  format: "webp",
  width: 1840,
  quality: 80,
});

type PublicMember = {
  id: string;
  name: string;
  status: string;
  avatarUrl: string | null;
};

const roleLabels: Record<MembresRoleOptions, string> = {
  [MembresRoleOptions.membre]: "Membre",
  [MembresRoleOptions["président"]]: "Président",
  [MembresRoleOptions["présidente"]]: "Présidente",
};

const roleOrder = ["Présidente", "Président", "Membre"];
let members: PublicMember[] = [];
const defaultMemberName = "Membre Kiwanis";

function sortMembers(list: PublicMember[]) {
  return [...list].sort((a, b) => {
    const roleIndexA = roleOrder.indexOf(a.status);
    const roleIndexB = roleOrder.indexOf(b.status);

    if (roleIndexA !== roleIndexB) {
      return (roleIndexA === -1 ? Number.MAX_SAFE_INTEGER : roleIndexA) -
        (roleIndexB === -1 ? Number.MAX_SAFE_INTEGER : roleIndexB);
    }

    return a.name.localeCompare(b.name, "fr", { sensitivity: "base" });
  });
}

async function loadMembersFromCollection(pbClient: PocketBase): Promise<PublicMember[]> {
  const membreRecords = await pbClient
    .collection(Collections.Membres)
    .getFullList<MembresResponse>({
      sort: "-created",
    });

  const members = membreRecords.map((membreRecord) => {
    const avatarValue = membreRecord.avatar;
    const avatarFile = typeof avatarValue === "string"
      ? avatarValue
      : Array.isArray(avatarValue)
        ? String(avatarValue[0] || "")
        : "";
    const role = membreRecord.role as MembresRoleOptions;

    return {
      id: membreRecord.id,
      name: String(membreRecord.nom || "").trim() || defaultMemberName,
      status: roleLabels[role] || "Membre",
      avatarUrl: avatarFile
        ? pbClient.files.getURL(membreRecord, avatarFile)
        : null,
    };
  });

  return members;
}

try {
  const membersFromCurrentSession = await loadMembersFromCollection(Astro.locals.pb);
  if (membersFromCurrentSession.length > 0) {
    members = membersFromCurrentSession;
  }
} catch (error) {
  console.error("Erreur lors du chargement public des membres:", error);
}

members = sortMembers(members);
---

<Layout>
  <Fragment slot="head">
    <link
      rel="preload"
      as="image"
      href={lcpMobile.src}
      type="image/webp"
      media="(max-width: 767px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href={lcpTablet.src}
      type="image/webp"
      media="(min-width: 768px) and (max-width: 1023px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href={lcpDesktop.src}
      imagesrcset={`${lcpDesktopMd.src} 1440w, ${lcpDesktop.src} 1840w`}
      imagesizes="95vw"
      type="image/webp"
      media="(min-width: 1024px)"
      fetchpriority="high"
    />
  </Fragment>
  <Hero
    image={HeroMembres}
    title="Nos membres"
    subtitle=""
  />
  <div class="flex flex-col max-w-7xl mx-auto my-32 gap-4 px-8">
    <p>
      Sur cette page, vous retrouverez les membres qui font vivre le Kiwanis féminin
      Pays de Montbéliard au quotidien. Ce sont elles que vous croisez lors des événements,
      derrière les stands, à l’organisation des actions et des projets pour les enfants.
    </p>
  </div>
  <MembersGrid members={members} />
  <div class="flex flex-col max-w-7xl mx-auto my-32 gap-4 px-8">
    <h3 class="mx-auto self-center font-medium!">
      Car <b>ensemble</b> nous sommes plus <b>forts</b>, et nous conjugons nos <b
        >talents</b
      >.
    </h3>
    <a
      href={membersTree.src}
      download="kiwanis-membres-arbre.webp"
      class="btn btn-accent w-fit px-8 py-6 mx-auto mt-16 md:24 lg:32"
    >
      Télécharger la liste des membres <DiagArrow />
    </a>
  </div>

  <div class="flex flex-col max-w-7xl mx-auto my-32 gap-8 px-8">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr] gap-8 lg:gap-16 min-h-[40dvh]">
      <div class="flex flex-col gap-4 mt-6">
        <h4>Une histoire qui continue</h4>
        <p>
          Le club évolue au fil des années : de nouvelles bénévoles nous rejoignent,
          de nouveaux projets naissent et notre façon d’agir s’enrichit des rencontres
          faites sur le territoire.
        </p>
        <p>
          Bien que le club soit féminin, nos actions s’adressent à tous. Toute personne
          souhaitant participer, soutenir un projet ou nous rencontrer est la bienvenue
          lors de nos événements.
        </p>
      </div>
      <div class="flex flex-col w-full mx-auto md:max-w-full">
        <img
          src={members1.src}
          alt="Photographie de collégiens avec les kiwaniens"
          class="w-full flex-1 object-cover rounded-box max-h-80 object-top"
          width={members1.width}
          height={members1.height}
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr] gap-8 lg:gap-16 min-h-[40dvh]">
      <div class="flex-col w-full mx-auto md:max-w-full hidden md:flex">
        <img
          src={members2.src}
          alt="Photographie des Kiwaniens avec Loïc Ballet"
          class="w-full flex-1 object-cover rounded-box max-h-80 object-bottom"
          width={members2.width}
          height={members2.height}
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="flex flex-col gap-4 mt-6">
        <h4>Nous rejoindre</h4>
        <p>
          Si vous partagez notre envie d’agir pour les enfants du Pays de Montbéliard
          et que vous avez un peu de temps à consacrer au bénévolat, vous pouvez nous
          rejoindre.
        </p>
        <p>
          La première étape est simple : assister à une réunion ou échanger avec nous
          sur votre envie de vous engager. Il suffit de nous contacter via la page
          Contact du site, et nous reviendrons vers vous pour la suite.
        </p>
      </div>
      <div class="flex flex-col w-full mx-auto md:max-w-full md:hidden">
        <img
          src={members2.src}
          alt="Photographie des Kiwaniens avec Loïc Ballet"
          class="w-full flex-1 object-cover rounded-box max-h-80 object-bottom"
          width={members2.width}
          height={members2.height}
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</Layout>
