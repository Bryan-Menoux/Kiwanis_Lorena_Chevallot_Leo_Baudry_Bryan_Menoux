---
import Layout from "../../layouts/Layout.astro";
import ActionContent from "../../components/ActionContent.astro";
import backArrow from "../../assets/back-arrow.svg";

const id = Astro.params.id;
const action = await Astro.locals.pb.collection("actions").getOne(id!);
---

<Layout>
  <a
    href="/actions"
    class="hidden fixed px-4 py-3 min-h-11 lg:flex items-center justify-center z-50 bg-base-100 bg-opacity-80 rounded-box text-sm lg:text-base lg:left-[2%] lg:top-[12%]"
  >
    <img
      src={backArrow.src}
      alt="Retour aux actions"
      class="inline-block mr-2 invert w-4 h-4 md:w-5 md:h-5"
    />Retour aux actions</a
  >
  <a href="/actions" class="flex lg:hidden items-center text-sm mb-8">
    <img
      src={backArrow.src}
      alt="Retour aux actions"
      class="inline-block mr-2 invert w-4 h-4 md:w-5 md:h-5"
    />Retour aux actions</a
  >
  <ActionContent action={action} />
</Layout>