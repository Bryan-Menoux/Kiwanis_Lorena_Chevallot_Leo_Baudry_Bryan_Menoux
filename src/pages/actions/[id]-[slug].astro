---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import ActionContent from "../../components/ActionContent.astro";
import backArrow from "../../assets/back-arrow.svg";

const id = Astro.params.id;
let action = null;
let slug = Astro.params.slug

try {
  action = await Astro.locals.pb.collection("actions").getOne(id!);
} catch (err) {
  // Si l'API renvoie 404, on ne veut pas lever une erreur serveur complète.
  // On capture et on rend une page utilisateur (thème sombre) indiquant que l'action est introuvable.
  const isNotFound =
    (err instanceof Error &&
      err.message?.includes("The requested resource wasn't found")) ||
    (err as any)?.response?.status === 404;
  if (isNotFound) {
    const message = "Action introuvable (identifiant: " + id + ")";
    return new Response(
      `<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Action introuvable</title><style>body{background:#0b1220;color:#e6eef8;font-family:system-ui,-apple-system,Segoe UI,Roboto,'Helvetica Neue',Arial;padding:40px}a{color:#9fe7c4}</style></head><body><h1>Action introuvable</h1><p>${message}</p><p><a href="/actions">Retour aux actions</a></p></body></html>`,
      { status: 404, headers: { "Content-Type": "text/html" } },
    );
  }
  throw err;
}
---

<Layout>
  <a
    href="/actions"
    class="hidden fixed px-4 py-3 min-h-11 lg:flex items-center justify-center z-50 bg-base-100 bg-opacity-80 rounded-box text-sm lg:text-base lg:left-[2%] lg:top-[12%]"
  >
    <Image
      src={backArrow}
      alt="Retour aux actions"
      loading="lazy"
      quality={80}
      class="inline-block mr-2 invert w-4 h-4 md:w-5 md:h-5"
    />Retour aux actions</a
  >
  <div class="flex w-full justify-between mb-8 mt-24 px-4">
    <a href="/actions" class="flex lg:hidden items-center text-sm">
    <Image
      src={backArrow}
      alt="Retour aux actions"
      loading="lazy"
      quality={80}
      class="inline-block mr-2 invert w-4 h-4 md:w-5 md:h-5"
    />Retour aux actions</a
  >
  
  {
    Astro.locals.pb.authStore.isValid && (
      <a href={`/creation/actions/edit/${id}-${slug}`} class="flex lg:hidden items-center text-sm w-fit btn btn-accent">
      Modifier l'action</a>
    <a
    href={`/creation/actions/edit/${id}-${slug}`}
    class="hidden fixed px-4 py-3 min-h-11 lg:flex items-center justify-center z-50 bg-opacity-80 rounded-box text-sm lg:text-base lg:right-[2%] lg:top-[12%] btn btn-accent"
    >
      Modifier l'action</a>
    )
  }
  </div>
  <ActionContent action={action} />
</Layout>
