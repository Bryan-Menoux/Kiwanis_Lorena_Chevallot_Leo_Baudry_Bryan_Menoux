---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/Hero.astro";
import SearchActions from "../../components/SearchActions.astro";
import ConsentManagedImage from "../../components/ConsentManagedImage.astro";
import slugify from "slugify";
import {
  buildResponsiveImageSrcSet,
  formatDateShort,
  normalizeImageUrl,
} from "../../utils/utilitaires.js";
import HeroActions from "../../assets/action-page/hero-action-page.png";
import HeroActionsMobile from "../../assets/action-page/hero-action-page-mobile.png";
import HeroActionsTablet from "../../assets/action-page/hero-action-page-tablette.png";
import { getImage } from "astro:assets";
import AdminEditBanner from "../../components/AdminEditBanner.astro";
import DiagArrow from "../../components/DiagArrow.astro";
import { Collections, type HerosResponse } from "../../pocketbase-types";

const currentUser = Astro.locals.pb.authStore.record;
const canEditActions =
  Astro.locals.pb.authStore.isValid &&
  currentUser?.verified === true &&
  currentUser?.administrateur === true;

let actionsRaw: any[] = [];
try {
  actionsRaw = await Astro.locals.pb.collection("actions").getFullList();
} catch (error) {
  actionsRaw = [];
}

const actions = [...actionsRaw].sort(
  (a, b) =>
    new Date(b.updated || 0).getTime() - new Date(a.updated || 0).getTime(),
);

const formatActionDate = (
  dateDebut: string | null | undefined,
  dateFin: string | null | undefined,
) => {
  if (dateDebut && dateFin) {
    return `${formatDateShort(dateDebut)} au ${formatDateShort(dateFin)}`;
  }
  if (dateDebut) {
    return formatDateShort(dateDebut);
  }
  return "";
};

const actionsWithUrls = actions.map((action) => {
  const safeTypes = Array.isArray(action.type_action) ? action.type_action : [];
  const selectedDate = action.date_debut || action.date_fin;

  return {
    ...action,
    slug: slugify(action.titre || "action", { lower: true, strict: true }),
    heroUrl: action.hero
      ? normalizeImageUrl(action.hero, action, Astro.locals.pb, { thumb: "960x0" })
      : null,
    heroSrcSet: action.hero
      ? buildResponsiveImageSrcSet(action.hero, action, Astro.locals.pb, [480, 768, 960, 1280])
      : null,
    dateLabel: formatActionDate(
      action.date_debut,
      action.date_fin,
    ),
    year: selectedDate ? new Date(selectedDate).getFullYear().toString() : "",
    typeActionSafe: safeTypes,
    typeActionNormalized: safeTypes.map((type: unknown) => String(type).toLowerCase()),
  };
});

let membres: any[] = [];
try {
  membres = await Astro.locals.pb.collection("membres").getFullList();
} catch (error) {
  membres = [];
}

const date = new Date().getFullYear();
const dureeEngagement = Math.max(0, date - 2019);

const yearOptions = Array.from(
  new Set(
    actions
      .map((action) => {
        const selectedDate = action.date_debut || action.date_fin;
        if (!selectedDate) return null;
        return new Date(selectedDate).getFullYear().toString();
      })
      .filter((v): v is string => Boolean(v)),
  ),
).sort((a, b) => b.localeCompare(a));


const lcpMobile = await getImage({ src: HeroActionsMobile, format: "webp", width: 440, quality: 68 });
const lcpTablet = await getImage({ src: HeroActionsTablet, format: "webp", width: 1280, quality: 72 });
const lcpDesktopMd = await getImage({ src: HeroActions, format: "webp", width: 1440, quality: 80 });
const lcpDesktop = await getImage({ src: HeroActions, format: "webp", width: 1840, quality: 80 });

const heroRecords = await Astro.locals.pb
  .collection(Collections.Heros)
  .getFullList<HerosResponse>();
const pageHeroRecord = heroRecords.find(
  (hero) => (hero.nom_page || "").trim().toLowerCase() === "actions",
);
const pageHeroImageUrl =
  pageHeroRecord?.image
    ? Astro.locals.pb.files.getURL(pageHeroRecord, pageHeroRecord.image)
    : null;
const heroImage = pageHeroImageUrl || HeroActions;
---

<Layout
  title="Actions du Kiwanis Montbéliard | Solidarité locale"
  description="Retrouvez les actions solidaires du Kiwanis à Montbéliard, menées pour les enfants, les jeunes et les partenaires du territoire."
  canonical="/actions"
  robots="index,follow"
  ogTitle="Actions du Kiwanis Montbéliard | Solidarité locale"
  ogDescription="Retrouvez les actions solidaires du Kiwanis à Montbéliard, menées pour les enfants, les jeunes et les partenaires du territoire."
>
  <Fragment slot="head">
    {pageHeroImageUrl ? (
      <link rel="preload" as="image" href={pageHeroImageUrl} fetchpriority="high" />
    ) : (
      <>
        <link rel="preload" as="image" href={lcpMobile.src} type="image/webp" media="(max-width: 767px)" fetchpriority="high" />
        <link rel="preload" as="image" href={lcpTablet.src} type="image/webp" media="(min-width: 768px) and (max-width: 1023px)" fetchpriority="high" />
        <link rel="preload" as="image" href={lcpDesktop.src} imagesrcset={`${lcpDesktopMd.src} 1440w, ${lcpDesktop.src} 1840w`} imagesizes="95vw" type="image/webp" media="(min-width: 1024px)" fetchpriority="high" />
      </>
    )}
  </Fragment>
  <Hero
    image={heroImage}
    title="Nos actions"
  />

  <AdminEditBanner
    canEdit={canEditActions}
    title="Modifier les actions"
    description="Cet espace vous permet de mettre à jour les actions du club à tout moment. Vous pouvez y ajouter, modifier ou supprimer les contenus en fonction des besoins et des projets menés sur le terrain."
    buttonLabel="Modifier les actions"
    href="/creation/actions"
  />

  <section
    class="mx-auto w-full max-w-[85dvw]! py-3 md:max-w-[80dvw]! md:py-5 lg:py-8"
  >
    <div
      class="grid grid-cols-1 gap-3 md:grid-cols-2 md:gap-4 lg:grid-cols-4 lg:gap-5"
    >
      <div class="rounded-2xl bg-accent flex flex-col items-center p-4 text-base-100 md:p-5 lg:p-6">
        <p class="text-3xl! font-bold md:text-4xl!">{actions.length}</p>
        <p class="mt-2 whitespace-nowrap">Actions réalisées</p>
      </div>
      <div class="rounded-2xl bg-accent flex flex-col items-center p-4 text-base-100 md:p-5 lg:p-6">
        <p class="text-3xl! font-bold md:text-4xl!">+150</p>
        <p class="mt-2 whitespace-nowrap">Enfants aidés</p>
      </div>
      <div class="rounded-2xl bg-accent flex flex-col items-center p-4 text-base-100 md:p-5 lg:p-6">
        <p class="text-3xl! font-bold md:text-4xl!">{membres.length}</p>
        <p class="mt-2 whitespace-nowrap">Bénévoles engagés</p>
      </div>
      <div class="rounded-2xl bg-accent flex flex-col items-center p-4 text-base-100 md:p-5 lg:p-6">
        <p class="text-3xl! font-bold md:text-4xl!">{dureeEngagement}</p>
        <p class="mt-2 whitespace-nowrap">Années d'engagement</p>
      </div>
    </div>
  </section>

  <section
   class="mx-auto w-full max-w-[85dvw]! py-3 md:max-w-[80dvw]! md:py-5 lg:py-8"
  >
    <div
      class="rounded-2xl border border-base-300 bg-base-100 p-4 shadow-sm md:p-5 lg:p-6"
    >
      <div class="mb-4 space-y-2 md:mb-5">
        <h2 class="text-2xl font-bold text-accent md:text-3xl lg:text-4xl">
          Nos actions sur le terrain
        </h2>
        <p class="text-sm leading-relaxed text-base-content/75 md:text-base">
          Découvrez les actions menées par le club Kiwanis Pays de Montbéliard
          pour soutenir les enfants et les familles du territoire.
        </p>
      </div>
      <SearchActions yearOptions={yearOptions} />
    </div>
  </section>

  <section
    class="mx-auto mb-16 mt-6 w-full max-w-7xl px-4 md:mt-8 md:px-6 lg:mt-10 lg:px-8"
  >
    {
      actionsWithUrls.length === 0 ? (
        <div class="rounded-2xl border border-base-300 bg-base-100 px-6 py-12 text-center shadow-sm">
          <p class="text-base text-base-content/70 md:text-lg">
            Aucune action disponible pour le moment.
          </p>
        </div>
      ) : (
        <div class="space-y-6">
          <div
            id="actions-empty"
            class="hidden rounded-2xl border border-base-300 bg-base-100 px-6 py-12 text-center shadow-sm"
          >
            <p class="text-base text-base-content/70 md:text-lg">
              Aucune action ne correspond à votre recherche.
            </p>
          </div>

          <div
            id="actions-grid"
            class="grid grid-cols-1 gap-4 md:gap-5 lg:gap-6"
          >
            {actionsWithUrls.map((action, index) => {
              const imageOrderClass =
                index % 2 === 0 ? "lg:order-1" : "lg:order-2";
              const contentOrderClass =
                index % 2 === 0 ? "lg:order-2" : "lg:order-1";

              return (
                <article
                  data-action-card
                  data-title={action.titre || ""}
                  data-subtitle={action.sous_titre || ""}
                  data-beneficiary={action.beneficiaire || ""}
                  data-year={action.year}
                  data-types={action.typeActionNormalized.join("||")}
                  class="overflow-hidden rounded-2xl border border-base-300 bg-base-100 shadow-sm min-h-[55dvh] lg:h-96"
                >
                  <div class="flex h-full flex-col lg:flex-row lg:items-stretch">
                    {action.heroUrl ? (
                      <ConsentManagedImage
                        src={action.heroUrl}
                        alt={
                          action.description_hero ||
                          `Illustration de ${action.titre}`
                        }
                        loading="lazy"
                        fetchpriority="low"
                        decoding="async"
                        srcset={action.heroSrcSet || undefined}
                        sizes="(min-width: 1024px) 50vw, 100vw"
                        width="960"
                        height="540"
                        class={`h-56 w-full object-cover md:h-[36dvh] lg:h-full lg:w-1/2 ${imageOrderClass}`}
                        placeholderClass={`h-56 w-full object-cover md:h-[36dvh] lg:h-full lg:w-1/2 ${imageOrderClass}`}
                        placeholderLabel="Cette image est chargée depuis un service externe. Autorisez les services externes pour l’afficher."
                      />
                    ) : (
                      <div
                        class={`flex h-56 w-full items-center justify-center bg-base-200 text-sm text-base-content/50 md:h-[36dvh] lg:h-full lg:w-1/2 ${imageOrderClass}`}
                      >
                        Image non disponible
                      </div>
                    )}

                    <div
                      class={`flex flex-1 flex-col gap-4 p-4 md:gap-5 md:p-6 lg:w-1/2 ${contentOrderClass}`}
                    >
                      <div class="space-y-2">
                        <h3 class="text-xl font-bold leading-tight text-base-content md:text-2xl capitalize mb-4 md:mb-8">
                          {action.titre}
                        </h3>
                        <div class="flex flex-wrap gap-2 md:gap-2.5">
                        {action.typeActionSafe.slice(0, 3).map((type: unknown) => (
                          <span class="badge badge-secondary  text-xs! font-bold! md:text-sm!">
                            {String(type)}
                          </span>
                        ))}
                        {action.typeActionSafe.length === 0 && (
                          <span class="badge badge-secondary  text-xs! font-bold! md:text-sm!">
                            Action solidaire
                          </span>
                        )}
                      </div>
                        {action.sous_titre && (
                          <p class="text-sm leading-relaxed text-base-content/75 md:text-base">
                            {action.sous_titre}
                          </p>
                        )}
                      </div>

                      

                      <div class="mt-auto flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
                        <div class="space-y-1 text-sm text-base-content/65 md:text-base">
                          {action.dateLabel && <p>{action.dateLabel}</p>}
                          {action.beneficiaire && (
                            <p class="wrap-break-word">{action.beneficiaire}</p>
                          )}
                        </div>
                        <a
                          href={`/actions/${action.id}-${action.slug}`}
                          class="btn btn-accent btn-sm w-full rounded-full md:btn-md lg:w-auto"
                        >
                          Voir l'action <DiagArrow class="h-3 w-auto" />
                        </a>
                      </div>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>

          <div
            id="actions-pagination"
            class="mt-6 flex flex-wrap items-center justify-center gap-2"
          />
        </div>
      )
    }
  </section>
</Layout>

<script>
  import { scrollToTarget } from "../../utils/scroll.js";
  import {
    getTotalPages,
    renderPagination,
    resolveNextPage,
  } from "../../utils/renderPagination";

  (() => {
    const PAGE_SIZE = 9;

    const byId = (id: string): HTMLElement | null => document.getElementById(id);
    const normalize = (value: unknown): string =>
      String(value || "")
        .toLowerCase()
        .trim();

    function init() {
      const grid = byId("actions-grid");
      const pagination = byId("actions-pagination");
      const emptyState = byId("actions-empty");
      if (!(grid instanceof HTMLElement)) return;

      const cards = Array.from(grid.querySelectorAll("[data-action-card]"));
      if (cards.length === 0) return;

      let currentPage = 1;
      let currentSearch = "";
      let currentYear = "";
      let currentType = "";
      let filteredCards = cards.slice();

      const applyFilters = () => {
        const searchToken = normalize(currentSearch);
        const typeToken = normalize(currentType);

        filteredCards = cards.filter((card) => {
          if (!(card instanceof HTMLElement)) return false;
          const title = normalize(card.dataset.title);
          const subtitle = normalize(card.dataset.subtitle);
          const beneficiary = normalize(card.dataset.beneficiary);
          const year = card.dataset.year || "";
          const types = String(card.dataset.types || "")
            .split("||")
            .map((value) => normalize(value))
            .filter(Boolean);

          const matchSearch =
            searchToken === "" ||
            title.includes(searchToken) ||
            subtitle.includes(searchToken) ||
            beneficiary.includes(searchToken);
          const matchYear = currentYear === "" || year === currentYear;
          const matchType = typeToken === "" || types.includes(typeToken);

          return matchSearch && matchYear && matchType;
        });

        const totalPages = getTotalPages(filteredCards.length, PAGE_SIZE);
        if (currentPage > totalPages) currentPage = totalPages;
        if (currentPage < 1) currentPage = 1;

        const start = (currentPage - 1) * PAGE_SIZE;
        const end = start + PAGE_SIZE;
        const pageCards = filteredCards.slice(start, end);
        const pageSet = new Set(pageCards);

        cards.forEach((card) => {
          if (!(card instanceof HTMLElement)) return;
          const shouldShow = pageSet.has(card);
          card.classList.toggle("hidden", !shouldShow);
        });

        if (emptyState instanceof HTMLElement) {
          emptyState.classList.toggle("hidden", filteredCards.length !== 0);
        }
        grid.classList.toggle("hidden", filteredCards.length === 0);

        if (pagination instanceof HTMLElement) {
          pagination.innerHTML = renderPagination(totalPages, currentPage, {
            wrapperClass: "contents",
            buttonClass: "btn btn-sm btn-ghost",
            activeButtonClass: "btn btn-sm btn-accent",
          });
        }
      };

      if (pagination instanceof HTMLElement) {
        pagination.addEventListener("click", (event: Event) => {
          const target =
            event.target instanceof HTMLElement
              ? event.target.closest("[data-page-action]")
              : null;
          if (!(target instanceof HTMLElement)) return;

          const totalPages = getTotalPages(filteredCards.length, PAGE_SIZE);
          const action = target.getAttribute("data-page-action");
          const previousPage = currentPage;
          currentPage = resolveNextPage(
            currentPage,
            totalPages,
            action,
            target.getAttribute("data-page"),
          );

          if (currentPage !== previousPage) {
            // Remonte légèrement au-dessus de la liste pour conserver un contexte visuel (10% de viewport).
            scrollToTarget("#actions-grid", {
              offset: -window.innerHeight * 0.1,
            });
          }
          applyFilters();
        });
      }

      document.addEventListener("search-actions-change", (event: Event) => {
        const custom = event as CustomEvent | Event;
        const detail = (custom && "detail" in custom ? (custom as CustomEvent).detail : {}) as {
          search?: string;
          year?: string;
          type?: string;
        };
        currentSearch = detail?.search || "";
        currentYear = detail?.year || "";
        currentType = detail?.type || "";
        currentPage = 1;
        applyFilters();
      });

      applyFilters();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init, { once: true });
    } else {
      init();
    }
  })();
</script>
