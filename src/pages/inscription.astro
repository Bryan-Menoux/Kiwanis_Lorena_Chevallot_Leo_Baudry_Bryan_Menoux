---
import Layout from "../layouts/Layout-login.astro";
import shapesLeft from "../assets/login-page/shapes-left.svg";
import shapesRight from "../assets/login-page/shapes-right.svg";
import logo from "../assets/logo-kiwanis-full.svg";
import backArrow from "../assets/back-arrow.svg";
import userIcon from "../assets/login-page/user.svg";
import lockIcon from "../assets/login-page/lock.svg";
---

<Layout>
  <!-- Bouton de retour à l'accueil -->
  <div
    class="absolute top-8 left-8 flex items-center text-white hover:underline z-10"
  >
    <img src={backArrow.src} aria-hidden="true" />
    <a href="/" class="text-white ml-2">Retour à l'accueil</a>
  </div>
  <!-- Éléments décoratifs -->
  <img
    src={shapesLeft.src}
    aria-hidden="true"
    class="absolute left-0 bottom-0 w-[50dvw] lg:w-[25dvw] select-none"
    draggable="false"
  />
  <img
    src={shapesRight.src}
    aria-hidden="true"
    class="absolute right-0 top-0 w-[70dvw] md:w-[50dvw] lg:w-[40dvw] select-none"
    draggable="false"
  />

  <!-- Contenu principal centré -->
  <div
    class="absolute -translate-x-1/2 -translate-y-1/2 left-1/2 top-1/2 flex flex-col lg:flex-row gap-4 md:gap-16 justify-center items-center z-10"
  >
    <img
      src={logo.src}
      alt="Logo Kiwanis Pays de Montbéliard"
      class="md:w-[30dvw] lg:w-[15dvw]"
    />
    <div class="lg:max-w-[20dvw]">
      <!-- Formulaire d'inscription -->
      <form class="flex flex-col w-full relative">
        <!-- Zone d'affichage des erreurs -->
        <div id="errorText" class="absolute left-0 right-0 text-sm text-start font-semibold opacity-0 pointer-events-none" style="bottom: calc(100% + 0.5rem);"></div>
        
        <!-- Champ Prénom -->
        <div class="relative my-2">
          <img
            src={userIcon.src}
            alt=""
            class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 opacity-70"
          />
          <input
            type="text"
            name="firstName"
            placeholder="Prénom"
            class="input input-bordered w-full pl-10 bg-transparent border-gray-200 text-gray-200"
            required
          />
        </div>
        <!-- Champ Nom -->
        <div class="relative my-2">
          <img
            src={userIcon.src}
            alt=""
            class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 opacity-70"
          />
          <input
            type="text"
            name="lastName"
            placeholder="Nom"
            class="input input-bordered w-full pl-10 bg-transparent border-gray-200 text-gray-200"
            required
          />
        </div>
        <!-- Champ Email -->
        <div class="relative my-2">
          <img
            src={userIcon.src}
            alt=""
            class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 opacity-70"
          />
          <input
            type="email"
            name="email"
            placeholder="Adresse e-mail"
            class="input input-bordered w-full pl-10 bg-transparent border-gray-200 text-gray-200"
            required
          />
        </div>
        <!-- Champ Mot de passe -->
        <div class="relative my-2">
          <img
            src={lockIcon.src}
            alt=""
            class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 opacity-70"
          />
          <input
            type="password"
            name="password"
            placeholder="Mot de passe"
            class="input input-bordered w-full pl-10 bg-transparent border-gray-200 text-gray-200"
            required
          />
        </div>
        <!-- Champ Confirmation mot de passe -->
        <div class="relative my-2">
          <img
            src={lockIcon.src}
            alt=""
            class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 opacity-70"
          />
          <input
            type="password"
            name="passwordConfirm"
            placeholder="Confirmer le mot de passe"
            class="input input-bordered w-full pl-10 bg-transparent border-gray-200 text-gray-200"
            required
          />
        </div>

        <!-- Bouton d'inscription -->
        <button
          class="btn btn-primary rounded-lg! bg-white text-primary w-full mt-4"
          >S'inscrire</button
        >
      </form>
      <!-- Lien vers la page de connexion -->
      <div class="flex justify-center w-full mt-4 text-sm text-white">
        <a href="/connexion">Déjà un compte ? Se connecter</a>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { createUser } from "../lib/pocketbase.mjs";
  import { gsap } from 'gsap';
  
  // Sélection des éléments DOM
  const form = document.querySelector("form");
  const errorText = document.getElementById("errorText") as HTMLElement | null;

  // Fonction pour afficher les erreurs avec animation GSAP
  function showError(message: string, type: string = "error") {
    if (errorText) {
      gsap.killTweensOf(errorText);
      gsap.set(errorText, { opacity: 0, y: 60 });
      
      errorText.classList.remove("text-red-500", "text-secondary");
      errorText.classList.add(type === "warning" ? "text-secondary" : "text-red-500");
      
      errorText.textContent = message;
      errorText.style.pointerEvents = "auto";
      
      requestAnimationFrame(() => {
        gsap.to(errorText, {
          opacity: 1,
          y: 0,
          duration: 0.5,
          ease: "power2.out"
        });
      });
    }
  }

  // Fonction pour masquer les erreurs avec animation GSAP
  function hideError() {
    if (errorText) {
      gsap.to(errorText, {
        opacity: 0,
        y: -60,
        duration: 0.3,
        ease: "power2.in",
        onComplete: () => {
          if (errorText) {
            errorText.style.pointerEvents = "none";
            errorText.classList.remove("text-red-500", "text-secondary");
          }
        }
      });
    }
  }

  // Gestionnaire d'événement pour la soumission du formulaire
  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    hideError();
    
    const formData = new FormData(form);
    const firstName = formData.get("firstName") as string;
    const lastName = formData.get("lastName") as string;
    const email = formData.get("email") as string;
    const password = formData.get("password") as string;
    const passwordConfirm = formData.get("passwordConfirm") as string;

    // Vérification de la correspondance des mots de passe
    if (password !== passwordConfirm) {
      showError("Les mots de passe ne correspondent pas.");
      return;
    }

    try {
      // Tentative de création de l'utilisateur via PocketBase
      await createUser({
        email: email,
        password: password,
        passwordConfirm: passwordConfirm,
        name: `${firstName} ${lastName}`,
      });
      showError("Inscription réussie ! Vous pouvez maintenant vous connecter.", "warning");
      setTimeout(() => {
        window.location.href = "/connexion";
      }, 2000);
    } catch (error: any) {
      const message = error.message || "Échec de l'inscription. Veuillez vérifier vos informations et réessayer.";
      showError(message);
    }
  });
</script>
