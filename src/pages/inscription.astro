---
import Layout from "../layouts/Layout-login.astro";
import shapesLeft from "../assets/login-page/shapes-left.svg";
import shapesRight from "../assets/login-page/shapes-right.svg";
import logo from "../assets/logo-kiwanis-full.svg";
import backArrow from "../assets/back-arrow.svg";
import userIcon from "../assets/login-page/user.svg";
import lockIcon from "../assets/login-page/lock.svg";

let success = false;
let serverMessage = "";

const isPostForm =
  Astro.request.method === "POST" &&
  Astro.request.headers.get("content-type")?.includes("form");

if (isPostForm) {
  try {
    const data = await Astro.request.formData();

    const firstName = data.get("firstName")?.toString() ?? "";
    const lastName = data.get("lastName")?.toString() ?? "";
    const email = data.get("email")?.toString() ?? "";
    const password = data.get("password")?.toString() ?? "";
    const passwordConfirm = data.get("passwordConfirm")?.toString() ?? "";

    if (!email || !password || password !== passwordConfirm) {
      throw new Error("Informations invalides.");
    }

    await Astro.locals.pb.collection("users").create({
      email,
      password,
      passwordConfirm,
      name: `${firstName} ${lastName}`,
      verified: false,
    });

    success = true;
    serverMessage =
      "Inscription réussie. Votre compte doit être validé avant connexion.";
  } catch (error) {
    serverMessage =
      error instanceof Error
        ? error.message
        : "Erreur lors de l'inscription.";
  }
}
---

<Layout>
  <div class="absolute top-8 left-8 flex items-center text-white hover:underline z-10">
    <img src={backArrow.src} aria-hidden="true" />
    <a href="/" class="text-white ml-2">Retour à l'accueil</a>
  </div>

  <img src={shapesLeft.src} aria-hidden="true"
    class="absolute left-0 bottom-0 w-[50dvw] lg:w-[25dvw] select-none" />
  <img src={shapesRight.src} aria-hidden="true"
    class="absolute right-0 top-0 w-[70dvw] md:w-[50dvw] lg:w-[40dvw] select-none" />

  <div class="absolute -translate-x-1/2 -translate-y-1/2 left-1/2 top-1/2
              flex flex-col lg:flex-row gap-4 md:gap-16 justify-center items-center z-10">

    <img src={logo.src} alt="Logo Kiwanis Pays de Montbéliard"
      class="md:w-[30dvw] lg:w-[15dvw]" />

    <div class="lg:max-w-[20dvw]">

      <!-- FLAGS SERVEUR -->
      <div
        id="auth-flags"
        data-success={String(success)}
        data-message={serverMessage}
        class="hidden">
      </div>

      <form method="post" class="flex flex-col w-full relative">

        <div id="errorText"
          class="absolute left-0 right-0 text-sm text-start font-semibold opacity-0 pointer-events-none"
          style="bottom: calc(100% + 0.5rem);">
        </div>

        <div class="relative my-2">
          <img src={userIcon.src} class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 opacity-70" />
          <input type="text" name="firstName" placeholder="Prénom"
            class="input input-bordered w-full pl-10 bg-transparent border-gray-200 text-gray-200" required />
        </div>

        <div class="relative my-2">
          <img src={userIcon.src} class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 opacity-70" />
          <input type="text" name="lastName" placeholder="Nom"
            class="input input-bordered w-full pl-10 bg-transparent border-gray-200 text-gray-200" required />
        </div>

        <div class="relative my-2">
          <img src={userIcon.src} class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 opacity-70" />
          <input type="email" name="email" placeholder="Adresse e-mail"
            class="input input-bordered w-full pl-10 bg-transparent border-gray-200 text-gray-200" required />
        </div>

        <div class="relative my-2">
          <img src={lockIcon.src} class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 opacity-70" />
          <input type="password" name="password" placeholder="Mot de passe"
            class="input input-bordered w-full pl-10 bg-transparent border-gray-200 text-gray-200" required />
        </div>

        <div class="relative my-2">
          <img src={lockIcon.src} class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 opacity-70" />
          <input type="password" name="passwordConfirm" placeholder="Confirmer le mot de passe"
            class="input input-bordered w-full pl-10 bg-transparent border-gray-200 text-gray-200" required />
        </div>

        <button class="btn btn-primary bg-white text-primary w-full mt-4">
          S'inscrire
        </button>
      </form>

      <div class="flex justify-center w-full mt-4 text-sm text-white">
        <a href="/connexion">Déjà un compte ? Se connecter</a>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { gsap } from "gsap";

  const errorText = document.getElementById("errorText");
  const flags = document.getElementById("auth-flags");

  function showError(message:string, type = "error") {
    if (!errorText) return;

    gsap.killTweensOf(errorText);
    gsap.set(errorText, { opacity: 0, y: 60 });

    errorText.classList.remove("text-red-500", "text-secondary");
    errorText.classList.add(type === "warning" ? "text-secondary" : "text-red-500");

    errorText.textContent = message;
    errorText.style.pointerEvents = "auto";

    requestAnimationFrame(() => {
      gsap.to(errorText, {
        opacity: 1,
        y: 0,
        duration: 0.5,
        ease: "power2.out",
      });
    });
  }

  if (flags) {
    const success = flags.dataset.success === "true";
    const message = flags.dataset.message;

    if (message) {
      showError(message, success ? "warning" : "error");
    }

    if (success) {
      setTimeout(() => {
        window.location.href = "/connexion";
      }, 2000);
    }
  }
</script>
