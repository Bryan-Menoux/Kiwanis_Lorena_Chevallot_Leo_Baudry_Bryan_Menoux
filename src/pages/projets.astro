---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import slugify from "slugify";
import { formatDateShort } from "../utils/utilitaires.js";
import HeroActions from "../assets/projects-page/hero-project-page.png";
import HeroActionsMobile from "../assets/projects-page/hero-project-page-mobile.png";
import HeroActionsTablet from "../assets/projects-page/hero-project-page-tablette.png";
import { getImage } from "astro:assets";

const lcpMobile = await getImage({ src: HeroActionsMobile, format: "webp", width: 440, quality: 68 });
const lcpTablet = await getImage({ src: HeroActionsTablet, format: "webp", width: 1280, quality: 72 });
const lcpDesktopMd = await getImage({ src: HeroActions, format: "webp", width: 1440, quality: 80 });
const lcpDesktop = await getImage({ src: HeroActions, format: "webp", width: 1840, quality: 80 });

const projects = await Astro.locals.pb.collection("projets").getFullList({ sort: "-date" });

import DiagArrow from "../components/DiagArrow.astro";

const projets = await Astro.locals.pb.collection("projets").getFullList({ sort: "-date" });

function truncateWords(text: string, limit = 70): string {
  const normalized = text.trim();
  if (!normalized) return "";

  const words = normalized.split(/\s+/).filter(Boolean);
  if (words.length <= limit) return normalized;

  return `${words.slice(0, limit).join(" ")}...`;
}
---

<Layout>
  <Fragment slot="head">
    <link rel="preload" as="image" href={lcpMobile.src} type="image/webp" media="(max-width: 767px)" fetchpriority="high" />
    <link rel="preload" as="image" href={lcpTablet.src} type="image/webp" media="(min-width: 768px) and (max-width: 1023px)" fetchpriority="high" />
    <link rel="preload" as="image" href={lcpDesktop.src} imagesrcset={`${lcpDesktopMd.src} 1440w, ${lcpDesktop.src} 1840w`} imagesizes="95vw" type="image/webp" media="(min-width: 1024px)" fetchpriority="high" />
  </Fragment>
  <Hero
    image={HeroActions}
    title="Kiwanis Pays de Montbéliard"
    subtitle="Servir les enfants du monde, au cœur de notre territoire"
  />

  <section class="min-h-[80dvh] h-fit w-full mt-64 flex">
    <div class="w-1/2 min-h-[80dvh] rounded-tr-box rounded-br-box bg-accent flex flex-col justify-between items-center px-8 py-16 text-base-100 sticky top-[15dvh] self-start">
      <div class="flex flex-col gap-8">
        <p class="text-sm font-bold" >Prochaines actions</p>
      <h2 class="text-5xl!">Découvrez nos projets futurs !</h2>
      <p>Découvrez les initiatives que nous préparons avec nos partenaires pour répondre à des besoins concrets sur le territoire. Chaque projet est pensé pour créer du lien, soutenir des publics fragilisés et renforcer la solidarité locale, avec des actions claires, des objectifs simples et un impact réel.</p>
      </div>
      <a href="/actions" class="btn btn-block flex items-center gap-2 uppercase w-fit self-end" >Découvrez nos actions passées <DiagArrow class="h-3 w-auto invert" /></a>
    </div>
    <div class="w-1/2 min-h-fit flex flex-col gap-16 px-16 py-32">
      {
        projets.map((projet) => (
          <div class="w-full h-[50dvh] bg-base-100 shadow-2xl rounded-box p-8 flex flex-col justify-between items-end">
            <div class="flex flex-col w-full min-w-0" >
              <ul class="flex gap-2">
              {
                projet.type_action.map((type) => (
                  <li class="bg-secondary px-4 py-2 rounded-full text-accent">{type}</li>
                ))
              }
            </ul>
            <h2
              class="font-medium! mt-4"
              style="overflow-wrap:anywhere; word-break:break-word;"
            >
              {projet.titre}
            </h2>
            <p style="overflow-wrap:anywhere; word-break:break-word;">
              {projet.description ? truncateWords(projet.description, 70) : ""}
            </p>
            </div>
            <div class="flex w-full items-end justify-between" >
              <p>{projet.date ? formatDateShort(new Date(projet.date)) : ""}</p>
              {projet.date && projet.nom_adresse ? (
              <button class="btn btn-accent mt-4">Ajouter à l'agenda <DiagArrow class="h-3 w-auto ml-2" /></button>
            ) : !projet.date && projet.nom_adresse ? (
              <a href={projet.url_adresse} target="_blank" rel="noopener noreferrer" class="btn btn-accent mt-4">Voir sur Maps <DiagArrow class="h-3 w-auto ml-2" /></a>
            ) : null}
            </div>
          </div>
        ))
      }
    </div>

  </section>
</Layout>
