---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import AlertProvider from "../components/AlertProvider.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  robots?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  structuredData?: Record<string, unknown>[];
  
  includeAlertProvider?: boolean;
  includeManifest?: boolean;
  loadPoppinsFont?: boolean;
}

const {
  title = "Kiwanis Pays de Montbéliard",
  description = "Découvrez le Kiwanis Pays de Montbéliard",
  canonical = "/",
  robots = "index,follow",
  ogTitle = "Kiwanis Pays de Montbéliard",
  ogDescription = "Découvrez le Kiwanis Pays de Montbéliard",
  ogImage,
  ogType = "website",
  structuredData = [],
  includeAlertProvider = false,
  includeManifest = true,
  loadPoppinsFont = true,
} = Astro.props as Props;

const pathname = new URL(Astro.request.url).pathname;
---

<!doctype html>
<html lang="fr" data-theme="Kiwanis">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO Basics -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical ? `https://kiwanis-montbeliard.fr${canonical}` : "https://kiwanis-montbeliard.fr"} />

    <!-- Open Graph / Social Media -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:url" content={`https://kiwanis-montbeliard.fr${pathname}`} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />

    <!-- Structured Data -->
    {structuredData && structuredData.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <slot name="head" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />

    {includeManifest && <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />}
    <meta name="mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />

    {includeManifest && <link rel="manifest" href="/site.webmanifest" />}

    <meta name="theme-color" content="#000000" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    {includeAlertProvider && <AlertProvider />}
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
