---
import "../styles/global.css";
import HeaderCreation from "../components/HeaderCreation.astro";
import Footer from "../components/Footer.astro";
import AlertProvider from "../components/AlertProvider.astro";
---

<!doctype html>
<html lang="fr" data-theme="Kiwanis">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      {`
        (() => {
          const root = document.documentElement;
          const markFontsReady = () => root.classList.add("fonts-ready");

          const schedulePoppinsLoad = () => {
            if (!("fonts" in document)) {
              markFontsReady();
              return;
            }

            const loadPoppins = () => {
              document.fonts
                .load('400 1em "Poppins"')
                .then(markFontsReady)
                .catch(markFontsReady);
            };

            if ("requestIdleCallback" in window) {
              window.requestIdleCallback(loadPoppins, { timeout: 1600 });
              return;
            }

            window.setTimeout(loadPoppins, 320);
          };

          if (document.readyState === "complete") {
            schedulePoppinsLoad();
            return;
          }

          window.addEventListener("load", schedulePoppinsLoad, { once: true });
        })();
      `}
    </script>

    <!-- Favicon: Standard et fallback (requis pour compatibilite Google) -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Favicon: PNG standards (recommande par Google) -->
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />

    <!-- Android Chrome (PWA homescreen) -->
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href="/android-chrome-192.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="512x512"
      href="/android-chrome-512.png"
    />
    <meta name="theme-color" content="#000000" />

    <!-- iOS / macOS (homescreen + bookmarks) -->
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />

    <!-- Web App Manifest (PWA) -->
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Meta tags additionnels pour SEO -->
    <meta
      name="description"
      content="Site officiel du Kiwanis Pays de Montbéliard"
    />
    <meta name="theme-color" content="#000000" />
    <meta name="generator" content={Astro.generator} />

    <title>Kiwanis Pays de Montbéliard</title>
  </head>
  <body class="overflow-x-hidden">
    <AlertProvider />
    <HeaderCreation></HeaderCreation>
    <slot />
    <Footer></Footer>
  </body>
</html>
<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>

