---
/**
 * Flèche diagonale décorative (15×15px) rendue inline en SVG.
 * Remplace <Image src={diagArrow}> qui générait une requête /_image par usage.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---
<svg
  class={className}
  width="15"
  height="15"
  viewBox="0 0 15 15"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  role="presentation"
>
  <path
    d="M0.75 13.75L13.75 0.75L0.75 13.75ZM13.75 0.75H2.05H13.75ZM13.75 0.75V12.45V0.75Z"
    fill="white"
  />
  <path
    d="M0.75 13.75L13.75 0.75M13.75 0.75H2.05M13.75 0.75V12.45"
    stroke="white"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>
