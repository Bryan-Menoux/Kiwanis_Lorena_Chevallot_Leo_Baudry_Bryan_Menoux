---
import logo from "../assets/logo.svg";
import { Image } from "astro:assets";
import DiagArrow from "./DiagArrow.astro";
---

<footer class="bg-[#2B2549] px-6 py-10 md:px-6 md:py-10 lg:px-6 lg:py-10 w-full lg:min-h-75 mt-16 lg:mt-32">
  <div class="flex flex-col lg:flex-row lg:gap-8 lg:items-stretch lg:h-full max-w-full">
    
    <!-- Logo et Titre -->
    <div class="h-full flex flex-col items-center gap-6 mb-10 sm:flex-row-reverse sm:items-start sm:gap-6 lg:mb-0 lg:justify-end lg:w-1/2 lg:h-full lg:flex-row-reverse lg:gap-12 lg:items-center min-w-0">
      <Image 
        src={logo} 
        alt="logo kiwanis" 
        loading="eager"
        quality={80}
        class="w-32 h-32 md:w-40 md:h-40 lg:w-auto lg:h-auto shrink lg:min-w-0 object-contain" 
      />
      <div class="text-left flex flex-col flex-1 lg:flex-initial justify-between lg:h-full gap-0 w-fit font-merriweather">
        <p class="text-white font-merriweather text-4xl! md:text-5xl! lg:text-6xl! font-normal leading-[1.1] tracking-tighter m-0">
          KIWANIS
        </p>
        <p class="text-white font-merriweather text-2xl! md:text-4xl! lg:text-5xl! font-light leading-[1.1] tracking-tighter m-0">
          PAYS
        </p>
        <p class="text-white font-merriweather text-2xl! md:text-4xl! lg:text-5xl! font-light leading-[1.1] tracking-tighter m-0">
          DE
        </p>
        <p class="text-white font-merriweather text-2xl! md:text-4xl! lg:text-5xl! font-light leading-[1.1] tracking-tighter m-0">
          MONTBÉLIARD
        </p>
      </div>
    </div>

    <!-- Navigation et Contact -->
    <div class="flex flex-col gap-8 lg:w-1/2 lg:justify-between min-w-0">
      
      <!-- Navigation -->
      <div class="flex flex-col gap-8 lg:flex-row lg:pb-8 lg:border-b lg:border-white/10 w-full min-w-0">
        <div class="flex flex-col gap-8 md:flex-row md:gap-6 md:flex-1 lg:flex-row lg:gap-12 flex-1 min-w-0">
          <nav class="flex flex-col gap-4 md:min-w-40 lg:gap-2">
            <a href="/nos-membres" class="text-white hover:opacity-70 transition-opacity flex items-center justify-between">
              Nos membres
              <DiagArrow class="w-3 h-3" />
            </a>
            <a href="/contact" class="text-white hover:opacity-70 transition-opacity flex items-center justify-between">
              Page contact
              <DiagArrow class="w-3 h-3" />
            </a>
            <a href="/faire-un-don" class="text-white hover:opacity-70 transition-opacity flex items-center justify-between">
              Faire un don
              <DiagArrow class="w-3 h-3" />
            </a>
          </nav>

          <nav class="flex flex-col gap-4 md:min-w-40 lg:gap-2">
            <a href="/nos-actions" class="text-white hover:opacity-70 transition-opacity flex items-center justify-between">
              Nos actions
              <DiagArrow class="w-3 h-3" />
            </a>
            <a href="/nos-projets" class="text-white hover:opacity-70 transition-opacity flex items-center justify-between">
              Nos projets
              <DiagArrow class="w-3 h-3" />
            </a>
            <a href="/nos-produits" class="text-white hover:opacity-70 transition-opacity flex items-center justify-between">
              Nos produits
              <DiagArrow class="w-3 h-3" />
            </a>
          </nav>
        </div>

        <div class="hidden lg:flex flex-col justify-start">
          <p class="text-white font-sans text-xs font-normal opacity-70">
            (c) 2026 - Copyright
          </p>
        </div>
      </div>

      <!-- Contact et Réseaux -->
      <div class="flex flex-col gap-8 md:flex-row md:justify-between md:items-end md:gap-6 lg:justify-between lg:items-end lg:gap-6">
        <div class="flex flex-col gap-3">
          <p class="text-white font-sans text-xs font-medium leading-[1.3] lg:leading-none tracking-widest uppercase opacity-60">
            Contactez-nous
          </p>
          <div class="flex flex-col gap-3 md:gap-1 lg:gap-0.5">
            <a href="tel:+33684523650" class="text-white font-sans text-sm font-normal leading-[1.4] lg:leading-tight tracking-wide hover:opacity-70 transition-opacity">
              06 84 52 36 50
            </a>
            <a href="mailto:kiwanisfeminin.montbeliard@gmail.com" class="text-white font-sans text-xs font-normal leading-[1.4] lg:leading-tight tracking-wide hover:opacity-70 transition-opacity break-all md:break-normal">
              kiwanisfeminin.montbeliard@gmail.com
            </a>
          </div>
        </div>

        <div class="flex gap-3 md:gap-2 lg:gap-2 items-center shrink-0">
          <svg class="w-6 h-6 md:w-7 md:h-7 lg:w-7 lg:h-7 shrink-0 hover:opacity-80 transition-opacity" viewBox="0 0 35 35" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Facebook">
            <path fill="white" d="M17.5 32c8.284 0 15-6.716 15-15 0-8.284-6.716-15-15-15-8.284 0-15 6.716-15 15 0 8.284 6.716 15 15 15Z"/>
            <path fill="#2B2549" d="M20.637 25V17.62h2.455l.368-2.853h-2.823V12.89c0-.826.229-1.389 1.415-1.389h1.512v-2.549c-.261-.034-1.156-.113-2.197-.113-2.176 0-3.67 1.327-3.67 3.764v2.105h-2.465v2.853h2.465V25h2.945Z"/>
          </svg>
          <a href="#" class="px-3 py-1.5 border border-white/30 rounded-full text-white font-sans text-xs font-normal leading-[1.3] md:leading-[1.3] lg:leading-tight tracking-wide whitespace-nowrap hover:bg-white/10 transition-colors duration-300">
            Facebook
          </a>
        </div>

      </div>
    </div>
  </div>

  <p class="text-white font-sans text-xs font-normal opacity-70 text-center md:text-right lg:text-right mt-6 pt-6 md:mt-0 md:pt-0 md:border-0 border-t border-white/10 md:hidden">
    (c) 2026 - Copyright
  </p>
</footer>

