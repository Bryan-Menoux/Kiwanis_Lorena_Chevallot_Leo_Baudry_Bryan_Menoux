---
import logo from "../assets/logo.svg";
import DiagArrow from "./DiagArrow.astro";

const facebookUrl = "https://www.facebook.com/Kiwaniennes25/";
const contactEmail = "kiwanisfeminin.montbeliard@gmail.com";
---

<footer
  class="bg-[#2B2549] px-6 py-10 md:px-6 md:py-10 lg:px-6 lg:py-10 w-full lg:min-h-75 mt-16 lg:mt-32"
>
  <div
    class="flex flex-col lg:flex-row lg:gap-8 lg:items-stretch lg:h-full max-w-full"
  >
    <!-- Logo et Titre -->
    <div
      class="h-full flex flex-col items-center gap-6 mb-10 sm:flex-row-reverse sm:items-start sm:gap-6 lg:mb-0 lg:justify-end lg:w-1/2 lg:h-full lg:flex-row-reverse lg:gap-12 lg:items-center min-w-0"
    >
      <img
        src={logo.src}
        alt="logo kiwanis"
        class="w-32 h-32 md:w-40 md:h-40 lg:w-64 lg:h-64 shrink lg:min-w-0 block object-contain"
      />
      <div
        class="text-left flex flex-col flex-1 lg:flex-initial justify-between lg:h-full gap-0 w-fit font-merriweather"
      >
        <p
          class="text-white font-merriweather text-4xl! md:text-5xl! lg:text-6xl! font-normal leading-[1.1] tracking-tighter m-0"
        >
          KIWANIS
        </p>
        <p
          class="text-white font-merriweather text-2xl! md:text-4xl! lg:text-5xl! font-light leading-[1.1] tracking-tighter m-0"
        >
          PAYS
        </p>
        <p
          class="text-white font-merriweather text-2xl! md:text-4xl! lg:text-5xl! font-light leading-[1.1] tracking-tighter m-0"
        >
          DE
        </p>
        <p
          class="text-white font-merriweather text-2xl! md:text-4xl! lg:text-5xl! font-light leading-[1.1] tracking-tighter m-0"
        >
          MONTBÉLIARD
        </p>
      </div>
    </div>

    <!-- Navigation et Contact -->
    <div class="flex flex-col gap-8 lg:w-1/2 lg:justify-between min-w-0">
      <!-- Navigation -->
      <div
        class="flex flex-col gap-8 lg:flex-row lg:pb-8 lg:border-b lg:border-white/10 w-full min-w-0"
      >
        <div
          class="flex flex-col gap-8 md:flex-row md:gap-6 md:flex-1 lg:flex-row lg:gap-12 flex-1 min-w-0"
        >
          <nav class="flex flex-col gap-4 md:min-w-40 lg:gap-2">
            <a
              href="/membres"
              class="text-white hover:opacity-70 transition-opacity flex items-center justify-between gap-4"
            >
              Nos membres
              <DiagArrow class="w-3 h-3" />
            </a>
            <a
              href="/contact"
              class="text-white hover:opacity-70 transition-opacity flex items-center justify-between gap-4"
            >
              Nous contacter
              <DiagArrow class="w-3 h-3" />
            </a>
            <a
              href="/recrutement"
              class="text-white hover:opacity-70 transition-opacity flex items-center justify-between gap-4"
            >
              Nous rejoindre
              <DiagArrow class="w-3 h-3" />
            </a>
            <a
              href="/conditions-utilisation"
              class="text-white hover:opacity-70 transition-opacity flex items-center justify-between gap-4"
            >
              Conditions d'utilisation
              <DiagArrow class="w-3 h-3" />
            </a>
          </nav>

          <nav class="flex flex-col gap-4 md:min-w-40 lg:gap-2">
            <a
              href="/actions"
              class="text-white hover:opacity-70 transition-opacity flex items-center justify-between gap-4"
            >
              Nos actions
              <DiagArrow class="w-3 h-3" />
            </a>
            <a
              href="/projets"
              class="text-white hover:opacity-70 transition-opacity flex items-center justify-between gap-4"
            >
              Nos projets
              <DiagArrow class="w-3 h-3" />
            </a>
            <a
              href="/produits"
              class="text-white hover:opacity-70 transition-opacity flex items-center justify-between gap-4"
            >
              Nos produits
              <DiagArrow class="w-3 h-3" />
            </a>
            <a
              href="/cookies"
              class="text-white hover:opacity-70 transition-opacity flex items-center justify-between gap-4"
            >
              Cookies
              <DiagArrow class="w-3 h-3" />
            </a>
          </nav>
        </div>

        <div class="hidden lg:flex flex-col justify-start">
        </div>
      </div>

      <!-- Contact et Réseaux -->
      <div
        class="flex flex-col gap-8 md:flex-row md:justify-between md:items-end md:gap-6 lg:justify-between lg:items-end lg:gap-6"
      >
        <div class="flex flex-col gap-3">
          <p
            class="text-white font-sans text-xs font-medium leading-[1.3] lg:leading-none tracking-widest uppercase opacity-60"
          >
            Contactez-nous
          </p>
          <div class="flex flex-col gap-3 md:gap-1 lg:gap-0.5">
            <a
              href="tel:+33684523650"
              class="text-white font-sans text-sm font-normal leading-[1.4] lg:leading-tight tracking-wide hover:opacity-70 transition-opacity"
            >
              06 84 52 36 50
            </a>
            <a
              href={`mailto:${contactEmail}`}
              class="text-white font-sans text-xs font-normal leading-[1.4] lg:leading-tight tracking-wide hover:opacity-70 transition-opacity break-all md:break-normal"
            >
              {contactEmail}
            </a>
          </div>
        </div>

        <div class="flex flex-col gap-3 items-end">
          <div class="flex gap-3 md:gap-2 lg:gap-2 items-center shrink-0 flex-wrap justify-end md:justify-end lg:justify-end">
            <button
              type="button"
              class="px-3 py-1.5 border border-white/30 rounded-full text-white font-sans text-xs font-normal leading-[1.3] md:leading-[1.3] lg:leading-tight tracking-wide whitespace-nowrap hover:bg-white/10 transition-colors duration-300"
              data-open-cookie-settings="customize"
            >
              Gérer mes cookies
            </button>
            <a
              href={facebookUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="px-3 py-1.5 border border-white/30 rounded-full text-white font-sans text-xs font-normal leading-[1.3] md:leading-[1.3] lg:leading-tight tracking-wide whitespace-nowrap hover:bg-white/10 transition-colors duration-300 flex items-center gap-2"
            >
              <svg
                width="35px"
                height="35px"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M20 12.05C19.9813 10.5255 19.5273 9.03809 18.6915 7.76295C17.8557 6.48781 16.673 5.47804 15.2826 4.85257C13.8921 4.2271 12.3519 4.01198 10.8433 4.23253C9.33473 4.45309 7.92057 5.10013 6.7674 6.09748C5.61422 7.09482 4.77005 8.40092 4.3343 9.86195C3.89856 11.323 3.88938 12.8781 4.30786 14.3442C4.72634 15.8103 5.55504 17.1262 6.69637 18.1371C7.83769 19.148 9.24412 19.8117 10.75 20.05V14.38H8.75001V12.05H10.75V10.28C10.7037 9.86846 10.7483 9.45175 10.8807 9.05931C11.0131 8.66687 11.23 8.30827 11.5161 8.00882C11.8022 7.70936 12.1505 7.47635 12.5365 7.32624C12.9225 7.17612 13.3368 7.11255 13.75 7.14003C14.3498 7.14824 14.9482 7.20173 15.54 7.30003V9.30003H14.54C14.3676 9.27828 14.1924 9.29556 14.0276 9.35059C13.8627 9.40562 13.7123 9.49699 13.5875 9.61795C13.4627 9.73891 13.3667 9.88637 13.3066 10.0494C13.2464 10.2125 13.2237 10.387 13.24 10.56V12.07H15.46L15.1 14.4H13.25V20C15.1399 19.7011 16.8601 18.7347 18.0985 17.2761C19.3369 15.8175 20.0115 13.9634 20 12.05Z"
                  fill="#ffffff"></path>
              </svg>
              Facebook
            </a>
          </div>
          <p class="text-white font-sans text-xs font-normal opacity-70 hidden md:block">
            (c) 2026 - Copyright
          </p>
        </div>
      </div>
    </div>
  </div>

  <p
    class="text-white font-sans text-xs font-normal opacity-70 text-center md:text-right lg:text-right mt-6 pt-6 md:mt-0 md:pt-0 md:border-0 border-t border-white/10 md:hidden"
  >
    (c) 2026 - Copyright
  </p>
</footer>
