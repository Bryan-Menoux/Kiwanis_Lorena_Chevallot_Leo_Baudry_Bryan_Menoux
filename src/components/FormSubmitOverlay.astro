---
export interface Props {
  formSelector: string;
  message?: string;
  id?: string;
}

const {
  formSelector,
  message = "Traitement en cours...",
  id = `submit-overlay-${formSelector
    .replace(/[^a-zA-Z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "")
    .toLowerCase() || "form"}`,
} = Astro.props;
---

<div
  id={id}
  class="fixed inset-0 z-9999 hidden items-center justify-center bg-base-100/70 backdrop-blur-sm"
  aria-hidden="true"
  role="status"
  aria-live="polite"
>
  <div class="rounded-2xl border border-base-300 bg-base-100 px-6 py-4 shadow-xl">
    <div class="flex items-center gap-3">
      <span class="loading loading-spinner loading-md text-accent" aria-hidden="true"></span>
      <p class="text-sm font-medium text-base-content">{message}</p>
    </div>
  </div>
</div>

<script define:vars={{ formSelector, overlayId: id }}>
  const PENDING_ATTR = "data-submit-overlay-pending";
  const IN_FLIGHT_ATTR = "data-submit-overlay-in-flight";
  const DISABLED_BY_OVERLAY_ATTR = "data-disabled-by-submit-overlay";
  const KEEP_VISIBLE_ATTR = "data-submit-overlay-keep-visible";
  const FALLBACK_TOKEN_ATTR = "data-submit-overlay-fallback-token";
  const FALLBACK_RESET_MS = 30000;
  const FAILURE_EVENT_NAME = "kc:submit-overlay-failed";
  const DEFAULT_FAILURE_MESSAGE =
    "L'enregistrement a échoue. Verifiez votre connexion puis reessayez.";

  const overlayNode = document.getElementById(overlayId);
  if (!(overlayNode instanceof HTMLElement)) {
    console.warn(`Overlay introuvable: ${overlayId}`);
  } else {
  // L'overlay doit vivre sous <body> pour eviter les conteneurs transform/sticky.
  if (overlayNode.parentElement !== document.body) {
    document.body.appendChild(overlayNode);
  }

  const windowState = window;
  const overlayBindings =
    windowState.__kcSubmitOverlayBindings ??
    (windowState.__kcSubmitOverlayBindings = new Set());
  const overlayBySelector =
    windowState.__kcSubmitOverlayBySelector ??
    (windowState.__kcSubmitOverlayBySelector = new Map());
  overlayBySelector.set(formSelector, overlayId);

  const getActiveOverlay = () => {
    const mappedId = overlayBySelector.get(formSelector) || overlayId;
    const node = document.getElementById(mappedId);
    return node instanceof HTMLElement ? node : null;
  };

  const showOverlay = () => {
    const overlay = getActiveOverlay();
    if (!(overlay instanceof HTMLElement)) return;
    overlay.classList.remove("hidden");
    overlay.classList.add("flex");
    overlay.setAttribute("aria-hidden", "false");
  };

  const hideOverlay = () => {
    const overlay = getActiveOverlay();
    if (!(overlay instanceof HTMLElement)) return;
    overlay.classList.add("hidden");
    overlay.classList.remove("flex");
    overlay.setAttribute("aria-hidden", "true");
  };

  const normalizeFailureMessage = (rawMessage) => {
    if (typeof rawMessage === "string" && rawMessage.trim() !== "") {
      return rawMessage.trim();
    }
    return DEFAULT_FAILURE_MESSAGE;
  };

  const pushErrorAlert = (message) => {
    const payload = { type: "error", message };
    if (
      window.KiwanisAlert &&
      typeof window.KiwanisAlert.show === "function"
    ) {
      window.KiwanisAlert.show(payload);
      return;
    }
    window.dispatchEvent(
      new CustomEvent("kiwanis:alert", {
        detail: payload,
      }),
    );
  };

  const disableSubmitControls = (form) => {
    const controls = form.querySelectorAll('button[type="submit"], input[type="submit"]');
    controls.forEach((control) => {
      if (
        control instanceof HTMLButtonElement ||
        control instanceof HTMLInputElement
      ) {
        control.disabled = true;
        control.setAttribute(DISABLED_BY_OVERLAY_ATTR, "true");
      }
    });
  };

  const restoreSubmitControls = (form) => {
    const controls = form.querySelectorAll('button[type="submit"], input[type="submit"]');
    controls.forEach((control) => {
      if (
        (control instanceof HTMLButtonElement ||
          control instanceof HTMLInputElement) &&
        control.getAttribute(DISABLED_BY_OVERLAY_ATTR) === "true"
      ) {
        control.disabled = false;
        control.removeAttribute(DISABLED_BY_OVERLAY_ATTR);
      }
    });
  };

  const resetMatchedForms = () => {
    const forms = document.querySelectorAll(formSelector);
    forms.forEach((form) => {
      if (!(form instanceof HTMLFormElement)) return;
      form.removeAttribute(PENDING_ATTR);
      form.removeAttribute(IN_FLIGHT_ATTR);
      form.removeAttribute(KEEP_VISIBLE_ATTR);
      form.removeAttribute(FALLBACK_TOKEN_ATTR);
      restoreSubmitControls(form);
    });
    hideOverlay();
  };

  const failMatchedForms = (rawMessage) => {
    const message = normalizeFailureMessage(rawMessage);
    let hasMatchedForm = false;

    const forms = document.querySelectorAll(formSelector);
    forms.forEach((form) => {
      if (!(form instanceof HTMLFormElement)) return;
      hasMatchedForm = true;
      form.removeAttribute(PENDING_ATTR);
      form.removeAttribute(IN_FLIGHT_ATTR);
      form.removeAttribute(KEEP_VISIBLE_ATTR);
      form.removeAttribute(FALLBACK_TOKEN_ATTR);
      restoreSubmitControls(form);
    });

    if (!hasMatchedForm) return;
    hideOverlay();
    pushErrorAlert(message);
  };

  const scheduleFallbackReset = (form) => {
    const token = `${Date.now()}-${Math.random().toString(36).slice(2)}`;
    form.setAttribute(FALLBACK_TOKEN_ATTR, token);

    window.setTimeout(() => {
      const stillSameToken = form.getAttribute(FALLBACK_TOKEN_ATTR) === token;
      if (!stillSameToken) return;

      const isStillBusy =
        form.getAttribute(PENDING_ATTR) === "true" ||
        form.getAttribute(IN_FLIGHT_ATTR) === "true" ||
        form.getAttribute(KEEP_VISIBLE_ATTR) === "true";
      if (!isStillBusy) return;
      failMatchedForms(
        "L'enregistrement a depasse le delai. Verifiez votre connexion et reessayez.",
      );
    }, FALLBACK_RESET_MS);
  };

  const bindingKey = formSelector;
  if (overlayBindings.has(bindingKey)) {
    resetMatchedForms();
  } else {
    overlayBindings.add(bindingKey);
    document.addEventListener("submit", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLFormElement)) return;
      if (!target.matches(formSelector)) return;

      const isPending = target.getAttribute(PENDING_ATTR) === "true";
      const isInFlight = target.getAttribute(IN_FLIGHT_ATTR) === "true";
      if (isPending || isInFlight) {
        event.preventDefault();
        return;
      }

      target.setAttribute(PENDING_ATTR, "true");
      showOverlay();
      scheduleFallbackReset(target);

      // La validation et les autres ecouteurs peuvent annuler la soumission.
      queueMicrotask(() => {
        target.removeAttribute(PENDING_ATTR);
        if (event.defaultPrevented) {
          const keepVisible = target.getAttribute(KEEP_VISIBLE_ATTR) === "true";
          if (keepVisible) return;
          target.removeAttribute(IN_FLIGHT_ATTR);
          target.removeAttribute(FALLBACK_TOKEN_ATTR);
          restoreSubmitControls(target);
          hideOverlay();
          return;
        }
        target.setAttribute(IN_FLIGHT_ATTR, "true");
        disableSubmitControls(target);
      });
    }, true);

    window.addEventListener(FAILURE_EVENT_NAME, (event) => {
      if (!(event instanceof CustomEvent)) return;
      const detail = event.detail;
      const detailForm = detail?.form;
      if (detailForm instanceof HTMLFormElement && !detailForm.matches(formSelector)) {
        return;
      }
      const detailSelector =
        typeof detail?.formSelector === "string" ? detail.formSelector : "";
      if (detailSelector && detailSelector !== formSelector) {
        return;
      }
      failMatchedForms(detail?.message);
    });

    document.addEventListener("astro:page-load", resetMatchedForms);
    window.addEventListener("pageshow", resetMatchedForms);
  }

    resetMatchedForms();
  }
</script>
