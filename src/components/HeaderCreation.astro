---
import LogoKiwanisSvg from "../assets/logo-kiwanis-full.svg";
import UserWhiteSvg from "../assets/user-white.svg";
import ArrowNextSvg from "../assets/arrow-next-small.svg";
import HamburgerToggle from "./HamburgerToggle.astro";
import CreationDropdown from "./CreationDropdown.astro";
import CreationAccountLink from "./CreationAccountLink.astro";
import CreationMobileMenu from "./CreationMobileMenu.astro";

const currentUser = Astro.locals.pb.authStore.record;

const creationMenuSections = [
  {
    title: "Ajouter du contenu",
    items: [
      { href: "/creation/actions/nouveau", label: "Actions" },
      { href: "/creation/projets/nouveau", label: "Projets" },
      { href: "/creation/produits/nouveau", label: "Produits" },
      { href: "/creation/remerciements/nouveau", label: "Remerciements" },
    ],
  },
  {
    title: "Supprimer du contenu",
    items: [
      { href: "/creation/actions/delete", label: "Actions" },
      { href: "/creation/projets/delete", label: "Projets" },
      { href: "/creation/produits/delete", label: "Produits" },
      { href: "/creation/remerciements/delete", label: "Remerciements" },
    ],
  },
  {
    title: "Modifier du contenu",
    items: [
      { href: "/creation/actions", label: "Actions" },
      { href: "/creation/projets", label: "Projets" },
      { href: "/creation/produits", label: "Produits" },
      { href: "/creation/remerciements", label: "Remerciements" },
    ],
  },
];
---

<header id="creation-header" class="fixed top-0 left-0 right-0 z-50 font-sans">
  <div class="hidden lg:flex items-center justify-center gap-8 py-6">
    <a href="/" class="flex items-center-safe">
      <LogoKiwanisSvg
        class="inline-block w-14 h-14 text-black"
        role="img"
        aria-label="Kiwanis Logo"
      />
    </a>
    <div
      class="w-full h-14 max-w-[80dvw] flex items-center justify-between gap-4 bg-accent rounded-xl px-4"
    >
      <div class="flex items-center gap-4 text-white">
        <CreationDropdown
          title="Ajouter du contenu"
          items={creationMenuSections[0].items}
        />
        <span>|</span>
        <CreationDropdown
          title="Supprimer du contenu"
          items={creationMenuSections[1].items}
        />
        <span>|</span>
        <CreationDropdown
          title="Modifier du contenu"
          items={creationMenuSections[2].items}
        />

        <span>|</span>
        <a href="/creation">Espace création</a>
      </div>
      <CreationAccountLink UserWhiteSvg={UserWhiteSvg} />
    </div>
  </div>

  <div
    class="lg:hidden flex flex-col items-center max-[359px]:p-2 p-4 max-[359px]:gap-2 gap-3 w-full"
  >
    <div
      class="w-full flex items-center justify-between max-[359px]:gap-2 gap-4 max-w-[90dvw]"
    >
      <a href="/" class="shrink-0 flex items-center">
        <LogoKiwanisSvg
          class="inline-block max-[359px]:h-9 max-[359px]:w-9 h-12 w-12 shrink-0 text-black"
          role="img"
          aria-label="Logo Kiwanis Pays de Montbéliard"
        />
      </a>

      <HamburgerToggle />
    </div>

    <CreationMobileMenu
      sections={creationMenuSections}
      currentUser={currentUser}
      UserWhiteSvg={UserWhiteSvg}
      ArrowNextSvg={ArrowNextSvg}
    />
  </div>
</header>

<style is:global>
  #creation-header a,
  #creation-header .nav-item {
    font-family: "Poppins", var(--font-sans-fallback);
  }
</style>

<style>
  #mobile-dropdown details > summary::-webkit-details-marker {
    display: none;
  }

  #mobile-dropdown details > summary .submenu-arrow {
    transition: transform 0.2s ease;
  }

  #mobile-dropdown details[open] > summary .submenu-arrow {
    transform: rotate(90deg);
  }
</style>

<script>
  import { preloadGsap, setupHeaderLogout, setupRedirectLinks } from "../utils/headerUtils";
  import { initMobileMenu } from "../utils/mobileMenu";

  function resetSubMenus() {
    document
      .querySelectorAll<HTMLDetailsElement>("#mobile-dropdown details")
      .forEach((menu) => {
        menu.removeAttribute("open");
      });
  }

  preloadGsap();

  document.addEventListener("DOMContentLoaded", () => {
    setupHeaderLogout();
    setupRedirectLinks();

    void initMobileMenu({
      toggleId: "menu-toggle",
      dropdownId: "mobile-dropdown",
      itemSelector: ".mob-link",
      onClose: resetSubMenus,
    });
  });
</script>
