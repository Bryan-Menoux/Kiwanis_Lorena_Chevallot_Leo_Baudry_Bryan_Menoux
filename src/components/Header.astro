---
// src/components/Header.astro
import LogoRaw from "../assets/logo-kiwanis-full.svg?raw";
import ArrowRaw from "../assets/arrow-previous-small.svg?raw";
import UserRaw from "../assets/user.svg?raw";
import UserWhiteRaw from "../assets/user-white.svg?raw";
import DiagArrow from "./DiagArrow.astro";

// Inline SVGs : supprime les dimensions codées en dur → remplit le conteneur
const logoSvg = LogoRaw
  .replace(/\s+width="[^"]*"/, ' width="100%"')
  .replace(/\s+height="[^"]*"/, ' height="100%"');
const arrowSvg = ArrowRaw
  .replace(/<\?xml[^?]*\?>\s*/g, '')
  .replace(/<!--[\s\S]*?-->\s*/g, '')
  .replace(/\s+width="[^"]*"/, ' width="100%"')
  .replace(/\s+height="[^"]*"/, ' height="100%"')
  .trim();
const userWhiteSvg = UserWhiteRaw
  .replace(/\s+width="[^"]*"/, ' width="100%"')
  .replace(/\s+height="[^"]*"/, ' height="100%"');
// Masque CSS : data URI (utilisé seulement si l'utilisateur est connecté)
const userDataUri = `data:image/svg+xml,${encodeURIComponent(UserRaw)}`;

const currentUser = Astro.locals.pb.authStore.record;
---

<header
  id="main-header"
  class="fixed z-100 w-full top-0 transition-transform duration-300 lg:bg-white lg:border-b lg:border-gray-100 bg-transparent font-sans"
>
  <div class="hidden lg:flex py-4 px-12 items-center justify-between">
    <a href="/" class="flex items-center gap-4">
      <span class="inline-block h-14 w-14 shrink-0" role="img" aria-label="Logo Kiwanis Pays de Montbéliard" set:html={logoSvg} />
      <div class="flex flex-col text-gray-900 leading-tight">
        <span class="text-xl font-bold tracking-tighter font-merriweather"
          >KIWANIS</span
        >
        <span
          class="text-xl font-light tracking-[-0.02em] text-[0.7rem] -mt-1 uppercase font-merriweather"
          >PAYS DE MONTBÉLIARD</span
        >
      </div>
    </a>

    <nav
      class="flex items-center gap-3 xl:gap-8 select-none text-[11px] xl:text-sm font-semibold text-base-content tracking-tight xl:tracking-normal"
    >
      <!-- Le club: Nos membres + Recrutement regroupés (lg uniquement) -->
      <div class="relative cursor-pointer py-2 [@media(min-width:1400px)]:hidden">
        <div
          id="leclub-toggle"
          class="nav-item hover:text-accent transition-colors uppercase flex items-center gap-2"
          role="button"
          aria-expanded="false"
          aria-controls="leclub-dropdown"
          tabindex="0"
        >
          <span class="whitespace-nowrap">Le club</span>
          <span
            id="leclub-arrow"
            class="inline-flex transition-transform duration-300"
            aria-hidden="true"
          >
            <span class="inline-flex h-6 w-6 rotate-180" aria-hidden="true" set:html={arrowSvg} />
          </span>
        </div>
        <div
          id="leclub-dropdown"
          class="absolute left-0 mt-2 w-44 bg-base-100 border border-base-100 shadow-xl rounded-lg overflow-hidden opacity-0 invisible transition-all duration-300 translate-y-2 pointer-events-none"
          role="menu"
          aria-hidden="true"
        >
          <a
            href="/membres"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent border-b border-base-100 transition-colors uppercase text-[10px] font-bold"
            role="menuitem">Nos membres</a
          >
          <a
            href="/recrutement"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent transition-colors uppercase text-[10px] font-bold"
            role="menuitem">Recrutement</a
          >
        </div>
      </div>
      <div class="h-4 w-px bg-base-content/20 [@media(min-width:1400px)]:hidden"></div>

      <a
        href="/membres"
        class="hidden [@media(min-width:1400px)]:block hover:text-accent transition-colors uppercase whitespace-nowrap"
        >Nos membres</a
      >
      <div class="hidden [@media(min-width:1400px)]:block h-6 w-px bg-base-content/20"></div>

      <div class="relative cursor-pointer py-2">
        <div
          id="discover-toggle"
          class="nav-item hover:text-accent transition-colors uppercase flex items-center gap-2 xl:gap-8"
          role="button"
          aria-expanded="false"
          aria-controls="discover-dropdown"
          tabindex="0"
        >
          <span class="whitespace-nowrap">Nous découvrir</span>
          <span
            id="discover-arrow"
            class="inline-flex transition-transform duration-300"
            aria-hidden="true"
          >
            <span class="inline-flex h-6 w-6 rotate-180" aria-hidden="true" set:html={arrowSvg} />
          </span
          >
        </div>
        <div
          id="discover-dropdown"
          class="absolute left-0 mt-2 w-44 xl:w-52 bg-base-100 border border-base-100 shadow-xl rounded-lg overflow-hidden opacity-0 invisible transition-all duration-300 translate-y-2 pointer-events-none"
          role="menu"
          aria-hidden="true"
        >
          <a
            href="/actions"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent border-b border-base-100 transition-colors uppercase text-[10px] xl:text-xs font-bold"
            role="menuitem">Nos actions</a
          >
          <a
            href="/projets"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent border-b border-base-100 transition-colors uppercase text-[10px] xl:text-xs font-bold"
            role="menuitem">Nos projets</a
          >
          <a
            href="/produits"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent transition-colors uppercase text-[10px] xl:text-xs font-bold"
            role="menuitem">Nos produits</a
          >
        </div>
      </div>
      <div class="h-4 xl:h-6 w-px bg-base-content/20"></div>

      <a
        href="/remerciments"
        class="hover:text-accent transition-colors uppercase whitespace-nowrap"
        >Remerciements</a
      >
      <div class="hidden [@media(min-width:1400px)]:block h-6 w-px bg-base-content/20"></div>

      <a
        href="/recrutement"
        class="hidden [@media(min-width:1400px)]:block hover:text-accent transition-colors uppercase whitespace-nowrap"
        >Recrutement</a
      >

      {
        Astro.locals.pb.authStore.isValid &&
          currentUser?.verified &&
          currentUser?.administrateur === true && (
            <>
              <div class="h-4 xl:h-6 w-px bg-base-content/20" />

              <a
                href="/creation"
                class="hover:text-accent transition-colors uppercase whitespace-nowrap"
              >
                Espace création
              </a>
            </>
          )
      }
    </nav>

    <div class="flex items-center gap-3">
      {
        currentUser ? (
            <a
              id="account-link"
              href="/mon-compte"
              class="flex items-center gap-4"
            >
              <span class="text-sm font-semibold whitespace-nowrap hidden [@media(min-width:1400px)]:inline">Mon compte</span>
              <div
                class="w-10 h-10 icon-accent"
                style={`--icon-url: url("${userDataUri}")`}
              />
            </a>
        ) : (
          <a
            id="connexion-link"
            href="/connexion"
            class="px-5 py-2 border-[1.5px] text-black border-gray-900 rounded-lg text-xs font-semibold uppercase hover:bg-gray-900 hover:text-white transition-all"
          >
            Connexion
          </a>
        )
      }
    </div>
  </div>

  <div class="lg:hidden flex flex-col items-center max-[359px]:p-2 p-4 max-[359px]:gap-2 gap-3 w-full">
    <div class="w-full flex items-center justify-between max-[359px]:gap-2 gap-4 max-w-[90dvw]">
      <a href="/" class="shrink-0">
        <span class="inline-block max-[359px]:h-9 max-[359px]:w-9 h-12 w-12 shrink-0" role="img" aria-label="Logo Kiwanis Pays de Montbéliard" set:html={logoSvg} />
      </a>

      <button
        id="menu-toggle"
        class="flex-1 flex items-center justify-between max-[359px]:px-3 max-[359px]:py-2 px-5 py-3 rounded-xl text-white bg-accent"
        aria-expanded="false"
        aria-controls="mobile-dropdown"
        aria-label="Ouvrir le menu"
      >
        <span class="max-[359px]:text-sm text-base font-medium">Menu</span>
        <div class="relative max-[359px]:w-5 max-[359px]:h-5 w-6 h-6 flex flex-col justify-center items-center gap-1.25 pointer-events-none">
          <span id="ham-top" class="block w-full h-0.5 bg-white rounded-full" style="transition: transform 0.2s ease;"></span>
          <span id="ham-bottom" class="block w-full h-0.5 bg-white rounded-full" style="transition: transform 0.2s ease;"></span>
        </div>
      </button>
    </div>

    <div
      id="mobile-dropdown"
      class="w-full max-w-[90dvw] rounded-2xl [@media(max-height:700px)]:p-4 p-7 text-white shadow-2xl bg-accent"
      style="display: none;"
      role="menu"
      aria-hidden="true"
    >
      <h2 class="text-xs font-bold tracking-widest [@media(max-height:700px)]:mb-3 mb-6 opacity-90 uppercase">
        KIWANIS PAYS DE MONTBÉLIARD
      </h2>

      <nav class="flex flex-col select-none" role="navigation">
        <a
          href="/membres"
          class="mob-link flex justify-between items-center [@media(max-height:700px)]:py-1 py-2 text-base"
          role="menuitem"
        >
          Nos membres <span class="opacity-40" aria-hidden="true"
            ><DiagArrow class="h-3 w-auto" />
           </span>
        </a>
        <a
          href="/remerciments"
          class="mob-link flex justify-between items-center [@media(max-height:700px)]:py-1 py-2 text-base"
          role="menuitem"
        >
          Remerciements <span class="opacity-40" aria-hidden="true"
            ><DiagArrow class="h-3 w-auto" />
           </span>
        </a>
        <a
          href="/recrutement"
          class="mob-link flex justify-between items-center [@media(max-height:700px)]:py-1 py-2 text-base"
          role="menuitem"
        >
          Recrutement <span class="opacity-40" aria-hidden="true"
            ><DiagArrow class="h-3 w-auto" />
           </span>
        </a>

        <div
          class="mob-link h-px w-full bg-white/20 [@media(max-height:700px)]:my-2 my-4"
          role="separator"
          aria-hidden="true"
        >
        </div>

        <a
          href="/actions"
          class="mob-link flex justify-between items-center [@media(max-height:700px)]:py-1 py-2 text-base"
          role="menuitem"
        >
          Nos actions <span class="opacity-40" aria-hidden="true"
            ><DiagArrow class="h-3 w-auto" />
           </span>
        </a>
        <a
          href="/projets"
          class="mob-link flex justify-between items-center [@media(max-height:700px)]:py-1 py-2 text-base"
          role="menuitem"
        >
          Nos projets <span class="opacity-40" aria-hidden="true"
            ><DiagArrow class="h-3 w-auto" />
           </span>
        </a>
        <a
          href="/produits"
          class="mob-link flex justify-between items-center [@media(max-height:700px)]:py-1 py-2 text-base"
          role="menuitem"
        >
          Nos produits <span class="opacity-40" aria-hidden="true"
            ><DiagArrow class="h-3 w-auto" />
           </span>
        </a>

        <div
          class="mob-link h-px w-full bg-white/20 [@media(max-height:700px)]:my-2 my-4"
          role="separator"
          aria-hidden="true"
        >
        </div>

        <div class="mob-actions [@media(max-height:700px)]:mt-2 mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
          <a
            href="/contact"
            class="btn btn-ghost border-base-100 rounded-lg! w-full"
            role="menuitem"
          >
            Contact
          </a>

          {
            currentUser ? (
              <>
                {currentUser.verified &&
                  currentUser.administrateur === true && (
                    <a
                      href="/creation"
                      class="btn btn-secondary rounded-lg! w-full"
                      role="menuitem"
                    >
                      Espace création
                    </a>
                  )}

                <div class="flex items-center gap-3 w-full md:col-span-2">
                  <a
                    id="mobile-account-link"
                    href="/mon-compte"
                    role="menuitem"
                    class="flex items-center gap-3 flex-1"
                  >
                    <div class="avatar">
                      <div class="w-10 rounded-full ring ring-offset-base-100 ring-white/30 overflow-hidden">
                        <span class="inline-block w-full h-full" aria-hidden="true" set:html={userWhiteSvg} />
                      </div>
                    </div>
                    <span class="text-sm font-semibold">Mon compte</span>
                  </a>

                  <button
                    id="mobile-logout-btn"
                    type="button"
                    class="btn btn-block w-fit px-4 py-2 md:px-8 md:py-4 btn-sm"
                    role="menuitem"
                  >
                    Déconnexion
                  </button>
                </div>
              </>
            ) : (
              <a
                id="mobile-connexion-link"
                href="/connexion"
                class="btn btn-block border-base-100 rounded-lg! w-full"
                role="menuitem"
              >
                Connexion
              </a>
            )
          }
        </div>
      </nav>
    </div>
  </div>
</header>

<style is:global>
  #main-header a,
  #main-header .nav-item {
    font-family: "Poppins", var(--font-sans-fallback);
  }

  #main-header.header-hidden {
    transform: translateY(-110%);
  }

  #discover-dropdown,
  #leclub-dropdown {
    transition:
      opacity 0.15s ease,
      transform 0.15s ease,
      visibility 0.15s ease;
  }

  #discover-dropdown.is-open,
  #leclub-dropdown.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  #discover-arrow,
  #leclub-arrow {
    transition: transform 0.15s ease;
  }

  #discover-arrow.is-open,
  #leclub-arrow.is-open {
    transform: rotate(90deg);
  }
</style>

<script>
  const DROPDOWN_IDS = ["leclub", "discover"] as const;
  type DropdownId = typeof DROPDOWN_IDS[number];

  const openState: Record<DropdownId, boolean> = { leclub: false, discover: false };
  let mobileMenuInitialized = false;

  function setState(id: DropdownId, isOpen: boolean) {
    const toggle = document.getElementById(`${id}-toggle`);
    const dropdown = document.getElementById(`${id}-dropdown`);
    const arrow = document.getElementById(`${id}-arrow`);
    if (!toggle || !dropdown || !arrow) return;
    openState[id] = isOpen;
    toggle.setAttribute("aria-expanded", String(isOpen));
    dropdown.setAttribute("aria-hidden", String(!isOpen));
    dropdown.classList.toggle("is-open", isOpen);
    arrow.classList.toggle("is-open", isOpen);
  }

  function initDropdown(id: DropdownId) {
    const toggle = document.getElementById(`${id}-toggle`);
    const dropdown = document.getElementById(`${id}-dropdown`);
    if (!toggle || !dropdown || toggle.dataset.bound === "true") return;
    toggle.dataset.bound = "true";

    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      const other = DROPDOWN_IDS.find((d) => d !== id)!;
      if (openState[other]) setState(other, false);
      setState(id, !openState[id]);
    });

    toggle.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        toggle.click();
      } else if (e.key === "Escape" && openState[id]) {
        setState(id, false);
      }
    });
  }

  // Handler global unique pour fermer tous les dropdowns au clic extérieur
  document.addEventListener("click", (e) => {
    for (const id of DROPDOWN_IDS) {
      if (!openState[id]) continue;
      const toggle = document.getElementById(`${id}-toggle`);
      const dropdown = document.getElementById(`${id}-dropdown`);
      if (
        !toggle?.contains(e.target as Node) &&
        !dropdown?.contains(e.target as Node)
      ) {
        setState(id, false);
      }
    }
  });

  function initMobileMenuWhenNeeded() {
    if (mobileMenuInitialized || !window.matchMedia("(max-width: 1023px)").matches) return;
    mobileMenuInitialized = true;
    void import("../utils/mobileMenu")
      .then(({ initMobileMenu }) => {
        initMobileMenu({
          toggleId: "menu-toggle",
          dropdownId: "mobile-dropdown",
          itemSelector: ".mob-link",
        });
      })
      .catch(() => {});
  }

  window.addEventListener("resize", initMobileMenuWhenNeeded, { passive: true });

  document.addEventListener("DOMContentLoaded", () => {
    document.getElementById("mobile-logout-btn")?.addEventListener("click", async () => {
      try {
        const res = await fetch("/api/logout", { method: "POST" });
        if (res.ok) window.location.href = "/connexion";
      } catch (e) {
        console.error("Erreur lors de la déconnexion:", e);
      }
    });

    const current = window.location.pathname + window.location.search;
    if (!current.startsWith("/connexion")) {
      const enc = encodeURIComponent(current);
      (document.getElementById("connexion-link") as HTMLAnchorElement | null)
        ?.setAttribute("href", "/connexion?redirect=" + enc);
      (document.getElementById("mobile-connexion-link") as HTMLAnchorElement | null)
        ?.setAttribute("href", "/connexion?redirect=" + enc);
    }

    initMobileMenuWhenNeeded();
    initDropdown("leclub");
    initDropdown("discover");
  });
</script>
