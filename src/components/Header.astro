---
import LogoKiwanisSvg from "../assets/logo-kiwanis-full.svg";
import ArrowPreviousSvg from "../assets/arrow-previous-small.svg";
import UserSvg from "../assets/user.svg";
import HamburgerToggle from "./HamburgerToggle.astro";
import MobileMenu from "./MobileMenu.astro";

/* user data URI removed (unused) */

const currentUser = Astro.locals.pb.authStore.record;

const menuItems = [
  { href: "/membres", label: "Nos membres" },
  { href: "/remerciements", label: "Remerciements" },
  { href: "/recrutement", label: "Recrutement" },
  { href: "/actions", label: "Nos actions" },
  { href: "/projets", label: "Nos projets" },
  { href: "/produits", label: "Nos produits" },
];

const actionButtons = [{ href: "/contact", label: "Contact" }];
---

<header
  id="main-header"
  class="fixed z-100 w-full top-0 transition-transform duration-300 lg:bg-white lg:border-b lg:border-gray-100 bg-transparent font-sans"
>
  <div class="hidden lg:flex py-4 px-12 items-center justify-between">
    <a href="/" class="flex items-center gap-4">
      <LogoKiwanisSvg
        class="inline-block h-14 w-14 shrink-0"
        role="img"
        aria-label="Logo Kiwanis Pays de Montbéliard"
      />
      <div class="flex flex-col text-gray-900 leading-tight">
        <span class="text-xl font-bold tracking-tighter font-merriweather"
          >KIWANIS</span
        >
        <span
          class="text-xl font-light tracking-[-0.02em] text-[0.7rem] -mt-1 uppercase font-merriweather"
          >PAYS DE MONTBÉLIARD</span
        >
      </div>
    </a>

    <nav
      class="flex items-center gap-3 xl:gap-8 select-none text-[11px] xl:text-sm font-semibold text-base-content tracking-tight xl:tracking-normal"
    >
      <!-- Le club: Nos membres + Recrutement regroupés (lg uniquement) -->
      <div
        class="relative cursor-pointer py-2 [@media(min-width:1400px)]:hidden"
      >
        <div
          id="leclub-toggle"
          class="nav-item hover:text-accent transition-colors uppercase flex items-center gap-2"
          role="button"
          aria-expanded="false"
          aria-controls="leclub-dropdown"
          tabindex="0"
        >
          <span class="whitespace-nowrap">Le club</span>
          <span
            id="leclub-arrow"
            class="inline-flex transition-transform duration-300"
            aria-hidden="true"
          >
            <ArrowPreviousSvg
              class="inline-flex h-6 w-6 rotate-180"
              aria-hidden="true"
            />
          </span>
        </div>
        <div
          id="leclub-dropdown"
          class="absolute left-0 mt-2 w-44 bg-base-100 border border-base-100 shadow-xl rounded-lg overflow-hidden opacity-0 invisible transition-all duration-300 translate-y-2 pointer-events-none"
          role="menu"
          aria-hidden="true"
        >
          <a
            href="/membres"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent border-b border-base-100 transition-colors uppercase text-[10px] font-bold"
            role="menuitem">Nos membres</a
          >
          <a
            href="/recrutement"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent transition-colors uppercase text-[10px] font-bold"
            role="menuitem">Recrutement</a
          >
        </div>
      </div>
      <div
        class="h-4 w-px bg-base-content/20 [@media(min-width:1400px)]:hidden"
      >
      </div>

      <a
        href="/membres"
        class="hidden [@media(min-width:1400px)]:block hover:text-accent transition-colors uppercase whitespace-nowrap"
        >Nos membres</a
      >
      <div
        class="hidden [@media(min-width:1400px)]:block h-6 w-px bg-base-content/20"
      >
      </div>

      <div class="relative cursor-pointer py-2">
        <div
          id="discover-toggle"
          class="nav-item hover:text-accent transition-colors uppercase flex items-center gap-2 xl:gap-8"
          role="button"
          aria-expanded="false"
          aria-controls="discover-dropdown"
          tabindex="0"
        >
          <span class="whitespace-nowrap">Nous découvrir</span>
          <span
            id="discover-arrow"
            class="inline-flex transition-transform duration-300"
            aria-hidden="true"
          >
            <ArrowPreviousSvg
              class="inline-flex h-6 w-6 rotate-180"
              aria-hidden="true"
            />
          </span>
        </div>
        <div
          id="discover-dropdown"
          class="absolute left-0 mt-2 w-44 xl:w-52 bg-base-100 border border-base-100 shadow-xl rounded-lg overflow-hidden opacity-0 invisible transition-all duration-300 translate-y-2 pointer-events-none"
          role="menu"
          aria-hidden="true"
        >
          <a
            href="/actions"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent border-b border-base-100 transition-colors uppercase text-[10px] xl:text-xs font-bold"
            role="menuitem">Nos actions</a
          >
          <a
            href="/projets"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent border-b border-base-100 transition-colors uppercase text-[10px] xl:text-xs font-bold"
            role="menuitem">Nos projets</a
          >
          <a
            href="/produits"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent transition-colors uppercase text-[10px] xl:text-xs font-bold"
            role="menuitem">Nos produits</a
          >
        </div>
      </div>
      <div class="h-4 xl:h-6 w-px bg-base-content/20"></div>

      <a
        href="/remerciements"
        class="hover:text-accent transition-colors uppercase whitespace-nowrap"
        >Remerciements</a
      >
      <div
        class="hidden [@media(min-width:1400px)]:block h-6 w-px bg-base-content/20"
      >
      </div>

      <a
        href="/recrutement"
        class="hidden [@media(min-width:1400px)]:block hover:text-accent transition-colors uppercase whitespace-nowrap"
        >Recrutement</a
      >

      {
        Astro.locals.pb.authStore.isValid &&
          currentUser?.verified && (
            <>
              <div class="h-4 xl:h-6 w-px bg-base-content/20" />

              <a
                href="/creation"
                class="hover:text-accent transition-colors uppercase whitespace-nowrap"
              >
                Espace création
              </a>
            </>
          )
      }
    </nav>

    <div class="flex items-center gap-3">
      {
        currentUser ? (
          <a
            id="account-link"
            href="/mon-compte"
            class="flex items-center gap-4"
          >
            <span class="text-sm font-semibold whitespace-nowrap hidden [@media(min-width:1500px)]:inline">
              Mon compte
            </span>
            <UserSvg
              class="inline-block w-8 h-8 rounded-full "
              aria-hidden="true"
            />
          </a>
        ) : (
          <a
            id="connexion-link"
            href="/connexion"
            class="px-5 py-2 border-[1.5px] text-black border-gray-900 rounded-lg text-xs font-semibold uppercase hover:bg-gray-900 hover:text-white transition-all"
          >
            Connexion
          </a>
        )
      }
    </div>
  </div>

  <div
    class="lg:hidden flex flex-col items-center max-[359px]:p-2 p-4 max-[359px]:gap-2 gap-3 w-full"
  >
    <div
      class="w-full flex items-center justify-between max-[359px]:gap-2 gap-4 max-w-[90dvw]"
    >
      <a href="/" class="shrink-0 h-full flex items-center">
        <LogoKiwanisSvg
          class="inline-block max-[359px]:h-9 max-[359px]:w-9 h-12 w-12 shrink-0"
          role="img"
          aria-label="Logo Kiwanis Pays de Montbéliard"
        />
      </a>
      <HamburgerToggle />
    </div>

    <MobileMenu
      menuTitle="KIWANIS PAYS DE MONTBÉLIARD"
      menuItems={menuItems}
      actionButtons={actionButtons}
      currentUser={currentUser}
      UserSvg={UserSvg}
    />
  </div>
</header>

<style is:global>
  #main-header a,
  #main-header .nav-item {
    font-family: "Poppins", var(--font-sans-fallback);
  }

  #main-header.header-hidden {
    transform: translateY(-110%);
  }

  #discover-dropdown,
  #leclub-dropdown {
    transition:
      opacity 0.15s ease,
      transform 0.15s ease,
      visibility 0.15s ease;
  }

  #discover-dropdown.is-open,
  #leclub-dropdown.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  #discover-arrow,
  #leclub-arrow {
    transition: transform 0.15s ease;
  }

  #discover-arrow.is-open,
  #leclub-arrow.is-open {
    transform: rotate(90deg);
  }
</style>

<script>
  import {
    setupHeaderLogout,
    setupRedirectLinks,
  } from "../utils/headerUtils";

  const DROPDOWN_IDS = ["leclub", "discover"] as const;
  type DropdownId = (typeof DROPDOWN_IDS)[number];

  const openState: Record<DropdownId, boolean> = {
    leclub: false,
    discover: false,
  };
  let mobileMenuInitialized = false;

  function setState(id: DropdownId, isOpen: boolean) {
    const toggle = document.getElementById(`${id}-toggle`);
    const dropdown = document.getElementById(`${id}-dropdown`);
    const arrow = document.getElementById(`${id}-arrow`);
    if (!toggle || !dropdown || !arrow) return;
    openState[id] = isOpen;
    toggle.setAttribute("aria-expanded", String(isOpen));
    dropdown.setAttribute("aria-hidden", String(!isOpen));
    dropdown.classList.toggle("is-open", isOpen);
    arrow.classList.toggle("is-open", isOpen);
  }

  function initDropdown(id: DropdownId) {
    const toggle = document.getElementById(`${id}-toggle`);
    const dropdown = document.getElementById(`${id}-dropdown`);
    if (!toggle || !dropdown || toggle.dataset.bound === "true") return;
    toggle.dataset.bound = "true";

    let closeTimeoutId: NodeJS.Timeout | null = null;

    const onToggle = (e: Event) => {
      e.stopPropagation();
      const other = DROPDOWN_IDS.find((d) => d !== id)!;
      if (openState[other]) setState(other, false);
      setState(id, !openState[id]);
    };

    const onMouseEnter = () => {
      if (closeTimeoutId) clearTimeout(closeTimeoutId);
      const other = DROPDOWN_IDS.find((d) => d !== id)!;
      if (openState[other]) setState(other, false);
      setState(id, true);
    };

    const onMouseLeave = () => {
      closeTimeoutId = setTimeout(() => {
        setState(id, false);
      }, 150);
    };

    toggle.addEventListener("click", onToggle);
    toggle.addEventListener("mouseenter", onMouseEnter);
    toggle.addEventListener("mouseleave", onMouseLeave);
    
    dropdown.addEventListener("mouseenter", onMouseEnter);
    dropdown.addEventListener("mouseleave", onMouseLeave);

    toggle.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        toggle.click();
      } else if (e.key === "Escape" && openState[id]) {
        setState(id, false);
      }
    });
  }

  document.addEventListener("click", (e) => {
    for (const id of DROPDOWN_IDS) {
      if (!openState[id]) continue;
      const toggle = document.getElementById(`${id}-toggle`);
      const dropdown = document.getElementById(`${id}-dropdown`);
      if (
        !toggle?.contains(e.target as Node) &&
        !dropdown?.contains(e.target as Node)
      ) {
        setState(id, false);
      }
    }
  });

  function initMobileMenuWhenNeeded() {
    if (
      mobileMenuInitialized ||
      !window.matchMedia("(max-width: 1023px)").matches
    )
      return;
    mobileMenuInitialized = true;
    void import("../utils/mobileMenu")
      .then(({ initMobileMenu }) => {
        initMobileMenu({
          toggleId: "menu-toggle",
          dropdownId: "mobile-dropdown",
          itemSelector: ".mob-link",
        });
      })
      .catch(() => {});
  }

  window.addEventListener("resize", initMobileMenuWhenNeeded, {
    passive: true,
  });

  document.addEventListener("DOMContentLoaded", () => {
    setupHeaderLogout();
    setupRedirectLinks();
    initMobileMenuWhenNeeded();
    initDropdown("leclub");
    initDropdown("discover");
  });
</script>
