---
// src/components/Header.astro
import LogoRaw from "../assets/logo-kiwanis-full.svg?raw";
import ArrowRaw from "../assets/arrow-previous-small.svg?raw";
import UserRaw from "../assets/user.svg?raw";
import UserWhiteRaw from "../assets/user-white.svg?raw";
import DiagArrow from "./DiagArrow.astro";

// Inline SVGs : supprime les dimensions codées en dur → remplit le conteneur
const logoSvg = LogoRaw
  .replace(/\s+width="[^"]*"/, ' width="100%"')
  .replace(/\s+height="[^"]*"/, ' height="100%"');
const arrowSvg = ArrowRaw
  .replace(/<\?xml[^?]*\?>\s*/g, '')
  .replace(/<!--[\s\S]*?-->\s*/g, '')
  .replace(/\s+width="[^"]*"/, ' width="100%"')
  .replace(/\s+height="[^"]*"/, ' height="100%"')
  .trim();
const userWhiteSvg = UserWhiteRaw
  .replace(/\s+width="[^"]*"/, ' width="100%"')
  .replace(/\s+height="[^"]*"/, ' height="100%"');
// Masque CSS : data URI (utilisé seulement si l'utilisateur est connecté)
const userDataUri = `data:image/svg+xml,${encodeURIComponent(UserRaw)}`;

const currentUser = Astro.locals.pb.authStore.record;
---

<header
  id="main-header"
  class="fixed z-100 w-full top-0 transition-transform duration-300 lg:bg-white lg:border-b lg:border-gray-100 bg-transparent font-sans"
>
  <div class="hidden lg:flex py-4 px-12 items-center justify-between">
    <a href="/" class="flex items-center gap-4">
      <span class="inline-block h-14 w-14 shrink-0" role="img" aria-label="Logo Kiwanis Pays de Montbéliard" set:html={logoSvg} />
      <div class="flex flex-col text-gray-900 leading-tight">
        <span class="text-xl font-bold tracking-tighter font-merriweather"
          >KIWANIS</span
        >
        <span
          class="text-xl font-light tracking-[-0.02em] text-[0.7rem] -mt-1 uppercase font-merriweather"
          >PAYS DE MONTBÉLIARD</span
        >
      </div>
    </a>

    <nav
      class="flex items-center gap-3 xl:gap-8 select-none text-[11px] xl:text-sm font-semibold text-base-content tracking-tight xl:tracking-normal"
    >
      <a
        href="/membres"
        class="hover:text-accent transition-colors uppercase whitespace-nowrap"
        >Nos membres</a
      >
      <div class="h-4 xl:h-6 w-px bg-base-content/20"></div>

      <div class="relative cursor-pointer py-2">
        <div
          id="discover-toggle"
          class="nav-item hover:text-accent transition-colors uppercase flex items-center gap-2 xl:gap-8"
          role="button"
          aria-expanded="false"
          aria-controls="discover-dropdown"
          tabindex="0"
        >
          <span class="whitespace-nowrap">Nous découvrir</span>
          <span
            id="discover-arrow"
            class="inline-flex transition-transform duration-300"
            aria-hidden="true"
          >
            <span class="inline-flex h-6 w-6 rotate-180" aria-hidden="true" set:html={arrowSvg} />
          </span
          >
        </div>
        <div
          id="discover-dropdown"
          class="absolute left-0 mt-2 w-44 xl:w-52 bg-base-100 border border-base-100 shadow-xl rounded-lg overflow-hidden opacity-0 invisible transition-all duration-300 translate-y-2 pointer-events-none"
          role="menu"
          aria-hidden="true"
        >
          <a
            href="/actions"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent border-b border-base-100 transition-colors uppercase text-[10px] xl:text-xs font-bold"
            role="menuitem">Nos actions</a
          >
          <a
            href="/projets"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent border-b border-base-100 transition-colors uppercase text-[10px] xl:text-xs font-bold"
            role="menuitem">Nos projets</a
          >
          <a
            href="/produits"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent transition-colors uppercase text-[10px] xl:text-xs font-bold"
            role="menuitem">Nos produits</a
          >
        </div>
      </div>
      <div class="h-4 xl:h-6 w-px bg-base-content/20"></div>

      <a
        href="/remerciments"
        class="hover:text-accent transition-colors uppercase whitespace-nowrap"
        >Remerciements</a
      >
      <div class="h-4 xl:h-6 w-px bg-base-content/20"></div>

      <a
        href="/recrutement"
        class="hover:text-accent transition-colors uppercase whitespace-nowrap"
        >Recrutement</a
      >


      {
        Astro.locals.pb.authStore.isValid &&
          currentUser?.verified &&
          currentUser?.administrateur === true && (
            <>
              <div class="h-4 xl:h-6 w-px bg-base-content/20" />

              <a
                href="/creation"
                class="hover:text-accent transition-colors uppercase whitespace-nowrap"
              >
                Espace création
              </a>
            </>
          )
      }
    </nav>

    <div class="flex items-center gap-3">
      {
        currentUser ? (
          <>
            <a
              id="account-link"
              href="/mon-compte"
              class="flex items-center gap-4"
            >
              <span class="text-sm font-semibold">Mon compte</span>
              <div
                class="w-10 h-10 icon-accent"
                style={`--icon-url: url("${userDataUri}")`}
              />
            </a>
          </>
        ) : (
          <a
            id="connexion-link"
            href="/connexion"
            class="px-5 py-2 border-[1.5px] text-black border-gray-900 rounded-lg text-xs font-semibold uppercase hover:bg-gray-900 hover:text-white transition-all"
          >
            Connexion
          </a>
        )
      }
    </div>
  </div>

  <div class="lg:hidden flex flex-col items-center p-4 gap-3 w-full">
    <div class="w-full flex items-center justify-between gap-4 max-w-[90dvw]">
      <a href="/" class="shrink-0">
        <span class="inline-block h-12 w-12 shrink-0" role="img" aria-label="Logo Kiwanis Pays de Montbéliard" set:html={logoSvg} />
      </a>

      <button
        id="menu-toggle"
        class="flex-1 flex items-center justify-between px-5 py-3 rounded-xl text-white bg-accent"
        aria-expanded="false"
        aria-controls="mobile-dropdown"
        aria-label="Ouvrir le menu"
      >
        <span class="text-base font-medium">Menu</span>
        <div class="relative w-6 h-6 flex flex-col justify-center items-center gap-1.25 pointer-events-none">
          <span id="ham-top" class="block w-full h-0.5 bg-white rounded-full" style="transition: transform 0.2s ease;"></span>
          <span id="ham-bottom" class="block w-full h-0.5 bg-white rounded-full" style="transition: transform 0.2s ease;"></span>
        </div>
      </button>
    </div>

    <div
      id="mobile-dropdown"
      class="w-full max-w-[90dvw] rounded-2xl p-7 text-white shadow-2xl bg-accent"
      style="display: none;"
      role="menu"
      aria-hidden="true"
    >
      <h2 class="text-xs font-bold tracking-widest mb-6 opacity-90 uppercase">
        KIWANIS PAYS DE MONTBÉLIARD
      </h2>

      <nav class="flex flex-col select-none" role="navigation">
        <a
          href="/membres"
          class="mob-link flex justify-between items-center py-2 text-base"
          role="menuitem"
        >
          Nos membres <span class="opacity-40" aria-hidden="true"
            ><DiagArrow class="h-3 w-auto" />
           </span>
        </a>
        <a
          href="/remerciments"
          class="mob-link flex justify-between items-center py-2 text-base"
          role="menuitem"
        >
          Remerciements <span class="opacity-40" aria-hidden="true"
            ><DiagArrow class="h-3 w-auto" />
           </span>
        </a>
        <a
          href="/recrutement"
          class="mob-link flex justify-between items-center py-2 text-base"
          role="menuitem"
        >
          Recrutement <span class="opacity-40" aria-hidden="true"
            ><DiagArrow class="h-3 w-auto" />
           </span>
        </a>

        <div
          class="mob-link h-px w-full bg-white/20 my-4"
          role="separator"
          aria-hidden="true"
        >
        </div>

        <a
          href="/actions"
          class="mob-link flex justify-between items-center py-2 text-base"
          role="menuitem"
        >
          Nos actions <span class="opacity-40" aria-hidden="true"
            ><DiagArrow class="h-3 w-auto" />
           </span>
        </a>
        <a
          href="/projets"
          class="mob-link flex justify-between items-center py-2 text-base"
          role="menuitem"
        >
          Nos projets <span class="opacity-40" aria-hidden="true"
            ><DiagArrow class="h-3 w-auto" />
           </span>
        </a>
        <a
          href="/produits"
          class="mob-link flex justify-between items-center py-2 text-base"
          role="menuitem"
        >
          Nos produits <span class="opacity-40" aria-hidden="true"
            ><DiagArrow class="h-3 w-auto" />
           </span>
        </a>

        <div
          class="mob-link h-px w-full bg-white/20 my-4"
          role="separator"
          aria-hidden="true"
        >
        </div>

        <div class="mob-actions mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
          <a
            href="/contact"
            class="btn btn-ghost border-base-100 rounded-lg! w-full"
            role="menuitem"
          >
            Contact
          </a>

          {
            currentUser ? (
              <>
                {currentUser.verified &&
                  currentUser.administrateur === true && (
                    <a
                      href="/creation"
                      class="btn btn-secondary rounded-lg! w-full"
                      role="menuitem"
                    >
                      Espace création
                    </a>
                  )}

                <div class="flex items-center gap-3 w-full md:col-span-2">
                  <a
                    id="mobile-account-link"
                    href="/mon-compte"
                    role="menuitem"
                    class="flex items-center gap-3 flex-1"
                  >
                    <div class="avatar">
                      <div class="w-10 rounded-full ring ring-offset-base-100 ring-white/30 overflow-hidden">
                        <span class="inline-block w-full h-full" aria-hidden="true" set:html={userWhiteSvg} />
                      </div>
                    </div>
                    <span class="text-sm font-semibold">Mon compte</span>
                  </a>

                  <button
                    id="mobile-logout-btn"
                    type="button"
                    class="btn btn-block w-fit px-4 py-2 md:px-8 md:py-4 btn-sm"
                    role="menuitem"
                  >
                    Déconnexion
                  </button>
                </div>
              </>
            ) : (
              <a
                id="mobile-connexion-link"
                href="/connexion"
                class="btn btn-block border-base-100 rounded-lg! w-full"
                role="menuitem"
              >
                Connexion
              </a>
            )
          }
        </div>
      </nav>
    </div>
  </div>
</header>

<style is:global>
  #main-header a,
  #main-header .nav-item {
    font-family: "Poppins", var(--font-sans-fallback);
  }

  #main-header.header-hidden {
    transform: translateY(-110%);
  }

  #discover-dropdown {
    transition:
      opacity 0.15s ease,
      transform 0.15s ease,
      visibility 0.15s ease;
  }

  #discover-dropdown.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  #discover-arrow {
    transition: transform 0.15s ease;
  }

  #discover-arrow.is-open {
    transform: rotate(90deg);
  }
</style>

<script>
  let discoverIsOpen = false;
  let globalClickHandler: ((e: Event) => void) | null = null;
  let mobileMenuInitialized = false;

  function initMenu() {
    initMobileMenuWhenNeeded();
  }

  function setDiscoverState(isOpen: boolean) {
    const discoverDropdown = document.getElementById(
      "discover-dropdown",
    ) as HTMLElement | null;
    const discoverArrow = document.getElementById(
      "discover-arrow",
    ) as HTMLElement | null;
    const discoverToggle = document.getElementById(
      "discover-toggle",
    ) as HTMLElement | null;

    if (!discoverDropdown || !discoverArrow || !discoverToggle) return;

    discoverIsOpen = isOpen;
    discoverToggle.setAttribute("aria-expanded", isOpen.toString());
    discoverDropdown.setAttribute("aria-hidden", (!isOpen).toString());
    discoverDropdown.classList.toggle("is-open", isOpen);
    discoverArrow.classList.toggle("is-open", isOpen);
  }

  function closeDiscoverDropdown() {
    setDiscoverState(false);
  }

  function initDiscoverDropdown() {
    const discoverToggle = document.getElementById(
      "discover-toggle",
    ) as HTMLElement;
    const discoverDropdown = document.getElementById(
      "discover-dropdown",
    ) as HTMLElement;

    if (!discoverToggle || !discoverDropdown) return;
    if (discoverToggle.dataset.discoverBound === "true") return;
    discoverToggle.dataset.discoverBound = "true";

    if (globalClickHandler) {
      document.removeEventListener("click", globalClickHandler);
    }

    const toggleDropdown = (e?: Event) => {
      e?.stopPropagation();
      setDiscoverState(!discoverIsOpen);
    };

    discoverToggle.addEventListener("click", toggleDropdown);

    discoverToggle.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        toggleDropdown();
      } else if (e.key === "Escape" && discoverIsOpen) {
        closeDiscoverDropdown();
      }
    });

    // Ajouter le handler global une seule fois
    globalClickHandler = (e: Event) => {
      if (
        discoverIsOpen &&
        !discoverToggle.contains(e.target as Node) &&
        !discoverDropdown.contains(e.target as Node)
      ) {
        closeDiscoverDropdown();
      }
    };
    document.addEventListener("click", globalClickHandler);
  }

  function initMobileMenuWhenNeeded() {
    if (mobileMenuInitialized) return;
    if (!window.matchMedia("(max-width: 1023px)").matches) return;

    mobileMenuInitialized = true;
    void import("../utils/mobileMenu")
      .then(({ initMobileMenu }) => {
        initMobileMenu({
          toggleId: "menu-toggle",
          dropdownId: "mobile-dropdown",
          itemSelector: ".mob-link",
        });
      })
      .catch(() => {});
  }

  document.addEventListener("DOMContentLoaded", () => {
    const mobileLogoutBtn = document.getElementById(
      "mobile-logout-btn",
    ) as HTMLButtonElement | null;
    if (mobileLogoutBtn) {
      mobileLogoutBtn.addEventListener("click", async () => {
        try {
          const response = await fetch("/api/logout", { method: "POST" });
          if (response.ok) {
            window.location.href = "/connexion";
          }
        } catch (error) {
          console.error("Erreur lors de la déconnexion:", error);
        }
      });
    }

    // si l'utilisateur clique sur un lien de connexion, on ajoute le param
    // redirect avec la page courante (sauf si on est déjà sur la page de connexion)
    const updateLoginLinks = () => {
      const current = window.location.pathname + window.location.search;
      if (current.startsWith("/connexion")) return;
      const enc = encodeURIComponent(current);
      const desktop = document.getElementById("connexion-link") as HTMLAnchorElement | null;
      const mobile = document.getElementById("mobile-connexion-link") as HTMLAnchorElement | null;
      if (desktop) desktop.setAttribute("href", "/connexion?redirect=" + enc);
      if (mobile) mobile.setAttribute("href", "/connexion?redirect=" + enc);
    };
    updateLoginLinks();

    initMenu();
    initDiscoverDropdown();
  });
</script>
