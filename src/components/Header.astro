---
// Header.astro
---

<header class="w-full bg-white py-4 px-6 md:px-12 flex items-center justify-between font-sans border-b border-gray-100 relative z-50">
  
  <div class="flex items-center gap-4">
    <img 
      src="../assets/logo-kiwanis-full.svg" 
      alt="Logo" 
      class="h-14 w-auto"
    />
    <div class="flex flex-col text-gray-900 leading-tight">
      <span class="text-xl font-bold tracking-tighter">KIWANIS</span>
      <span class="text-xl font-light tracking-[0.2em] text-[0.7rem] -mt-1">PAYS MONTBÉLIARD</span>
    </div>
  </div>

  <nav class="hidden lg:flex items-center gap-8 text-sm font-bold text-gray-800">
    <a href="/membres" class="hover:text-blue-900 transition-colors uppercase">Nos membres</a>
    
    <div class="h-6 w-[1px] bg-gray-300"></div>
    
    <div class="relative group cursor-pointer py-2">
      <button class="hover:text-blue-900 transition-colors uppercase flex items-center gap-2 group-hover:text-blue-900">
        Découvrir 
        <span class="text-[10px] transition-transform duration-300 group-hover:rotate-90">❯</span>
      </button>

      <div class="absolute left-0 mt-2 w-52 bg-white border border-gray-100 shadow-xl rounded-lg overflow-hidden opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0">
        <a href="/histoire" class="block px-4 py-3 text-gray-700 hover:bg-gray-50 hover:text-blue-900 border-b border-gray-50 transition-colors">
          Notre histoire
        </a>
        <a href="/membres" class="block px-4 py-3 text-gray-700 hover:bg-gray-50 hover:text-blue-900 transition-colors">
          Nos membres
        </a>
      </div>
    </div>
    
    <div class="h-6 w-[1px] bg-gray-300"></div>
    
    <a href="/don" class="hover:text-blue-900 transition-colors uppercase">Faire un don</a>
  </nav>

  <div class="flex items-center gap-3">
    <a href="/connexion" class="px-5 py-2 border-[1.5px] border-gray-900 rounded-xl text-xs font-bold uppercase hover:bg-gray-900 hover:text-white transition-all">
      Connexion
    </a>
    <a href="/contact" class="px-5 py-2 border-[1.5px] border-gray-900 rounded-xl text-xs font-bold uppercase hover:bg-gray-900 hover:text-white transition-all">
      Contact
    </a>
  </div>
</header>