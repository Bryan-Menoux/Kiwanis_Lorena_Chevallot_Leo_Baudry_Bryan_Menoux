---
// src/components/Header.astro
import Logo from "../assets/logo-kiwanis-full.svg";
import user from "../assets/user.svg";
import userWhite from "../assets/user-white.svg";
import { Image } from "astro:assets";

const currentUser = Astro.locals.pb.authStore.record;
import diagArrow from "../assets/diag-arrow.svg";
---

<header
  id="main-header"
  class="fixed z-100 w-full top-0 transition-transform duration-300 lg:bg-white lg:border-b lg:border-gray-100 bg-transparent font-sans"
>
  <div class="hidden lg:flex py-4 px-12 items-center justify-between">
    <a href="/" class="flex items-center gap-4">
      <Image src={Logo} alt="Logo" loading="eager" quality={80} class="h-14 w-auto" draggable="false" />
      <div class="flex flex-col text-gray-900 leading-tight">
        <span class="text-xl font-bold tracking-tighter font-merriweather"
          >KIWANIS</span
        >
        <span
          class="text-xl font-light tracking-[-0.02em] text-[0.7rem] -mt-1 uppercase font-merriweather"
          >PAYS DE MONTBÉLIARD</span
        >
      </div>
    </a>

    <nav
      class="flex items-center gap-3 xl:gap-8 select-none text-[11px] xl:text-sm font-semibold text-base-content tracking-tight xl:tracking-normal"
    >
      <a
        href="/membres"
        class="hover:text-accent transition-colors uppercase whitespace-nowrap"
        >Nos membres</a
      >

      <div class="h-4 xl:h-6 w-px bg-base-content/20"></div>

      <div class="relative cursor-pointer py-2">
        <div
          id="discover-toggle"
          class="nav-item hover:text-accent transition-colors uppercase flex items-center gap-2 xl:gap-8"
          role="button"
          aria-expanded="false"
          aria-controls="discover-dropdown"
          tabindex="0"
        >
          <span class="whitespace-nowrap">Nous découvrir</span>
          <span
            id="discover-arrow"
            class="text-[10px] transition-transform duration-300"
            aria-hidden="true">></span
          >
        </div>
        <div
          id="discover-dropdown"
          class="absolute left-0 mt-2 w-44 xl:w-52 bg-base-100 border border-base-100 shadow-xl rounded-lg overflow-hidden opacity-0 invisible transition-all duration-300 translate-y-2 pointer-events-none"
          role="menu"
          aria-hidden="true"
        >
          <a
            href="/actions"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent border-b border-base-100 transition-colors uppercase text-[10px] xl:text-xs font-bold"
            role="menuitem">Nos actions</a
          >
          <a
            href="/projets"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent border-b border-base-100 transition-colors uppercase text-[10px] xl:text-xs font-bold"
            role="menuitem">Nos projets</a
          >
          <a
            href="/produits"
            class="block px-4 py-3 text-base-content hover:bg-base-content/20 hover:text-accent transition-colors uppercase text-[10px] xl:text-xs font-bold"
            role="menuitem">Nos produits</a
          >
        </div>
      </div>

      <div class="h-4 xl:h-6 w-px bg-base-content/20"></div>

      <a
        href="/don"
        class="hover:text-accent transition-colors uppercase whitespace-nowrap"
        >Faire un don</a
      >
      {
        Astro.locals.pb.authStore.isValid &&
          currentUser?.verified &&
          currentUser?.administrateur === true && (
            <>
              <div class="h-4 xl:h-6 w-px bg-base-content/20" />

              <a
                href="/creation"
                class="hover:text-accent transition-colors uppercase whitespace-nowrap"
              >
                Espace création
              </a>
            </>
          )
      }
    </nav>

    <div class="flex items-center gap-3">
      {
        currentUser ? (
          <>
            <a
              id="account-link"
              href="/mon-compte"
              class="flex items-center gap-4"
            >
              <span class="text-sm font-semibold">Mon compte</span>
              <div
                class="w-10 h-10 icon-accent"
                style={`--icon-url: url(${user.src})`}
              />
            </a>
          </>
        ) : (
          <a
            id="connexion-link"
            href="/connexion"
            class="px-5 py-2 border-[1.5px] text-black border-gray-900 rounded-lg text-xs font-semibold uppercase hover:bg-gray-900 hover:text-white transition-all"
          >
            Connexion
          </a>
        )
      }
    </div>
  </div>

  <div class="lg:hidden flex flex-col items-center p-4 gap-3 w-full">
    <div class="w-full flex items-center justify-between gap-4 max-w-[90dvw]">
      <a href="/" class="shrink-0">
        <Image src={Logo} alt="Logo" loading="eager" quality={80} class="h-12 w-auto" />
      </a>

      <button
        id="menu-toggle"
        class="flex-1 flex items-center justify-between px-5 py-3 rounded-xl text-white bg-accent"
        aria-expanded="false"
        aria-controls="mobile-dropdown"
        aria-label="Ouvrir le menu"
      >
        <span class="text-base font-medium">Menu</span>
        <div class="relative w-6 h-6">
          <svg
            id="ham-icon"
            class="w-6 h-6 absolute"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              id="ham-top"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M4 8h16"></path>
            <path
              id="ham-bottom"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M4 16h16"></path>
          </svg>
        </div>
      </button>
    </div>

    <div
      id="mobile-dropdown"
      class="w-full max-w-[90dvw] rounded-2xl p-7 text-white shadow-2xl bg-accent"
      style="display: none;"
      role="menu"
      aria-hidden="true"
    >
      <h2 class="text-xs font-bold tracking-widest mb-6 opacity-90 uppercase">
        KIWANIS PAYS DE MONTBÉLIARD
      </h2>

      <nav class="flex flex-col select-none" role="navigation">
        <a
          href="/membres"
          class="mob-link flex justify-between items-center py-2 text-base"
          role="menuitem"
        >
          Nos membres <span class="opacity-40" aria-hidden="true"><Image src={diagArrow} alt="" layout="fixed" quality={80} class="h-3 w-auto" aria-hidden="true" /> </span>
        </a>
        <a
          href="/don"
          class="mob-link flex justify-between items-center py-2 text-base"
          role="menuitem"
        >
          Faire un don <span class="opacity-40" aria-hidden="true"><Image src={diagArrow} alt="" layout="fixed" quality={80} class="h-3 w-auto" aria-hidden="true" /> </span>
        </a>

        <div
          class="mob-link h-px w-full bg-white/20 my-4"
          role="separator"
          aria-hidden="true"
        >
        </div>

        <a
          href="/actions"
          class="mob-link flex justify-between items-center py-2 text-base"
          role="menuitem"
        >
          Nos actions <span class="opacity-40" aria-hidden="true"><Image src={diagArrow} alt="" layout="fixed" quality={80} class="h-3 w-auto" aria-hidden="true" /> </span>
        </a>
        <a
          href="/projets"
          class="mob-link flex justify-between items-center py-2 text-base"
          role="menuitem"
        >
          Nos projets <span class="opacity-40" aria-hidden="true"><Image src={diagArrow} alt="" layout="fixed" quality={80} class="h-3 w-auto" aria-hidden="true" /> </span>
        </a>
        <a
          href="/produits"
          class="mob-link flex justify-between items-center py-2 text-base"
          role="menuitem"
        >
          Nos produits <span class="opacity-40" aria-hidden="true"><Image src={diagArrow} alt="" layout="fixed" quality={80} class="h-3 w-auto" aria-hidden="true" /> </span>
        </a>

        <div
          class="mob-link h-px w-full bg-white/20 my-4"
          role="separator"
          aria-hidden="true"
        >
        </div>

        <div class="mob-actions mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
          <a
            href="/contact"
            class="btn btn-ghost border-base-100 rounded-lg! w-full"
            role="menuitem"
          >
            Contact
          </a>

          {
            currentUser ? (
              <>
                {currentUser.verified &&
                  currentUser.administrateur === true && (
                    <a
                      href="/creation"
                      class="btn btn-secondary rounded-lg! w-full"
                      role="menuitem"
                    >
                      Espace création
                    </a>
                  )}

                <div class="flex items-center gap-3 w-full md:col-span-2">
                  <a
                    id="mobile-account-link"
                    href="/mon-compte"
                    role="menuitem"
                    class="flex items-center gap-3 flex-1"
                  >
                    <div class="avatar">
                      <div class="w-10 rounded-full ring ring-offset-base-100 ring-white/30 overflow-hidden">
                        <Image src={userWhite} alt="" aria-hidden="true" loading="eager" quality={80} />
                      </div>
                    </div>
                    <span class="text-sm font-semibold">Mon compte</span>
                  </a>

                  <button
                    id="mobile-logout-btn"
                    type="button"
                    class="btn btn-block w-fit px-4 py-2 md:px-8 md:py-4 btn-sm"
                    role="menuitem"
                  >
                    Déconnexion
                  </button>
                </div>
              </>
            ) : (
              <a
                id="mobile-connexion-link"
                href="/connexion"
                class="btn btn-block border-base-100 rounded-lg! w-full"
                role="menuitem"
              >
                Connexion
              </a>
            )
          }
        </div>
      </nav>
    </div>
  </div>
</header>

<style is:global>
  #main-header.header-hidden {
    transform: translateY(-110%);
  }

  #discover-dropdown.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  #discover-arrow.is-open {
    transform: rotate(90deg);
  }
</style>

<script>
  import { loadGsap } from "../utils/loadGsap";

  let discoverIsOpen = false;
  let globalClickHandler: ((e: Event) => void) | null = null;
  let gsapInstance: NonNullable<Window["gsap"]> | null = null;
  let gsapPromise: Promise<NonNullable<Window["gsap"]> | null> | null = null;

  function ensureGsap() {
    if (gsapInstance) return Promise.resolve(gsapInstance);
    if (!gsapPromise) {
      gsapPromise = loadGsap().then((instance) => {
        gsapInstance = instance;
        return instance;
      });
    }
    return gsapPromise;
  }

  function setHamburgerState(isOpen: boolean) {
    const hamTop = document.getElementById("ham-top");
    const hamBottom = document.getElementById("ham-bottom");
    if (!(hamTop instanceof SVGElement) || !(hamBottom instanceof SVGElement)) return;

    if (gsapInstance) {
      gsapInstance.to(hamTop, {
        y: isOpen ? 4 : 0,
        rotate: isOpen ? 45 : 0,
        duration: isOpen ? 0.18 : 0.12,
        ease: isOpen ? "power2.out" : "power2.in",
      });
      gsapInstance.to(hamBottom, {
        y: isOpen ? -4 : 0,
        rotate: isOpen ? -45 : 0,
        duration: isOpen ? 0.18 : 0.12,
        ease: isOpen ? "power2.out" : "power2.in",
      });
      return;
    }

    hamTop.style.transformOrigin = "50% 50%";
    hamBottom.style.transformOrigin = "50% 50%";
    hamTop.style.transformBox = "fill-box";
    hamBottom.style.transformBox = "fill-box";
    hamTop.style.transform = isOpen
      ? "translateY(4px) rotate(45deg)"
      : "translateY(0) rotate(0deg)";
    hamBottom.style.transform = isOpen
      ? "translateY(-4px) rotate(-45deg)"
      : "translateY(0) rotate(0deg)";
  }

  function openMobileDropdown(dropdown: HTMLElement, links: HTMLElement[]) {
    if (!gsapInstance) {
      dropdown.style.display = "block";
      dropdown.style.opacity = "1";
      dropdown.style.transform = "translateY(0)";
      return;
    }

    gsapInstance.killTweensOf([dropdown, ...links]);
    dropdown.style.display = "block";
    gsapInstance
      .timeline()
      .to(dropdown, { opacity: 1, y: 0, duration: 0.2, ease: "power2.out" })
      .fromTo(
        links,
        { opacity: 0, y: 5 },
        { opacity: 1, y: 0, stagger: 0.02, duration: 0.15, overwrite: "auto" },
        "-=0.1",
      );
  }

  function closeMobileDropdown(dropdown: HTMLElement) {
    if (!gsapInstance) {
      dropdown.style.opacity = "0";
      dropdown.style.transform = "translateY(-10px)";
      window.setTimeout(() => {
        dropdown.style.display = "none";
      }, 150);
      return;
    }

    gsapInstance.killTweensOf(dropdown);
    gsapInstance
      .timeline()
      .to(dropdown, { opacity: 0, y: -10, duration: 0.15, ease: "power2.in" })
      .set(dropdown, { display: "none" });
  }

  function setDiscoverState(isOpen: boolean) {
    const discoverDropdown = document.getElementById(
      "discover-dropdown",
    ) as HTMLElement | null;
    const discoverArrow = document.getElementById(
      "discover-arrow",
    ) as HTMLElement | null;
    const discoverToggle = document.getElementById(
      "discover-toggle",
    ) as HTMLElement | null;

    if (!discoverDropdown || !discoverArrow || !discoverToggle) return;

    discoverIsOpen = isOpen;
    discoverToggle.setAttribute("aria-expanded", isOpen.toString());
    discoverDropdown.setAttribute("aria-hidden", (!isOpen).toString());

    if (!gsapInstance) {
      discoverDropdown.classList.toggle("is-open", isOpen);
      discoverArrow.classList.toggle("is-open", isOpen);
      return;
    }

    gsapInstance.killTweensOf([discoverDropdown, discoverArrow]);
    if (isOpen) {
      discoverDropdown.classList.add("is-open");
      discoverArrow.classList.add("is-open");
      gsapInstance.to(discoverDropdown, {
        opacity: 1,
        visibility: "visible",
        y: 0,
        pointerEvents: "auto",
        duration: 0.08,
      });
      gsapInstance.to(discoverArrow, { rotate: 90, duration: 0.08 });
      return;
    }

    gsapInstance.to(discoverDropdown, {
      opacity: 0,
      visibility: "hidden",
      y: -10,
      pointerEvents: "none",
      duration: 0.15,
      onComplete: () => {
        discoverDropdown.classList.remove("is-open");
      },
    });
    gsapInstance.to(discoverArrow, {
      rotate: 0,
      duration: 0.15,
      onComplete: () => {
        discoverArrow.classList.remove("is-open");
      },
    });
  }

  async function initMenu() {
    const toggle = document.getElementById("menu-toggle") as HTMLButtonElement;
    const dropdown = document.getElementById("mobile-dropdown") as HTMLElement;
    const links = Array.from(
      document.querySelectorAll<HTMLElement>(".mob-link"),
    );

    if (!toggle || !dropdown) return;

    let isOpen = false;
    await ensureGsap();

    if (gsapInstance) {
      gsapInstance.set(dropdown, { display: "none", opacity: 0, y: -10 });
      const hamTop = document.getElementById("ham-top");
      const hamBottom = document.getElementById("ham-bottom");
      if (hamTop && hamBottom) {
        gsapInstance.set([hamTop, hamBottom], {
          transformOrigin: "50% 50%",
          y: 0,
          rotate: 0,
        });
      }
    } else {
      dropdown.style.display = "none";
      dropdown.style.opacity = "0";
      dropdown.style.transform = "translateY(-10px)";
    }

    setHamburgerState(false);

    const toggleMenu = (e?: Event) => {
      e?.stopPropagation();
      isOpen = !isOpen;

      toggle.setAttribute("aria-expanded", isOpen.toString());
      dropdown.setAttribute("aria-hidden", (!isOpen).toString());

      if (isOpen) {
        openMobileDropdown(dropdown, links);
      } else {
        closeMobileDropdown(dropdown);
      }

      setHamburgerState(isOpen);
    };

    toggle.addEventListener("click", toggleMenu);

    toggle.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        toggleMenu();
      }
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1024 && isOpen) {
        isOpen = false;
        dropdown.style.display = "none";
        dropdown.style.opacity = "0";
        dropdown.style.transform = "translateY(-10px)";
        toggle.setAttribute("aria-expanded", "false");
        dropdown.setAttribute("aria-hidden", "true");
        setHamburgerState(false);
      }
    });
  }

  function closeDiscoverDropdown() {
    setDiscoverState(false);
  }

  function initDiscoverDropdown() {
    const discoverToggle = document.getElementById(
      "discover-toggle",
    ) as HTMLElement;
    const discoverDropdown = document.getElementById(
      "discover-dropdown",
    ) as HTMLElement;
    const discoverArrow = document.getElementById(
      "discover-arrow",
    ) as HTMLElement;

    if (!discoverToggle || !discoverDropdown) return;

    if (globalClickHandler) {
      document.removeEventListener("click", globalClickHandler);
    }

    const toggleDropdown = (e?: Event) => {
      e?.stopPropagation();
      void ensureGsap();
      setDiscoverState(!discoverIsOpen);
    };

    discoverToggle.addEventListener("click", toggleDropdown);

    discoverToggle.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        toggleDropdown();
      } else if (e.key === "Escape" && discoverIsOpen) {
        closeDiscoverDropdown();
        discoverToggle.setAttribute("aria-expanded", "false");
        discoverDropdown.setAttribute("aria-hidden", "true");
      }
    });

    // Ajouter le handler global une seule fois
    globalClickHandler = (e: Event) => {
      if (
        discoverIsOpen &&
        !discoverToggle.contains(e.target as Node) &&
        !discoverDropdown.contains(e.target as Node)
      ) {
        closeDiscoverDropdown();
        discoverToggle.setAttribute("aria-expanded", "false");
        discoverDropdown.setAttribute("aria-hidden", "true");
      }
    };
    document.addEventListener("click", globalClickHandler);
  }

  document.addEventListener("DOMContentLoaded", () => {
    const mobileLogoutBtn = document.getElementById(
      "mobile-logout-btn",
    ) as HTMLButtonElement | null;
    if (mobileLogoutBtn) {
      mobileLogoutBtn.addEventListener("click", async () => {
        try {
          const response = await fetch("/api/logout", { method: "POST" });
          if (response.ok) {
            window.location.href = "/connexion";
          }
        } catch (error) {
          console.error("Erreur lors de la déconnexion:", error);
        }
      });
    }

    void initMenu();
    initDiscoverDropdown();
  });
</script>
