---
import diagArrow from "../assets/diag-arrow.svg";
import imageIcon from "../assets/image-icon.svg";
import galleryUrl from "../scripts/gallery.js?url";
import galleryDisplayUrl from "../scripts/gallery-display.js?url";
import {
  formatDateLong,
  isDataUrl as isDataUrlRuntime,
} from "../utils/utilitaires.js";
import type { ActionsResponse } from "../pocketbase-types";
export interface Props {
  action: ActionsResponse;
  forcePreviewLocationSection?: boolean;
  tabletPreviewAsMobile?: boolean;
}

const {
  action,
  forcePreviewLocationSection = false,
  tabletPreviewAsMobile = false,
} = Astro.props;

// Helper d'exécution importé (on conserve le garde TypeScript localement).
const isDataUrl = isDataUrlRuntime as (v: unknown) => v is string;
// Préparation des URLs d'images : si c'est une URL de données, on l'utilise directement, sinon on génère l'URL via `Astro.locals.pb.files.getURL`
const heroImg =
  action && action.hero
    ? isDataUrl(action.hero)
      ? action.hero
      : Astro.locals.pb.files.getURL(action, action.hero)
    : null;
const partie1Img =
  action && action.photo_partie_1
    ? isDataUrl(action.photo_partie_1)
      ? action.photo_partie_1
      : Astro.locals.pb.files.getURL(action, action.photo_partie_1)
    : null;
const partie2Img =
  action && action.photo_partie_2
    ? isDataUrl(action.photo_partie_2)
      ? action.photo_partie_2
      : Astro.locals.pb.files.getURL(action, action.photo_partie_2)
    : null;
const partie3Img =
  action && action.photo_partie_3
    ? isDataUrl(action.photo_partie_3)
      ? action.photo_partie_3
      : Astro.locals.pb.files.getURL(action, action.photo_partie_3)
    : null;
const hasNonEmptyText = (value: unknown) => String(value ?? "").trim() !== "";
const hasChiffreValue = (value: unknown) => {
  if (typeof value === "number") return Number.isFinite(value);
  if (typeof value === "string") return value.trim() !== "";
  return value !== null && value !== undefined && String(value).trim() !== "";
};
const hasTypeDeChiffreValue = hasNonEmptyText(action?.type_de_chiffre) &&
  String(action?.type_de_chiffre).trim().toLowerCase() !== "type de chiffre";
const chiffreNumber = Number(action?.chiffre);
const chiffreIsNegative = Number.isFinite(chiffreNumber) && chiffreNumber < 0;
const chiffreIsZero =
  action?.chiffre === 0 ||
  String(action?.chiffre ?? "").trim() === "0";
const hasLieuCard =
  hasNonEmptyText(action?.nom_lieu) || hasNonEmptyText(action?.adresse_lieu);
const hasChiffreCard = chiffreIsZero
  ? false
  : hasChiffreValue(action?.chiffre);
const chiffreTypeLabel = hasTypeDeChiffreValue
  ? String(action?.type_de_chiffre)
  : (chiffreIsNegative ? "chiffre clé" : "");
const hasBeneficiaireCard = hasNonEmptyText(action?.beneficiaire);
const hasLocationSection = hasLieuCard || hasChiffreCard || hasBeneficiaireCard;
const shouldRenderLocationSection =
  hasLocationSection || forcePreviewLocationSection;
const hasPart1Section = hasNonEmptyText(action?.texte_partie_1);
const hasPart2Section = hasNonEmptyText(action?.texte_partie_2);
const hasPart3Section = hasNonEmptyText(action?.texte_partie_3);
const hasThanksSection = hasNonEmptyText(action?.description_remerciements);
---

<style>
  [data-location-section] {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: stretch;
  }

  @media (min-width: 1024px) {
    [data-location-section] {
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 2rem;
    }
  }
</style>

<div
  id="actionPreview"
  data-tablet-mobile-preview={tabletPreviewAsMobile ? "true" : "false"}
  style="container-type: inline-size;"
  class="w-full max-w-7xl mx-auto lg:mt-48 relative px-4 md:px-8"
>
  <!-- Section titre -->
  {
    Object.prototype.hasOwnProperty.call(action, "titre") && (
      <h1
        data-field="titre"
        class="uppercase w-full text-3xl md:text-4xl lg:text-5xl"
      >
        {action.titre}
      </h1>
    )
  }

  <div
    class="flex flex-col md:flex-row items-start md:items-center mt-4 md:mt-0 w-full justify-between"
  >
    {
      Object.prototype.hasOwnProperty.call(action, "sous_titre") && (
        <h3 data-field="sous_titre">{action.sous_titre}</h3>
      )
    }
    <div data-field="dates">
      {action.date_debut ? `${formatDateLong(action.date_debut)}` : ""}
      {action.date_fin ? ` au ${formatDateLong(action.date_fin)}` : ""}
    </div>
  </div>

  <!-- Section En-tête -->
  {
    // N'afficher la section d'en-tête (image + description) que si une image existe ;
    // ne pas afficher la description si l'image est absente.
    action && action.hero && (
        <div class="flex flex-col items-end my-12 md:my-32">
        <img
          data-field="hero"
          src={heroImg}
          alt={action.description_hero}
          loading="lazy"
          decoding="async"
          class="w-full min-h-[50dvh] object-cover object-center rounded-lg"
        />
        {action.description_hero && (
          <p data-field="description_hero" class="text-sm md:text-base mt-4">
            {action.description_hero}
          </p>
        )}
      </div>
    )
  }

  <!-- Section Partie 1 -->
  {
    (hasPart1Section || forcePreviewLocationSection) && (
      <div
        data-part-section="1"
        style={hasPart1Section ? "" : "display:none;"}
        class="flex flex-col max-w-7xl mx-auto my-12 md:my-20 lg:mb-48 gap-4 px-4 md:px-0"
      >
        {Object.prototype.hasOwnProperty.call(action, "titre_partie_1") && (
          <h2
            data-field="titre_partie_1"
            class="uppercase font-light! text-2xl md:text-3xl"
          >
            {action.titre_partie_1}
          </h2>
        )}
        <div
          data-image-layout="photo_partie_1"
          class={`grid grid-cols-1 ${action.photo_partie_1 ? "lg:grid-cols-[1fr_1fr] min-h-[40dvh]" : "lg:grid-cols-1"} gap-8 lg:gap-16`}
        >
          {Object.prototype.hasOwnProperty.call(action, "texte_partie_1") && (
            <div data-field="texte_partie_1" class="flex flex-col gap-8">
              <div class="flex flex-col gap-4">
                {action.texte_partie_1.split("\n").map((line: string) => (
                  <p>{line}</p>
                ))}
              </div>
            </div>
          )}
          {(action.photo_partie_1 || forcePreviewLocationSection) && (
            <div
              data-image-layout-media="photo_partie_1"
              style={action.photo_partie_1 ? "" : "display:none;"}
              class="flex flex-col items-end w-full mx-auto max-h-[50dvh] lg:max-w-full"
            >
              {action.photo_partie_1 && (
                <img
                  data-field="photo_partie_1"
                  src={partie1Img}
                  alt={action.description_photo_partie_1}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-[50dvh] min-h-[50dvh] object-cover rounded-lg"
                />
              )}
              {action.photo_partie_1 && action.description_photo_partie_1 && (
                <p data-field="description_photo_partie_1" class="text-sm mt-4">
                  {action.description_photo_partie_1}
                </p>
              )}
            </div>
          )}
        </div>
      </div>
    )
  }

  <!-- Section Lieu, Chiffres, Bénéficiaires -->
  {
    shouldRenderLocationSection && (
      <div
        data-location-section
        data-kc="compact"
        style={hasLocationSection ? "" : "display:none;"}
        class="w-full h-auto mx-auto my-16 md:my-32 px-4 md:px-0"
      >
        {(hasLieuCard || forcePreviewLocationSection) ? (
          <div
            data-location-card="lieu"
            style={hasLieuCard ? "" : "display:none;"}
            class="bg-accent text-base-100 w-full h-full rounded-2xl px-6 md:px-8 py-4 md:py-6 flex flex-col gap-4 justify-between min-h-30 md:min-h-48"
          >
            <div class="flex flex-col gap-2 min-w-fit max-w-fit">
              <h2
                data-field="nom_lieu"
                class="text-lg md:text-xl leading-tight min-w-fit max-w-fit"
                title={action.nom_lieu}
                style={`${hasNonEmptyText(action.nom_lieu) ? "display:-webkit-box;-webkit-box-orient:vertical;overflow:hidden;-webkit-line-clamp:3;" : "display:none;"}`}
              >
                {action.nom_lieu}
              </h2>
              <p
                data-field="adresse_lieu"
                class="text-lg md:text-2xl! min-w-fit max-w-fit"
                style={hasNonEmptyText(action.adresse_lieu) ? "" : "display:none;"}
              >
                {action.adresse_lieu}
              </p>
            </div>
            <div class="flex items-center justify-between w-full">
              <a
                data-field="lien_lieu"
                href={action.lien_lieu ? action.lien_lieu : "#"}
                target="_blank"
                class="flex items-center gap-2 md:gap-4 text-base md:text-xl!"
              >
                Voir sur Google maps{" "}
                <img src={diagArrow.src} aria-hidden="true" />
              </a>
              <p class="text-base md:text-xl!">LIEU</p>
            </div>
          </div>
        ) : null}
        {(hasChiffreCard || forcePreviewLocationSection) && (
          <div
            data-location-card="chiffre"
            style={hasChiffreCard ? "" : "display:none;"}
            class="bg-accent text-base-100 w-full h-full max-w-full rounded-2xl px-6 md:px-8 py-4 md:py-6 flex flex-col justify-between min-h-30 md:min-h-48"
          >
            <h2 data-field="chiffre" class="text-5xl! md:text-7xl!">
              {action.chiffre} €
            </h2>
            {/* inclure l'élément systématiquement pour que le script de preview puisse le cibler */}
            <p
              data-field="type_de_chiffre"
              class="text-base md:text-xl! uppercase self-end"
              style={chiffreTypeLabel ? "" : "display:none;"}
            >
              {chiffreTypeLabel}
            </p>
          </div>
        )}
        {(hasBeneficiaireCard || forcePreviewLocationSection) && (
          <div
            data-location-card="beneficiaire"
            style={hasBeneficiaireCard ? "" : "display:none;"}
            class="bg-accent text-base-100 rounded-2xl px-6 md:px-8 py-4 md:py-6 flex flex-col justify-between min-h-30 md:min-h-48 w-full h-full"
          >
            <h2
              data-field="beneficiaire"
              class="text-lg md:text-xl w-full"
              style="overflow-wrap: anywhere; word-break: break-word;"
            >
              {action.beneficiaire}
            </h2>
            <p class="text-base md:text-xl! uppercase self-end">
              bénéficiaires
            </p>
          </div>
        )}
      </div>
    )
  }

  <!-- Section Partie 2 -->
  {
    (hasPart2Section || forcePreviewLocationSection) && (
      <div
        data-part-section="2"
        style={hasPart2Section ? "" : "display:none;"}
        data-image-layout="photo_partie_2"
        class={`grid grid-cols-1 ${action.photo_partie_2 ? "lg:grid-cols-[1fr_1fr] min-h-[40dvh]" : "lg:grid-cols-1"} gap-6 md:gap-8 lg:gap-16 my-12 md:my-20 lg:my-32 px-4 md:px-0`}
      >
        <div class="flex flex-col gap-8">
          {Object.prototype.hasOwnProperty.call(action, "titre_partie_2") && (
            <h2
              data-field="titre_partie_2"
              class="uppercase font-light! text-2xl md:text-3xl"
            >
              {action.titre_partie_2}
            </h2>
          )}

          {Object.prototype.hasOwnProperty.call(action, "texte_partie_2") && (
            <div data-field="texte_partie_2" class="flex flex-col gap-8">
              <div class="flex flex-col gap-4">
                {action.texte_partie_2.split("\n").map((line: string) => (
                  <p>{line}</p>
                ))}
              </div>
            </div>
          )}
        </div>
        {(action.photo_partie_2 || forcePreviewLocationSection) && (
          <div
            data-image-layout-media="photo_partie_2"
            style={action.photo_partie_2 ? "" : "display:none;"}
            class="flex flex-col items-end w-full mx-auto max-h-[50dvh] lg:max-w-full"
          >
            {action.photo_partie_2 && (
              <img
                data-field="photo_partie_2"
                src={partie2Img}
                alt={action.description_photo_partie_2}
                loading="lazy"
                decoding="async"
                class="w-full h-[50dvh] min-h-[50dvh] object-cover rounded-lg"
              />
            )}
            {action.photo_partie_2 && action.description_photo_partie_2 && (
              <p data-field="description_photo_partie_2" class="text-sm mt-4">
                {action.description_photo_partie_2}
              </p>
            )}
          </div>
        )}
      </div>
    )
  }

  <!-- Section Partie 3 -->
  {
    (hasPart3Section || forcePreviewLocationSection) && (
      <div
        data-part-section="3"
        style={hasPart3Section ? "" : "display:none;"}
        data-image-layout="photo_partie_3"
        class={`flex flex-col-reverse lg:grid ${action.photo_partie_3 ? "lg:grid-cols-[1fr_1fr] min-h-[40dvh]" : "lg:grid-cols-1"} gap-6 md:gap-8 lg:gap-16 mt-12 mb-12 md:mt-12 md:mb-20 lg:mt-10 lg:mb-14 px-4 md:px-0`}
      >
        {(action.photo_partie_3 || forcePreviewLocationSection) && (
          <div
            data-image-layout-media="photo_partie_3"
            style={action.photo_partie_3 ? "" : "display:none;"}
            class="flex flex-col w-full mx-auto max-h-[50dvh] lg:max-w-full"
          >
            {action.photo_partie_3 && (
              <img
                data-field="photo_partie_3"
                src={partie3Img}
                alt={action.description_photo_partie_3}
                loading="lazy"
                decoding="async"
                class="w-full h-[50dvh] min-h-[50dvh] object-cover rounded-lg"
              />
            )}
            {action.photo_partie_3 && action.description_photo_partie_3 && (
              <p
                data-field="description_photo_partie_3"
                class="text-sm mt-4 self-end lg:self-auto"
              >
                {action.description_photo_partie_3}
              </p>
            )}
          </div>
        )}
        <div class="flex flex-col gap-8">
          {Object.prototype.hasOwnProperty.call(action, "titre_partie_3") && (
            <h2
              data-field="titre_partie_3"
              class="uppercase font-light! text-2xl md:text-3xl"
            >
              {action.titre_partie_3}
            </h2>
          )}

          {Object.prototype.hasOwnProperty.call(action, "texte_partie_3") && (
            <div data-field="texte_partie_3" class="flex flex-col gap-8">
              <div class="flex flex-col gap-4">
                {action.texte_partie_3.split("\n").map((line: string) => (
                  <p>{line}</p>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    )
  }

  <!-- Section Remerciements -->
  {
    (hasThanksSection || forcePreviewLocationSection) && (
      <div
        data-thanks-section
        style={hasThanksSection ? "" : "display:none;"}
        class="flex flex-col max-w-full md:max-w-1/2 px-4 md:px-0 gap-4 md:gap-8 my-16 md:my-32"
      >
        {action.titre_remerciements && (
          <h2
            data-field="titre_remerciements"
            class="uppercase font-light! text-2xl md:text-3xl"
          >
            {action.titre_remerciements}
          </h2>
        )}
        <div data-field="description_remerciements" class="flex flex-col gap-4">
          {action.description_remerciements.split("\n").map((line: string) => (
            <p>{line}</p>
          ))}
        </div>
      </div>
    )
  }

  <!-- Section Galerie Photo -->
  {
    action.galerie_photos && action.galerie_photos.length > 0 && (
      <div id="gallerieSection" class="flex flex-col gap-6 md:gap-8 my-16 md:my-32 px-4 md:px-0">
        <div class="bg-accent text-base-100 uppercase w-full h-fit rounded-box">
          <h2 class="text-2xl md:text-3xl! px-6 md:px-8 py-4 md:py-6">
            Galerie photo
          </h2>
        </div>
        <div
          id="photoGrid"
          class="grid gap-4 w-full opacity-0 transition-opacity"
          data-photo-count={action.galerie_photos.length}
        >
          {action.galerie_photos &&
            action.galerie_photos.map((photo: string, index: number) => {
              const photoURL =
                typeof photo === "string" &&
                (photo.startsWith("data:") ||
                  photo.startsWith("blob:") ||
                  photo.startsWith("http"))
                  ? photo
                  : Astro.locals.pb.files.getURL(action, photo);

              return (
                <div
                  class="overflow-hidden rounded-box cursor-pointer"
                  data-photo-url={photoURL}
                >
                  <img
                    src={photoURL}
                    alt="Photo de la galerie"
                    class="w-full h-[60dvh] object-cover block"
                  />
                </div>
              );
            })}
        </div>
      </div>
    )
  }

  <!-- Modal pour afficher l'image en grand -->
  {
    Object.prototype.hasOwnProperty.call(action, "galerie_photos") &&
      action.galerie_photos &&
      action.galerie_photos.length > 0 && (
        <div
          id="imageModal"
          class="fixed inset-0 bg-accent/60 items-center justify-center z-120 hidden"
        >
          <button
            id="closeButton"
            class="absolute top-16 right-4 text-xl! bg-base-100 bg-opacity-80 rounded-full w-8 h-8 md:w-10 md:h-10 flex items-center justify-center z-110 cursor-pointer"
          >
            ×
          </button>
          <button
            id="prevButton"
            class="absolute left-4 top-1/2 -translate-y-1/2 text-xl! bg-base-100 bg-opacity-80 rounded-full w-8 h-8 md:w-10 md:h-10 flex items-center justify-center z-110"
          >
            ‹
          </button>
          <button
            id="nextButton"
            class="absolute right-4 top-1/2 -translate-y-1/2 text-xl! bg-base-100 bg-opacity-80 rounded-full w-8 h-8 md:w-10 md:h-10 flex items-center justify-center z-110"
          >
            ›
          </button>
          <div class="relative p-2 md:p-4">
            <img
              id="modalImage"
              src=""
              alt="Image agrandie"
              class="h-[80dvh] max-w-[80dvw] w-auto object-contain"
            />
          </div>
        </div>
      )
  }
</div>

{
  tabletPreviewAsMobile && (
    <script is:inline>
      (() => {
        const rootSelector = '[data-tablet-mobile-preview="true"]';
        const snapshotAttr = "data-md-class-snapshot";
        const appliedAttr = "data-md-class-applied";
        const globalStateKey = "__kcTabletPreviewAsMobileState";
        const tabletQuery = window.matchMedia(
          "(min-width: 768px) and (max-width: 1023px)",
        );

        const syncElement = (element, stripMdClasses) => {
          if (!(element instanceof HTMLElement)) return;
          const currentSnapshot = element.getAttribute(snapshotAttr);

          if (stripMdClasses) {
            // On retire temporairement les classes md:* en conservant un snapshot pour restauration.
            if (currentSnapshot) return;
            const mdClasses = Array.from(element.classList).filter((className) =>
              className.startsWith("md:"),
            );
            if (!mdClasses.length) return;
            element.setAttribute(snapshotAttr, mdClasses.join(" "));
            mdClasses.forEach((className) => element.classList.remove(className));
            return;
          }

          if (!currentSnapshot) return;
          // Sortie du mode tablette: on restaure les classes md:* sauvegardées.
          currentSnapshot
            .split(" ")
            .filter(Boolean)
            .forEach((className) => element.classList.add(className));
          element.removeAttribute(snapshotAttr);
        };

        const hasSnapshots = (root) =>
          root.hasAttribute(snapshotAttr) ||
          root.querySelector(`[${snapshotAttr}]`);

        const stripRootMdClasses = (root) => {
          if (!(root instanceof HTMLElement)) return;
          if (root.getAttribute(appliedAttr) === "true") return;
          let hasAppliedMutation = false;

          syncElement(root, true);
          if (root.hasAttribute(snapshotAttr)) hasAppliedMutation = true;

          root.querySelectorAll("*").forEach((child) => {
            syncElement(child, true);
            if (child instanceof HTMLElement && child.hasAttribute(snapshotAttr)) {
              hasAppliedMutation = true;
            }
          });

          if (hasAppliedMutation) {
            root.setAttribute(appliedAttr, "true");
          } else {
            root.removeAttribute(appliedAttr);
          }
        };

        const restoreRootMdClasses = (root) => {
          if (!(root instanceof HTMLElement)) return;
          const wasApplied = root.getAttribute(appliedAttr) === "true";
          if (!wasApplied && !hasSnapshots(root)) return;

          syncElement(root, false);
          root
            .querySelectorAll(`[${snapshotAttr}]`)
            .forEach((child) => syncElement(child, false));
          root.removeAttribute(appliedAttr);
        };

        const syncRoots = () => {
          // Le comportement "preview tablette comme mobile" est limité strictement à 768-1023.
          const isTablet = tabletQuery.matches;
          document.querySelectorAll(rootSelector).forEach((root) => {
            if (!(root instanceof HTMLElement)) return;
            if (isTablet) {
              stripRootMdClasses(root);
              return;
            }
            restoreRootMdClasses(root);
          });
        };

        const globalState = window[globalStateKey] || {
          listenersBound: false,
          syncRoots: null,
        };
        globalState.syncRoots = syncRoots;
        window[globalStateKey] = globalState;

        const init = () => {
          if (!globalState.listenersBound) {
            // Garde globale: un seul binding même si Astro recharge la page côté client.
            tabletQuery.addEventListener("change", () => {
              window[globalStateKey]?.syncRoots?.();
            });
            document.addEventListener("astro:page-load", () => {
              window[globalStateKey]?.syncRoots?.();
            });
            globalState.listenersBound = true;
          }
          window[globalStateKey]?.syncRoots?.();
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", init, { once: true });
        } else {
          init();
        }
      })();
    </script>
  )
}

{
  action.galerie_photos && action.galerie_photos.length > 0 && (
    <>
      <script src={galleryUrl} />
      <script src={galleryDisplayUrl} />
    </>
  )
}
