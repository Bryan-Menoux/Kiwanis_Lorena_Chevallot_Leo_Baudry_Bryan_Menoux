---
import diagArrow from "../assets/diag-arrow.svg";
import imageIcon from "../assets/image-icon.svg";
import galleryUrl from "../scripts/gallery.js?url";
import galleryDisplayUrl from "../scripts/gallery-display.js?url";
export interface Props {
  action: any;
}

const { action } = Astro.props;

// Helper pour vérifier si une valeur est une URL de données ou un blob (pour les images)
const isDataUrl = (v: unknown): v is string => {
  if (typeof v !== "string") return false;
  return v.startsWith("data:") || v.startsWith("blob:");
};
// Préparation des URLs d'images : si c'est une URL de données, on l'utilise directement, sinon on génère l'URL via `Astro.locals.pb.files.getURL`
const heroImg =
  action && action.hero
    ? isDataUrl(action.hero)
      ? action.hero
      : Astro.locals.pb.files.getURL(action, action.hero)
    : null;
const partie1Img =
  action && action.photo_partie_1
    ? isDataUrl(action.photo_partie_1)
      ? action.photo_partie_1
      : Astro.locals.pb.files.getURL(action, action.photo_partie_1)
    : null;
const partie2Img =
  action && action.photo_partie_2
    ? isDataUrl(action.photo_partie_2)
      ? action.photo_partie_2
      : Astro.locals.pb.files.getURL(action, action.photo_partie_2)
    : null;
const partie3Img =
  action && action.photo_partie_3
    ? isDataUrl(action.photo_partie_3)
      ? action.photo_partie_3
      : Astro.locals.pb.files.getURL(action, action.photo_partie_3)
    : null;
---

<style>
  @container (max-width: 950px) {
    [data-kc="compact"] {
      flex-direction: column !important;
      /* make immediate children behave like `w-full` */
      > * {
        flex-basis: 100% !important;
        max-width: 100% !important;
        width: 100% !important;
      }
    }
    
  }
</style>

<div
  id="actionPreview"
  style="container-type: inline-size;"
  class="w-full max-w-7xl mx-auto lg:mt-48 relative px-4 md:px-8"
>
  <!-- Section titre -->
  {
    Object.prototype.hasOwnProperty.call(action, "titre") && (
      <h1
        data-field="titre"
        class="uppercase w-full text-3xl md:text-4xl lg:text-5xl"
      >
        {action.titre}
      </h1>
    )
  }

  <div
    class="flex flex-col md:flex-row items-start md:items-center mt-4 md:mt-0 w-full justify-between"
  >
    {
      Object.prototype.hasOwnProperty.call(action, "sous_titre") && (
        <p data-field="sous_titre">{action.sous_titre}</p>
      )
    }
    <div data-field="dates">
      {
        action.date_debut
          ? `${new Date(action.date_debut).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}`
          : ""
      }
      {
        action.date_fin
          ? ` au ${new Date(action.date_fin).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}`
          : ""
      }
    </div>
  </div>

  <!-- Section En-tête -->
  {
    // N'afficher la section d'en-tête (image + description) que si une image existe ;
    // ne pas afficher la description si l'image est absente.
    action && action.hero && (
      <div class="flex flex-col items-end my-12 md:my-32">
        <img
          data-field="hero"
          src={heroImg}
          alt={action.description_hero}
          loading="lazy"
          decoding="async"
          class="w-full min-h-[30dvh] object-cover object-center rounded-lg"
        />
        {action.description_hero && (
          <p data-field="description_hero" class="text-sm md:text-base mt-4">
            {action.description_hero}
          </p>
        )}
      </div>
    )
  }

  <!-- Section Partie 1 -->
  {
    (Object.prototype.hasOwnProperty.call(action, "titre_partie_1") ||
      Object.prototype.hasOwnProperty.call(action, "texte_partie_1") ||
      Object.prototype.hasOwnProperty.call(action, "photo_partie_1")) && (
      <div class="flex flex-col max-w-7xl mx-auto my-16 md:my-32 gap-4 px-4 md:px-8">
        {Object.prototype.hasOwnProperty.call(action, "titre_partie_1") && (
          <h2 data-field="titre_partie_1" class="text-2xl md:text-3xl">
            {action.titre_partie_1}
          </h2>
        )}
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-8 lg:gap-16 min-h-[40dvh]">
          {Object.prototype.hasOwnProperty.call(action, "texte_partie_1") && (
            <div data-field="texte_partie_1" class="flex flex-col gap-8">
              <div class="flex flex-col gap-4">
                {action.texte_partie_1.split("\n").map((line: string) => (
                  <p>{line}</p>
                ))}
              </div>
            </div>
          )}
          {
            <div class="flex flex-col items-end w-full mx-auto max-h-[50dvh] lg:max-w-full">
                  {
                    action.photo_partie_1 && (
                      <img
                        data-field="photo_partie_1"
                        src={partie1Img}
                        alt={action.description_photo_partie_1}
                        loading="lazy"
                        decoding="async"
                        class="w-full h-full flex-1 object-cover rounded-lg"
                      />
                    )
                  }
                  {action.photo_partie_1 && action.description_photo_partie_1 && (
                    <p data-field="description_photo_partie_1" class="text-sm mt-4">
                      {action.description_photo_partie_1}
                    </p>
                  )}
            </div>
          }
        </div>
      </div>
    )
  }

  <!-- Section Lieu, Chiffres, Bénéficiaires -->
  {
    (Object.prototype.hasOwnProperty.call(action, "nom_lieu") ||
      Object.prototype.hasOwnProperty.call(action, "adresse_lieu") ||
      Object.prototype.hasOwnProperty.call(action, "chiffre") ||
      Object.prototype.hasOwnProperty.call(action, "beneficiaire")) && (
      <div
        data-kc="compact"
        class="flex flex-col lg:flex-row justify-between gap-6 md:gap-8 w-full h-auto mx-auto my-16 md:my-32 px-4 md:px-0"
      >
        {Object.prototype.hasOwnProperty.call(action, "nom_lieu") ||
        Object.prototype.hasOwnProperty.call(action, "adresse_lieu") ? (
          <div class="bg-accent text-base-100 w-full lg:min-w-1/3 lg:max-w-fit h-fit rounded-2xl px-6 md:px-8 py-4 md:py-6 flex flex-col gap-4 justify-between min-h-30 md:min-h-48">
            <div class="flex flex-col gap-2 min-w-fit max-w-fit">
              {Object.prototype.hasOwnProperty.call(action, "nom_lieu") && (
                <h2
                  data-field="nom_lieu"
                  class="text-lg md:text-xl leading-tight min-w-fit max-w-fit"
                  title={action.nom_lieu}
                  style={`display:-webkit-box;-webkit-box-orient:vertical;overflow:hidden;-webkit-line-clamp:3;`}
                >
                  {action.nom_lieu}
                  {action.adresse_lieu ? "," : ""}
                </h2>
              )}
              {Object.prototype.hasOwnProperty.call(action, "adresse_lieu") && (
                <p
                  data-field="adresse_lieu"
                  class="text-lg md:text-2xl! min-w-fit max-w-fit"
                >
                  {action.adresse_lieu}
                </p>
              )}
            </div>
            <div class="flex items-center justify-between w-full">
              <a
                href=""
                class="flex items-center gap-2 md:gap-4 text-base md:text-xl!"
              >
                Voir sur Google maps{" "}
                <img src={diagArrow.src} aria-hidden="true" />
              </a>
              <p class="text-base md:text-xl!">LIEU</p>
            </div>
          </div>
        ) : null}
        {Object.prototype.hasOwnProperty.call(action, "chiffre") && (
          <div class="bg-accent text-base-100 w-full lg:min-w-fit lg:w-1/3 max-w-full rounded-2xl px-6 md:px-8 py-4 md:py-6 flex flex-col justify-between min-h-30 md:min-h-48">
            <h2 data-field="chiffre" class="text-5xl! md:text-7xl!">
              {action.chiffre} €
            </h2>
            {Object.prototype.hasOwnProperty.call(action, "type_de_chiffre") &&
            action.type_de_chiffre ? (
              <p
                data-field="type_de_chiffre"
                class="text-base md:text-xl! uppercase self-end"
              >
                {action.type_de_chiffre}
              </p>
            ) : (
              <p class="text-base md:text-xl! uppercase self-end">
                chiffres clés
              </p>
            )}
          </div>
        )}
        {Object.prototype.hasOwnProperty.call(action, "beneficiaire") && (
          <div class="bg-accent text-base-100 lg:min-w-0 lg:grow-0 rounded-2xl px-6 md:px-8 py-4 md:py-6 flex flex-col justify-between min-h-30 md:min-h-48 w-full">
            <h2
              data-field="beneficiaire"
              class="text-lg md:text-xl w-full"
              style="overflow-wrap: anywhere; word-break: break-word;"
            >
              {action.beneficiaire}
            </h2>
            <p class="text-base md:text-xl! uppercase self-end">
              bénéficiaires
            </p>
          </div>
        )}
      </div>
    )
  }

  <!-- Section Partie 2 -->
  {
    (Object.prototype.hasOwnProperty.call(action, "titre_partie_2") ||
      Object.prototype.hasOwnProperty.call(action, "texte_partie_2") ||
      Object.prototype.hasOwnProperty.call(action, "photo_partie_2")) && (
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-6 md:gap-8 lg:gap-16 min-h-[40dvh] my-16 md:my-32 px-4 md:px-0">
        <div class="flex flex-col gap-8">
          {Object.prototype.hasOwnProperty.call(action, "titre_partie_2") && (
            <h2
              data-field="titre_partie_2"
              class="uppercase font-light! text-2xl md:text-3xl"
            >
              {action.titre_partie_2}
            </h2>
          )}

          {Object.prototype.hasOwnProperty.call(action, "texte_partie_2") && (
            <div data-field="texte_partie_2" class="flex flex-col gap-8">
              <div class="flex flex-col gap-4">
                {action.texte_partie_2.split("\n").map((line: string) => (
                  <p>{line}</p>
                ))}
              </div>
            </div>
          )}
        </div>
        <div class="flex flex-col items-end w-full mx-auto max-h-[50dvh] lg:max-w-full">
          {
            action.photo_partie_2 && (
              <img
                data-field="photo_partie_2"
                src={partie2Img}
                alt={action.description_photo_partie_2}
                loading="lazy"
                decoding="async"
                class="w-full h-full flex-1 object-cover rounded-lg"
              />
            )
          }
          {action.photo_partie_2 && action.description_photo_partie_2 && (
            <p data-field="description_photo_partie_2" class="text-sm mt-4">
              {action.description_photo_partie_2}
            </p>
          )}
        </div>
      </div>
    )
  }

  <!-- Section Partie 3 -->
  {
    (Object.prototype.hasOwnProperty.call(action, "titre_partie_3") ||
      Object.prototype.hasOwnProperty.call(action, "texte_partie_3") ||
      Object.prototype.hasOwnProperty.call(action, "photo_partie_3")) && (
      <div class="flex flex-col-reverse lg:grid lg:grid-cols-[1fr_1fr] gap-6 md:gap-8 lg:gap-16 min-h-[40dvh] mt-16 mb-16 md:mt-16 md:mb-32 px-4 md:px-0">
        <div class="flex flex-col w-full mx-auto max-h-[50dvh] lg:max-w-full">
          {
            action.photo_partie_3 && (
              <img
                data-field="photo_partie_3"
                src={partie3Img}
                alt={action.description_photo_partie_3}
                loading="lazy"
                decoding="async"
                class="w-full h-full flex-1 object-cover rounded-lg"
              />
            )
          }
          {action.photo_partie_3 && action.description_photo_partie_3 && (
            <p
              data-field="description_photo_partie_3"
              class="text-sm mt-4 self-end lg:self-auto"
            >
              {action.description_photo_partie_3}
            </p>
          )}
        </div>
        <div class="flex flex-col gap-8">
          {Object.prototype.hasOwnProperty.call(action, "titre_partie_3") && (
            <h2
              data-field="titre_partie_3"
              class="uppercase font-light! text-2xl md:text-3xl"
            >
              {action.titre_partie_3}
            </h2>
          )}

          {Object.prototype.hasOwnProperty.call(action, "texte_partie_3") && (
            <div data-field="texte_partie_3" class="flex flex-col gap-8">
              <div class="flex flex-col gap-4">
                {action.texte_partie_3.split("\n").map((line: string) => (
                  <p>{line}</p>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    )
  }

  <!-- Section Remerciements -->
  {
    Object.prototype.hasOwnProperty.call(
      action,
      "description_remerciements",
    ) && (
      <div class="flex flex-col max-w-full md:max-w-1/2 px-4 md:px-0 gap-4 md:gap-8 my-16 md:my-32">
        {action.titre_remerciements && (
          <h2
            data-field="titre_remerciements"
            class="uppercase font-light! text-2xl md:text-3xl"
          >
            {action.titre_remerciements}
          </h2>
        )}
        <div data-field="description_remerciements" class="flex flex-col gap-4">
          {action.description_remerciements.split("\n").map((line: string) => (
            <p>{line}</p>
          ))}
        </div>
      </div>
    )
  }

  <!-- Section Galerie Photo -->
  {
    action.galerie_photos && action.galerie_photos.length > 0 && (
      <div class="flex flex-col gap-6 md:gap-8 my-16 md:my-32 px-4 md:px-0">
        <div class="bg-accent text-base-100 uppercase w-full h-fit rounded-box">
          <h2 class="text-2xl md:text-3xl! px-6 md:px-8 py-4 md:py-6">
            Galerie photo
          </h2>
        </div>
        <div
          id="photoGrid"
          class="grid gap-4 min-h-[90dvh] md:minh-[50dvh] lg:min-h-[80dvh] opacity-0 transition-opacity"
          data-photo-count={action.galerie_photos.length}
        >
          {action.galerie_photos &&
            action.galerie_photos.map((photo: string, index: number) => {
              const photoURL =
                typeof photo === "string" &&
                (photo.startsWith("data:") ||
                  photo.startsWith("blob:") ||
                  photo.startsWith("http"))
                  ? photo
                  : Astro.locals.pb.files.getURL(action, photo);

              return (
                <div
                  class="relative w-full h-full overflow-hidden rounded-box cursor-pointer"
                  data-photo-url={photoURL}
                >
                  <img
                    src={photoURL}
                    alt="Photo de la galerie"
                    class="absolute inset-0 w-full h-full object-center object-cover"
                  />
                </div>
              );
            })}
        </div>
      </div>
    )
  }

  <!-- Modal pour afficher l'image en grand -->
  {
    Object.prototype.hasOwnProperty.call(action, "galerie_photos") &&
      action.galerie_photos &&
      action.galerie_photos.length > 0 && (
        <div
          id="imageModal"
          class="fixed inset-0 bg-accent/60 items-center justify-center z-50 hidden lg:mt-16"
        >
          <div class="relative max-w-full max-h-full p-2 md:p-4">
            <img
              id="modalImage"
              src=""
              alt="Image agrandie"
              class="max-w-full max-h-[80dvh] w-auto h-auto object-contain"
            />
            <button
              id="closeButton"
              class="absolute top-2 right-2 md:top-4 md:right-4 text-xl! bg-base-100 bg-opacity-80 rounded-full w-8 h-8 md:w-10 md:h-10 flex items-center justify-center"
            >
              ×
            </button>
            <button
              id="prevButton"
              class="absolute left-2 md:left-4 top-1/2 transform -translate-y-1/2 text-xl! bg-base-100 bg-opacity-80 rounded-full w-8 h-8 md:w-10 md:h-10 flex items-center justify-center"
            >
              ‹
            </button>
            <button
              id="nextButton"
              class="absolute right-2 md:right-4 top-1/2 transform -translate-y-1/2 text-xl! bg-base-100 bg-opacity-80 rounded-full w-8 h-8 md:w-10 md:h-10 flex items-center justify-center"
            >
              ›
            </button>
          </div>
        </div>
      )
  }
</div>

{
  action.galerie_photos && action.galerie_photos.length > 0 && (
    <>
      <script src={galleryUrl}></script>
      <script src={galleryDisplayUrl}></script>
    </>
  )
}
