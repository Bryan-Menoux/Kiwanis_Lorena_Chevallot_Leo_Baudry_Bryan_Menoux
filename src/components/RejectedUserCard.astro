---
import { Image } from "astro:assets";
import wait from "../assets/wait.svg";
import { formatDateShort } from "../utils/utilitaires.js";

type User = {
  id: string;
  name?: string;
  email: string;
  created: string;
  verified: boolean;
  rejected?: boolean;
  rejectionDate?: string;
};

const user = Astro.props.user as any as User;
---

<div
  class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 p-3 bg-error/10 rounded-lg border border-error/20 transition-all duration-300"
  data-user-id={user.id}
  data-list-type="rejected"
>
  <div class="flex items-center gap-4 min-w-0 flex-1">
    <input
    type="checkbox"
    class="checkbox checkbox-error checkbox-reject mr-4"
    data-user-id={user.id}
  />
  <div class="flex-1">
    <p class="font-semibold text-sm">
      {user.name ?? "Nom non spécifié"}
    </p>
    <p class="text-xs text-base-content/60 break-all">{user.email}</p>
    <p class="text-xs text-base-content/50">
      Rejeté le{" "}
      {user.rejectionDate ? formatDateShort(user.rejectionDate) : "-"}
    </p>
  </div>
  </div>

  <button
    class="btn btn-warning btn-sm verify-action self-end md:self-auto md:ml-auto md:shrink-0 w-full md:w-fit"
    data-user-id={user.id}
    data-action="unreject"
    data-list-type="rejected"
    type="button"
  >
    <Image src={wait} alt="" loading="lazy" quality={80} class="w-5 h-5 invert" />
    Remettre en attente
  </button>
</div>

