---
import wait from "../assets/wait.svg";

type User = {
  id: string;
  name?: string;
  email: string;
  created: string;
  verified: boolean;
  rejected?: boolean;
  rejectionDate?: string;
};

const user = Astro.props.user as any as User;
---

<div
  class="flex flex-col md:flex-row md:items-center justify-between p-3 bg-error/10 rounded-lg border border-error/20 transition-all duration-300"
  data-user-id={user.id}
  data-list-type="rejected"
>
  <div class="flex items-center gap-4">
    <input
    type="checkbox"
    class="checkbox checkbox-error checkbox-reject mr-4"
    data-user-id={user.id}
  />
  <div class="flex-1">
    <p class="font-semibold text-sm">
      {user.name ?? "Nom non spécifié"}
    </p>
    <p class="text-xs text-base-content/60">{user.email}</p>
    <p class="text-xs text-base-content/50">
      Rejeté le{" "}
      {user.rejectionDate
        ? new Date(user.rejectionDate).toLocaleDateString("fr-FR")
        : "—"}
    </p>
  </div>
  </div>

  <button
    class="btn btn-warning btn-sm verify-action self-center mt-4 md:mt-0 w-full md:w-auto"
    data-user-id={user.id}
    data-action="unreject"
    data-list-type="rejected"
    type="button"
  >
    <img src={wait.src} class="w-5 h-5 invert" />
    Remettre en attente
  </button>
</div>