---
import wait from "../assets/wait.svg";

type User = {
  id: string;
  name?: string;
  email: string;
  created: string;
  verified: boolean;
  rejected?: boolean;
  rejectionDate?: string;
};

const user = Astro.props.user as any as User;
---

<div
  class="flex justify-between p-3 bg-error/10 rounded-lg border border-error/20"
  data-user-id={user.id}
  data-list-type="rejected"
>
  <div>
    <p class="font-semibold text-sm">
      {user.name ?? "Nom non spécifié"}
    </p>
    <p class="text-xs text-base-content/60">{user.email}</p>
    <p class="text-xs text-base-content/50">
      Rejeté le{" "}
      {user.rejectionDate
        ? new Date(user.rejectionDate).toLocaleDateString("fr-FR")
        : "—"}
    </p>
  </div>

  <form method="post" class="inline">
    <input type="hidden" name="formSource" value="verification" />
    <input type="hidden" name="userId" value={user.id} />
    <input type="hidden" name="userName" value={user.name ?? "Nom non spécifié"} />
    <input type="hidden" name="userEmail" value={user.email} />
    <input type="hidden" name="userCreated" value={user.created} />
    <input type="hidden" name="action" value="unreject" />
    <input type="hidden" name="listType" value="rejected" />
    <button
      class="btn btn-warning btn-sm verify-action"
      data-user-id={user.id}
      data-action="unreject"
      data-list="rejected"
      type="submit"
      name="submitAction"
      value="unreject"
    >
      <img src={wait.src} class="w-5 h-5 invert" />
      Remettre en attente
    </button>
  </form>
</div>