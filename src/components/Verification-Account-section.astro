---
import { Image } from "astro:assets";
import paper from "../assets/paper.svg";
import crossCircle from "../assets/cross-circle.svg";
import circleCheck from "../assets/circle-check.svg";
import wait from "../assets/wait.svg";
import PendingUserCard from "./PendingUserCard.astro";
import RejectedUserCard from "./RejectedUserCard.astro";
import VerifiedUserCard from "./VerifiedUserCard.astro";

// Définition des types TypeScript
type User = {
  id: string;
  name?: string;
  email: string;
  created: string;
  verified: boolean;
  rejected?: boolean;
  rejectionDate?: string;
};

// Propriétés passées au composant
const users: User[] = Astro.props.users ?? [];
const isAdmin: boolean = Astro.props.isAdmin ?? false;
const currentUserId: string = Astro.props.currentUserId ?? "";

// Statuts des utilisateurs
const pendingUsers = users.filter(
  (u: User) => !u.verified && u.rejected !== true,
);
const rejectedUsers = users.filter((u: User) => u.rejected === true);
const verifiedUsers = users.filter((u: User) => u.verified === true);

---

<div
  class="min-h-screen mt-24 lg:bg-linear-to-br from-base-100 via-base-100 to-base-200 py-8 px-4 md:px-8 pt-4 md:pt-12"
>
  <div class="max-w-4xl mx-auto">
    <!-- Section d'en-tête -->
    <div class="mb-12 text-center">
      <h1
        class="text-4xl md:text-5xl lg:text-7xl font-bold title font-merriweather mb-4"
      >
        Vérifications
      </h1>
      <p class="text-base-content/60 text-lg">Gérer les demandes d'adhésion</p>
    </div>

    <div class="bg-white rounded-2xl shadow-2xl overflow-hidden" id="verifications">
      <!-- Section des demandes en attente -->
      <div class="px-8 py-8">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
          <Image src={wait} alt="" loading="lazy" quality={80} class="h-8 opacity-70" />
          Demandes en attente
          <span class="badge badge-warning text-center text-sm! md:text-md! font-bold" id="pending-badge" style={pendingUsers.length > 0 ? '' : 'display: none'}>{pendingUsers.length}</span>
        </h2>

        <search>
          <input
            type="text"
            id="pending-search"
            placeholder="Rechercher par nom ou email..."
            class="input input-bordered input-primary w-full mb-4 focus:input-primary-focus"
          />
        </search>

        <div class="space-y-4" id="pending-list">
          {
            pendingUsers.length > 0 ? (
              pendingUsers.map((user: User) => <PendingUserCard user={user} />)
            ) : (
              <div class="text-center py-12 text-base-content/60">
                <Image src={paper} alt="" loading="lazy" quality={80} class="h-16 mx-auto mb-4 opacity-50" />
                <p>Aucune demande en attente</p>
              </div>
            )
          }
        </div>
      </div>

      <!-- Section des utilisateurs rejetés -->
      <div class="px-8 pb-8">
        <details class="collapse collapse-arrow border border-base-300">
          <summary class="collapse-title">
            <div class="flex items-center gap-2">
              <Image src={crossCircle} alt="" loading="lazy" quality={80} class="w-6 h-6 shrink-0" />
              <span class="flex-1">Utilisateurs rejetés</span>
              <span class="badge badge-error text-center text-sm! md:text-md! font-bold" id="rejected-badge" style={rejectedUsers.length > 0 ? '' : 'display: none'}>{rejectedUsers.length}</span>
            </div>
          </summary>

          <div class="collapse-content space-y-2" id="rejected-list">
            <search>
              <input
                type="text"
                id="rejected-search"
                placeholder="Rechercher par nom ou email..."
                class="input input-bordered input-primary w-full my-4 focus:input-primary-focus"
              />
            </search>
            {
              rejectedUsers.length > 0 ? (
                <>
                  <div class="flex items-center gap-3 p-3 mb-4 bg-base-200 rounded-lg">
                    <input
                      type="checkbox"
                      id="select-all-rejected"
                      class="checkbox checkbox-error"
                    />
                    <label for="select-all-rejected" class="cursor-pointer font-semibold text-sm">
                      Sélectionner tous
                    </label>
                  </div>
                  <div class="space-y-2">
                    {rejectedUsers.map((user: User) => (
                      <RejectedUserCard user={user} />
                    ))}
                  </div>
                  <button
                    id="reject-selected-btn"
                    class="btn btn-error btn-sm w-full mt-4"
                    disabled
                  >
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"
                      ></path>
                    </svg>
                    Rejeter les utilisateurs sélectionnés
                  </button>
                </>
              ) : (
                <p class="text-center text-base-content/60 py-4">
                  Aucun utilisateur rejeté
                </p>
              )
            }
          </div>
        </details>
      </div>

      <!-- Section des utilisateurs vérifiés -->
      <div class="px-8 pb-8">
        <details class="collapse collapse-arrow border border-base-300">
          <summary class="collapse-title">
            <div class="flex items-center gap-2">
              <Image src={circleCheck} alt="" loading="lazy" quality={80} class="w-6 h-6 shrink-0" />
              <span class="flex-1">Utilisateurs vérifiés</span>
              <span class="badge badge-success text-center text-sm! md:text-md! font-bold" id="verified-badge" style={verifiedUsers.length > 0 ? '' : 'display: none'}>{verifiedUsers.length}</span>
            </div>
          </summary>
          <div class="collapse-content space-y-2" id="verified-list">
            <search>
              <input
                type="text"
                id="verified-search"
                placeholder="Rechercher par nom ou email..."
                class="input input-bordered input-primary w-full my-4 ml-auto focus:input-primary-focus"
              />
            </search>
            {
              verifiedUsers.length > 0 ? (
                verifiedUsers.map((user: User) => (
                  <VerifiedUserCard user={user} currentUserId={currentUserId} />
                ))
              ) : (
                <p class="text-center py-4 text-base-content/60">
                  Aucun utilisateur vérifié
                </p>
              )
            }
          </div>
        </details>
      </div>

      {
        !isAdmin && (
          <div class="text-center py-12">
            <h3 class="text-xl font-semibold text-error">Accès refusé</h3>
          </div>
        )
      }
    </div>
  </div>
</div>

<script>
  import { initVerifications } from "../scripts/verification-handlers.js";
  import { showAlert, showConfirm } from "../utils/alerts";
  
  // Gestion de la sélection des utilisateurs rejetés
  function updateButtonState() {
    const rejectBtn = document.getElementById('reject-selected-btn') as HTMLButtonElement | null;
    if (rejectBtn) {
      const selectedCount = document.querySelectorAll('.checkbox-reject:checked').length;
      rejectBtn.disabled = selectedCount === 0;
    }
  }

  // Fonction pour recharger les listes
  async function reloadUserLists() {
    try {
      const response = await fetch(window.location.pathname);
      if (response.ok) {
        const html = await response.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, "text/html");

        const listIds = ["pending-list", "rejected-list", "verified-list"];
        
        listIds.forEach(id => {
          const newList = doc.querySelector(`#${id}`);
          if (newList) {
            const oldList = document.querySelector(`#${id}`);
            if (oldList) oldList.replaceWith(newList);
          }
        });

        // Réinitialiser la page
        initVerifications();
      }
    } catch (error) {
      console.error("Erreur lors du rechargement:", error);
    }
  }

  // Délégation d'événements pour tous les checkboxes
  document.addEventListener('change', function(e) {
    const target = e.target as HTMLElement;
    
    // Gestion de "Sélectionner tous"
    if (target.id === 'select-all-rejected') {
      const isChecked = (target as HTMLInputElement).checked;
      document.querySelectorAll('.checkbox-reject').forEach(checkbox => {
        (checkbox as HTMLInputElement).checked = isChecked;
      });
      updateButtonState();
      return;
    }
    
    // Gestion des checkboxes individuelles
    if (target.classList.contains('checkbox-reject')) {
      const selectAllCheckbox = document.getElementById('select-all-rejected') as HTMLInputElement | null;
      
      // Mettre à jour la checkbox "Sélectionner tous"
      if (selectAllCheckbox) {
        const allCheckboxes = document.querySelectorAll('.checkbox-reject');
        const checkedCheckboxes = document.querySelectorAll('.checkbox-reject:checked');
        selectAllCheckbox.checked = allCheckboxes.length === checkedCheckboxes.length && allCheckboxes.length > 0;
      }
      
      // Mettre à jour l'état du bouton
      updateButtonState();
    }
  });

  // Délégation d'événements pour le bouton de suppression
  document.addEventListener('click', async function(e) {
    const target = e.target as HTMLElement;
    const rejectBtn = target.closest('#reject-selected-btn');
    
    if (!rejectBtn) {
      return;
    }

    const selectedCheckboxes = document.querySelectorAll('.checkbox-reject:checked');
    const userIds = Array.from(selectedCheckboxes).map(checkbox => {
      return (checkbox as HTMLElement).getAttribute('data-user-id');
    });

    if (userIds.length === 0) {
      showAlert({
        type: 'warning',
        message: 'Aucun utilisateur sélectionné',
      });
      return;
    }

    const confirmed = await showConfirm({
      title: "Supprimer les utilisateurs",
      message: `Êtes-vous sûr de vouloir supprimer ${userIds.length} utilisateur(s) ?`,
      type: "warning",
      confirmLabel: "Supprimer",
      cancelLabel: "Annuler",
    });

    if (!confirmed) {
      return;
    }

    try {
      // Effectuer les requêtes de suppression pour chaque utilisateur
      const promises = userIds.map(userId =>
        fetch('/api/form-submit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
          },
          body: JSON.stringify({
            formType: 'deletion',
            userId: userId,
          }),
        })
      );

      const responses = await Promise.all(promises);
      const allSuccess = responses.every(response => response.ok);

      if (allSuccess) {
        // Recharger les listes complètement
        await reloadUserLists();
        showAlert({
          type: 'success',
          message: `${userIds.length} utilisateur(s) supprimé(s) avec succès`,
        });
      } else {
        showAlert({
          type: 'error',
          message: 'Erreur lors de la suppression de certains utilisateurs',
        });
      }
    } catch (error) {
      showAlert({
        type: 'error',
        message: 'Erreur réseau : ' + ((error as Error).message),
      });
    }
  });

  // Initialiser l'état du bouton au chargement
  document.addEventListener('DOMContentLoaded', updateButtonState);
  
  // Initialiser aussi immédiatement si le DOM est déjà chargé
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    updateButtonState();
  }
</script>
