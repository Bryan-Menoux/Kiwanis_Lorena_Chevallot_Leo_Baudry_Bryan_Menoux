---
export type AlertType = "success" | "error" | "warning" | "info";

interface Props {
  message: string;
  type?: AlertType;
  dismissible?: boolean;
  toastId?: string;
}

const { message, type = "info", dismissible = true, toastId = "" } =
  Astro.props as Props;

const variants: Record<
  AlertType,
  {
    container: string;
    iconWrapper: string;
    icon: string;
  }
> = {
  success: {
    container: "bg-success text-success-content border-success",
    iconWrapper: "bg-base-100/20 text-success-content",
    icon: "+",
  },
  error: {
    container: "bg-error text-error-content border-error",
    iconWrapper: "bg-base-100/20 text-error-content",
    icon: "x",
  },
  warning: {
    container: "bg-warning text-warning-content border-warning",
    iconWrapper: "bg-base-100/20 text-warning-content",
    icon: "!",
  },
  info: {
    container: "bg-info text-info-content border-info",
    iconWrapper: "bg-base-100/20 text-info-content",
    icon: "i",
  },
};

const variant = variants[type];
---

<article
  class={`kiwanis-alert pointer-events-auto relative flex w-full min-w-0 items-center gap-3 overflow-hidden rounded-xl border p-3 shadow-xl backdrop-blur-sm sm:p-4 ${variant.container}`}
  role="status"
  aria-live="polite"
  aria-atomic="true"
  data-alert-id={toastId}
  data-alert-type={type}
>
  <span
    class={`flex h-6 w-6 shrink-0 items-center justify-center self-center rounded-full text-xs font-bold ${variant.iconWrapper}`}
    aria-hidden="true"
    data-alert-icon
  >
    {variant.icon}
  </span>

  <p
    class="min-w-0 flex-1 wrap-break-word whitespace-pre-wrap text-sm leading-snug sm:text-base"
    data-alert-message
  >
    {message}
  </p>

  {
    dismissible && (
      <button
        type="button"
        class="ml-auto grid h-8 w-8 shrink-0 cursor-pointer place-items-center rounded-full text-lg leading-none md:h-9 md:w-9"
        aria-label="Fermer l'alerte"
        data-alert-close
      >
        ×
      </button>
    )
  }
</article>
