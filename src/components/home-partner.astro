---
const imageModules = import.meta.glob('/src/assets/partners/*.webp', { eager: true });

const images = Object.keys(imageModules).map((path, index) => {
  const name = path.split('/').pop()!.replace('.webp', '');
  return {
    src: path,
    alt: `Logo du partenaire ${name}`
  };
});

const duplicatedImages = [...images, ...images];
---

<div class="partner-carousel-container overflow-hidden relative w-full h-fit">
  <div class="partner-carousel-inner flex gap-16 lg:gap-32 h-full">
    {duplicatedImages.map((image, index) => (
      <img
        src={image.src}
        alt={image.alt}
        class="shrink-0 w-1/3 md:w-1/5 lg:w-1/6 h-full max-h-24 object-contain rounded-box"
      />
    ))}
  </div>
</div>

<style>
  .partner-carousel-inner {
    will-change: transform;
  }
</style>

<script>
  // For smoother infinite scroll without jerking
  const carousel = document.querySelector('.partner-carousel-inner') as HTMLElement;
  if (carousel) {
    let startTime: number | null = null;
    let position = 0;
    const speed = 50; // pixels per second

    function animate(currentTime: number) {
      if (startTime === null) {
        startTime = currentTime;
      }
      const delta = (currentTime - startTime) * speed / 1000;
      position -= delta;
      startTime = currentTime;
      if (position <= -(carousel.scrollWidth / 2)) {
        position += carousel.scrollWidth / 2;
      }
      carousel.style.transform = `translateX(${position}px)`;
      requestAnimationFrame(animate);
    }
    requestAnimationFrame(animate);
  }
</script>