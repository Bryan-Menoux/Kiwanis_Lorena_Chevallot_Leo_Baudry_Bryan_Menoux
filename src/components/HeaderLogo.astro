---
interface Props {
  logoSvg: string;
  showText?: boolean;
}

const { logoSvg, showText = true } = Astro.props;
---

<a href="/" class="flex items-center gap-4">
  <span class="inline-block h-14 w-14 shrink-0" role="img" aria-label="Logo Kiwanis Pays de Montbéliard" set:html={logoSvg} />
  {showText && (
    <div class="flex flex-col text-gray-900 leading-tight">
      <span class="text-xl font-bold tracking-tighter font-merriweather">KIWANIS</span>
      <span class="text-xl font-light tracking-[-0.02em] text-[0.7rem] -mt-1 uppercase font-merriweather">PAYS DE MONTBÉLIARD</span>
    </div>
  )}
</a>

<style>
  a {
    font-family: "Poppins", var(--font-sans-fallback);
  }
</style>
