---
const props = Astro.props || {};
const {
  value = "",
  showBeneficiary = true,
  showStatus = false,
  statusOptions = [],
  yearOptions = [],
  typeOptions = [],
  initialYear = "",
  initialType = "",
  embedded = true,
} = props;

const getStatusLabel = (status: string) => {
  if (status === "all") return "Tous";
  if (status === "brouillon") return "Brouillons uniquement";
  return status;
};

const secondaryFilterCount =
  (yearOptions.length > 0 ? 1 : 0) +
  (typeOptions.length > 0 ? 1 : 0) +
  (showStatus ? 1 : 0) +
  (Astro.slots.has("secondary-extra") ? 1 : 0);

const secondaryGridClass =
  secondaryFilterCount >= 4
    ? "lg:grid-cols-4"
    : secondaryFilterCount === 3
      ? "lg:grid-cols-3"
      : secondaryFilterCount === 2
        ? "lg:grid-cols-2"
        : "lg:grid-cols-1";
---

<div
  class:list={[
    "w-full actions-search",
    embedded ? "bg-transparent p-0" : "rounded-2xl border border-base-300 bg-base-100 p-3 md:p-4",
  ]}
  data-initial-search={value}
  data-initial-year={initialYear}
  data-initial-type={initialType}
>
  <div class="flex w-full flex-col gap-3">
    <div class:list={["grid w-full grid-cols-1 gap-3", showBeneficiary ? "lg:grid-cols-2" : "lg:grid-cols-1"]}>
      <label class="form-control w-full gap-1">
        <span class="text-sm! font-medium tracking-wide text-base-content">Titre</span>
        <input
          id="search-input"
          class="input input-bordered w-full"
          type="text"
          placeholder="Rechercher par titre..."
        />
      </label>
      {showBeneficiary && (
        <label class="form-control w-full gap-1">
          <span class="text-sm! font-medium tracking-wide text-base-content">Bénéficiaire</span>
          <input
            id="beneficiary-input"
            class="input input-bordered w-full"
            type="text"
            placeholder="Filtre bénéficiaire"
          />
        </label>
      )}
    </div>

    {(yearOptions.length > 0 || typeOptions.length > 0 || showStatus || Astro.slots.has("secondary-extra")) && (
      <div class:list={["grid w-full grid-cols-1 gap-3", secondaryGridClass]}>
        {yearOptions.length > 0 && (
          <div class="w-full">
            <label class="form-control w-full gap-1">
              <span class="text-sm! font-medium tracking-wide text-base-content">Année</span>
              <select id="year-select" class="select select-bordered w-full">
                <option value="">Toutes les années</option>
                {yearOptions.map((y: string) => <option value={y}>{y}</option>)}
              </select>
            </label>
          </div>
        )}
        {typeOptions.length > 0 && (
          <div class="w-full">
            <label class="form-control w-full gap-1">
              <span class="text-sm! font-medium tracking-wide text-base-content">Type</span>
              <select id="type-select" class="select select-bordered w-full">
                <option value="">Tous les types</option>
                {typeOptions.map((t: string) => <option value={t}>{t}</option>)}
              </select>
            </label>
          </div>
        )}
        {showStatus && (
          <div class="w-full">
            <label class="form-control w-full gap-1">
              <span class="text-sm! font-medium tracking-wide text-base-content">Statut</span>
              <select id="status-select" class="select select-bordered w-full">
                {statusOptions.map((s: string) => <option value={s}>{getStatusLabel(s)}</option>)}
              </select>
            </label>
          </div>
        )}
        {Astro.slots.has("secondary-extra") && (
          <div class="w-full">
            <slot name="secondary-extra" />
          </div>
        )}
      </div>
    )}
  </div>

  <div class="mt-3 flex justify-end">
    <button
      type="button"
      class="link link-primary text-sm font-medium"
      data-reset-filters
    >
      Réinitialiser les filtres
    </button>
  </div>
</div>

<script>
  (function() {
    function initOne(root: HTMLElement) {
      if (root.dataset.actionsSearchBound === "true") return;
      root.dataset.actionsSearchBound = "true";
      const searchInput = root.querySelector("#search-input");
      const beneficiaryInput = root.querySelector("#beneficiary-input");
      const yearSelect = root.querySelector('#year-select');
      const typeSelect = root.querySelector('#type-select');
      const statusSelect = root.querySelector('#status-select');
      const sortSelect = root.querySelector('#sort-select');
      const resetButton = root.querySelector('[data-reset-filters]');
      const initialSearch = root.dataset.initialSearch || "";

      if (searchInput instanceof HTMLInputElement) searchInput.value = initialSearch;
      const initialYear = root.dataset.initialYear || "";
      const initialType = root.dataset.initialType || "";
      if (yearSelect instanceof HTMLSelectElement && initialYear) yearSelect.value = initialYear;
      if (typeSelect instanceof HTMLSelectElement && initialType) typeSelect.value = initialType;

      function emit() {
        const detail: any = {
          search: (searchInput instanceof HTMLInputElement) ? searchInput.value.trim() : "",
          beneficiary: (beneficiaryInput instanceof HTMLInputElement) ? beneficiaryInput.value.trim() : "",
        };
        if (yearSelect instanceof HTMLSelectElement) detail.year = yearSelect.value;
        if (typeSelect instanceof HTMLSelectElement) detail.type = typeSelect.value;
        if (statusSelect instanceof HTMLSelectElement) detail.status = statusSelect.value;

        document.dispatchEvent(new CustomEvent("actions-filter-change", { detail, bubbles: true }));
      }

      function resetFilters() {
        if (searchInput instanceof HTMLInputElement) searchInput.value = "";
        if (beneficiaryInput instanceof HTMLInputElement) beneficiaryInput.value = "";
        if (yearSelect instanceof HTMLSelectElement) yearSelect.value = "";
        if (typeSelect instanceof HTMLSelectElement) typeSelect.value = "";
        if (statusSelect instanceof HTMLSelectElement) statusSelect.value = "all";
        if (sortSelect instanceof HTMLSelectElement) {
          sortSelect.selectedIndex = 0;
          sortSelect.dispatchEvent(new Event("change", { bubbles: true }));
        }
        emit();
      }

      if (searchInput instanceof Element) {
        searchInput.addEventListener('input', emit);
        searchInput.addEventListener('change', emit);
      }
      if (beneficiaryInput instanceof Element) {
        beneficiaryInput.addEventListener('input', emit);
        beneficiaryInput.addEventListener('change', emit);
      }
      if (yearSelect instanceof Element) {
        yearSelect.addEventListener('change', emit);
      }
      if (typeSelect instanceof Element) {
        typeSelect.addEventListener('change', emit);
      }
      if (statusSelect instanceof Element) {
        statusSelect.addEventListener('change', emit);
      }

      if (resetButton instanceof HTMLButtonElement) {
        resetButton.addEventListener("click", resetFilters);
      }

      emit();
    }

    function initAll() {
      document.querySelectorAll(".actions-search").forEach((node) => {
        if (node instanceof HTMLElement) {
          initOne(node);
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAll, { once: true });
    } else {
      initAll();
    }

    document.addEventListener("astro:page-load", initAll);
  })();
</script>
