---
const partenairesRaw: any[] = await Astro.locals.pb
  .collection("partenaires")
  .getFullList(200, { sort: "-updated" });

const images = partenairesRaw
  .filter((partenaire) => partenaire?.logo)
  .map((partenaire, index) => ({
    src: Astro.locals.pb.files.getURL(partenaire, partenaire.logo),
    alt: partenaire.nom
      ? `Logo du partenaire ${partenaire.nom}`
      : `Logo du partenaire ${index + 1}`,
  }));

---

<div class="partner-carousel-container overflow-hidden relative w-full h-fit">
  <div class="partner-carousel-track h-full">
    <div class="partner-carousel-group flex items-center gap-10 md:gap-14 lg:gap-20 h-full">
      {images.map((image) => (
        <div class="partner-carousel-item shrink-0 flex w-32 items-center justify-center md:w-40 lg:w-48">
          <img
            src={image.src}
            alt={image.alt}
            loading="lazy"
            fetchpriority="low"
            class="block h-14 w-full object-contain md:h-16 lg:h-20"
           decoding="async" />
        </div>
      ))}
    </div>
    <div class="partner-carousel-group flex items-center gap-10 md:gap-14 lg:gap-20 h-full" aria-hidden="true">
      {images.map((image) => (
        <div class="partner-carousel-item shrink-0 flex w-32 items-center justify-center md:w-40 lg:w-48">
          <img
            src={image.src}
            alt=""
            aria-hidden="true"
            loading="lazy"
            fetchpriority="low"
            class="block h-14 w-full object-contain md:h-16 lg:h-20"
           decoding="async" />
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .partner-carousel-track {
    display: flex;
    width: max-content;
    animation: partner-carousel-marquee 34s linear infinite;
  }

  .partner-carousel-group {
    flex-shrink: 0;
    padding-right: 1.5rem;
  }

  .partner-carousel-track {
    will-change: transform;
  }

  @keyframes partner-carousel-marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .partner-carousel-track {
      animation: none;
      transform: translateX(0);
    }
  }

  @media (min-width: 768px) {
    .partner-carousel-group {
      padding-right: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .partner-carousel-group {
      padding-right: 3rem;
    }
  }
</style>
