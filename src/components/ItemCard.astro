---
import Card from "./Card.astro";
import imageIcon from "../assets/image-icon.svg";

export interface Props {
  id: string;
  title: string;
  slug?: string;
  source: "action" | "brouillon" | "projet" | "produit" | "partenaire" | "contributeur";
  isDraft?: boolean;
  subtitle?: string;
  beneficiary?: string;
  meta?: string;
  formattedDate?: string;
  viewUrl?: string;
  editUrl: string;
  publishButton?: string;
  badge?: string;
  class?: string;
  showCheckbox?: boolean;
  checkboxSlot?: string;
  maxHeightContent?: boolean;
  photoUrl?: string;
  photoClass?: string;
  price?: number;
  deleteMode?: boolean;
  showDeleteButton?: boolean;
  showViewButton?: boolean;
  showPhotoPlaceholder?: boolean;
}

const {
  id,
  title,
  slug,
  source,
  isDraft = false,
  subtitle,
  beneficiary,
  meta,
  formattedDate,
  viewUrl,
  editUrl,
  publishButton,
  badge,
  class: className = "",
  showCheckbox = false,
  checkboxSlot,
  maxHeightContent = true,
  photoUrl,
  photoClass = "",
  price,
  deleteMode = false,
  showDeleteButton = false,
  showViewButton = true,
  showPhotoPlaceholder = false,
} = Astro.props;
---

<Card {id} {slug} {source} {isDraft} class={className} title={title} updated={formattedDate}>
  <div slot="header" class="flex items-start justify-between gap-3">
    <div class="flex items-start gap-3 flex-1">
      {showCheckbox && checkboxSlot ? <div set:html={checkboxSlot} /> : null}
      <h3 class="wrap-break-word text-xl font-bold leading-tight md:text-2xl line-clamp-1">
        {title || "Sans titre"}
      </h3>
    </div>
    {isDraft && (
      <span class="badge badge-secondary text-secondary-content shrink-0">
        Brouillon
      </span>
    )}
    {badge && <span set:html={badge} />}
  </div>

  <div slot="content" class={`space-y-2 ${maxHeightContent ? "max-h-74 overflow-hidden" : ""}`}>
    {photoUrl && (
      <img
        src={photoUrl}
        alt={title}
        class={`w-full rounded-lg bg-white object-contain lg:object-contain object-center px-4 ${photoClass || "h-74"}`}
      />
    )}
    {!photoUrl && showPhotoPlaceholder && (
      <div
        class={`w-full rounded-lg border border-base-300 bg-base-200/40 flex items-center justify-center overflow-hidden ${photoClass || "h-74"}`}
      >
        <img
          src={imageIcon.src}
          alt="Image par défaut"
          class="h-16 w-16 opacity-30"
          loading="lazy"
          decoding="async"
        />
      </div>
    )}
    {price !== undefined && (
      <p class="text-sm font-semibold text-accent">
        {new Intl.NumberFormat("fr-FR", {
          style: "currency",
          currency: "CAD",
        }).format(price)}
      </p>
    )}
    {subtitle && (
      <p class="leading-relaxed wrap-break-word text-sm text-base-content/75 line-clamp-2">
        {subtitle}
      </p>
    )}
    {beneficiary && (
      <p class="leading-relaxed wrap-break-word text-sm text-base-content/75">
        {beneficiary}
      </p>
    )}
    {meta && <div set:html={meta} />}
  </div>

  <div slot="footer" class="flex w-full flex-wrap items-end gap-x-4 gap-y-2 mt-4">
    {formattedDate && (
      <p class="max-w-full whitespace-nowrap text-xs leading-tight text-base-content/60">
        {formattedDate}
      </p>
    )}
    <div class="ml-auto flex shrink-0 gap-2">
      {showDeleteButton && (
        <button
          type="button"
          class="btn btn-sm btn-error rounded-full"
          data-item-delete-btn
          data-item-id={id}
          data-item-edit-url={editUrl}
          data-item-title={title}
        >
          Supprimer
        </button>
      )}
      {deleteMode && (
        <button
          type="button"
          class="btn btn-sm btn-error rounded-full"
          data-item-delete-btn
          data-item-id={id}
        >
          Supprimer
        </button>
      )}
      {!deleteMode && (
        <>
          {showViewButton && viewUrl && (
            <a href={viewUrl} class="btn btn-sm btn-ghost action-btn-text">Voir</a>
          )}
          <a href={editUrl} class="btn btn-sm btn-accent action-btn-text rounded-full">
            Modifier
          </a>
        </>
      )}
      {publishButton && <span set:html={publishButton} />}
    </div>
  </div>
</Card>

<script>
  import { showConfirm } from "../utils/alerts";

  document.addEventListener("click", (event) => {
    const button = (event.target as HTMLElement)?.closest("[data-item-delete-btn]");
    if (!button) return;

    event.preventDefault();
    event.stopPropagation();

    const itemId = button.getAttribute("data-item-id");
    const editUrl = button.getAttribute("data-item-edit-url");
    if (!itemId) return;

    void showConfirm({
      title: "Supprimer",
      message: editUrl
        ? `Supprimer "${button.getAttribute("data-item-title") || "cet élément"}" ?`
        : "Supprimer cet élément ?",
      confirmLabel: "Supprimer",
      cancelLabel: "Annuler",
      type: "warning",
    }).then((confirmed) => {
      if (!confirmed) return;

      if (editUrl) {
        const tempForm = document.createElement("form");
        tempForm.method = "POST";
        tempForm.action = editUrl;
        tempForm.style.display = "none";

        const actionInput = document.createElement("input");
        actionInput.type = "hidden";
        actionInput.name = "_action";
        actionInput.value = "delete";
        tempForm.appendChild(actionInput);

        document.body.appendChild(tempForm);
        tempForm.submit();
        return;
      }

      const tempForm = document.createElement("form");
      tempForm.method = "POST";
      tempForm.style.display = "none";

      const input = document.createElement("input");
      input.type = "hidden";
      input.name = "ids";
      input.value = itemId;

      tempForm.appendChild(input);
      document.body.appendChild(tempForm);
      tempForm.submit();
    });
  });
</script>
