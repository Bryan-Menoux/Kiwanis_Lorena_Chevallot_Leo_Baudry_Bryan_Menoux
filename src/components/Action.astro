---
import { ActionsTypeDeChiffreOptions } from '../pocketbase-types';
---

<form id="actionForm" method="POST" enctype="multipart/form-data" class="w-full max-w-7xl mx-auto mt-32 lg:mt-48 relative px-4 md:px-8">
  <!-- Section titre -->
  <h1 class="uppercase w-full text-3xl md:text-4xl lg:text-5xl outline-none border border-gray-400/40 rounded px-1" data-name="titre">Titre de l'action</h1>
  <input type="hidden" name="titre" />

  <div class="flex flex-col md:flex-row items-start md:items-center mt-4 md:mt-0 w-full justify-between">
    <p class="outline-none border border-gray-400/40 rounded px-1" data-name="sous_titre">Sous-titre</p>
    <input type="hidden" name="sous_titre" />
    <div class="flex gap-4">
      <div class="flex flex-col">
        <label class="text-sm text-gray-600">Date début</label>
        <input
          type="date"
          name="date"
          class="border border-gray-400/40 rounded px-1 bg-transparent outline-none"
        />
      </div>
      <div class="flex flex-col">
        <label class="text-sm text-gray-600">Date fin</label>
        <input
          type="date"
          name="date_fin"
          class="border border-gray-400/40 rounded px-1 bg-transparent outline-none"
        />
      </div>
    </div>
  </div>

  <!-- Section Hero -->
  <div class="flex flex-col items-end my-12 md:my-32">
    <input type="file" name="hero" accept="image/*" class="hidden" id="heroInput" />
    <div class="relative w-full">
      <label for="heroInput" class="cursor-pointer w-full">
        <div class="bg-gray-300 w-full min-h-[50dvh] object-cover object-center rounded-lg flex items-center justify-center text-gray-500 relative group">
          Cliquez pour ajouter l'image hero
        </div>
      </label>
    </div>
    <p class="text-sm md:text-base mt-4 outline-none border border-gray-400/40 rounded px-1" data-name="description_hero">Description de l'image hero</p>
    <input type="hidden" name="description_hero" />
  </div>

  <!-- Section Partie 1 -->
  <div class="flex flex-col max-w-7xl mx-auto my-16 md:my-32 gap-4 px-4 md:px-8">
    <h2 class="text-2xl md:text-3xl outline-none border border-gray-400/40 rounded px-1" data-name="titre_partie_1">Titre partie 1</h2>
    <input type="hidden" name="titre_partie_1" />
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-8 lg:gap-16 min-h-[40dvh]">
      <div class="flex flex-col gap-8">
        <div class="flex flex-col gap-4 outline-none border border-gray-400/40 rounded px-1 py-1 h-full" data-name="texte_partie_1">Texte partie 1</div>
        <input type="hidden" name="texte_partie_1" />
      </div>
      <div class="flex flex-col items-end w-full mx-auto max-h-[50dvh] lg:max-w-full">
        <input type="file" name="photo_partie_1" accept="image/*" class="hidden" id="partie1Input" />
        <div class="relative w-full h-full">
          <label for="partie1Input" class="cursor-pointer w-full h-full">
            <div class="bg-gray-300 w-full h-full flex-1 object-cover rounded-lg flex items-center justify-center text-gray-500 relative group">
              Cliquez pour ajouter la photo partie 1
            </div>
          </label>
        </div>
        <p class="text-sm mt-4 outline-none border border-gray-400/40 rounded px-1" data-name="description_photo_partie_1">Description photo partie 1</p>
        <input type="hidden" name="description_photo_partie_1" />
      </div>
    </div>
  </div>

  <!-- Section Lieu, Chiffres, Bénéficiaires -->
  <div class="flex flex-col lg:flex-row justify-between gap-6 md:gap-8 w-full h-auto mx-auto lg:h-48 my-16 md:my-32 px-4 md:px-0 max-w-7xl">
    <div class="bg-accent text-base-100 w-full max-w-1/3 h-full rounded-2xl px-6 md:px-8 py-4 md:py-6 flex flex-col justify-between min-h-30 md:min-h-48">
      <div class="flex flex-col">
        <input
          type="text"
          name="nom_lieu"
          placeholder="Nom du lieu"
          class="text-lg md:text-xl border border-gray-400/40 rounded px-1 bg-transparent outline-none text-base-100"
        />
        <input
          type="text"
          name="adresse_lieu"
          placeholder="Adresse du lieu"
          class="text-lg md:text-2xl! border border-gray-400/40 rounded px-1 bg-transparent outline-none text-base-100"
        />
        <input
          type="url"
          name="lien_lieu"
          placeholder="Lien Google Maps"
          class="border border-gray-400/40 rounded px-1 bg-transparent outline-none text-base-100"
        />
      </div>
      <div class="flex items-center justify-between w-full">
        <a href="" class="flex items-center gap-2 md:gap-4 text-base md:text-xl!">
          Voir sur Google maps
          <img loading="lazy" src="" aria-hidden="true" />
        </a>
        <p class="text-base md:text-xl!">LIEU</p>
      </div>
    </div>
    <div class="bg-accent text-base-100 w-full max-w-1/3 h-full rounded-2xl px-6 md:px-8 py-4 md:py-6 flex flex-col justify-between min-h-30 md:min-h-48">
      <input
        type="number"
        name="chiffre"
        placeholder="Chiffre"
        class="text-5xl! md:text-7xl! border border-gray-400/40 rounded px-1 bg-transparent outline-none text-base-100"
      />
      <select
        name="type_de_chiffre"
        class="text-base md:text-xl! uppercase self-end border border-gray-400/40 rounded px-1 bg-transparent outline-none text-base-100"
      >
        <option value="">Type de chiffre</option>
        {Object.values(ActionsTypeDeChiffreOptions).map((option) => (
          <option value={option} selected>{option}</option>
        ))}
      </select>
    </div>
    <div class="bg-accent text-base-100 w-full max-w-1/3 h-full rounded-2xl px-6 md:px-8 py-4 md:py-6 flex flex-col justify-between min-h-30 md:min-h-48">
      <input
        type="text"
        name="beneficiaire"
        placeholder="Bénéficiaire"
        class="text-lg md:text-xl border border-gray-400/40 rounded px-1 bg-transparent outline-none text-base-100"
      />
      <p class="text-base md:text-xl! uppercase self-end">bénéficiaires</p>
    </div>
  </div>

  <!-- Section Partie 2 -->
  <div class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-6 md:gap-8 lg:gap-16 min-h-[40dvh] my-16 md:my-32 px-4 md:px-0">
    <div class="flex flex-col gap-8">
      <h2 class="uppercase font-light! text-2xl md:text-3xl outline-none border border-gray-400/40 rounded px-1" data-name="titre_partie_2">Titre partie 2</h2>
      <input type="hidden" name="titre_partie_2" />
      <div class="flex flex-col gap-4 outline-none border border-gray-400/40 rounded px-1 py-1 h-full" data-name="texte_partie_2">Texte partie 2</div>
      <input type="hidden" name="texte_partie_2" />
    </div>
    <div class="flex flex-col items-end w-full mx-auto max-h-[50dvh] lg:max-w-full">
      <input type="file" name="photo_partie_2" accept="image/*" class="hidden" id="partie2Input" />
      <div class="relative w-full h-full">
        <label for="partie2Input" class="cursor-pointer w-full h-full">
          <div class="bg-gray-300 w-full h-full flex-1 object-cover rounded-lg flex items-center justify-center text-gray-500 relative group">
            Cliquez pour ajouter la photo partie 2
          </div>
        </label>
      </div>
      <p class="text-sm mt-4 outline-none border border-gray-400/40 rounded px-1" data-name="description_photo_partie_2">Description photo partie 2</p>
      <input type="hidden" name="description_photo_partie_2" />
    </div>
  </div>

  <!-- Section Partie 3 -->
  <div class="flex flex-col-reverse lg:grid lg:grid-cols-[1fr_1fr] gap-6 md:gap-8 lg:gap-16 min-h-[40dvh] mt-16 mb-16 md:mt-16 md:mb-32 px-4 md:px-0">
    <div class="flex flex-col w-full mx-auto max-h-[50dvh] lg:max-w-full">
      <input type="file" name="photo_partie_3" accept="image/*" class="hidden" id="partie3Input" />
      <div class="relative w-full h-full">
        <label for="partie3Input" class="cursor-pointer w-full h-full">
          <div class="bg-gray-300 w-full h-full flex-1 object-cover rounded-lg flex items-center justify-center text-gray-500 relative group">
            Cliquez pour ajouter la photo partie 3
          </div>
        </label>
      </div>
      <p class="text-sm mt-4 self-end lg:self-auto outline-none border border-gray-400/40 rounded px-1" data-name="description_photo_partie_3">Description photo partie 3</p>
      <input type="hidden" name="description_photo_partie_3" />
    </div>
    <div class="flex flex-col gap-8">
      <h2 class="uppercase font-light! text-2xl md:text-3xl outline-none border border-gray-400/40 rounded px-1" data-name="titre_partie_3">Titre partie 3</h2>
      <input type="hidden" name="titre_partie_3" />
      <div class="flex flex-col gap-4 outline-none border border-gray-400/40 rounded px-1 py-1 h-full" data-name="texte_partie_3">Texte partie 3</div>
      <input type="hidden" name="texte_partie_3" />
    </div>
  </div>

  <!-- Section Remerciements -->
  <div class="flex flex-col max-w-full md:max-w-1/2 px-4 md:px-0 gap-4 md:gap-8 my-16 md:my-32">
    <h2 class="uppercase font-light! text-2xl md:text-3xl outline-none border border-gray-400/40 rounded px-1" data-name="titre_remerciement">Titre remerciements</h2>
    <input type="hidden" name="titre_remerciements" />
    <div class="flex flex-col gap-4 outline-none border border-gray-400/40 rounded px-1 py-1" data-name="description_remerciement">Description remerciements</div>
    <input type="hidden" name="description_remerciements" />
  </div>

  <!-- Section Galerie Photo -->
  <div class="flex flex-col gap-6 md:gap-8 my-16 md:my-32 px-4 md:px-0">
    <div class="bg-accent text-base-100 uppercase w-full h-fit rounded-box">
      <h2 class="text-2xl md:text-3xl! px-6 md:px-8 py-4 md:py-6">Galerie photo</h2>
    </div>
    <!-- Container pour les images de la galerie -->
    <div id="galleryImages" class="hidden gap-4">
      <div id="photoGrid" class="grid gap-4 min-h-[80dvh]" data-photo-count="0"></div>
    </div>
    <!-- Zone de drop toujours visible -->
    <input type="file" name="galerie_photos" accept="image/*" multiple class="hidden" id="galleryInput" />
    <label for="galleryInput" class="cursor-pointer w-full">
      <div class="h-[30dvh] md:h-[20dvh] rounded-box bg-gray-300 flex items-center justify-center text-gray-500 border-2 border-dashed border-gray-400 hover:border-accent transition-colors">
        Cliquez pour ajouter des photos à la galerie
      </div>
    </label>
  </div>

  <!-- Bouton de soumission -->
  <div class="flex justify-center my-16">
    <button type="submit" class="bg-accent text-base-100 px-8 py-4 rounded-lg uppercase">
      Créer l'action
    </button>
  </div>
</form>

<script>
  import { showAlert } from "../utils/alerts";
  document.addEventListener('DOMContentLoaded', () => {
    //Synchronisation des éléments contenteditable avec les inputs cachés correspondants
    Array.from(document.querySelectorAll('[contenteditable="true"]')).forEach((el) => {
      const htmlEl = el as HTMLElement;
      const name = htmlEl.dataset?.name;
      if (!name) return;
      const hidden = document.querySelector(`input[name="${name}"]`) as HTMLInputElement | null;
      if (hidden) {
        htmlEl.addEventListener('input', () => {
          hidden.value = htmlEl.textContent?.trim() || '';
        });
        // Synchroniser initialement le contenu des éléments contenteditable avec les inputs cachés
        hidden.value = htmlEl.textContent?.trim() || '';
      }
    });

    // Aperçu de l'image pour les inputs de type file
    Array.from(document.querySelectorAll('input[type="file"]')).forEach((input) => {
      input.addEventListener('change', (e) => {
        const fileInput = e.target as HTMLInputElement | null;
        if (!fileInput) return;
        const file = fileInput.files?.[0] ?? null;
        if (file && !fileInput.multiple) {
          const reader = new FileReader();
          reader.onload = (ev) => {
            const label = fileInput.parentElement as HTMLElement | null;
            const div = label ? label.querySelector('div') as HTMLElement | null : null;
            if (div) {
              div.style.backgroundImage = `url(${(ev.target as FileReader).result})`;
              div.style.backgroundSize = 'cover';
              div.style.backgroundPosition = 'center';
              div.textContent = '';
              div.style.border = '2px solid #ccc';
            }
          };
          reader.readAsDataURL(file);
        } else if (fileInput.multiple && fileInput.id === 'galleryInput') {
          // Gestion de la galerie - minimal et rapide : createObjectURL + DocumentFragment + decode
          let files = fileInput.files ? Array.from(fileInput.files) as File[] : [];
          if (!files || files.length === 0) return;

          // Limiter à 8 images au total
          const galleryImages = document.getElementById('galleryImages');
          const photoGrid = document.getElementById('photoGrid');
          if (!photoGrid) return;
          const existingCount = parseInt(photoGrid.dataset.photoCount || '0');
          const MAX_IMAGES = 8;
          const remaining = MAX_IMAGES - existingCount;
          if (remaining <= 0) {
            showAlert({
              type: "warning",
              message: "Vous avez déjà atteint la limite de 8 images pour la galerie.",
            });
            return;
          }
          if (files.length > remaining) {
            files = files.slice(0, remaining);
            showAlert({
              type: "warning",
              message: `Seules ${remaining} image(s) ont été ajoutées. La galerie est limitée à ${MAX_IMAGES} images au total.`,
            });
          }

          if (galleryImages) {
            galleryImages.classList.remove('hidden');
            galleryImages.classList.add('flex', 'flex-col');
          }

          const createdUrls: string[] = [];
          const frag = document.createDocumentFragment();
          files.forEach((file: File) => {
            const url = URL.createObjectURL(file);
            createdUrls.push(url);
            const div = document.createElement('div');
            div.className = 'relative w-full h-full overflow-hidden rounded-box cursor-pointer';
            div.setAttribute('data-photo-url', url);
            const img = document.createElement('img');
            img.alt = 'Photo de la galerie';
            img.className = 'absolute inset-0 w-full h-full object-center object-cover';
            img.src = url;
            div.appendChild(img);
            frag.appendChild(div);
          });

          photoGrid.appendChild(frag);
          // mettre à jour le compteur
          const existing = parseInt(photoGrid.dataset.photoCount || '0');
          photoGrid.dataset.photoCount = String(existing + files.length);

          // attendre que toutes les images du grid soient décodées, puis appliquer les styles et révéler
          const imgs = Array.from(photoGrid.querySelectorAll('img')) as HTMLImageElement[];
          Promise.all(imgs.map((i) => i.decode().catch(() => {}))).then(() => {
            if (typeof window !== 'undefined' && typeof window.setGridStyles === 'function') {
              try { window.setGridStyles(); } catch (e) {}
            }
            photoGrid.classList.remove('opacity-0');
            // révoquer uniquement les object URLs créées
            createdUrls.forEach((u) => URL.revokeObjectURL(u));
          });
        }
      });
    });

    // Initialiser les styles de la grille
    const grid = document.getElementById('photoGrid');
    if (grid) {
      window.addEventListener('resize', () => {
        if (typeof window.setGridStyles === 'function') {
          try { window.setGridStyles(); } catch (e) {}
        }
      });
    }
  });


</script>

