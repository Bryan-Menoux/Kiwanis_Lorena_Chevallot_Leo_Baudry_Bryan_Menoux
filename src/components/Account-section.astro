---
import { splitUserName } from "../utils/utilitaires.js";

interface Props {
  success?: boolean;
}

const { success = false } = Astro.props;

let user = Astro.locals.pb.authStore.record;
const isAdmin = user?.administrateur === true;

const { firstName, lastName } = splitUserName(user!.name);
---

<div
  class="min-h-screen mt-24 lg: from-base-100 via-base-100 to-base-200 py-8 px-4 md:px-8 pt-4 md:pt-12"
>
  <div class="max-w-3xl mx-auto">
    <!-- En-tête de la section compte -->
    <div class="mb-12 text-center">
      <h1
        class="text-4xl md:text-5xl lg:text-7xl font-bold title font-merriweather mb-4"
      >
        Mon Compte
      </h1>
      <p class="text-base-content/60 text-lg">
        Mettez à jour vos informations personnelles
      </p>
    </div>

    <!-- Carte principale contenant le formulaire -->
    <div class="bg-white rounded-2xl shadow-2xl overflow-hidden">
      <!-- Formulaire de mise à jour du profil -->
      <form method="post" id="profileForm" class="px-8 py-8 space-y-8">
        <!-- Flag pour le succès -->
        <div
          id="success-flag"
          data-success={success ? "true" : "false"}
          class="hidden"
        >
        </div>

        <!-- Section des informations personnelles -->
        <div>
          <h3 class="text-lg font-bold text-base-content mb-6">
            Informations personnelles
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Champ prénom -->
            <div class="form-control w-full">
              <label class="label pb-2">
                <span class="label-text font-semibold text-base-content"
                  >Prénom</span
                >
              </label>
              <input
                type="text"
                id="firstName"
                name="firstName"
                class="input input-bordered w-full"
                placeholder="Votre prénom"
                value={firstName || ""}
                required
              />
            </div>

            <!-- Champ nom -->
            <div class="form-control w-full">
              <label class="label pb-2">
                <span class="label-text font-semibold text-base-content"
                  >Nom</span
                >
              </label>
              <input
                type="text"
                id="lastName"
                name="lastName"
                class="input input-bordered w-full"
                placeholder="Votre nom"
                value={lastName || ""}
              />
            </div>
          </div>

          <!-- Champ email -->
          <div class="form-control w-full mt-6">
            <label class="label pb-2">
              <span class="label-text font-semibold text-base-content"
                >Adresse e-mail</span
              >
            </label>
            <input
              type="email"
              id="email"
              name="email"
              class={`input input-bordered w-full ${!isAdmin ? "bg-base-200" : ""}`}
              placeholder="votre.email@exemple.com"
              value={user?.email || ""}
              disabled={!isAdmin}
            />
            {
              !isAdmin && (
                <p class="text-sm text-base-content/60 mt-2">
                  Seul un administrateur peut modifier votre adresse e-mail.
                  Veuillez contacter un administrateur.
                </p>
              )
            }
          </div>
        </div>

        <!-- Section du mot de passe -->
        <div>
          <h3 class="text-lg font-bold text-base-content mb-6">Mot de passe</h3>
          <p class="text-base-content/60 text-sm mb-6">
            Laissez vide pour ne pas changer votre mot de passe.
          </p>
          <div class="space-y-6">
            <!-- Champ ancien mot de passe -->
            <div class="form-control w-full">
              <label class="label pb-2">
                <span class="label-text font-semibold text-base-content"
                  >Ancien mot de passe</span
                >
              </label>
              <input
                type="password"
                id="oldPassword"
                name="oldPassword"
                class="input input-bordered w-full"
                placeholder="Minimum 8 caractères"
              />
            </div>
            <!-- Champ nouveau mot de passe -->
            <div class="form-control w-full">
              <label class="label pb-2">
                <span class="label-text font-semibold text-base-content"
                  >Nouveau mot de passe</span
                >
              </label>
              <input
                type="password"
                id="newPassword"
                name="newPassword"
                class="input input-bordered w-full"
                placeholder="Minimum 8 caractères"
              />
            </div>

            <!-- Champ confirmation mot de passe -->
            <div class="form-control w-full">
              <label class="label pb-2">
                <span class="label-text font-semibold text-base-content"
                  >Confirmer le mot de passe</span
                >
              </label>
              <input
                type="password"
                id="newPasswordConfirm"
                name="newPasswordConfirm"
                class="input input-bordered w-full"
                placeholder="Confirmez votre mot de passe"
              />
            </div>
          </div>
        </div>

        <!-- Section des actions du formulaire -->
        <div class="flex flex-row gap-4 pt-8 border-t border-base-300">
          <a href="/" class="btn btn-outline btn-lg rounded-full min-h-full">
            Retour
          </a>
          <button
            type="submit"
            class="btn btn-accent btn-lg flex-1 rounded-full gap-2 min-h-full"
          >
            <span id="submitText">Enregistrer</span>
            <span
              id="loadingSpinner"
              class="loading loading-spinner loading-sm hidden"></span>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  import { showAlert } from "../utils/alerts";

  const flag = document.getElementById("success-flag");
  const profileForm = document.getElementById("profileForm");
  const submitBtn = profileForm?.querySelector(
    'button[type="submit"]',
  ) as HTMLButtonElement;
  const submitText = document.getElementById("submitText");
  const loadingSpinner = document.getElementById("loadingSpinner");

  function showSuccess(
    message = "OK Vos modifications ont bien été enregistrées.",
  ) {
    showAlert({
      message,
      type: "success",
    });
  }

  function showError(message: string) {
    showAlert({
      message,
      type: "error",
    });
  }

  // Afficher le succès du rechargement si présent
  if (flag) {
    const success = flag.dataset.success === "true";
    if (success) {
      showSuccess();
    }
  }

  // Intercepter la soumission du formulaire
  if (profileForm) {
    (profileForm as HTMLFormElement).addEventListener(
      "submit",
      async (e: Event) => {
        e.preventDefault();

        if (!submitBtn || !loadingSpinner || !submitText) return;

        // Récupérer les données du formulaire
        const formData = new FormData(profileForm as HTMLFormElement);
        const firstName = (formData.get("firstName") as string) || "";
        const lastName = (formData.get("lastName") as string) || "";
        const email = (formData.get("email") as string) || "";
        const oldPassword = (formData.get("oldPassword") as string) || "";
        const newPassword = (formData.get("newPassword") as string) || "";
        const newPasswordConfirm =
          (formData.get("newPasswordConfirm") as string) || "";

        // Validation simple
        if (!firstName.trim()) {
          showError("Le prénom est requis");
          return;
        }

        // Affichage optimiste immédiat
        const displayFirstName = document.querySelector(
          `input[name="firstName"]`,
        ) as HTMLInputElement;
        const displayLastName = document.querySelector(
          `input[name="lastName"]`,
        ) as HTMLInputElement;
        const displayEmail = document.querySelector(
          `input[name="email"]`,
        ) as HTMLInputElement;

        // État avant optimistic update (pour rollback si erreur)
        const oldFirstName = displayFirstName?.value;
        const oldLastName = displayLastName?.value;
        const oldEmail = displayEmail?.value;

        // Optimistic UI: afficher immédiatement
        submitBtn.disabled = true;
        submitText.textContent = "Enregistrement...";
        loadingSpinner.classList.remove("hidden");

        try {
          const response = await fetch("/api/form-submit", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-Requested-With": "XMLHttpRequest",
            },
            body: JSON.stringify({
              formType: "profile",
              firstName,
              lastName,
              email,
              oldPassword,
              newPassword,
              newPasswordConfirm,
            }),
          });

          const result = await response.json();

          if (response.ok && result.success) {
            // Mettre à jour les champs avec les données retournées
            if (displayFirstName) displayFirstName.value = firstName;
            if (displayLastName) displayLastName.value = lastName;
            if (displayEmail) displayEmail.value = result.email;

            // Réinitialiser les champs de mot de passe
            const oldPasswordInput = profileForm.querySelector(
              `input[name="oldPassword"]`,
            ) as HTMLInputElement;
            const newPasswordInput = profileForm.querySelector(
              `input[name="newPassword"]`,
            ) as HTMLInputElement;
            const confirmPasswordInput = profileForm.querySelector(
              `input[name="newPasswordConfirm"]`,
            ) as HTMLInputElement;

            if (oldPasswordInput) oldPasswordInput.value = "";
            if (newPasswordInput) newPasswordInput.value = "";
            if (confirmPasswordInput) confirmPasswordInput.value = "";

            // Si déconnexion requise (changement d'email ou mot de passe), rediriger vers connexion
            if (result.logout) {
              showSuccess(
                "OK Profil mis à jour. Veuillez vous reconnecter avec vos nouvelles informations.",
              );
              setTimeout(() => {
                window.location.href = "/connexion";
              }, 2000);
            } else {
              showSuccess(
                result.message ||
                  "OK Vos modifications ont bien été enregistrées.",
              );
            }
          } else {
            // Rollback si erreur
            if (displayFirstName) displayFirstName.value = oldFirstName!;
            if (displayLastName) displayLastName.value = oldLastName!;
            if (displayEmail) displayEmail.value = oldEmail!;

            showError(
              result.error || "Erreur lors de la mise à jour",
            );
          }
        } catch (error) {
          // Rollback en cas d'erreur réseau
          if (displayFirstName) displayFirstName.value = oldFirstName!;
          if (displayLastName) displayLastName.value = oldLastName!;
          if (displayEmail) displayEmail.value = oldEmail!;

          showError("Erreur de connexion au serveur");
        } finally {
          submitBtn.disabled = false;
          submitText.textContent = "Enregistrer";
          loadingSpinner.classList.add("hidden");
        }
      },
    );
  }
</script>

