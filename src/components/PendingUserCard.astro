---
import circleCheck from "../assets/circle-check.svg";
import crossCircle from "../assets/cross-circle.svg";

type User = {
  id: string;
  name?: string;
  email: string;
  created: string;
  verified: boolean;
  rejected?: boolean;
  rejectionDate?: string;
};

const user = Astro.props.user as any as User;
---

<div
  class="bg-base-100 rounded-xl p-6 border border-base-300 transition-all duration-300"
  data-user-id={user.id}
  data-list-type="pending"
>
  <div class="flex justify-between gap-4">
    <div>
      <h3 class="text-lg font-semibold">
        {user.name ?? "Nom non spécifié"}
      </h3>
      <p class="text-base-content/70">{user.email}</p>
      <p class="text-sm text-base-content/50">
        Inscrit le{" "}
        {new Date(user.created).toLocaleDateString("fr-FR")}
      </p>
    </div>

    <div class="flex gap-3 action-buttons">
      <button
        class="btn btn-success btn-sm verify-action"
        data-user-id={user.id}
        data-action="approve"
        data-list-type="pending"
        type="button"
      >
        <img src={circleCheck.src} class="w-5 h-5 invert" />
        Approuver
      </button>

      <button
        class="btn btn-error btn-sm verify-action"
        data-user-id={user.id}
        data-action="reject"
        data-list-type="pending"
        type="button"
      >
        <img src={crossCircle.src} class="w-5 h-5 invert" />
        Rejeter
      </button>
    </div>
  </div>
</div>