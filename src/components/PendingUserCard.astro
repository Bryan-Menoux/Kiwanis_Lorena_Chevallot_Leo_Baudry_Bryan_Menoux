---
import circleCheck from "../assets/circle-check.svg";
import crossCircle from "../assets/cross-circle.svg";

type User = {
  id: string;
  name?: string;
  email: string;
  created: string;
  verified: boolean;
  rejected?: boolean;
  rejectionDate?: string;
};

const user = Astro.props.user as any as User;
---

<div
  class="bg-base-100 rounded-xl p-6 border border-base-300"
  data-user-id={user.id}
  data-list-type="pending"
>
  <div class="flex justify-between gap-4">
    <div>
      <h3 class="text-lg font-semibold">
        {user.name ?? "Nom non spécifié"}
      </h3>
      <p class="text-base-content/70">{user.email}</p>
      <p class="text-sm text-base-content/50">
        Inscrit le{" "}
        {new Date(user.created).toLocaleDateString("fr-FR")}
      </p>
    </div>

    <div class="flex gap-3">
      <form method="post">
        <input type="hidden" name="formSource" value="verification" />
        <input type="hidden" name="userId" value={user.id} />
        <input type="hidden" name="userName" value={user.name ?? "Nom non spécifié"} />
        <input type="hidden" name="userEmail" value={user.email} />
        <input type="hidden" name="userCreated" value={user.created} />
        <input type="hidden" name="action" value="approve" />
        <input type="hidden" name="listType" value="pending" />
        <button
          class="btn btn-success btn-sm verify-action"
          data-user-id={user.id}
          data-action="approve"
          data-list="pending"
          type="submit"
          name="submitAction"
          value="approve"
        >
          <img src={circleCheck.src} class="w-5 h-5 invert" />
          Approuver
        </button>
      </form>

      <form method="post">
        <input type="hidden" name="formSource" value="verification" />
        <input type="hidden" name="userId" value={user.id} />
        <input type="hidden" name="userName" value={user.name ?? "Nom non spécifié"} />
        <input type="hidden" name="userEmail" value={user.email} />
        <input type="hidden" name="userCreated" value={user.created} />
        <input type="hidden" name="action" value="reject" />
        <input type="hidden" name="listType" value="pending" />
        <button
          class="btn btn-error btn-sm verify-action"
          data-user-id={user.id}
          data-action="reject"
          data-list="pending"
          type="submit"
          name="submitAction"
          value="reject"
        >
          <img src={crossCircle.src} class="w-5 h-5 invert" />
          Rejeter
        </button>
      </form>
    </div>
  </div>
</div>