---
import { Image } from "astro:assets";
import circleCheck from "../assets/circle-check.svg";
import crossCircle from "../assets/cross-circle.svg";
import { formatDateShort } from "../utils/utilitaires.js";

type User = {
  id: string;
  name?: string;
  email: string;
  created: string;
  verified: boolean;
  rejected?: boolean;
  rejectionDate?: string;
};

const user = Astro.props.user as any as User;
---

<div
  class="flex w-full flex-col md:flex-row md:items-start md:justify-between gap-4 p-6 bg-base-100 rounded-xl border border-base-300 transition-all duration-300"
  data-user-id={user.id}
  data-list-type="pending"
>
  <div class="flex-1 min-w-0">
    <div>
      <h3 class="text-lg font-semibold">
        {user.name ?? "Nom non spécifié"}
      </h3>
      <p class="text-base-content/70 break-all">{user.email}</p>
      <p class="text-sm text-base-content/50">
        Inscrit le{" "}
        {formatDateShort(user.created)}
      </p>
    </div>
  </div>

  <div class="flex w-full md:w-auto flex-wrap gap-3 action-buttons justify-end md:ml-auto md:shrink-0">
    <button
      class="btn btn-error btn-sm verify-action flex gap-4 items-center w-full md:w-fit flex-1"
      data-user-id={user.id}
      data-action="reject"
      data-list-type="pending"
      type="button"
    >
      <Image src={crossCircle} alt="" loading="lazy" quality={80} class="w-5 h-5 invert" />
      Rejeter
    </button>
    <button
      class="btn btn-success btn-sm verify-action flex gap-4 items-center w-full md:w-fit flex-1"
      data-user-id={user.id}
      data-action="approve"
      data-list-type="pending"
      type="button"
    >
      <Image src={circleCheck} alt="" loading="lazy" quality={80} class="w-5 h-5 invert" />
      Approuver
    </button>
  </div>
</div>
