---
import edit from "../assets/edit.svg";
const user = Astro.props.user;
const isAdmin = Astro.props.isAdmin;

---

<div class="user-card flex flex-col md:flex-row md:items-center justify-between p-4 bg-base-200 rounded-lg shadow-md transition-all duration-300" data-user-id={user?.id} data-admin={user?.administrateur ? 'true' : 'false'}>
  <div class="flex items-center gap-4">
    <div>
      <h3 class="text-lg font-bold">{user?.name || 'N/A'}</h3>
      <p class="text-sm text-gray-500">{user?.email || 'N/A'}</p>
    </div>
  </div>
  {isAdmin && <button class="modify-btn btn btn-sm btn-primary mt-4 md:mt-0 w-full md:w-auto flex items-center" type="button">
    <img src={edit.src} aria-hidden="true" class="w-4 h-4 mr-2" style="filter: brightness(0) invert(1);" />
    Modifier</button>}
</div>
