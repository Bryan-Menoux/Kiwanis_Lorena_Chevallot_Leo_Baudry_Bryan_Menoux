---
import type { ImageMetadata } from 'astro';

const imageModules = import.meta.glob<{ default: ImageMetadata }>('/src/assets/home-carousel/*.webp', { eager: true });

const images = Object.entries(imageModules).map(([path, module], index) => ({
  src: module.default.src,
  alt: `Image du carousel Kiwanis numéro ${index + 1}`
}));

const duplicatedImages = [...images, ...images];
---

<div class="home-carousel-container overflow-x-auto relative w-full h-fit">
  <div class="home-carousel-inner flex gap-4 md:gap-8 h-full">
    {duplicatedImages.map((image, index) => (
      <img
        src={image.src}
        alt={image.alt}
        class="shrink-0 w-80 md:w-1/2 lg:w-1/4 h-full object-cover rounded-box"
      />
    ))}
  </div>
</div>

<style>
  .home-carousel-container {
    /* Permettre le scroll horizontal mais cacher la scrollbar */
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE et Edge */
  }
  
  /* Cacher la scrollbar sur Webkit (Chrome, Safari, Edge) */
  .home-carousel-container::-webkit-scrollbar {
    height: 0;
    width: 0;
    display: none;
  }
  
  .home-carousel-inner {
    will-change: transform;
  }
</style>

<script>
  // Rendre le défilement infini plus fluide, sans à-coups.
  const carousel = document.querySelector('.home-carousel-inner') as HTMLElement;
  const container = document.querySelector('.home-carousel-container') as HTMLElement;

  // Empêche le scroll horizontal via la molette ou le touch, mais permet au script de faire défiler
  if (container) {
    container.addEventListener('wheel', (e) => {
      // Empêche le scroll horizontal mais permet au script de faire défiler
      if (Math.abs(e.deltaX) > Math.abs(e.deltaY)) {
        e.preventDefault();
      }
    }, { passive: false });

    container.addEventListener('touchmove', (e) => {
      // Empêche le scroll tactile mais permet au script de faire défiler
      e.preventDefault();
    }, { passive: false });
  }

  if (carousel) {
    let startTime: number | null = null;
    let position = 0;
    const speed = 50; // pixels par seconde

    function animate(currentTime: number) {
      if (startTime === null) {
        startTime = currentTime;
      }
      const delta = (currentTime - startTime) * speed / 1000;
      position -= delta;
      startTime = currentTime;
      if (position <= -(carousel.scrollWidth / 2)) {
        position += carousel.scrollWidth / 2;
      }
      carousel.style.transform = `translateX(${position}px)`;
      requestAnimationFrame(animate);
    }
    requestAnimationFrame(animate);
  }
</script>
