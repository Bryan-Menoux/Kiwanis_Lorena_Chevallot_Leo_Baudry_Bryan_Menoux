---
import { getImage } from "astro:assets";

import type { ImageMetadata } from "astro";

const imageModules = import.meta.glob<{ default: ImageMetadata }>("/src/assets/home-carousel/*.webp", { eager: true });
const MAX_VISIBLE_IMAGES = 4;

const images = await Promise.all(
  Object.entries(imageModules)
    .sort(([pathA], [pathB]) => pathA.localeCompare(pathB))
    .slice(0, MAX_VISIBLE_IMAGES)
    .map(async ([, module], index) => {
      const srcSm = await getImage({ src: module.default, width: 320, format: "webp" });
      const src = await getImage({ src: module.default, width: 500, format: "webp" });
      return {
        src,
        srcSm,
        alt: `Image du carousel Kiwanis numero ${index + 1}`,
      };
    }),
);
---

<div class="home-carousel-container relative w-full h-fit">
  <div class="home-carousel-track h-full">
    <div class="home-carousel-group flex gap-4 md:gap-8 h-full">
      {images.map((image) => (
        <div class="home-carousel-item shrink-0 w-72 md:w-80 lg:w-104">
          <img
            src={image.src.src}
            srcset={`${image.srcSm.src} 320w, ${image.src.src} 500w`}
            sizes="(min-width: 1024px) 416px, (min-width: 768px) 320px, 288px"
            alt={image.alt}
            width={image.src.attributes.width}
            height={image.src.attributes.height}
            loading="lazy"
            fetchpriority="low"
            class="block h-56 w-full object-cover rounded-box md:h-64 lg:h-76"
           decoding="async" />
        </div>
      ))}
    </div>
    <div class="home-carousel-group flex gap-4 md:gap-8 h-full" aria-hidden="true">
      {images.map((image) => (
        <div class="home-carousel-item shrink-0 w-72 md:w-80 lg:w-104">
          <img
            src={image.src.src}
            srcset={`${image.srcSm.src} 320w, ${image.src.src} 500w`}
            sizes="(min-width: 1024px) 416px, (min-width: 768px) 320px, 288px"
            alt=""
            aria-hidden="true"
            width={image.src.attributes.width}
            height={image.src.attributes.height}
            loading="lazy"
            fetchpriority="low"
            class="block h-56 w-full object-cover rounded-box md:h-64 lg:h-76"
           decoding="async" />
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .home-carousel-container {
    overflow-x: hidden;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-y;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .home-carousel-container::-webkit-scrollbar {
    height: 0;
    width: 0;
    display: none;
  }

  .home-carousel-track {
    display: flex;
    width: max-content;
    animation: home-carousel-marquee 38s linear infinite;
  }

  .home-carousel-group {
    flex-shrink: 0;
    padding-right: 1.5rem;
  }

  .home-carousel-track {
    will-change: transform;
  }

  @keyframes home-carousel-marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-carousel-track {
      animation: none;
      transform: translateX(0);
    }
  }

  @media (min-width: 768px) {
    .home-carousel-group {
      padding-right: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .home-carousel-group {
      padding-right: 3rem;
    }
  }
</style>
