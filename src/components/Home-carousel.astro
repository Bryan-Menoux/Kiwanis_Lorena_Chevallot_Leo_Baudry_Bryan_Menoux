---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

const imageModules = import.meta.glob<{ default: ImageMetadata }>('/src/assets/home-carousel/*.webp', { eager: true });

const images = Object.entries(imageModules).map(([path, module], index) => ({
  src: module.default,
  alt: `Image du carousel Kiwanis numéro ${index + 1}`,
}));

---

<div class="home-carousel-container relative w-full h-fit">
  <div class="home-carousel-track h-full">
    <div class="home-carousel-group flex gap-4 md:gap-8 h-full">
      {images.map((image) => (
        <div class="home-carousel-item shrink-0 w-72 md:w-80 lg:w-[26rem]">
          <Image
            src={image.src}
            alt={image.alt}
            layout="constrained"
            fit="cover"
            sizes="(min-width: 1024px) 26rem, (min-width: 768px) 20rem, 18rem"
            quality={80}
            loading="lazy"
            class="block h-56 w-full object-cover rounded-box md:h-64 lg:h-[19rem]"
          />
        </div>
      ))}
    </div>
    <div class="home-carousel-group flex gap-4 md:gap-8 h-full" aria-hidden="true">
      {images.map((image) => (
        <div class="home-carousel-item shrink-0 w-72 md:w-80 lg:w-[26rem]">
          <Image
            src={image.src}
            alt=""
            aria-hidden="true"
            layout="constrained"
            fit="cover"
            sizes="(min-width: 1024px) 26rem, (min-width: 768px) 20rem, 18rem"
            quality={80}
            loading="lazy"
            class="block h-56 w-full object-cover rounded-box md:h-64 lg:h-[19rem]"
          />
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .home-carousel-container {
    overflow-x: hidden;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-y;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .home-carousel-container::-webkit-scrollbar {
    height: 0;
    width: 0;
    display: none;
  }

  .home-carousel-track {
    display: flex;
    width: max-content;
    animation: home-carousel-marquee 38s linear infinite;
  }

  .home-carousel-group {
    flex-shrink: 0;
    padding-right: 1.5rem;
  }

  .home-carousel-track {
    will-change: transform;
  }

  @keyframes home-carousel-marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-carousel-track {
      animation: none;
      transform: translateX(0);
    }
  }

  @media (min-width: 768px) {
    .home-carousel-group {
      padding-right: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .home-carousel-group {
      padding-right: 3rem;
    }
  }
</style>
