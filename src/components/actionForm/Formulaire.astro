---
import SectionMainInfo from "./sections/SectionMainInfo.astro";
import SectionPart from "./sections/SectionPart.astro";
import SectionLocation from "./sections/SectionLocation.astro";
import SectionThanks from "./sections/SectionThanks.astro";
import SectionGallery from "./sections/SectionGallery.astro";

import imageIcon from "../../assets/image-icon.svg";
import previewDefaults from "../../scripts/previewDefaults.js";

export interface Props {
  mode?: string;
  previewPlaceholder: any;
  previewData?: any;
  typeDeChiffreOptions?: string[];
  typeActionOptions?: string[];
  imageIcon?: any;
  actionRecord?: any;
  error?: string;
}

const {
  mode = "create",
  previewPlaceholder,
  previewData,
  typeDeChiffreOptions: typeDeChiffreOptionsProp,
  typeActionOptions: typeActionOptionsProp = [],
  imageIcon: imageIconProp,
  actionRecord,
  error = "",
} = Astro.props;

const typeDeChiffreOptions = typeDeChiffreOptionsProp || [
  "type de chiffre",
  "dépenses",
  "récoltes",
];

const placeholders = {
  ...previewDefaults,
  ...(previewPlaceholder || {}),
};
---

<form
  id="leftForm"
  class="space-y-8 text-accent"
  method="POST"
  enctype="multipart/form-data"
>
  <h1 class="text-4xl! font-bold mb-8 mt-24 text-white">
    Créer une nouvelle action
  </h1>
  {error && <p class="text-red-300 mb-2">{error}</p>}

  <SectionMainInfo
    mode={mode}
    previewData={previewData}
    placeholders={placeholders}
    imageIcon={imageIcon}
    typeActionOptions={typeActionOptionsProp}
  />

  <SectionPart
    partNumber={1}
    mode={mode}
    previewData={previewData}
    placeholders={placeholders}
    imageIcon={imageIcon}
  />

  <SectionLocation
    mode={mode}
    previewData={previewData}
    placeholders={placeholders}
    typeDeChiffreOptions={typeDeChiffreOptions}
  />

  <SectionPart
    partNumber={2}
    mode={mode}
    previewData={previewData}
    placeholders={placeholders}
    imageIcon={imageIcon}
  />

  <SectionPart
    partNumber={3}
    mode={mode}
    previewData={previewData}
    placeholders={placeholders}
    imageIcon={imageIcon}
  />

  <SectionThanks mode={mode} previewData={previewData} placeholders={placeholders} />

  <SectionGallery mode={mode} previewData={previewData} imageIcon={imageIcon} />

  <div class="pt-4 flex gap-2">
    {
      mode === "create" && (
        <button
          type="submit"
          name="save_as"
          value="brouillon"
          class="btn btn-ghost hover:text-accent text-base-100 px-4 py-2 rounded-md!"
        >
          Enregistrer en brouillon
        </button>
      )
    }
    <button
      type="submit"
      class="btn btn-border text-base-content px-4 py-2 rounded-md! flex-1"
      >{mode === "create" ? "Créer l'action" : "Enregistrer les modifications"}</button
    >
  </div>
</form>

<script>
  import "../../scripts/actionForm/imageDeletion.js";
  import "../../scripts/actionForm/mapsToggle.js";
  import "../../scripts/actionForm/placeholders.js";
  import "../../scripts/actionForm/editableTitle.js";
  import "../../scripts/preview/index.js";
</script>
