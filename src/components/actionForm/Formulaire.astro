---
import SectionMainInfo from "./sections/SectionMainInfo.astro";
import SectionPart from "./sections/SectionPart.astro";
import SectionLocation from "./sections/SectionLocation.astro";
import SectionThanks from "./sections/SectionThanks.astro";
import SectionGallery from "./sections/SectionGallery.astro";

import imageIcon from "../../assets/image-icon.svg";
import previewDefaults from "../../scripts/previewDefaults.js";

export interface Props {
  mode?: string;
  previewPlaceholder: any;
  previewData?: any;
  typeDeChiffreOptions?: string[];
  typeActionOptions?: string[];
  imageIcon?: any;
  actionRecord?: any;
  isDraft?: boolean;
  error?: string;
  uiMode?: "desktop" | "mobile-wizard";
  initialStep?: number;
  recordKey?: string;
}

const {
  mode = "create",
  previewPlaceholder,
  previewData,
  typeDeChiffreOptions: typeDeChiffreOptionsProp,
  typeActionOptions: typeActionOptionsProp = [],
  imageIcon: imageIconProp,
  actionRecord,
  isDraft = false,
  error = "",
  uiMode = "desktop",
  initialStep = 1,
  recordKey = "new",
} = Astro.props;

// Valeurs de select robustes: on retombe sur une liste metier par defaut
// si aucune option n'est injectee par la page.
const typeDeChiffreOptions = typeDeChiffreOptionsProp || [
  "type de chiffre",
  "dépenses",
  "récoltes",
];

// Fusion placeholder "socle + surcharge eventuelle" pour garder
// un comportement identique entre création et édition.
const placeholders = {
  ...previewDefaults,
  ...(previewPlaceholder || {}),
};

const resolvedImageIcon = imageIconProp || imageIcon;
const isMobileWizard = uiMode === "mobile-wizard";
const formTitle =
  mode === "create" ? "Créer une nouvelle action" : "Modifier l'action";
---

<form
  id="leftForm"
  class:list={["space-y-8 text-accent", isMobileWizard ? "pb-10" : ""]}
  method="POST"
  enctype="multipart/form-data"
  data-ui-mode={uiMode}
  data-initial-step={String(initialStep)}
  data-wizard-storage-key={recordKey}
>
  <h1 class="text-4xl! font-bold mb-6 mt-6 lg:mb-8 lg:mt-16 text-white">
    {formTitle}
  </h1>

  {
    isMobileWizard && (
      <div data-mobile-wizard-header class="lg:hidden space-y-3">
        <div class="flex items-center justify-between">
          <p class="text-sm text-base-100/80">Progression</p>
          <p data-mobile-step-label class="text-sm text-base-100">Étape 1/7</p>
        </div>
        <div class="grid grid-cols-7 gap-1">
          {
            Array.from({ length: 7 }, (_, i) => i + 1).map((step) => (
              <button
                type="button"
                data-mobile-go-step={String(step)}
                class="btn btn-xs rounded-full border border-base-100/30 bg-transparent text-base-100/60 hover:bg-base-100/10"
              >
                {step}
              </button>
            ))
          }
        </div>
        <p
          data-mobile-step-error
          class="hidden text-sm text-error bg-base-100 rounded-md px-3 py-2"
        >
        </p>
      </div>
    )
  }

  {error && <p class="text-red-300 mb-2">{error}</p>}

  <div data-mobile-step-wrapper data-mobile-step="1">
    <SectionMainInfo
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      imageIcon={resolvedImageIcon}
      typeActionOptions={typeActionOptionsProp}
    />
  </div>

  <div data-mobile-step-wrapper data-mobile-step="2">
    <SectionPart
      partNumber={1}
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      imageIcon={resolvedImageIcon}
    />
  </div>

  <div data-mobile-step-wrapper data-mobile-step="3">
    <SectionLocation
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      typeDeChiffreOptions={typeDeChiffreOptions}
    />
  </div>

  <div data-mobile-step-wrapper data-mobile-step="4">
    <SectionPart
      partNumber={2}
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      imageIcon={resolvedImageIcon}
    />
  </div>

  <div data-mobile-step-wrapper data-mobile-step="5">
    <SectionPart
      partNumber={3}
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      imageIcon={resolvedImageIcon}
    />
  </div>

  <div data-mobile-step-wrapper data-mobile-step="6">
    <SectionThanks
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
    />
  </div>

  <div data-mobile-step-wrapper data-mobile-step="7">
    <SectionGallery
      mode={mode}
      previewData={previewData}
      imageIcon={resolvedImageIcon}
    />
  </div>

  <div
    class:list={[
      "pt-4 gap-2",
      isMobileWizard ? "hidden lg:flex" : "flex",
    ]}
  >
    {
      mode === "create" && (
        <button
          type="submit"
          name="save_as"
          value="brouillon"
          class="btn btn-ghost hover:text-accent text-base-100 px-4 py-2 rounded-md!"
        >
          Enregistrer en brouillon
        </button>
      )
    }

    <div class="flex flex-col w-full gap-4">
      <button
        type="submit"
        class="btn btn-border text-base-content px-4 py-2 rounded-md! flex-1"
      >
        {mode === "create" ? "Créer l'action" : "Enregistrer les modifications"}
      </button>
      {
        mode === "edit" && isDraft && (
          <button
            type="submit"
            name="publish_action"
            value="true"
            class="btn btn-ghost px-4 py-2 rounded-md! text-base-100 hover:text-accent"
          >
            Publier l'action
          </button>
        )
      }
    </div>
  </div>

  {
    isMobileWizard && (
      <div
        data-mobile-wizard-footer
        class="lg:hidden sticky bottom-2 z-40 bg-base-100/95 backdrop-blur border border-base-300 rounded-2xl px-3 py-3 space-y-2"
      >
        <div class="flex gap-2">
          <button
            type="button"
            data-mobile-prev
            class="btn btn-outline rounded-full flex-1"
          >
            Précédent
          </button>
          <button
            type="button"
            data-mobile-next
            class="btn btn-accent rounded-full flex-1"
          >
            Suivant
          </button>
          <button
            type="submit"
            data-mobile-submit
            class="btn btn-accent rounded-full flex-1 hidden"
          >
            {mode === "create" ? "Créer l'action" : "Enregistrer"}
          </button>
        </div>
        <div class="flex gap-2">
          {
            mode === "create" && (
              <button
                type="submit"
                name="save_as"
                value="brouillon"
                class="btn btn-ghost rounded-full flex-1"
              >
                Enregistrer en brouillon
              </button>
            )
          }
          {
            mode === "edit" && isDraft && (
              <button
                type="submit"
                name="publish_action"
                value="true"
                class="btn btn-outline rounded-full flex-1"
              >
                Publier
              </button>
            )
          }
        </div>
      </div>
    )
  }
</form>

<script>
  // Scripts métier du formulaire:
  // - suppression d'images
  // - gestion Maps
  // - placeholders
  // - édition des titres
  // - wizard mobile
  // - prévisualisation en direct
  import "../../scripts/actionForm/imageDeletion.js";
  import "../../scripts/actionForm/mapsToggle.js";
  import "../../scripts/actionForm/placeholders.js";
  import "../../scripts/actionForm/editableTitle.js";
  import "../../scripts/actionForm/mobileWizard.js";
  import "../../scripts/preview/index.js";

  function animateCards() {
    const cards = Array.from(document.querySelectorAll("#leftForm .p-4"));
    const form = document.getElementById("leftForm");
    const isMobileWizard =
      form?.getAttribute("data-ui-mode") === "mobile-wizard" &&
      window.matchMedia("(max-width: 1023px)").matches;

    if (isMobileWizard) {
      // En wizard mobile, on désactive l'animation pour garder une navigation instantanée.
      cards.forEach((card) => {
        card.classList.remove("opacity-0", "-translate-x-4");
      });
      return;
    }

    cards.forEach((card, idx) => {
      card.classList.add(
        "opacity-0",
        "-translate-x-4",
        "transition-all",
        "duration-300",
        "ease-out",
      );
      setTimeout(() => {
        card.classList.remove("opacity-0", "-translate-x-4");
      }, idx * 100 + 50);
    });
  }

  const initCardAnimation = () => {
    const sidebar = document.getElementById("sidebar");
    const canUseSidebarAnimation = window.matchMedia("(min-width: 1024px)")
      .matches;
    const shouldWaitForSidebarTransition =
      sidebar instanceof HTMLElement &&
      canUseSidebarAnimation &&
      sidebar.classList.contains("lg:transition-all");

    if (!shouldWaitForSidebarTransition) {
      // Pas d'animation sidebar: on anime les cartes immédiatement.
      animateCards();
      return;
    }

    let hasAnimated = false;
    const runOnce = () => {
      if (hasAnimated) return;
      hasAnimated = true;
      animateCards();
    };

    sidebar.addEventListener("transitionend", runOnce, { once: true });
    // Filet de sécurité: si aucun event ne part, on anime quand même.
    window.setTimeout(runOnce, 700);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCardAnimation, {
      once: true,
    });
  } else {
    initCardAnimation();
  }

  document.addEventListener("astro:page-load", initCardAnimation);
</script>
