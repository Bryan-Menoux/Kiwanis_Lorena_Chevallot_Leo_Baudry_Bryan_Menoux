---
import SectionMainInfo from "./sections/SectionMainInfo.astro";
import SectionPart from "./sections/SectionPart.astro";
import SectionLocation from "./sections/SectionLocation.astro";
import SectionThanks from "./sections/SectionThanks.astro";
import SectionGallery from "./sections/SectionGallery.astro";
import FormSubmitOverlay from "../FormSubmitOverlay.astro";

import imageIcon from "../../assets/image-icon.svg";
import previewDefaults from "../../scripts/previewDefaults.js";
import { ActionsTypeDeChiffreOptions } from "../../pocketbase-types";

export interface Props {
  mode?: string;
  previewPlaceholder: any;
  previewData?: any;
  typeDeChiffreOptions?: string[];
  typeActionOptions?: string[];
  imageIcon?: any;
  actionRecord?: any;
  isDraft?: boolean;
  error?: string;
  uiMode?: "desktop" | "mobile-wizard";
  initialStep?: number;
  recordKey?: string;
  canPublish?: boolean;
}

const {
  mode = "create",
  previewPlaceholder,
  previewData,
  typeDeChiffreOptions: typeDeChiffreOptionsProp,
  typeActionOptions: typeActionOptionsProp = [],
  imageIcon: imageIconProp,
  isDraft = false,
  error = "",
  uiMode = "desktop",
  initialStep = 1,
  recordKey = "new",
  canPublish = true,
} = Astro.props;

// Valeurs de select robustes: on retombe sur une liste metier par defaut
// si aucune option n'est injectee par la page.
const typeDeChiffreOptions = typeDeChiffreOptionsProp || [
  "type de chiffre",
  ...(Array.isArray(ActionsTypeDeChiffreOptions)
    ? ActionsTypeDeChiffreOptions
    : Object.values(ActionsTypeDeChiffreOptions)),
];

// Fusion placeholder "socle + surcharge eventuelle" pour garder
// un comportement identique entre création et édition.
const placeholders = {
  ...previewDefaults,
  ...(previewPlaceholder || {}),
};

const resolvedImageIcon = imageIconProp || imageIcon;
const isMobileWizard = uiMode === "mobile-wizard";
const createActionLabel = canPublish ? "Créer l'action" : "Enregistrer le brouillon";
const formTitle =
  mode === "create" ? "Créer une nouvelle action" : "Modifier l'action";
const showUnsavedModal = mode === "create" || mode === "edit";
const unsavedModalTitle = "Modifications non enregistrées";
const unsavedModalMessage =
  mode === "create"
    ? "Vous pouvez enregistrer un brouillon avant de quitter, ou abandonner les modifications."
    : "Vous pouvez enregistrer les modifications avant de quitter, ou abandonner les changements.";
const unsavedModalSaveLabel =
  mode === "create" ? "Enregistrer brouillon" : "Enregistrer les modifications";
const initialRecadrageValue = (() => {
  const value = previewData?.recadrage;
  if (typeof value === "string") {
    const trimmed = value.trim();
    return trimmed || "{}";
  }

  if (value && typeof value === "object") {
    try {
      return JSON.stringify(value);
    } catch {
      return "{}";
    }
  }

  return "{}";
})();
---

<form
  id="leftForm"
  class:list={[
    "space-y-8 text-accent",
    isMobileWizard ? "[--mobile-wizard-footer-offset:0px]" : "",
  ]}
  method="POST"
  enctype="multipart/form-data"
  data-submit-overlay-requires-ready="true"
  data-form-mode={mode}
  data-is-draft={isDraft ? "true" : "false"}
  data-ui-mode={uiMode}
  data-initial-step={String(initialStep)}
  data-wizard-storage-key={recordKey}
>
  <h1 class="text-4xl! font-bold mb-6 mt-20 lg:mb-8 lg:mt-24 text-white">
    {formTitle}
  </h1>

  {
    isMobileWizard && (
      <div data-mobile-wizard-header class="lg:hidden space-y-3">
        <div class="flex items-center justify-between">
          <p class="text-sm text-base-100!">Progression</p>
          <p data-mobile-step-label class="text-sm text-base-100!">Étape 1/7</p>
        </div>
        <div data-mobile-step-nav class="grid grid-cols-7 gap-1"></div>
        <p
          data-mobile-step-error
          class="hidden text-sm text-error bg-base-100 rounded-md px-3 py-2"
        >
        </p>
      </div>
    )
  }

  {error && <p class="text-red-300 mb-2">{error}</p>}
  <p class="text-xs text-base-100/80">
    Pour publier: titre, date de début, image de l'en-tête, type d'action, et au moins une partie (texte ou photo).
  </p>

  {
    mode === "create" && (
      <input type="hidden" name="draft_id" data-autodraft-id value="" />
    )
  }
  <input
    type="hidden"
    name="recadrage"
    data-recadrage-input
    value={initialRecadrageValue}
  />
  {
    mode === "create" && (
      <p data-autodraft-status class="text-xs text-base-100/70">
        Brouillon non enregistré
      </p>
    )
  }

  <div
    data-mobile-step-wrapper
    data-mobile-step="1"
    class:list={[
      isMobileWizard
        ? "min-h-[60dvh] pb-(--mobile-wizard-footer-offset) lg:min-h-0 lg:pb-0"
        : "",
    ]}
  >
    <SectionMainInfo
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      imageIcon={resolvedImageIcon}
      typeActionOptions={typeActionOptionsProp}
    />
  </div>

  <div
    data-mobile-step-wrapper
    data-mobile-step="2"
    class:list={[
      isMobileWizard
        ? "min-h-[60dvh] pb-(--mobile-wizard-footer-offset) lg:min-h-0 lg:pb-0"
        : "",
    ]}
  >
    <SectionPart
      partNumber={1}
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      imageIcon={resolvedImageIcon}
    />
  </div>

  <div
    data-mobile-step-wrapper
    data-mobile-step="3"
    class:list={[
      isMobileWizard
        ? "min-h-[60dvh] pb-(--mobile-wizard-footer-offset) lg:min-h-0 lg:pb-0"
        : "",
    ]}
  >
    <SectionLocation
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      typeDeChiffreOptions={typeDeChiffreOptions}
    />
  </div>

  <div
    data-mobile-step-wrapper
    data-mobile-step="4"
    class:list={[
      isMobileWizard
        ? "min-h-[60dvh] pb-(--mobile-wizard-footer-offset) lg:min-h-0 lg:pb-0"
        : "",
    ]}
  >
    <SectionPart
      partNumber={2}
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      imageIcon={resolvedImageIcon}
    />
  </div>

  <div
    data-mobile-step-wrapper
    data-mobile-step="5"
    class:list={[
      isMobileWizard
        ? "min-h-[60dvh] pb-(--mobile-wizard-footer-offset) lg:min-h-0 lg:pb-0"
        : "",
    ]}
  >
    <SectionPart
      partNumber={3}
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      imageIcon={resolvedImageIcon}
    />
  </div>

  <div
    data-mobile-step-wrapper
    data-mobile-step="6"
    class:list={[
      isMobileWizard
        ? "min-h-[60dvh] pb-(--mobile-wizard-footer-offset) lg:min-h-0 lg:pb-0"
        : "",
    ]}
  >
    <SectionThanks
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
    />
  </div>

  <div
    data-mobile-step-wrapper
    data-mobile-step="7"
    class:list={[
      isMobileWizard
        ? "min-h-[60dvh] pb-(--mobile-wizard-footer-offset) lg:min-h-0 lg:pb-0"
        : "",
    ]}
  >
    <SectionGallery
      mode={mode}
      previewData={previewData}
      imageIcon={resolvedImageIcon}
    />
  </div>

  <div
    class:list={[
      "pt-4 gap-2",
      isMobileWizard ? "hidden lg:flex" : "flex",
    ]}
  >
    <div class="flex flex-col w-full gap-4">
      {
        mode === "edit" && isDraft && canPublish && (
          <button
            type="submit"
            name="publish_action"
            value="true"
            class="btn btn-block text-accent px-4 py-2 rounded-md! flex-1"
          >
            Publier l'action
          </button>
        )
      }
      <button
        type="submit"
        name={mode === "create" && !canPublish ? "save_as" : undefined}
        value={mode === "create" && !canPublish ? "brouillon" : undefined}
        class:list={[
          "px-4 py-2 rounded-md! flex-1",
          mode === "create"
            ? "btn text-accent"
            : "btn btn-outline border-base-100 text-base-100 hover:text-accent",
        ]}
        >
          {mode === "create" ? createActionLabel : "Enregistrer les modifications"}
      </button>
      {
        mode === "create" && canPublish && (
          <button
            type="submit"
            name="save_as"
            value="brouillon"
            class="btn btn-outline border-base-100 text-base-100 hover:text-accent px-4 py-2 rounded-md! w-full"
          >
            Enregistrer en brouillon
          </button>
        )
      }
    </div>
  </div>

  {
    isMobileWizard && (
      <div
        data-mobile-wizard-footer
        class="lg:hidden sticky bottom-0 z-40 -mx-4 mt-4 border-t border-base-300 bg-base-100/95 px-4 pt-3 space-y-2 backdrop-blur"
        style="padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 0.75rem);"
      >
        <div class="flex gap-2">
          <button
            type="button"
            data-mobile-prev
            class="btn btn-outline btn-accent rounded-full flex-1"
          >
            Précédent
          </button>
          <button
            type="button"
            data-mobile-next
            class="btn btn-accent rounded-full flex-1"
            data-next-text="Suivant"
            data-last-text={mode === "edit" && isDraft && canPublish ? "Publier l'action" : undefined}
            name={mode === "edit" && isDraft && canPublish ? "publish_action" : undefined}
            value={mode === "edit" && isDraft && canPublish ? "true" : undefined}
          >
            Suivant
          </button>
        </div>
        {
          mode === "edit" && isDraft && (
            <button
              type="submit"
              name="edit_save"
              value="true"
              class="btn btn-outline btn-accent hover:text-accent rounded-full w-full"
            >
              Enregistrer les modifications
            </button>
          )
        }
      </div>
    )
  }
</form>

<dialog id="preview-image-crop-modal" class="modal">
  <div class="modal-box max-w-4xl">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h3 class="text-xl font-bold">Recadrer l'image</h3>
        <p class="mt-2 text-sm text-base-content/70">
          Cliquez sur l'image pour déplacer le cadrage.
        </p>
      </div>
      <button type="button" class="btn btn-ghost btn-sm" data-crop-close>
        Enregistrer
      </button>
    </div>

    <div class="mt-4 overflow-hidden rounded-2xl border border-base-300 bg-base-100">
      <div
        data-crop-canvas
        class="relative cursor-crosshair select-none overflow-hidden bg-base-200"
      >
        <img
          data-crop-modal-image
          alt="Aperçu du recadrage"
          class="block h-[65dvh] w-full object-cover"
          draggable="false"
        />
        <span
          data-crop-marker
          class="pointer-events-none absolute h-4 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full border-2 border-white bg-accent shadow-lg"
        ></span>
      </div>
    </div>

    <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <p data-crop-position class="text-sm text-base-content/70">
        Cliquez sur l'image pour déplacer le cadrage
      </p>
      <div class="flex flex-wrap gap-2">
        <button type="button" class="btn btn-outline btn-sm" data-crop-reset>
          Réinitialiser
        </button>
        <button type="button" class="btn btn-accent btn-sm" data-crop-close>
          Enregistrer
        </button>
      </div>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button type="button" data-crop-close>Enregistrer</button>
  </form>
</dialog>

{
  showUnsavedModal && (
    <dialog id="unsaved-changes-modal" class="modal">
      <div class="modal-box max-w-lg">
        <h3 data-unsaved-title class="text-xl font-bold">{unsavedModalTitle}</h3>
        <p data-unsaved-message class="mt-2 text-sm text-base-content/70">
          {unsavedModalMessage}
        </p>
        <div class="mt-6 flex flex-col-reverse gap-2 sm:flex-row sm:justify-end">
          <button type="button" class="btn btn-ghost rounded-full" data-unsaved-cancel>
            Annuler
          </button>
          <button type="button" class="btn btn-outline rounded-full" data-unsaved-abandon>
            Abandonner
          </button>
          <button type="button" class="btn btn-accent rounded-full" data-unsaved-save>
            {unsavedModalSaveLabel}
          </button>
        </div>
      </div>
      <form method="dialog" class="modal-backdrop">
        <button type="button" data-unsaved-cancel>Fermer</button>
      </form>
    </dialog>
  )
}

<FormSubmitOverlay
  formSelector="#leftForm"
  message="Enregistrement en cours... Cela peut prendre jusqu’à une minute."
/>

<script define:vars={{ serverErrorMessage: error }}>
  function pushErrorAlert(message) {
    if (!message) return;

    const payload = {
      type: "error",
      message,
    };

    if (
      typeof window !== "undefined" &&
      window.KiwanisAlert &&
      typeof window.KiwanisAlert.show === "function"
    ) {
      window.KiwanisAlert.show(payload);
      return;
    }

    if (typeof window !== "undefined" && typeof CustomEvent === "function") {
      window.dispatchEvent(
        new CustomEvent("kiwanis:alert", {
          detail: payload,
        }),
      );
    }
  }

  const message =
    typeof serverErrorMessage === "string" ? serverErrorMessage.trim() : "";

  if (message) {
    pushErrorAlert(message);
  }
</script>

<script>
  import "../../scripts/actionForm/imageDeletion.js";
  import "../../scripts/actionForm/mapsToggle.js";
  import "../../scripts/actionForm/placeholders.js";
  import "../../scripts/actionForm/editableTitle.js";
  import "../../scripts/actionForm/formAnimations.js";
  import "../../scripts/actionForm/formValidation.js";
  import "../../scripts/actionForm/autoDraftAutosave.js";
  import "../../scripts/actionForm/unsavedChangesGuard.js";
  import "../../scripts/actionForm/mobileWizard.js";
  import "../../scripts/preview/index.js";
  import "../../scripts/preview/cropper.js";
  import { initWebpConversion } from "../../scripts/actionForm/convertToWebp.js";
  initWebpConversion();
</script>

