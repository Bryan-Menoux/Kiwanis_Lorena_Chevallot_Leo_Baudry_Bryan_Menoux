---
import SectionMainInfo from "./sections/SectionMainInfo.astro";
import SectionPart from "./sections/SectionPart.astro";
import SectionLocation from "./sections/SectionLocation.astro";
import SectionThanks from "./sections/SectionThanks.astro";
import SectionGallery from "./sections/SectionGallery.astro";
import FormSubmitOverlay from "../FormSubmitOverlay.astro";

import imageIcon from "../../assets/image-icon.svg";
import previewDefaults from "../../scripts/previewDefaults.js";

export interface Props {
  mode?: string;
  previewPlaceholder: any;
  previewData?: any;
  typeDeChiffreOptions?: string[];
  typeActionOptions?: string[];
  imageIcon?: any;
  actionRecord?: any;
  isDraft?: boolean;
  error?: string;
  uiMode?: "desktop" | "mobile-wizard";
  initialStep?: number;
  recordKey?: string;
}

const {
  mode = "create",
  previewPlaceholder,
  previewData,
  typeDeChiffreOptions: typeDeChiffreOptionsProp,
  typeActionOptions: typeActionOptionsProp = [],
  imageIcon: imageIconProp,
  actionRecord,
  isDraft = false,
  error = "",
  uiMode = "desktop",
  initialStep = 1,
  recordKey = "new",
} = Astro.props;

// Valeurs de select robustes: on retombe sur une liste metier par defaut
// si aucune option n'est injectee par la page.
const typeDeChiffreOptions = typeDeChiffreOptionsProp || [
  "type de chiffre",
  "dépenses",
  "récoltes",
];

// Fusion placeholder "socle + surcharge eventuelle" pour garder
// un comportement identique entre création et édition.
const placeholders = {
  ...previewDefaults,
  ...(previewPlaceholder || {}),
};

const resolvedImageIcon = imageIconProp || imageIcon;
const isMobileWizard = uiMode === "mobile-wizard";
const formTitle =
  mode === "create" ? "Créer une nouvelle action" : "Modifier l'action";
---

<form
  id="leftForm"
  class:list={["space-y-8 text-accent", isMobileWizard ? "pb-10" : ""]}
  method="POST"
  enctype="multipart/form-data"
  data-submit-overlay-requires-ready="true"
  data-form-mode={mode}
  data-is-draft={isDraft ? "true" : "false"}
  data-ui-mode={uiMode}
  data-initial-step={String(initialStep)}
  data-wizard-storage-key={recordKey}
>
  <h1 class="text-4xl! font-bold mb-6 mt-6 lg:mb-8 lg:mt-16 text-white">
    {formTitle}
  </h1>

  {
    isMobileWizard && (
      <div data-mobile-wizard-header class="lg:hidden space-y-3">
        <div class="flex items-center justify-between">
          <p class="text-sm text-base-100!">Progression</p>
          <p data-mobile-step-label class="text-sm text-base-100!">Étape 1/7</p>
        </div>
        <div class="grid grid-cols-7 gap-1">
          {
            Array.from({ length: 7 }, (_, i) => i + 1).map((step) => (
              <button
                type="button"
                data-mobile-go-step={String(step)}
                class="btn btn-xs rounded-full border border-base-100 bg-transparent text-base-100! hover:bg-base-100/10"
              >
                {step}
              </button>
            ))
          }
        </div>
        <p
          data-mobile-step-error
          class="hidden text-sm text-error bg-base-100 rounded-md px-3 py-2"
        >
        </p>
      </div>
    )
  }

  {error && <p class="text-red-300 mb-2">{error}</p>}
  <p class="text-xs text-base-100/80">
    Pour publier: titre, date de début, image de l'en-tête, et au moins une partie (texte ou photo).
  </p>

  <div
    data-mobile-step-wrapper
    data-mobile-step="1"
    class:list={[isMobileWizard ? "min-h-[60dvh] lg:min-h-0" : ""]}
  >
    <SectionMainInfo
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      imageIcon={resolvedImageIcon}
      typeActionOptions={typeActionOptionsProp}
    />
  </div>

  <div
    data-mobile-step-wrapper
    data-mobile-step="2"
    class:list={[isMobileWizard ? "min-h-[60dvh] lg:min-h-0" : ""]}
  >
    <SectionPart
      partNumber={1}
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      imageIcon={resolvedImageIcon}
    />
  </div>

  <div
    data-mobile-step-wrapper
    data-mobile-step="3"
    class:list={[isMobileWizard ? "min-h-[60dvh] lg:min-h-0" : ""]}
  >
    <SectionLocation
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      typeDeChiffreOptions={typeDeChiffreOptions}
    />
  </div>

  <div
    data-mobile-step-wrapper
    data-mobile-step="4"
    class:list={[isMobileWizard ? "min-h-[60dvh] lg:min-h-0" : ""]}
  >
    <SectionPart
      partNumber={2}
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      imageIcon={resolvedImageIcon}
    />
  </div>

  <div
    data-mobile-step-wrapper
    data-mobile-step="5"
    class:list={[isMobileWizard ? "min-h-[60dvh] lg:min-h-0" : ""]}
  >
    <SectionPart
      partNumber={3}
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
      imageIcon={resolvedImageIcon}
    />
  </div>

  <div
    data-mobile-step-wrapper
    data-mobile-step="6"
    class:list={[isMobileWizard ? "min-h-[60dvh] lg:min-h-0" : ""]}
  >
    <SectionThanks
      mode={mode}
      previewData={previewData}
      placeholders={placeholders}
    />
  </div>

  <div
    data-mobile-step-wrapper
    data-mobile-step="7"
    class:list={[isMobileWizard ? "min-h-[60dvh] lg:min-h-0" : ""]}
  >
    <SectionGallery
      mode={mode}
      previewData={previewData}
      imageIcon={resolvedImageIcon}
    />
  </div>

  <div
    class:list={[
      "pt-4 gap-2",
      isMobileWizard ? "hidden lg:flex" : "flex",
    ]}
  >
    {
      mode === "create" && (
        <button
          type="submit"
          name="save_as"
          value="brouillon"
          class="btn btn-ghost hover:text-accent text-base-100 px-4 py-2 rounded-md!"
        >
          Enregistrer en brouillon
        </button>
      )
    }

    <div class="flex flex-col w-full gap-4">
      <button
        type="submit"
        class="btn btn-border text-base-content px-4 py-2 rounded-md! flex-1"
      >
        {mode === "create" ? "Créer l'action" : "Enregistrer les modifications"}
      </button>
      {
        mode === "edit" && isDraft && (
          <button
            type="submit"
            name="publish_action"
            value="true"
            class="btn btn-ghost px-4 py-2 rounded-md! text-base-100 hover:text-accent"
          >
            Publier l'action
          </button>
        )
      }
    </div>
  </div>

  {
    isMobileWizard && (
      <div
        data-mobile-wizard-footer
        class="lg:hidden sticky bottom-0 z-40 -mx-4 mt-4 border-t border-base-300 bg-base-100/95 px-4 pt-3 space-y-2 backdrop-blur"
        style="padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 0.75rem);"
      >
        <div class="flex gap-2">
          <button
            type="button"
            data-mobile-prev
            class="btn btn-outline rounded-full flex-1"
          >
            Précédent
          </button>
          <button
            type="button"
            data-mobile-next
            class="btn btn-accent rounded-full flex-1"
          >
            Suivant
          </button>
          <button
            type="submit"
            data-mobile-submit
            class="btn btn-accent rounded-full flex-1 hidden"
          >
            {mode === "create" ? "Créer l'action" : "Enregistrer"}
          </button>
        </div>
        <div class="flex gap-2">
          {
            mode === "create" && (
              <button
                type="submit"
                name="save_as"
                value="brouillon"
                class="btn btn-ghost rounded-full flex-1"
              >
                Enregistrer en brouillon
              </button>
            )
          }
          {
            mode === "edit" && isDraft && (
              <button
                type="submit"
                name="publish_action"
                value="true"
                class="btn btn-outline rounded-full flex-1"
              >
                Publier
              </button>
            )
          }
        </div>
      </div>
    )
  }
</form>

<FormSubmitOverlay
  formSelector="#leftForm"
  message="Enregistrement en cours... Cela peut prendre jusqu’à une minute."
/>

<script define:vars={{ serverErrorMessage: error }}>
  function pushErrorAlert(message) {
    if (!message) return;

    const payload = {
      type: "error",
      message,
    };

    if (
      typeof window !== "undefined" &&
      window.KiwanisAlert &&
      typeof window.KiwanisAlert.show === "function"
    ) {
      window.KiwanisAlert.show(payload);
      return;
    }

    if (typeof window !== "undefined" && typeof CustomEvent === "function") {
      window.dispatchEvent(
        new CustomEvent("kiwanis:alert", {
          detail: payload,
        }),
      );
    }
  }

  const message =
    typeof serverErrorMessage === "string" ? serverErrorMessage.trim() : "";

  if (message) {
    pushErrorAlert(message);
  }
</script>

<script>
  // Scripts métier du formulaire:
  // - suppression d'images
  // - gestion Maps
  // - placeholders
  // - édition des titres
  // - wizard mobile
  // - prévisualisation en direct
  import "../../scripts/actionForm/imageDeletion.js";
  import "../../scripts/actionForm/mapsToggle.js";
  import "../../scripts/actionForm/placeholders.js";
  import "../../scripts/actionForm/editableTitle.js";
  import "../../scripts/actionForm/mobileWizard.js";
  import "../../scripts/preview/index.js";
  import { initWebpConversion } from "../../scripts/actionForm/convertToWebp.js";
  import { showAlert, showConfirm } from "../../utils/alerts";

  const PUBLISH_CONFIRMED_ATTR = "data-publish-confirmed";
  const SUBMIT_OVERLAY_READY_ATTR = "data-submit-overlay-ready";
  const VALIDATION_ALERT_DEBOUNCE_MS = 1200;
  let lastValidationAlertMessage = "";
  let lastValidationAlertAt = 0;

  async function confirmPublish(): Promise<boolean> {
    return showConfirm({
      title: "Publier l'action",
      message:
        "Confirmez la publication de ce brouillon. Cette action sera visible publiquement sur le site.",
      type: "warning",
      confirmLabel: "Publier",
      cancelLabel: "Annuler",
    });
  }

  function setClientValidationError(form: HTMLFormElement, message: string) {
    if (!message) return;

    const now = Date.now();
    const shouldSkipDuplicate =
      message === lastValidationAlertMessage &&
      now - lastValidationAlertAt < VALIDATION_ALERT_DEBOUNCE_MS;

    if (shouldSkipDuplicate) {
      return;
    }

    lastValidationAlertMessage = message;
    lastValidationAlertAt = now;
    showAlert({
      type: "warning",
      message,
    });
  }

  function hasExistingImagePreview(
    form: HTMLFormElement,
    fieldName: string,
  ): boolean {
    const existingPreview = form.querySelector(
      `#preview_${fieldName} [data-delete-image="${fieldName}"]`,
    );
    return existingPreview instanceof HTMLElement;
  }

  function hasSelectedFile(form: HTMLFormElement, fieldName: string): boolean {
    const input = form.querySelector(
      `[data-prop-file="${fieldName}"]`,
    );
    return (
      input instanceof HTMLInputElement &&
      input.files instanceof FileList &&
      input.files.length > 0
    );
  }

  function hasAtLeastOnePart(form: HTMLFormElement): boolean {
    const parts = [1, 2, 3];
    return parts.some((partNumber) => {
      const textInput = form.querySelector(
        `#input_texte_partie_${partNumber}`,
      );
      const hasText =
        (textInput instanceof HTMLTextAreaElement ||
          textInput instanceof HTMLInputElement) &&
        textInput.value.trim().length > 0;
      const photoField = `photo_partie_${partNumber}`;
      const hasPhoto =
        hasSelectedFile(form, photoField) ||
        hasExistingImagePreview(form, photoField);
      return hasText || hasPhoto;
    });
  }

  function getMissingHeaderFields(form: HTMLFormElement): string[] {
    const missingFields: string[] = [];

    const titleInput = form.querySelector("#input_titre");
    const hasTitle =
      (titleInput instanceof HTMLInputElement ||
        titleInput instanceof HTMLTextAreaElement) &&
      titleInput.value.trim().length > 0;
    if (!hasTitle) missingFields.push("titre");

    const startDateInput = form.querySelector("#input_date_debut");
    const hasStartDate =
      startDateInput instanceof HTMLInputElement &&
      startDateInput.value.trim().length > 0;
    if (!hasStartDate) missingFields.push("date de début");

    const hasHero =
      hasSelectedFile(form, "hero") || hasExistingImagePreview(form, "hero");
    if (!hasHero) missingFields.push("image de l'en-tête");

    return missingFields;
  }

  function buildRequiredMessage(
    missingHeaderFields: string[],
    missingPart: boolean,
  ): string {
    const chunks: string[] = [];

    if (missingHeaderFields.length > 0) {
      chunks.push(`en-tête: ${missingHeaderFields.join(", ")}`);
    }
    if (missingPart) {
      chunks.push("au moins une partie (texte ou photo)");
    }

    if (chunks.length === 0) return "";
    return `Informations obligatoires manquantes: ${chunks.join(" ; ")}.`;
  }

  function initActionFormRequiredValidation() {
    const form = document.getElementById("leftForm");
    if (!(form instanceof HTMLFormElement)) return;
    if (form.dataset.requiredValidationInit === "true") return;
    form.dataset.requiredValidationInit = "true";

    form.addEventListener("submit", (event) => {
      if (event.defaultPrevented) return;

      const hasPreapprovedSubmit =
        form.getAttribute(SUBMIT_OVERLAY_READY_ATTR) === "true";
      if (!hasPreapprovedSubmit) {
        form.removeAttribute(SUBMIT_OVERLAY_READY_ATTR);
      }

      const submitter = event.submitter;
      const submitterName =
        submitter instanceof HTMLButtonElement ||
        submitter instanceof HTMLInputElement
          ? submitter.name
          : "";
      const isDraftSave = submitterName === "save_as";
      const isPublishSubmit = submitterName === "publish_action";
      const isEditDraftSubmit =
        form.getAttribute("data-form-mode") === "edit" &&
        form.getAttribute("data-is-draft") === "true" &&
        !isPublishSubmit;
      if (isDraftSave || isEditDraftSubmit) {
        form.setAttribute(SUBMIT_OVERLAY_READY_ATTR, "true");
        setClientValidationError(form, "");
        return;
      }

      const missingHeaderFields = getMissingHeaderFields(form);
      const missingPart = !hasAtLeastOnePart(form);
      if (missingHeaderFields.length > 0 || missingPart) {
        event.preventDefault();
        form.removeAttribute(SUBMIT_OVERLAY_READY_ATTR);
        setClientValidationError(
          form,
          buildRequiredMessage(missingHeaderFields, missingPart),
        );

        if (missingHeaderFields.includes("titre")) {
          const titleInput = form.querySelector("#input_titre");
          if (
            titleInput instanceof HTMLInputElement ||
            titleInput instanceof HTMLTextAreaElement
          ) {
            titleInput.focus();
          }
          return;
        }

        if (missingHeaderFields.includes("date de début")) {
          const startDateInput = form.querySelector("#input_date_debut");
          if (startDateInput instanceof HTMLInputElement) startDateInput.focus();
          return;
        }

        if (missingHeaderFields.includes("image de l'en-tête")) {
          const heroInput = form.querySelector("#input_hero_file");
          if (heroInput instanceof HTMLInputElement) heroInput.focus();
          return;
        }

        if (missingPart) {
          const firstPartText = form.querySelector("#input_texte_partie_1");
          if (
            firstPartText instanceof HTMLTextAreaElement ||
            firstPartText instanceof HTMLInputElement
          ) {
            firstPartText.focus();
          }
        }
        return;
      }

      if (isPublishSubmit) {
        const alreadyConfirmed =
          form.getAttribute(PUBLISH_CONFIRMED_ATTR) === "true";
        if (!alreadyConfirmed) {
          event.preventDefault();
          form.removeAttribute(SUBMIT_OVERLAY_READY_ATTR);
          setClientValidationError(form, "");

          void confirmPublish().then((confirmed) => {
            if (!confirmed) return;

            form.setAttribute(PUBLISH_CONFIRMED_ATTR, "true");
            form.setAttribute(SUBMIT_OVERLAY_READY_ATTR, "true");
            if (
              submitter instanceof HTMLButtonElement ||
              submitter instanceof HTMLInputElement
            ) {
              form.requestSubmit(submitter);
              return;
            }

            const fallbackSubmitter = form.querySelector(
              'button[name="publish_action"], input[name="publish_action"]',
            );
            if (
              fallbackSubmitter instanceof HTMLButtonElement ||
              fallbackSubmitter instanceof HTMLInputElement
            ) {
              form.requestSubmit(fallbackSubmitter);
              return;
            }

            form.requestSubmit();
          });
          return;
        }
        form.removeAttribute(PUBLISH_CONFIRMED_ATTR);
        form.setAttribute(SUBMIT_OVERLAY_READY_ATTR, "true");
      }

      if (!isPublishSubmit) {
        form.setAttribute(SUBMIT_OVERLAY_READY_ATTR, "true");
      }
      setClientValidationError(form, "");
    });
  }

  function animateCards() {
    const cards = Array.from(document.querySelectorAll("#leftForm .p-4"));
    const form = document.getElementById("leftForm");
    const isMobileWizard =
      form?.getAttribute("data-ui-mode") === "mobile-wizard" &&
      window.matchMedia("(max-width: 1023px)").matches;

    if (isMobileWizard) {
      // En wizard mobile, on désactive l'animation pour garder une navigation instantanée.
      cards.forEach((card) => {
        card.classList.remove("opacity-0", "-translate-x-4");
      });
      return;
    }

    cards.forEach((card, idx) => {
      card.classList.add(
        "opacity-0",
        "-translate-x-4",
        "transition-all",
        "duration-300",
        "ease-out",
      );
      setTimeout(() => {
        card.classList.remove("opacity-0", "-translate-x-4");
      }, idx * 100 + 50);
    });
  }

  const initCardAnimation = () => {
    const sidebar = document.getElementById("sidebar");
    const canUseSidebarAnimation = window.matchMedia("(min-width: 1024px)")
      .matches;
    const shouldWaitForSidebarTransition =
      sidebar instanceof HTMLElement &&
      canUseSidebarAnimation &&
      sidebar.classList.contains("lg:transition-all");

    if (!shouldWaitForSidebarTransition) {
      // Pas d'animation sidebar: on anime les cartes immédiatement.
      animateCards();
      return;
    }

    let hasAnimated = false;
    const runOnce = () => {
      if (hasAnimated) return;
      hasAnimated = true;
      animateCards();
    };

    sidebar.addEventListener("transitionend", runOnce, { once: true });
    // Filet de sécurité: si aucun event ne part, on anime quand même.
    window.setTimeout(runOnce, 700);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initCardAnimation, {
      once: true,
    });
    document.addEventListener("DOMContentLoaded", initActionFormRequiredValidation, {
      once: true,
    });
    document.addEventListener("DOMContentLoaded", initWebpConversion, {
      once: true,
    });
  } else {
    initCardAnimation();
    initActionFormRequiredValidation();
    initWebpConversion();
  }

  document.addEventListener("astro:page-load", initCardAnimation);
  document.addEventListener("astro:page-load", initActionFormRequiredValidation);
  document.addEventListener("astro:page-load", initWebpConversion);
</script>

