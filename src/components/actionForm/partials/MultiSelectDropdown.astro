---
import arrowNextSmall from "../../../assets/arrow-next-small.svg";

export interface Props {
  id: string;
  dataProp: string;
  name?: string;
  options: string[];
  selectedValues?: string[];
  maxSelect?: number;
  placeholder?: string;
  variant?: "default" | "input";
}

const {
  id,
  dataProp,
  name,
  options = [],
  selectedValues = [],
  maxSelect = 7,
  placeholder = "Sélectionner des options",
  variant = "default",
} = Astro.props;

const toggleClass =
  variant === "input"
    ? "input input-bordered flex w-full items-center justify-between gap-2 text-left"
    : "flex w-full items-center justify-between gap-2 rounded border border-accent bg-base-100 px-3 py-2 text-left text-black";

const menuClass =
  variant === "input"
    ? "hidden absolute z-50 mt-1 max-h-64 w-full overflow-auto rounded border border-base-300 bg-base-100 p-2 shadow"
    : "hidden absolute z-50 mt-1 max-h-64 w-full overflow-auto rounded border border-accent bg-base-100 p-2 shadow";

const selectedSet = new Set((selectedValues || []).map((value) => String(value)));
---

<div data-kc-ms-root data-select-id={id} class="relative w-full">
  <button
    type="button"
    data-kc-ms-toggle
    class={toggleClass}
    aria-haspopup="listbox"
    aria-expanded="false"
  >
    <span data-kc-ms-label class="truncate text-base-content/50">{placeholder}</span>
    <img
      data-kc-ms-arrow
      src={arrowNextSmall.src}
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
      class="h-6 w-6 shrink-0 rotate-0 opacity-80 transition-transform duration-200"
    />
  </button>

  <div data-kc-ms-menu class={menuClass}>
    {
      options.map((opt, idx) => {
        const optionId = `${id}_opt_${idx}`;
        return (
          <label
            for={optionId}
            class="flex cursor-pointer items-center gap-2 rounded px-2 py-1 hover:bg-base-200"
          >
            <input
              id={optionId}
              type="checkbox"
              class="checkbox checkbox-sm"
              data-kc-ms-check
              value={opt}
              checked={selectedSet.has(String(opt))}
            />
            <span>{opt}</span>
          </label>
        );
      })
    }
  </div>

  <select
    id={id}
    data-prop={dataProp}
    name={name || dataProp}
    multiple
    data-max-select={maxSelect}
    class="hidden"
    aria-hidden="true"
    tabindex="50"
  >
    {
      options.map((opt) => (
        <option value={opt} selected={selectedSet.has(String(opt))}>{opt}</option>
      ))
    }
  </select>
</div>

<script is:inline>
  (() => {
    const init = () => {
      document.querySelectorAll("[data-kc-ms-root]").forEach((root) => {
        if (!(root instanceof HTMLElement)) return;
        if (root.dataset.kcMsBound === "true") return;

        const selectId = root.dataset.selectId;
        if (!selectId) return;

        const select = document.getElementById(selectId);
        const toggle = root.querySelector("[data-kc-ms-toggle]");
        const menu = root.querySelector("[data-kc-ms-menu]");
        const label = root.querySelector("[data-kc-ms-label]");
        const arrow = root.querySelector("[data-kc-ms-arrow]");
        const checks = Array.from(root.querySelectorAll("[data-kc-ms-check]"));

        if (!(select instanceof HTMLSelectElement)) return;
        if (!(toggle instanceof HTMLButtonElement)) return;
        if (!(menu instanceof HTMLElement)) return;
        if (!(label instanceof HTMLElement)) return;

        const maxRaw = Number.parseInt(select.dataset.maxSelect || "", 10);
        const maxAllowed = Number.isFinite(maxRaw) && maxRaw > 0 ? maxRaw : Infinity;
        const placeholderText = label.textContent || "Sélectionner des options";

        const setMenuState = (isOpen) => {
          menu.classList.toggle("hidden", !isOpen);
          toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
          if (arrow instanceof HTMLElement) {
            arrow.classList.toggle("rotate-0", !isOpen);
            arrow.classList.toggle("rotate-90", isOpen);
          }
        };

        const syncLabel = () => {
          const selected = Array.from(select.selectedOptions).map((opt) => opt.value);
          label.textContent = selected.length ? selected.join(", ") : placeholderText;
          // Appliquer la classe d'opacité selon si quelque chose est sélectionné
          if (selected.length > 0) {
            label.classList.remove("text-base-content/50");
            label.classList.add("text-base-content");
          } else {
            label.classList.add("text-base-content/50");
            label.classList.remove("text-base-content");
          }
        };

        const syncChecksFromSelect = () => {
          const selected = new Set(
            Array.from(select.selectedOptions).map((opt) => opt.value),
          );

          checks.forEach((node) => {
            if (node instanceof HTMLInputElement) {
              node.checked = selected.has(node.value);
            }
          });

          syncLabel();
        };

        toggle.addEventListener("click", () => {
          const isOpen = !menu.classList.contains("hidden");
          setMenuState(!isOpen);
        });

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Node)) return;
          if (root.contains(target)) return;
          setMenuState(false);
        });

        checks.forEach((node) => {
          if (!(node instanceof HTMLInputElement)) return;

          node.addEventListener("change", () => {
            const selectedCount = checks.filter(
              (item) => item instanceof HTMLInputElement && item.checked,
            ).length;

            if (selectedCount > maxAllowed) {
              node.checked = false;
              return;
            }

            const option = Array.from(select.options).find(
              (opt) => opt.value === node.value,
            );

            if (option) option.selected = node.checked;

            syncLabel();
            select.dispatchEvent(new Event("change", { bubbles: true }));
          });
        });

        syncChecksFromSelect();
        setMenuState(false);
        root.dataset.kcMsBound = "true";
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
