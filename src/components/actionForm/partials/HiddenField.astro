---
export interface Props {
  name: string;
  id: string;
  value?: string | number | null;
}

const { name, id, value } = Astro.props;

// Champ technique "source de soumission":
// le champ visible peut etre adapte pour le preview, mais le POST final
// conserve ce nom de cle stable via ce hidden input.
---
<input type="hidden" name={name} id={id} value={value} />
