---
export interface Props {
  target: string;
  displayValue: string;
  placeholderValue: string;
  inputValue?: string;
}

const { target, displayValue, placeholderValue, inputValue } =
  Astro.props;

// Convention d'IDs partagee avec editableTitle.js:
// le script trouve le label, l'input et le hidden via ces motifs.
const labelId = `titre_label_${target.replace(/^titre_/, "")}`;
const inputId = `input_${target}`;
---

<div class="flex items-center justify-between">
  <div class="flex-1">
    <h4 class="font-semibold mr-2" id={labelId}>{displayValue}</h4>
    <input
      data-prop={target}
      id={inputId}
      name={target}
      class="w-full border border-accent rounded px-2 py-1 text-black bg-base-100"
      placeholder={"Ex : " + placeholderValue}
      data-example={placeholderValue}
      {...inputValue !== undefined && inputValue !== null ? { value: inputValue } : {}}
      style="display:none;"
    />
  </div>
  <button
    type="button"
    class="btn btn-accent rounded-md! h-full px-2 py-1 ml-2"
    aria-label="Modifier le titre de la section"
    data-edit-target={target}
    aria-pressed="false"
  >
    Modifier le titre de la section
  </button>
</div>
