---
export interface Props {
  animateDesktopSidebar?: boolean;
}

const { animateDesktopSidebar = false } = Astro.props;
---

<div
  class="w-full pt-24 lg:pt-0"
  data-action-editor-shell
  data-animate-desktop-sidebar={animateDesktopSidebar ? "true" : "false"}
>
  <div class="lg:hidden sticky top-21 z-40 px-4 mb-4">
    <div
      class="bg-base-200 border border-base-300 rounded-full p-1 flex gap-1"
      data-shell-tab-list
      role="tablist"
      aria-label="Navigation éditeur"
    >
      <button
        type="button"
        class="btn btn-sm rounded-full flex-1 btn-accent"
        id="editor-form-tab"
        role="tab"
        aria-selected="true"
        tabindex="0"
        data-shell-tab-trigger="form"
        aria-controls="editor-form-panel"
      >
        Formulaire
      </button>
      <button
        type="button"
        class="btn btn-sm rounded-full flex-1 btn-ghost"
        id="editor-preview-tab"
        role="tab"
        aria-selected="false"
        tabindex="-1"
        data-shell-tab-trigger="preview"
        aria-controls="editor-preview-panel"
      >
        Aperçu
      </button>
    </div>
  </div>

  <div class="flex flex-col lg:flex-row h-fit w-full">
    <section
      id="editor-form-panel"
      data-shell-tab-panel="form"
      role="tabpanel"
      aria-labelledby="editor-form-tab"
      class="w-full lg:w-1/3"
      aria-hidden="false"
    >
      <div
        id="sidebar"
        data-shell-sidebar
        class:list={[
          "bg-accent pb-8 p-4 lg:p-6 lg:pb-24 lg:h-[105dvh] lg:sticky lg:left-0 lg:top-0 lg:rounded-br-box lg:overflow-auto",
          animateDesktopSidebar
            ? "lg:transform lg:-translate-x-full lg:opacity-0 lg:transition-all lg:duration-500 lg:ease-out"
            : "",
        ]}
      >
        <slot name="form" />
      </div>
    </section>

    <section
      id="editor-preview-panel"
      data-shell-tab-panel="preview"
      role="tabpanel"
      aria-labelledby="editor-preview-tab"
      class="hidden w-full lg:block lg:w-2/3 px-4 lg:px-8"
      aria-hidden="true"
    >
      <slot name="preview" />
    </section>
  </div>
</div>

<script>
  // Mobile/tablette: on affiche un onglet à la fois.
  // Bureau: les deux panneaux restent visibles en parallèle.
  const MOBILE_QUERY = "(max-width: 1023px)";
  const mediaQuery = window.matchMedia(MOBILE_QUERY);
  const DESKTOP_QUERY = "(min-width: 1024px)";
  const desktopMediaQuery = window.matchMedia(DESKTOP_QUERY);
  const VALID_TABS = new Set(["form", "preview"]);

  const normalizeTab = (rawTab: string | null | undefined) =>
    VALID_TABS.has(rawTab || "") ? (rawTab as string) : "form";

  const setPanelVisibility = (panel: HTMLElement, isVisible: boolean) => {
    // On force les 3 sources de vérité (classe, style inline, aria) pour éviter les états fantômes.
    panel.classList.toggle("hidden", !isVisible);
    if (isVisible) {
      panel.style.removeProperty("display");
      panel.setAttribute("aria-hidden", "false");
      return;
    }

    panel.style.setProperty("display", "none");
    panel.setAttribute("aria-hidden", "true");
  };

  const syncShell = (shell: HTMLElement) => {
    const isMobile = mediaQuery.matches;
    const activeTab = normalizeTab(shell.dataset.activeTab);
    shell.dataset.activeTab = activeTab;
    const triggers = Array.from(
      shell.querySelectorAll("[data-shell-tab-trigger]"),
    ) as HTMLElement[];
    const panels = Array.from(
      shell.querySelectorAll("[data-shell-tab-panel]"),
    ) as HTMLElement[];

    triggers.forEach((btn) => {
      const tabName = normalizeTab(btn.getAttribute("data-shell-tab-trigger"));
      const isActive = tabName === activeTab;
      btn.setAttribute("aria-selected", isActive ? "true" : "false");
      btn.setAttribute("tabindex", isActive ? "0" : "-1");

      if (!isMobile) {
        // En vue bureau, les boutons d'onglet sont masqués.
        btn.classList.add("hidden");
        return;
      }

      btn.classList.remove("hidden");
      btn.classList.toggle("btn-accent", isActive);
      btn.classList.toggle("btn-ghost", !isActive);
    });

    panels.forEach((panel) => {
      if (!isMobile) {
        // En vue bureau, le mode onglet est désactivé: les deux panneaux sont visibles.
        setPanelVisibility(panel, true);
        return;
      }

      const isActive =
        normalizeTab(panel.getAttribute("data-shell-tab-panel")) === activeTab;
      setPanelVisibility(panel, isActive);
    });
  };

  const getShells = () =>
    Array.from(
      document.querySelectorAll("[data-action-editor-shell]"),
    ) as HTMLElement[];

  const initActionEditorShellTabs = () => {
    const shells = getShells();
    if (!shells.length) return;

    shells.forEach((shell) => {
      if (shell.dataset.tabsInit === "true") {
        // Si déjà initialisé (navigation Astro), on resynchronise uniquement l'affichage.
        syncShell(shell);
        return;
      }

      shell.dataset.tabsInit = "true";
      shell.dataset.activeTab = normalizeTab(shell.dataset.activeTab);

      shell.addEventListener("click", (event) => {
        // Délégation de clic: un seul listener pour les deux boutons.
        const target = event.target;
        if (!(target instanceof Element)) return;
        const trigger = target.closest("[data-shell-tab-trigger]");
        if (!(trigger instanceof HTMLElement)) return;
        event.preventDefault();
        shell.dataset.activeTab = normalizeTab(
          trigger.getAttribute("data-shell-tab-trigger"),
        );
        syncShell(shell);
      });

      shell.addEventListener("keydown", (event) => {
        // Navigation clavier gauche/droite entre onglets pour l'accessibilité.
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        if (!target.matches("[data-shell-tab-trigger]")) return;
        if (!(event.key === "ArrowLeft" || event.key === "ArrowRight")) return;
        event.preventDefault();
        const currentTab = normalizeTab(shell.dataset.activeTab);
        const nextTab =
          event.key === "ArrowRight"
            ? currentTab === "form"
              ? "preview"
              : "form"
            : currentTab === "preview"
              ? "form"
              : "preview";
        shell.dataset.activeTab = nextTab;
        syncShell(shell);

        const nextTrigger = shell.querySelector(
          `[data-shell-tab-trigger="${nextTab}"]`,
        );
        if (nextTrigger instanceof HTMLElement) {
          nextTrigger.focus();
        }
      });

      syncShell(shell);
    });
  };

  const syncDesktopSidebarAnimation = () => {
    if (!desktopMediaQuery.matches) return;
    getShells().forEach((shell) => {
      if (shell.dataset.animateDesktopSidebar !== "true") return;
      const sidebar = shell.querySelector("[data-shell-sidebar]");
      if (!(sidebar instanceof HTMLElement)) return;
      // On retire l'état de départ de l'animation une fois en desktop.
      sidebar.classList.remove("lg:-translate-x-full", "lg:opacity-0");
    });
  };

  const syncAllShells = () => {
    getShells().forEach((shell) => syncShell(shell));
  };

  const bootActionEditorShell = () => {
    initActionEditorShellTabs();
    syncDesktopSidebarAnimation();
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bootActionEditorShell, {
      once: true,
    });
  } else {
    bootActionEditorShell();
  }

  const windowState = window as Window & {
    __kcActionEditorShellListenersBound?: boolean;
  };

  if (!windowState.__kcActionEditorShellListenersBound) {
    // Garde globale : évite de doubler les écouteurs à chaque astro:page-load.
    mediaQuery.addEventListener("change", syncAllShells);
    desktopMediaQuery.addEventListener("change", syncDesktopSidebarAnimation);
    document.addEventListener("astro:page-load", bootActionEditorShell);
    windowState.__kcActionEditorShellListenersBound = true;
  }
</script>
