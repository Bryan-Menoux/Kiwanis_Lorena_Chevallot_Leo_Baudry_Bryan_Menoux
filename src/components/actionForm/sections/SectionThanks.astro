---
import HiddenField from "../partials/HiddenField.astro";

export interface Props {
  mode?: string;
  previewData?: any;
  placeholders: any;
}

const { mode = "create", previewData, placeholders } = Astro.props;
---

<div class="p-4 bg-base-200 rounded-box border border-contrast space-y-4 opacity-0 -translate-x-4">
  <h4 class="font-semibold">Remerciements</h4>
  <input
    data-prop="titre_remerciement"
    id="input_titre_remerciement"
    class="w-full border border-accent rounded px-2 py-1 text-black bg-base-100"
    placeholder={placeholders.titre_remerciements}
    value={mode === "edit" && previewData ? previewData.titre_remerciements : ""}
  />
  <HiddenField
    name="titre_remerciements"
    id="hidden_titre_remerciement"
    value={mode === "edit" && previewData ? previewData.titre_remerciements : ""}
  />

  <label class="block text-sm font-medium mt-3 mb-1">Description remerciements</label>
  <textarea
    data-prop="description_remerciement"
    name="description_remerciement"
    id="input_description_remerciement"
    placeholder={placeholders.description_remerciements}
    class="w-full border border-accent rounded px-2 py-1 text-black bg-base-100"
    rows="3"
    >{mode === "edit" && previewData
      ? previewData.description_remerciements
      : ""}</textarea
  >
  <HiddenField
    name="description_remerciements"
    id="hidden_description_remerciement"
    value={mode === "edit" && previewData
      ? previewData.description_remerciements
      : ""}
  />
</div>
