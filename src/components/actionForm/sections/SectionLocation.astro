---
import SearchLocation from "../../searchLocation.astro";
import HiddenField from "../partials/HiddenField.astro";

export interface Props {
  mode?: string;
  previewData?: any;
  placeholders: any;
  typeDeChiffreOptions: string[];
}

const {
  mode = "create",
  previewData,
  placeholders,
  typeDeChiffreOptions,
} = Astro.props;

// Fonction utilitaire unique pour gerer proprement:
// - nombres (0 valide),
// - chaines non vides,
// - valeurs null/undefined.
const hasValue = (value: unknown) => {
  if (typeof value === "number") return Number.isFinite(value);
  if (typeof value === "string") return value.trim() !== "";
  return value !== null && value !== undefined;
};

const hasNomLieu = mode === "edit" && hasValue(previewData?.nom_lieu);
const hasAdresseLieu = mode === "edit" && hasValue(previewData?.adresse_lieu);
const hasLienLieu = mode === "edit" && hasValue(previewData?.lien_lieu);
const hasChiffre = mode === "edit" && hasValue(previewData?.chiffre);
const hasTypeDeChiffre =
  mode === "edit" &&
  hasValue(previewData?.type_de_chiffre) &&
  // On ignore la valeur placeholder de select en base.
  String(previewData?.type_de_chiffre).trim() !== "type de chiffre";
const hasBeneficiaire = mode === "edit" && hasValue(previewData?.beneficiaire);

// Les IDs de SearchLocation et du bloc manuel sont fixes:
// mapsToggle.js s'appuie sur ces selecteurs pour piloter l'UI.
---

<div class="p-4 bg-base-200 rounded-box border border-contrast space-y-4 opacity-0 -translate-x-4">
  <h4 class="font-semibold">Lieu / Chiffres / Bénéficiaires</h4>
  <label class="block text-sm font-medium mt-3 mb-1">Nom du lieu (max 30 caractères)</label>
  <input
    data-prop="nom_lieu"
    id="input_nom_lieu"
    name="nom_lieu_local"
    maxlength="30"
    class="w-full border border-accent rounded px-2 py-1 text-black bg-base-100"
    placeholder={placeholders.nom_lieu}
    {...hasNomLieu ? { value: previewData.nom_lieu } : {}}
  />
  <HiddenField
    name="nom_lieu"
    id="hidden_nom_lieu"
    value={hasNomLieu ? previewData.nom_lieu : undefined}
  />

  <label class="block text-sm font-medium mt-3 mb-1">Adresse du lieu (max 30 caractères)</label>
  <div class="flex items-stretch gap-2">
    <SearchLocation
      inputId="input_adresse_lieu"
      suggestionsId="suggestions_adresse_lieu"
      placeholder={placeholders.adresse_lieu}
      value={hasAdresseLieu ? previewData.adresse_lieu : undefined}
      dataProp="adresse_lieu"
      maxLength={30}
      inputClass="w-full border border-accent rounded px-2 py-1 text-black bg-base-100 flex-1"
      mapLinkInputId="input_lien_lieu"
    />
    <HiddenField
      name="adresse_lieu"
      id="hidden_adresse_lieu"
      value={hasAdresseLieu ? previewData.adresse_lieu : undefined}
    />

    <input
      type="hidden"
      data-prop="lien_lieu"
      id="input_lien_lieu"
      name="lien_lieu"
      {...hasLienLieu ? { value: previewData.lien_lieu } : {}}
    />

    <div class="w-fit flex items-stretch shrink-0">
      <a
        id="btn_voir_maps"
        class="btn btn-accent rounded-md! flex items-center justify-center whitespace-nowrap h-full"
        target="_blank"
        rel="noopener noreferrer"
        href={hasLienLieu ? previewData.lien_lieu : "#"}
        style={hasLienLieu ? "" : "display:none;"}>Voir sur Maps</a
      >
    </div>
  </div>

  <div class="mt-3">
    <a
      href="#"
      id="manual_toggle_link"
      class="text-sm text-accent underline"
      >L'adresse ciblée n'est pas la bonne ? modifiez l'adresse manuellement</a
    >
  </div>
  <div id="manual_lien_lieu_container" style="display:none;" class="mt-3">
    <label class="block text-sm font-medium mt-3 mb-1">Coller le lien Google Maps</label>
    <input
      id="manual_lien_lieu"
      placeholder="https://www.google.com/maps/..."
      class="w-full border border-accent rounded px-2 py-1 text-black bg-base-100"
    />
    <div class="flex gap-2 mt-3 justify-end">
      <button type="button" id="manual_cancel_btn" class="btn btn-ghost"
        >Annuler</button
      >
      <button type="button" id="manual_validate_btn" class="btn btn-accent"
        >Valider l'adresse</button
      >
    </div>
  </div>

  <div class="flex gap-2 mt-3">
    <div class="w-1/2">
      <label for="input_chiffre" class="block text-sm font-medium mt-3 mb-1"
        >Chiffre</label
      >
      <input
        data-prop="chiffre"
        id="input_chiffre"
        type="number"
        class="border border-accent rounded px-2 py-1 w-full text-black bg-base-100"
        placeholder={placeholders.chiffre}
        {...hasChiffre ? { value: previewData.chiffre } : {}}
      />
    </div>
    <div class="w-1/2">
      <label
        for="input_type_de_chiffre"
        class="block text-sm font-medium mt-3 mb-1">Type de chiffre</label
      >
      <select
        data-prop="type_de_chiffre"
        id="input_type_de_chiffre"
        class="border border-accent rounded px-2 py-1 w-full text-black bg-base-100"
        {...hasTypeDeChiffre ? { value: previewData.type_de_chiffre } : {}}
      >
        {
          typeDeChiffreOptions.map((opt) => (
            <option value={opt}>{opt}</option>
          ))
        }
      </select>
    </div>
  </div>

  <HiddenField
    name="chiffre"
    id="hidden_chiffre"
    value={hasChiffre ? previewData.chiffre : undefined}
  />
  <HiddenField
    name="type_de_chiffre"
    id="hidden_type_de_chiffre"
    value={hasTypeDeChiffre ? previewData.type_de_chiffre : undefined}
  />

  <label for="input_beneficiaire" class="block text-sm font-medium mt-3 mb-1"
    >Bénéficiaires</label
  >
  <input
    data-prop="beneficiaire"
    id="input_beneficiaire"
    class="w-full border border-accent rounded px-2 py-1 text-black bg-base-100"
    placeholder={placeholders.beneficiaire}
    {...hasBeneficiaire ? { value: previewData.beneficiaire } : {}}
  />
  <HiddenField
    name="beneficiaire"
    id="hidden_beneficiaire"
    value={hasBeneficiaire ? previewData.beneficiaire : undefined}
  />
</div>
