---
import Formulaire from "./actionForm/Formulaire.astro";

export interface Props {
  mode?: string;
  previewPlaceholder: any;
  previewData?: any;
  typeDeChiffreOptions?: string[];
  typeActionOptions?: string[];  
  imageIcon?: any;
  actionRecord?: any;
  isDraft?: boolean;
  error?: string;
  uiMode?: "desktop" | "mobile-wizard";
  initialStep?: number;
  recordKey?: string;
}

// Composant passerelle : on expose une API stable (`ActionForm`) et on délègue
// toute la logique au composant `Formulaire`.
---

<Formulaire {...Astro.props} />
