---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  title: string;
  subtitle: string;
  imageAlt?: string;
}

const { image, title, subtitle, imageAlt = "" } = Astro.props as Props;
---

<div class="relative w-[95dvw] h-[85dvh] mx-auto rounded-box mt-[10dvh] lg:mt-28 flex flex-col justify-end px-8 md:px-12 lg:px-16 py-12 md:py-20 lg:py-44 overflow-hidden">
    <Picture
      src={image}
      alt={imageAlt}
      formats={["avif", "webp"]}
      layout="full-width"
      fit="cover"
      position="center"
      sizes="95vw"
      loading="eager"
      decoding="sync"
      fetchpriority="high"
      pictureAttributes={{ class: "absolute inset-0 h-full w-full", style: "height:100%;width:100%;" }}
      class="h-full w-full"
      style="height:100%;width:100%;object-fit:cover;object-position:center;"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/100 via-black/0 to-transparent" aria-hidden="true"></div>
    <h1 class="relative z-10 text-white text-4xl! md:text-5xl! lg:text-7xl! font-bold title" >{title}</h1>
    <p class="relative z-10 text-white text-lg! md:text-xl! lg:text-2xl! font-medium text">{subtitle}</p>
</div>

<script>
    // Animation du titre
    gsap.from(".title", {
        opacity: 0, 
        y: 500,
        x: -400, 
        duration: 1
    });
    // Animation du sous-titre
    gsap.from(".text", {
        opacity: 0, 
        y: 500,
        x: 100,
        duration: 1
    });
</script>
