---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

import { resolveHeroVariants } from "../utils/imageOptimization";

interface Props {
  image: ImageMetadata;
  title: string;
  subtitle: string;
  imageAlt?: string;
}

const { image, title, subtitle, imageAlt = "" } = Astro.props as Props;
const { desktop, tablet, mobile } = resolveHeroVariants(image);

const desktopImage = await getImage({
  src: desktop,
  format: "webp",
  width: 1600,
  /* Qualité réduite à 80 : économie de ~40 % sans perte visible */
  quality: 80,
});

const tabletImage = tablet
  ? await getImage({
      src: tablet,
      format: "webp",
      width: 1280,
      /* Qualité réduite à 80 : économie de ~40 % sans perte visible */
      quality: 80,
    })
  : null;

const mobileImage = mobile
  ? await getImage({
      src: mobile,
      format: "webp",
      /* Largeur corrigée : 440 px = taille réelle d'un mobile (880 était en double résolution) */
      width: 440,
      /* Qualité réduite à 80 : économie de ~40 % sans perte visible */
      quality: 72,
    })
  : null;

const desktopSrcSet = desktopImage.srcSet.attribute || desktopImage.src;
const tabletSrcSet = tabletImage?.srcSet.attribute || tabletImage?.src;
const mobileSrcSet = mobileImage?.srcSet.attribute || mobileImage?.src;
---

<div
  data-hero-root
  class="relative w-[95dvw] h-[85dvh] mx-auto rounded-box mt-[10dvh] lg:mt-28 flex flex-col justify-end px-8 md:px-12 lg:px-16 py-12 md:py-20 lg:py-44 overflow-hidden"
>
  <picture class="absolute inset-0">
    {
      mobileSrcSet && (
        <source
          media="(max-width: 767px)"
          srcset={mobileSrcSet}
          sizes="95vw"
          type="image/webp"
        />
      )
    }
    {
      tabletSrcSet && (
        <source
          media="(min-width: 768px) and (max-width: 1023px)"
          srcset={tabletSrcSet}
          sizes="95vw"
          type="image/webp"
        />
      )
    }
    <img
      src={desktopImage.src}
      srcset={desktopSrcSet !== desktopImage.src ? desktopSrcSet : undefined}
      sizes="95vw"
      width={desktopImage.attributes.width}
      height={desktopImage.attributes.height}
      alt={imageAlt}
      loading="eager"
      decoding="sync"
      fetchpriority="high"
      class="h-full w-full"
      style="height:100%;width:100%;object-fit:cover;object-position:center;"
    />
  </picture>

  <div class="absolute inset-0 bg-linear-to-t from-black via-black/0 to-transparent" aria-hidden="true"></div>

  <h1
    data-hero-title
    class="relative z-10 text-white text-4xl! md:text-5xl! lg:text-7xl! font-bold"
  >
    {title}
  </h1>
  <p
    data-hero-text
    class="relative z-10 text-white text-lg! md:text-xl! lg:text-2xl! font-medium"
  >
    {subtitle}
  </p>
</div>

<script>
  type IdleCallback = (callback: () => void) => void;
  type GsapInstance = NonNullable<Window["gsap"]>;

  let gsapLoader: Promise<GsapInstance | null> | null = null;

  const scheduleOnIdle: IdleCallback = (callback) => {
    if (typeof window.requestIdleCallback === "function") {
      window.requestIdleCallback(callback, { timeout: 700 });
      return;
    }

    window.setTimeout(callback, 120);
  };

  const runAfterWindowLoad = (callback: () => void) => {
    if (document.readyState === "complete") {
      callback();
      return;
    }

    window.addEventListener("load", callback, { once: true });
  };

  const loadGsapOnDemand = () => {
    if (window.gsap) return Promise.resolve(window.gsap);

    if (!gsapLoader) {
      gsapLoader = import("../utils/loadGsap")
        .then(({ loadGsap }) => loadGsap())
        .catch(() => null);
    }

    return gsapLoader;
  };

  document.querySelectorAll<HTMLElement>("[data-hero-root]").forEach((root) => {
    if (root.dataset.heroBound === "true") return;
    root.dataset.heroBound = "true";

    const isMobileViewport = window.matchMedia("(max-width: 1023px)").matches;
    if (isMobileViewport) return;

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (prefersReducedMotion) return;

    const title = root.querySelector<HTMLElement>("[data-hero-title]");
    const text = root.querySelector<HTMLElement>("[data-hero-text]");
    if (!title || !text) return;

    runAfterWindowLoad(() => {
      const scriptStart = performance.now();

      scheduleOnIdle(async () => {
        if (!root.isConnected) return;
        if (window.scrollY > 40) return;

        const gsap = await loadGsapOnDemand();
        if (!gsap) return;
        if (performance.now() - scriptStart > 1200) return;

        gsap.from(title, {
          opacity: 0,
          y: 48,
          x: -24,
          duration: 0.8,
          ease: "power2.out",
          overwrite: "auto",
        });

        gsap.from(text, {
          opacity: 0,
          y: 32,
          x: 16,
          duration: 0.7,
          delay: 0.08,
          ease: "power2.out",
          overwrite: "auto",
        });
      });
    });
  });
</script>

