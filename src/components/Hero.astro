---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

import { resolveHeroVariants } from "../utils/imageOptimization";
import { getHeroObjectPosition } from "../utils/heroCentrage";

interface Props {
  image: ImageMetadata | string;
  title: string;
  subtitle?: string;
  imageAlt?: string;
  centrage?: unknown;
}

const {
  image,
  title,
  subtitle,
  imageAlt = "",
  centrage,
} = Astro.props as Props;
const isRemoteImage = typeof image === "string";
const localImage = !isRemoteImage ? image : null;
const { desktop, tablet, mobile } = localImage
  ? resolveHeroVariants(localImage)
  : { desktop: null, tablet: undefined, mobile: undefined };

const desktopImageMd = desktop
  ? await getImage({
      src: desktop,
      format: "webp",
      width: 1440,
      quality: 80,
    })
  : null;
const desktopImageLg = desktop
  ? await getImage({
      src: desktop,
      format: "webp",
      width: 1840,
      quality: 80,
    })
  : null;

const tabletImage = tablet
  ? await getImage({
      src: tablet,
      format: "webp",
      width: 1280,
      quality: 72,
    })
  : null;

const mobileImage = mobile
  ? await getImage({
      src: mobile,
      format: "webp",
      width: 440,
      quality: 68,
    })
  : null;

const tabletSrcSet = tabletImage?.srcSet.attribute || tabletImage?.src;
const mobileSrcSet = mobileImage?.srcSet.attribute || mobileImage?.src;
const mobileObjectPosition = getHeroObjectPosition(centrage, "mobile");
const tabletObjectPosition = getHeroObjectPosition(centrage, "tablet");
const desktopObjectPosition = getHeroObjectPosition(centrage, "desktop");
---

<div
  class="hero-root relative w-[95dvw] h-[85dvh] mx-auto rounded-box mt-[10dvh] lg:mt-28 flex flex-col justify-end px-8 md:px-12 lg:px-16 py-12 md:py-20 lg:py-44 overflow-hidden"
  style={`--hero-object-position-mobile:${mobileObjectPosition};--hero-object-position-tablet:${tabletObjectPosition};--hero-object-position-desktop:${desktopObjectPosition};`}
>
  <picture class="absolute inset-0">
    {isRemoteImage ? (
      <img
        src={image}
        alt={imageAlt}
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="h-full w-full"
        style="height:100%;width:100%;object-fit:cover;"
      />
    ) : (
      <>
        {
          mobileSrcSet && (
            <source
              media="(max-width: 767px)"
              srcset={mobileSrcSet}
              sizes="95vw"
              type="image/webp"
            />
          )
        }
        {
          tabletSrcSet && (
            <source
              media="(min-width: 768px) and (max-width: 1023px)"
              srcset={tabletSrcSet}
              sizes="95vw"
              type="image/webp"
            />
          )
        }
        {
          desktopImageMd &&
            desktopImageLg && (
              <img
                src={desktopImageLg.src}
                srcset={`${desktopImageMd.src} 1440w, ${desktopImageLg.src} 1840w`}
                sizes="95vw"
                width={desktopImageLg.attributes.width}
                height={desktopImageLg.attributes.height}
                alt={imageAlt}
                loading="eager"
                fetchpriority="high"
                decoding="async"
                class="h-full w-full"
                style="height:100%;width:100%;object-fit:cover;"
              />
            )
        }
      </>
    )}
  </picture>

  <div class="absolute inset-0 bg-linear-to-t from-black via-black/0 to-transparent" aria-hidden="true"></div>

  <h1 class="relative z-10 text-white text-4xl! md:text-5xl! lg:text-7xl! font-bold uppercase">
    {title}
  </h1>
  {subtitle && (
    <p class="relative z-10 text-white text-lg! md:text-xl! lg:text-2xl! font-medium">
      {subtitle}
    </p>
  )}
</div>

<style>
  .hero-root picture > img {
    object-position: var(--hero-object-position-mobile, 50% 50%);
  }

  @media (min-width: 768px) {
    .hero-root picture > img {
      object-position: var(--hero-object-position-tablet, 50% 50%);
    }
  }

  @media (min-width: 1024px) {
    .hero-root picture > img {
      object-position: var(--hero-object-position-desktop, 50% 50%);
    }
  }
</style>
