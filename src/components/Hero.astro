---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

import { resolveHeroVariants } from "../utils/imageOptimization";

interface Props {
  image: ImageMetadata;
  title: string;
  subtitle: string;
  imageAlt?: string;
}

const { image, title, subtitle, imageAlt = "" } = Astro.props as Props;
const { desktop, tablet, mobile } = resolveHeroVariants(image);

const desktopImage = await getImage({
  src: desktop,
  format: "webp",
  width: 1600,
  quality: 100,
});

const tabletImage = tablet
  ? await getImage({
      src: tablet,
      format: "webp",
      width: 1280,
      quality: 100,
    })
  : null;

const mobileImage = mobile
  ? await getImage({
      src: mobile,
      format: "webp",
      width: 880,
      quality: 100,
    })
  : null;

const desktopSrcSet = desktopImage.srcSet.attribute || desktopImage.src;
const tabletSrcSet = tabletImage?.srcSet.attribute || tabletImage?.src;
const mobileSrcSet = mobileImage?.srcSet.attribute || mobileImage?.src;
---

<div class="relative w-[95dvw] h-[85dvh] mx-auto rounded-box mt-[10dvh] lg:mt-28 flex flex-col justify-end px-8 md:px-12 lg:px-16 py-12 md:py-20 lg:py-44 overflow-hidden">
  <picture class="absolute inset-0">
    {
      mobileSrcSet && (
        <source
          media="(max-width: 767px)"
          srcset={mobileSrcSet}
          sizes="95vw"
          type="image/webp"
        />
      )
    }
    {
      tabletSrcSet && (
        <source
          media="(min-width: 768px) and (max-width: 1023px)"
          srcset={tabletSrcSet}
          sizes="95vw"
          type="image/webp"
        />
      )
    }
    <img
      src={desktopImage.src}
      srcset={desktopSrcSet !== desktopImage.src ? desktopSrcSet : undefined}
      sizes="95vw"
      width={desktopImage.attributes.width}
      height={desktopImage.attributes.height}
      alt={imageAlt}
      loading="eager"
      decoding="async"
      fetchpriority="high"
      class="h-full w-full"
      style="height:100%;width:100%;object-fit:cover;object-position:center;"
    />
  </picture>

  <div class="absolute inset-0 bg-linear-to-t from-black via-black/0 to-transparent" aria-hidden="true"></div>

  <h1 class="relative z-10 text-white text-4xl! md:text-5xl! lg:text-7xl! font-bold title">{title}</h1>
  <p class="relative z-10 text-white text-lg! md:text-xl! lg:text-2xl! font-medium text">{subtitle}</p>
</div>

<script>
  gsap.from(".title", {
    opacity: 0,
    y: 500,
    x: -400,
    duration: 1
  });

  gsap.from(".text", {
    opacity: 0,
    y: 500,
    x: 100,
    duration: 1
  });
</script>
