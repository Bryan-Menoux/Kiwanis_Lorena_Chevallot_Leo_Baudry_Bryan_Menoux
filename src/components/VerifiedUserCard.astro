---
import { Image } from "astro:assets";
import crossCircle from "../assets/cross-circle.svg";

type User = {
  id: string;
  name?: string;
  email: string;
  created: string;
  verified: boolean;
  rejected?: boolean;
  rejectionDate?: string;
};

interface Props {
  user: User;
  currentUserId?: string;
  showUnverifyButton?: boolean;
}

const { user, currentUserId = '', showUnverifyButton = true } = Astro.props as Props;
---

<div class="flex items-start justify-between gap-4 p-4 border border-success/20 rounded-xl transition-all duration-300" data-user-id={user.id} data-list-type="verified">
  <div class="min-w-0 flex-1">
    <p class="font-semibold">{user.name || 'Nom non spécifié'}</p>
    <p class="text-sm text-base-content/70 break-all">{user.email}</p>
  </div>
  {showUnverifyButton && user.id !== currentUserId && (
    <button
      class="btn btn-error btn-sm verify-action ml-auto shrink-0 flex gap-4 items-center"
      data-user-id={user.id}
      data-action="unverify"
      data-list-type="verified"
      type="button"
    >
      <Image src={crossCircle} alt="" loading="lazy" quality={80} class="w-5 h-5 invert" />
      Retirer l'utilisateur de la liste
    </button>
  )}
</div>
