---
import UserCard from "./UserCard.astro";

import crossIcon from "../assets/cross-circle.svg";
import { Collections, type MembresResponse } from "../pocketbase-types";

if (!Astro.locals.pb.authStore.isValid) {
  throw new Error("Utilisateur non authentifié");
}

const user = Astro.locals.pb.authStore.record;
const isAdmin = user?.administrateur;

let effectiveRole: unknown = (user as any)?.role;
try {
  try {
    const currentMember = await Astro.locals.pb
      .collection(Collections.Membres)
      .getFirstListItem<MembresResponse>(`utilisateur = "${user?.id}"`);
    effectiveRole = currentMember?.role ?? effectiveRole;
  } catch {
    const legacyMember = await Astro.locals.pb
      .collection(Collections.Membres)
      .getFirstListItem<MembresResponse>(`nom = "${user?.id}"`);
    effectiveRole = legacyMember?.role ?? effectiveRole;
  }
} catch {
  // Aucun enregistrement membre lié : on conserve le rôle utilisateur.
}

const roleActuel = String(effectiveRole || "").trim().toLowerCase();
const isPresidentOrPresidente = [
  "président",
  "présidente",
  "president",
  "presidente",
].includes(roleActuel);

let users: any[] = [];
if (isAdmin) {
  // Récupérer tous les utilisateurs vérifiés
  users = await Astro.locals.pb.collection("users").getFullList({
    filter: "verified = true && rejected = false",
  });
}

const perPage = 6;
const pages = [];
for (let i = 0; i < users.length; i += perPage) {
  pages.push(users.slice(i, i + perPage));
}
const totalPages = pages.length || 1;
---

<div class="min-h-screen mt-24 py-8 px-4">
  <div class="max-w-4xl mx-auto">
    <!-- en-tête -->
    <div class="mb-12 text-center">
      <h1 class="text-5xl font-bold mb-4">Modifications</h1>
      <p class="text-base-content/60">
        Modifier les informations des utilisateurs
      </p>
    </div>

    <div class="bg-white rounded-2xl shadow-2xl overflow-hidden">
      <div class="px-8 py-8">
        {
          isAdmin && (
            <>
              <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
                Utilisateurs
              </h2>
              <search>
                <input
                  type="text"
                  id="user-search"
                  placeholder="Rechercher par nom ou email..."
                  class="input input-bordered input-primary w-full mb-8 focus:input-primary-focus"
                />
              </search>
              <div
                class="carousel-container overflow-hidden relative"
                data-total-pages={totalPages}
                data-is-admin={isAdmin}
              >
                <div
                  class="carousel-inner flex gap-16 transition-transform duration-300 ease-in-out"
                  id="carousel-inner"
                >
                  {
                    users.length > 0 ? (
                      pages.map((pageUsers) => (
                        <div class="carousel-slide shrink-0 w-full  mb-16">
                          <div class="flex flex-col gap-6">
                            {pageUsers.map((listedUser) => (
                              <UserCard user={listedUser} isAdmin={isAdmin} />
                            ))}
                          </div>
                        </div>
                      ))
                    ) : (
                      <div class="carousel-slide shrink-0 w-full mb-16">
                        <p class="text-center text-base-content/60 py-12">Aucun utilisateur vérifié à modifier</p>
                      </div>
                    )
                  }
                </div>
              </div>
              {
                totalPages > 1 && (
                  <div class="flex justify-center items-center gap-4 mt-8">
                    <button id="prev-btn" class="btn btn-sm">
                      Précédent
                    </button>
                    <span id="page-indicator" class="flex items-center px-3">
                      Page 1 sur {totalPages}
                    </span>
                    <button
                      id="next-btn"
                      class="btn btn-sm"
                      disabled={totalPages <= 1}
                    >
                      Suivant
                    </button>
                  </div>
                )
              }
            </>
          )
        }

        {
          isPresidentOrPresidente && (
            <div class="mt-10 p-5 rounded-xl border border-warning/40 bg-warning/10">
              <h3 class="text-xl font-bold mb-2">Transmission de direction</h3>
              <p class="text-sm text-base-content/70 mb-4">
                Transmettez la présidence depuis la page de succession dédiée.
              </p>
              <a href="/transmission-direction" class="btn btn-warning">
                Aller à la page de succession
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</div>

{
  isAdmin && (
    <>
      <!-- Fenêtre modale pour modifier les informations d'un utilisateur -->
      <div id="modify-modal" class="modal" data-current-user-id={user?.id}>
        <div class="modal-box w-[min(92vw,40rem)] max-w-none overflow-hidden rounded-3xl border border-base-300 bg-base-100 p-0 shadow-2xl">
          <div class="flex items-start justify-between gap-4 border-b border-base-300/70 bg-linear-to-b from-base-100 via-base-100 to-base-200/40 px-6 py-5 md:px-8 md:py-6">
            <div class="flex min-w-0 items-start gap-4">
              <div class="flex h-12 w-12 flex-none items-center justify-center rounded-full bg-accent text-accent-content shadow-sm shadow-accent/20" aria-hidden="true">
                <svg
                  class="h-6 w-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                  ></path>
                </svg>
              </div>
              <div class="min-w-0">
                <p class="text-sm! text-base-content/80 font-semibold!">Compte utilisateur</p>
                <h3 class="mt-1 font-bold leading-tight">
                  Modifier l'utilisateur
                </h3>
                <p class="mt-2 max-w-xl text-sm! leading-6 text-base-content/60">
                  Mettre à jour le nom, l'adresse e-mail ou le rôle.
                </p>
              </div>
            </div>
            <button class="btn btn-circle btn-ghost shrink-0 border border-base-300 bg-base-100/80 text-base-content hover:bg-base-200 cancel-btn" type="button" aria-label="Fermer">
              <img src={crossIcon.src} alt="" aria-hidden="true" loading="lazy" class="h-5 w-5"  decoding="async" />
            </button>
          </div>

          <form id="modify-form" class="grid gap-4 px-6 pt-6 md:grid-cols-2 md:px-8">
            <input type="hidden" name="userId" id="modal-user-id" />
            <div class="form-control md:col-span-1">
              <label class="label pb-2">
                <span class="label-text text-sm font-semibold tracking-wide text-base-content/80">Nom complet</span>
              </label>
              <input
                type="text"
                name="name"
                id="modal-name"
                placeholder="Entrez le nom complet"
                class="input input-bordered input-primary w-full rounded-xl bg-base-100 focus:input-primary-focus"
                required
              />
            </div>
            <div class="form-control md:col-span-1">
              <label class="label pb-2">
                <span class="label-text text-sm font-semibold tracking-wide text-base-content/80">Adresse e-mail</span>
              </label>
              <input
                type="email"
                name="email"
                id="modal-email"
                placeholder="Entrez l'e-mail"
                class="input input-bordered input-primary w-full rounded-xl bg-base-100 focus:input-primary-focus"
                required
              />
            </div>
            <div class="md:col-span-2 flex items-center justify-between gap-4 rounded-2xl border border-base-300 bg-base-200/50 px-4 py-4">
              <div>
                <p class="text-sm font-semibold text-base-content">Administrateur</p>
                <p class="text-xs text-base-content/60">Autorise l'accès aux outils d'administration.</p>
              </div>
              <input
                type="checkbox"
                name="admin"
                id="modal-admin"
                class="toggle toggle-primary"
              />
            </div>
          </form>

          <div class="flex flex-col gap-3 px-6 pb-6 pt-6 md:flex-row md:items-center md:justify-between md:px-8">
            <button class="btn btn-ghost btn-md rounded-full cancel-btn" type="button">Annuler</button>
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-end">
              <button
                id="delete-btn"
                class="btn btn-error btn-md rounded-full sm:min-w-52"
                style="display: none;"
                type="button"
              >
                <svg
                  class="h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                  ></path>
                </svg>
                Supprimer l'utilisateur
              </button>
              <button type="submit" form="modify-form" class="btn btn-accent btn-md rounded-full sm:min-w-52">
                <svg
                  class="mr-2 h-4 w-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"
                  ></path>
                </svg>
                Enregistrer
              </button>
            </div>
          </div>
        </div>
      </div>
    </>
  )
}

<script>
  import { initModifications } from "../scripts/modification-handlers.js";
  
  initModifications();
</script>


