---
import UserCard from "./UserCard.astro";

import crossIcon from "../assets/cross-circle.svg";
import { Collections, type MembresResponse } from "../pocketbase-types";

if (!Astro.locals.pb.authStore.isValid) {
  throw new Error("Utilisateur non authentifié");
}

const user = Astro.locals.pb.authStore.record;
const isAdmin = user?.administrateur;

let effectiveRole: unknown = (user as any)?.role;
try {
  try {
    const currentMember = await Astro.locals.pb
      .collection(Collections.Membres)
      .getFirstListItem<MembresResponse>(`utilisateur = "${user?.id}"`);
    effectiveRole = currentMember?.role ?? effectiveRole;
  } catch {
    const legacyMember = await Astro.locals.pb
      .collection(Collections.Membres)
      .getFirstListItem<MembresResponse>(`nom = "${user?.id}"`);
    effectiveRole = legacyMember?.role ?? effectiveRole;
  }
} catch {
  // Aucun enregistrement membre lié : on conserve le rôle utilisateur.
}

const roleActuel = String(effectiveRole || "").trim().toLowerCase();
const isPresidentOrPresidente = [
  "président",
  "présidente",
  "president",
  "presidente",
].includes(roleActuel);

let users: any[] = [];
if (isAdmin) {
  // Récupérer tous les utilisateurs vérifiés
  users = await Astro.locals.pb.collection("users").getFullList({
    filter: "verified = true && rejected = false",
  });
}

const perPage = 6;
const pages = [];
for (let i = 0; i < users.length; i += perPage) {
  pages.push(users.slice(i, i + perPage));
}
const totalPages = pages.length || 1;
---

<div class="min-h-screen mt-24 py-8 px-4">
  <div class="max-w-4xl mx-auto">
    <!-- en-tête -->
    <div class="mb-12 text-center">
      <h1 class="text-5xl font-bold mb-4">Modifications</h1>
      <p class="text-base-content/60">
        Modifier les informations des utilisateurs
      </p>
    </div>

    <div class="bg-white rounded-2xl shadow-2xl overflow-hidden">
      <div class="px-8 py-8">
        {
          isAdmin && (
            <>
              <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
                Utilisateurs
              </h2>
              <search>
                <input
                  type="text"
                  id="user-search"
                  placeholder="Rechercher par nom ou email..."
                  class="input input-bordered input-primary w-full mb-8 focus:input-primary-focus"
                />
              </search>
              <div
                class="carousel-container overflow-hidden relative"
                data-total-pages={totalPages}
                data-is-admin={isAdmin}
              >
                <div
                  class="carousel-inner flex gap-16 transition-transform duration-300 ease-in-out"
                  id="carousel-inner"
                >
                  {
                    users.length > 0 ? (
                      pages.map((pageUsers) => (
                        <div class="carousel-slide shrink-0 w-full  mb-16">
                          <div class="flex flex-col gap-6">
                            {pageUsers.map((listedUser) => (
                              <UserCard user={listedUser} isAdmin={isAdmin} />
                            ))}
                          </div>
                        </div>
                      ))
                    ) : (
                      <div class="carousel-slide shrink-0 w-full mb-16">
                        <p class="text-center text-base-content/60 py-12">Aucun utilisateur vérifié à modifier</p>
                      </div>
                    )
                  }
                </div>
              </div>
              {
                totalPages > 1 && (
                  <div class="flex justify-center items-center gap-4 mt-8">
                    <button id="prev-btn" class="btn btn-sm">
                      Précédent
                    </button>
                    <span id="page-indicator" class="flex items-center px-3">
                      Page 1 sur {totalPages}
                    </span>
                    <button
                      id="next-btn"
                      class="btn btn-sm"
                      disabled={totalPages <= 1}
                    >
                      Suivant
                    </button>
                  </div>
                )
              }
            </>
          )
        }

        {
          isPresidentOrPresidente && (
            <div class="mt-10 p-5 rounded-xl border border-warning/40 bg-warning/10">
              <h3 class="text-xl font-bold mb-2">Transmission de direction</h3>
              <p class="text-sm text-base-content/70 mb-4">
                Transmettez la présidence depuis la page de succession dédiée.
              </p>
              <a href="/transmission-direction" class="btn btn-warning">
                Aller à la page de succession
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</div>

{
  isAdmin && (
    <>
      <!-- Fenêtre modale pour modifier les informations d'un utilisateur -->
      <div id="modify-modal" class="modal" data-current-user-id={user?.id}>
        <div class="modal-box max-w-md bg-white shadow-2xl border border-gray-200">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center justify-start gap-3">
        <div
        class="w-10 h-10 bg-accent rounded-full flex items-center justify-center"
      >
        <svg
          class="w-5 h-5 text-white"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
          ></path>
        </svg>
      </div>
      <h3 class="font-bold text-xl text-gray-800">Modifier l'utilisateur</h3>
      </div>
      <button class="btn btn-ghost cancel-btn self-end"><img src={crossIcon.src} alt="Fermer" loading="lazy" class="h-5 w-5"  decoding="async" /></button>
    </div>
    <form id="modify-form" class="space-y-4">
      <input type="hidden" name="userId" id="modal-user-id" />
      <div class="form-control">
        <label class="label">
          <span class="label-text font-semibold text-gray-700">Nom complet</span
          >
        </label>
        <input
          type="text"
          name="name"
          id="modal-name"
          placeholder="Entrez le nom complet"
          class="input input-bordered input-primary focus:input-primary-focus"
          required
        />
      </div>
      <div class="form-control">
        <label class="label">
          <span class="label-text font-semibold text-gray-700"
            >Adresse email</span
          >
        </label>
        <input
          type="email"
          name="email"
          id="modal-email"
          placeholder="Entrez l'email"
          class="input input-bordered input-primary focus:input-primary-focus"
          required
        />
      </div>
      <div class="form-control">
        <label class="label cursor-pointer">
          <span class="label-text font-semibold text-gray-700"
            >Administrateur</span
          >
          <input
            type="checkbox"
            name="admin"
            id="modal-admin"
            class="toggle toggle-primary"
          />
        </label>
      </div>
    </form>
    <div class="modal-action mt-6 flex justify-end gap-4">
      <button class="btn btn-ghost cancel-btn">Annuler</button>
      <button type="submit" form="modify-form" class="btn btn-accent flex-1">
        <svg
          class="w-4 h-4 mr-2"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M5 13l4 4L19 7"></path>
        </svg>
        Enregistrer
      </button>
    </div>
    <div class="w-full mt-8">
      <button
        id="delete-btn"
        class="btn btn-error btn-sm w-full flex items-center justify-center gap-2"
        style="display: none;"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
        </svg>
        Supprimer l'utilisateur
      </button>
    </div>
        </div>
      </div>
    </>
  )
}

<script>
  import { initModifications } from "../scripts/modification-handlers.js";
  
  initModifications();
</script>


