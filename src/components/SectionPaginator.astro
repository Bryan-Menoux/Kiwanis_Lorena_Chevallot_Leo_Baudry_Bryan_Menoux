---
interface Props {
  itemAttr: string;
  pageSize?: number;
  class?: string;
  searchInputId?: string;
  searchAttr?: string;
  beneficiaryAttr?: string;
  yearAttr?: string;
  typeAttr?: string;
  emptyMessage?: string;
  sortSelectId?: string;
  filterEventName?: string;
}

const {
  itemAttr,
  pageSize = 6,
  class: className = "mt-6",
  searchInputId = "",
  searchAttr = "data-search",
  beneficiaryAttr = "",
  yearAttr = "",
  typeAttr = "",
  emptyMessage = "",
  sortSelectId = "",
  filterEventName = "",
} = Astro.props;
---

<div
  class={className}
  data-section-paginator
  data-item-attr={itemAttr}
  data-page-size={pageSize}
  data-search-input-id={searchInputId}
  data-search-attr={searchAttr}
  data-beneficiary-attr={beneficiaryAttr}
  data-year-attr={yearAttr}
  data-type-attr={typeAttr}
  data-empty-message={emptyMessage}
  data-sort-select-id={sortSelectId}
  data-filter-event-name={filterEventName}
></div>

<script>
  import {
    getTotalPages,
    renderPagination,
    resolveNextPage,
  } from "../utils/renderPagination";

  function initPaginator(root: HTMLElement) {
    const itemAttr = root.dataset.itemAttr;
    const parsedPageSize = Number(root.dataset.pageSize);
    const pageSize =
      Number.isFinite(parsedPageSize) && parsedPageSize > 0
        ? Math.floor(parsedPageSize)
        : 6;
    const searchInputId = root.dataset.searchInputId || "";
    const searchAttr = root.dataset.searchAttr || "data-search";
    const beneficiaryAttr = root.dataset.beneficiaryAttr || "";
    const yearAttr = root.dataset.yearAttr || "";
    const typeAttr = root.dataset.typeAttr || "";
    const emptyMessage = root.dataset.emptyMessage || "";
    const sortSelectId = root.dataset.sortSelectId || "";
    const filterEventName = root.dataset.filterEventName || "";

    if (!itemAttr) return;

    const getItems = () =>
      Array.from(document.querySelectorAll(`[${itemAttr}]`)).filter(
        (el): el is HTMLElement => el instanceof HTMLElement,
      );
    const searchInput = searchInputId
      ? document.getElementById(searchInputId)
      : null;
    const sortSelect = sortSelectId
      ? document.getElementById(sortSelectId)
      : null;

    if (getItems().length === 0) return;

    let page = 1;
    let currentSearch = "";
    let currentBeneficiary = "";
    let currentYear = "";
    let currentType = "";

    const getSortDirection = () => {
      if (
        sortSelect instanceof HTMLSelectElement &&
        sortSelect.value === "updated_asc"
      ) {
        return "asc";
      }
      return "desc";
    };

    const getCardDate = (item: HTMLElement) =>
      new Date(item.getAttribute("data-updated") || "0").getTime();

    const getFilteredItems = () => {
      const items = getItems();
      const query =
        searchInput instanceof HTMLInputElement
          ? searchInput.value.trim().toLowerCase()
          : currentSearch;
      const beneficiaryQuery = currentBeneficiary;
      const yearQuery = currentYear;
      const typeQuery = currentType;

      const filtered = items.filter((item) => {
        const searchValue = (item.getAttribute(searchAttr) || "").toLowerCase();
        const beneficiaryValue = beneficiaryAttr
          ? (item.getAttribute(beneficiaryAttr) || "").toLowerCase()
          : "";
        const yearValue = yearAttr ? (item.getAttribute(yearAttr) || "") : "";
        const typeValue = typeAttr
          ? String(item.getAttribute(typeAttr) || "")
              .toLowerCase()
              .split("||")
              .map((value) => value.trim())
              .filter(Boolean)
          : [];

        if (query && !searchValue.includes(query)) return false;
        if (beneficiaryQuery && !beneficiaryValue.includes(beneficiaryQuery)) return false;
        if (yearQuery && yearValue !== yearQuery) return false;
        if (typeQuery && !typeValue.includes(typeQuery)) return false;
        return true;
      });

      filtered.sort((a, b) => {
        const delta = getCardDate(a) - getCardDate(b);
        return getSortDirection() === "asc" ? delta : -delta;
      });

      return filtered;
    };

    const render = () => {
      const filteredItems = getFilteredItems();
      const totalPages = getTotalPages(filteredItems.length, pageSize);
      page = Math.min(page, totalPages);
      const start = (page - 1) * pageSize;
      const pageItems = filteredItems.slice(start, start + pageSize);
      const pageSet = new Set(pageItems);
      const filteredSet = new Set(filteredItems);
      const currentItems = getItems();
      const itemsContainer = currentItems[0]?.parentElement;

      currentItems.forEach((el) => {
        el.style.display = filteredSet.has(el) && pageSet.has(el) ? "" : "none";
      });

      if (itemsContainer) {
        pageItems.forEach((el) => {
          itemsContainer.appendChild(el);
        });
      }

      if (filteredItems.length === 0) {
        root.innerHTML = emptyMessage
          ? `<div class="rounded-xl border border-base-300 bg-base-100 p-6 text-center text-base-content/60">${emptyMessage}</div>`
          : "";
        return;
      }

      if (filteredItems.length <= pageSize) {
        root.innerHTML = "";
        return;
      }

      root.innerHTML = renderPagination(totalPages, page, {
        wrapperClass: "flex flex-wrap items-center justify-center gap-2",
      });
    };

    root.addEventListener("click", (event) => {
      const button =
        event.target instanceof HTMLElement
          ? event.target.closest("[data-page-action]")
          : null;
      if (!(button instanceof HTMLElement)) return;

      const filteredItems = getFilteredItems();
      const totalPages = getTotalPages(filteredItems.length, pageSize);
      const action = button.getAttribute("data-page-action");
      const previousPage = page;
      page = resolveNextPage(page, totalPages, action, button.dataset.page);

      if (page !== previousPage) {
        render();
      }
    });

    if (searchInput instanceof HTMLInputElement) {
      searchInput.addEventListener("input", () => {
        currentSearch = searchInput.value.trim().toLowerCase();
        page = 1;
        render();
      });
    }

    if (sortSelect instanceof HTMLSelectElement) {
      sortSelect.addEventListener("change", () => {
        page = 1;
        render();
      });
    }

    if (filterEventName) {
      document.addEventListener(filterEventName, (event) => {
        const detail = (event as CustomEvent<{
          search?: string;
          beneficiary?: string;
          year?: string;
          type?: string;
        }>).detail || {};

        currentSearch = (detail.search || "").toLowerCase().trim();
        currentBeneficiary = (detail.beneficiary || "").toLowerCase().trim();
        currentYear = (detail.year || "").trim();
        currentType = (detail.type || "").toLowerCase().trim();
        page = 1;
        render();
      });
    }

    render();
  }

  document.querySelectorAll("[data-section-paginator]").forEach((el) => {
    if (el instanceof HTMLElement) initPaginator(el);
  });
</script>
