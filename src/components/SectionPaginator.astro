---
interface Props {
  itemAttr: string;
  pageSize?: number;
  class?: string;
}

const { itemAttr, pageSize = 6, class: className = "mt-6" } = Astro.props;
---

<div
  class={className}
  data-section-paginator
  data-item-attr={itemAttr}
  data-page-size={pageSize}
></div>

<script>
  function initPaginator(root: HTMLElement) {
    const itemAttr = root.dataset.itemAttr;
    const pageSize = Number(root.dataset.pageSize) || 6;

    if (!itemAttr) return;

    const items = Array.from(document.querySelectorAll(`[${itemAttr}]`));
    if (items.length <= pageSize) return;

    let page = 1;
    const totalPages = Math.ceil(items.length / pageSize);

    const renderItems = () => {
      const start = (page - 1) * pageSize;
      items.forEach((el, i) => {
        if (!(el instanceof HTMLElement)) return;
        el.style.display = i >= start && i < start + pageSize ? "" : "none";
      });
    };

    const renderControls = () => {
      const prev = `<button type="button" class="btn btn-sm btn-ghost rounded-full" data-page-action="prev"${page === 1 ? " disabled" : ""}>Précédent</button>`;
      const next = `<button type="button" class="btn btn-sm btn-ghost rounded-full" data-page-action="next"${page === totalPages ? " disabled" : ""}>Suivant</button>`;
      const pages = Array.from({ length: totalPages }, (_, i) => {
        const n = i + 1;
        return `<button type="button" class="btn btn-sm ${n === page ? "btn-accent" : "btn-ghost"} rounded-full" data-page-action="go" data-page="${n}">${n}</button>`;
      }).join("");
      root.innerHTML = `<div class="flex flex-wrap items-center justify-center gap-2">${prev}${pages}${next}</div>`;
    };

    root.addEventListener("click", (e) => {
      const btn =
        e.target instanceof HTMLElement
          ? e.target.closest("[data-page-action]")
          : null;
      if (!(btn instanceof HTMLElement)) return;

      const action = btn.getAttribute("data-page-action");
      const prev = page;
      if (action === "prev") page = Math.max(1, page - 1);
      else if (action === "next") page = Math.min(totalPages, page + 1);
      else if (action === "go")
        page = Math.min(totalPages, Math.max(1, Number(btn.dataset.page)));

      if (page !== prev) {
        renderItems();
        renderControls();
      }
    });

    renderItems();
    renderControls();
  }

  document
    .querySelectorAll("[data-section-paginator]")
    .forEach((el) => {
      if (el instanceof HTMLElement) initPaginator(el);
    });
</script>
